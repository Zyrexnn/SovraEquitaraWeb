---
import Layout from '../layouts/Layout.astro';
import '../styles/dashboard-shared.css';
---

<Layout title="Profil Saya — SovraEquitara">
  <div class="app-container">
    <!-- Desktop Sidebar -->
    <aside class="desktop-sidebar">
      <div class="sidebar-brand">
        <img src="/logo.svg" alt="Sovra" class="brand-img" />
      </div>
      <nav class="sidebar-nav-v2">
        <a href="/dashboard" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
          <span>Dashboard</span>
        </a>
        <a href="/profile" class="side-item active">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          <span>Profil Saya</span>
        </a>
        <a href="/history" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
          <span>Riwayat</span>
        </a>
      </nav>
      <div class="sidebar-bottom">
        <button id="btn-logout-desktop" class="side-item logout">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
          <span>Keluar</span>
        </button>
      </div>
    </aside>

    <!-- Mobile Nav -->
    <nav class="mobile-nav">
      <a href="/dashboard" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
      </a>
      <a href="/profile" class="mob-item active">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a href="/history" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <button id="btn-logout-mobile" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
      </button>
    </nav>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <header class="app-header">
        <div class="header-left">
          <div class="mobile-logo-only">
            <img src="/logo.svg" alt="Sovra" />
          </div>
          <div class="desktop-breadcrumb">
            <span class="crumb">App</span> / <span class="crumb active">Profil Saya</span>
          </div>
        </div>
      </header>

      <div class="content-inner fade-in">
        <div class="profile-layout">
          <!-- Profile Header Block -->
          <div class="card-zen profile-hero-card">
            <div class="card-p">
              <div class="profile-header-main">
                <div class="profile-avatar-large" id="avatar-circle">
                  <span id="avatar-text">U</span>
                </div>
                <div class="profile-meta-text">
                  <h1 id="display-name-hero">Memuat...</h1>
                  <p id="display-email-hero">email@example.com</p>
                </div>
              </div>
            </div>
          </div>

          <div class="profile-grid">
            <!-- Edit Information -->
            <div class="card-zen info-card">
              <div class="card-p">
                <h3 class="card-title-v2">Informasi Publik</h3>
                <form id="form-profile" class="form-zen">
                  <div class="input-group">
                    <label>Nama Lengkap</label>
                    <input type="text" id="full_name" placeholder="Nama Lengkap Anda" required />
                  </div>
                  <div class="input-group">
                    <label>Nomor Telepon</label>
                    <input type="tel" id="phone" placeholder="08xxxxxxxxxx" />
                  </div>
                  <button type="submit" id="btn-save" class="btn-saas btn-saas-primary">Simpan Perubahan</button>
                </form>
              </div>
            </div>

            <!-- Security Card -->
            <div class="card-zen security-card">
              <div class="card-p">
                <h3 class="card-title-v2">Keamanan & Akses</h3>
                <div class="security-item">
                  <div class="s-info">
                    <h4>Ganti Kata Sandi</h4>
                    <p>Atur ulang password Anda melalui email verifikasi.</p>
                  </div>
                  <button id="btn-reset-pw" class="btn-saas btn-outline-v2">Ganti Password</button>
                </div>
                <div class="security-item danger-item">
                  <div class="s-info">
                    <h4>Keluar Sesi</h4>
                    <p>Keluar dari akun Anda di perangkat ini.</p>
                  </div>
                  <button id="btn-logout-main" class="btn-saas btn-danger-v2">Keluar</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <div id="toast" class="saas-toast"></div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) window.location.href = '/login';

    const user = JSON.parse(userRaw);
    document.getElementById('display-email-hero').textContent = user.email;
    document.getElementById('avatar-text').textContent = (user.name || 'U')[0].toUpperCase();

    async function fetchProfile() {
      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if (data.data) {
          document.getElementById('full_name').value = data.data.full_name || '';
          document.getElementById('phone').value = data.data.phone || '';
          document.getElementById('display-name-hero').textContent = data.data.full_name || user.email.split('@')[0];
          document.getElementById('avatar-text').textContent = (data.data.full_name || 'U')[0].toUpperCase();
        }
      } catch (err) { console.error('Gagal ambil profil'); }
    }

    document.getElementById('form-profile').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      const payload = {
        full_name: document.getElementById('full_name').value,
        phone: document.getElementById('phone').value
      };
      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          method: 'PUT',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });
        if (res.ok) {
          showToast('Profil berhasil diperbarui!');
          user.name = payload.full_name;
          localStorage.setItem('user', JSON.stringify(user));
          document.getElementById('display-name-hero').textContent = payload.full_name;
          document.getElementById('avatar-text').textContent = payload.full_name[0].toUpperCase();
        } else { showToast('Gagal menyimpan', 'error'); }
      } catch (err) { showToast('Terjadi kesalahan', 'error'); }
      finally { btn.disabled = false; }
    });

    document.getElementById('btn-reset-pw').onclick = async () => {
      const btn = document.getElementById('btn-reset-pw');
      btn.disabled = true;
      try {
        const res = await fetch(`${API_URL}/api/auth/forgot-password`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: user.email })
        });
        if (res.ok) {
          showToast('OTP dikirim ke email!');
          setTimeout(() => window.location.href = `/reset-password?email=${user.email}`, 1500);
        } else { showToast('Gagal mengirim OTP', 'error'); }
      } catch (err) { showToast('Terjadi kesalahan', 'error'); }
      finally { btn.disabled = false; }
    };

    const logout = () => { localStorage.clear(); window.location.href = '/login'; };
    document.getElementById('btn-logout-desktop').onclick = logout;
    document.getElementById('btn-logout-mobile').onclick = logout;
    document.getElementById('btn-logout-main').onclick = logout;

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.textContent = msg; t.className = `saas-toast show ${type}`;
      setTimeout(() => t.className = 'saas-toast', 3000);
    }

    fetchProfile();
  </script>
</Layout>

<style>
  /* Profile Specific Layout */
  .profile-layout { max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: 24px; }
  
  .profile-hero-card { background: white; }
  .profile-header-main { display: flex; align-items: center; gap: 32px; }
  .profile-avatar-large { width: 100px; height: 100px; background: #111827; color: white; border-radius: 32px; display: flex; align-items: center; justify-content: center; font-size: 36px; font-weight: 900; }
  .profile-meta-text h1 { font-size: 32px; font-weight: 900; letter-spacing: -0.03em; margin-bottom: 4px; }
  .profile-meta-text p { color: var(--color-saas-text-muted); font-size: 16px; font-weight: 600; }

  .profile-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 24px; }
  .card-p { padding: 32px; }
  .card-title-v2 { font-size: 18px; font-weight: 800; margin-bottom: 24px; }

  .security-item { padding: 20px; background: #F9FAFB; border-radius: 20px; display: flex; flex-direction: column; gap: 16px; margin-bottom: 16px; border: 1px solid var(--color-saas-border); }
  .s-info h4 { font-size: 15px; font-weight: 800; margin-bottom: 4px; }
  .s-info p { font-size: 13px; color: var(--color-saas-text-muted); }
  
  .btn-outline-v2 { background: white; border: 1.5px solid var(--color-saas-border); color: #111827; }
  .btn-outline-v2:hover { background: #F9FAFB; border-color: #D1D5DB; }
  
  .btn-danger-v2 { background: #FEE2E2; color: #EF4444; border: 1.5px solid #FCA5A5; }
  .btn-danger-v2:hover { background: #FECACA; }

  /* Responsive Adjustments */
  @media (max-width: 1024px) {
    .profile-grid { grid-template-columns: 1fr; }
    .profile-header-main { flex-direction: column; text-align: center; }
  }

  @media (max-width: 767px) {
    .profile-hero-card .card-p { padding: 24px; }
    .profile-avatar-large { width: 80px; height: 80px; font-size: 28px; border-radius: 24px; }
    .profile-meta-text h1 { font-size: 24px; }
    .card-p { padding: 24px; }
  }

  /* Shared Sidebar Local overrides */
  .sidebar-brand { margin-bottom: 48px; padding: 0 12px; }
  .brand-img { height: 48px; width: auto; filter: invert(1); }
  .sidebar-nav-v2 { display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .side-item { display: flex; align-items: center; gap: 16px; padding: 14px 20px; border-radius: 14px; color: rgba(255,255,255,0.6); text-decoration: none; font-weight: 600; font-size: 15px; transition: 0.2s; }
  .side-item:hover { background: rgba(255,255,255,0.05); color: white; }
  .side-item.active { background: var(--color-saas-accent); color: #111827; }
  .side-item.logout { color: #F87171; margin-top: auto; }
  .s-icon { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; }
  .mob-item { color: var(--color-saas-text-muted); padding: 12px; border-radius: 12px; }
  .mob-item.active { color: #111827; background: #F9FAFB; }
  .m-icon { width: 24px; height: 24px; stroke: currentColor; fill: none; stroke-width: 2.5; }
  .mobile-logo-only { display: none; }
  @media (max-width: 767px) { .mobile-logo-only { display: block; height: 32px; } .mobile-logo-only img { height: 100%; } }
</style>
