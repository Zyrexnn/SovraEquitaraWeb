---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Profil Saya — SovraEquitara">
  <div class="dashboard-wrapper">
    <!-- Sidebar -->
    <aside class="sidebar-nav">
      <div class="nav-brand">
        <div class="brand-logo-pill">
          <img src="/logo.svg" alt="Sovra" />
        </div>
      </div>
      <nav class="nav-links">
        <a href="/dashboard" class="nav-link" title="Dashboard">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        </a>
        <a href="/profile" class="nav-link active" title="Profil">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
      </nav>
      <div class="nav-footer">
        <button id="btn-logout" class="nav-link logout-link" title="Keluar">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-viewport scroll-slim">
      <header class="top-nav">
        <div class="welcome-msg">
          <h1>Pengaturan Profil</h1>
          <p>Kelola informasi publik dan keamanan akun Anda.</p>
        </div>
      </header>

      <div class="bento-container">
        <!-- Profile Card -->
        <div class="bento-item glass animate-up" style="grid-column: span 12;">
          <div class="profile-header-zen">
            <div class="avatar-zen">
              <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            </div>
            <div class="avatar-details">
              <h3 id="display-name-header">Memuat...</h3>
              <p id="display-email">email@example.com</p>
            </div>
          </div>

          <form id="form-profile" class="zen-form">
            <div class="form-row">
              <div class="form-group">
                <label for="full_name">Nama Lengkap</label>
                <div class="zen-input">
                  <input type="text" id="full_name" placeholder="Nama Lengkap Anda" required />
                </div>
              </div>
              <div class="form-group">
                <label for="phone">Nomor Telepon</label>
                <div class="zen-input">
                  <input type="tel" id="phone" placeholder="08xxxxxxxxxx" />
                </div>
              </div>
            </div>
            <div class="form-actions-right">
              <button type="submit" id="btn-save" class="btn btn-primary">Simpan Perubahan</button>
            </div>
          </form>
        </div>

        <!-- Security Section -->
        <div class="bento-item glass animate-up delay-1" style="grid-column: span 12;">
          <div class="card-header-flex">
            <h3>Keamanan Akun</h3>
            <p>Perbarui password secara berkala.</p>
          </div>
          
          <div class="security-list">
            <div class="security-row">
              <div class="security-info">
                <h4>Ganti Kata Sandi</h4>
                <p>Gunakan verifikasi OTP email untuk mengatur ulang password.</p>
              </div>
              <button id="btn-reset-pw" class="btn btn-glass">Minta Reset</button>
            </div>
          </div>
        </div>
      </div>
    </main>

    <div id="toast" class="toast-bento"></div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) window.location.href = '/login';

    const user = JSON.parse(userRaw);
    document.getElementById('display-email').textContent = user.email;

    async function fetchProfile() {
      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if (data.data) {
          document.getElementById('full_name').value = data.data.full_name || '';
          document.getElementById('phone').value = data.data.phone || '';
          document.getElementById('display-name-header').textContent = data.data.full_name || user.email.split('@')[0];
        }
      } catch (err) { console.error('Gagal ambil profil'); }
    }

    document.getElementById('form-profile').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-save');
      btn.disabled = true; btn.textContent = 'Menyimpan...';

      const payload = {
        full_name: document.getElementById('full_name').value,
        phone: document.getElementById('phone').value
      };

      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          method: 'PUT',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });

        if (res.ok) {
          showToast('Profil diperbarui!');
          user.name = payload.full_name;
          localStorage.setItem('user', JSON.stringify(user));
          document.getElementById('display-name-header').textContent = payload.full_name;
        } else { showToast('Gagal menyimpan', 'error'); }
      } catch (err) { showToast('Masalah koneksi', 'error'); } 
      finally { btn.disabled = false; btn.textContent = 'Simpan Perubahan'; }
    });

    document.getElementById('btn-reset-pw').onclick = async () => {
      const btn = document.getElementById('btn-reset-pw');
      btn.disabled = true; btn.textContent = 'Memproses...';
      try {
        const res = await fetch(`${API_URL}/api/auth/forgot-password`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: user.email })
        });
        if (res.ok) {
          showToast('OTP dikirim ke email!');
          setTimeout(() => window.location.href = `/reset-password?email=${user.email}`, 1500);
        } else { showToast('Gagal kirim OTP', 'error'); }
      } catch (err) { showToast('Masalah koneksi', 'error'); } 
      finally { btn.disabled = false; btn.textContent = 'Minta Reset'; }
    };

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.textContent = msg; t.className = `toast-bento show ${type}`;
      setTimeout(() => t.className = 'toast-bento', 3000);
    }

    document.getElementById('btn-logout').onclick = () => { localStorage.clear(); window.location.href = '/login'; };
    fetchProfile();
  </script>
</Layout>

<style>
  .profile-header-zen { display: flex; align-items: center; gap: var(--space-xl); margin-bottom: var(--space-2xl); }
  .avatar-zen { 
    width: 90px; height: 90px; border-radius: 30px; 
    background: var(--color-bg); color: var(--color-brand);
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-soft);
  }
  .avatar-details h3 { font-size: 24px; font-weight: 800; color: var(--color-text-title); margin-bottom: 4px; }
  .avatar-details p { font-size: 15px; color: var(--color-text-muted); font-weight: 600; }

  .zen-form { display: flex; flex-direction: column; gap: var(--space-xl); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); }
  .form-group label { display: block; font-size: 13px; font-weight: 800; color: var(--color-text-title); margin-bottom: 8px; }
  
  .zen-input input {
    width: 100%; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 16px; padding: 14px 20px; color: var(--color-text-title);
    font-family: inherit; font-size: 15px; transition: all 0.3s;
  }
  .zen-input input:focus { outline: none; border-color: var(--color-brand); box-shadow: 0 0 0 4px rgba(26,26,26,0.05); }

  .form-actions-right { display: flex; justify-content: flex-end; margin-top: var(--space-lg); }

  .security-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: var(--space-lg); background: var(--color-bg); border-radius: 20px;
    margin-top: var(--space-xl);
  }
  .security-info h4 { font-size: 15px; font-weight: 800; color: var(--color-text-title); margin-bottom: 4px; }
  .security-info p { font-size: 13px; color: var(--color-text-muted); }

  @media (max-width: 768px) {
    .form-row { grid-template-columns: 1fr; }
    .profile-header-zen { flex-direction: column; text-align: center; }
    .security-row { flex-direction: column; gap: var(--space-lg); text-align: center; }
  }
</style>
