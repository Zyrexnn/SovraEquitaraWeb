---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Profil Saya — SovraEquitara">
  <div class="flex h-screen overflow-hidden bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark font-display">
    <!-- Desktop Sidebar -->
    <aside class="hidden md:flex w-[280px] bg-zen-card/40 dark:bg-zen-card-dark/40 backdrop-blur-xl border-r border-zen-border dark:border-zen-border-dark flex-col z-[100]">
      <div class="p-10 pb-6">
        <a href="/" class="block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-16 w-auto dark:brightness-0 dark:invert" />
        </a>
      </div>
      
      <nav class="flex-1 px-4 flex flex-col gap-1">
        <div id="nav-section-title" class="text-[10px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark px-3 py-3 tracking-widest uppercase">NAVIGASI</div>
        <a href="/dashboard" id="nav-dashboard-link" class="flex items-center gap-3 p-3 rounded-xl text-zen-text-secondary dark:text-zen-text-secondary-dark hover:bg-zen-bg hover:text-zen-text dark:hover:bg-zen-bg-dark dark:hover:text-zen-text-dark font-semibold text-sm transition-colors no-underline">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          <span id="nav-dashboard-text">Dashboard Warga</span>
        </a>
        <a href="/profile" class="flex items-center gap-3 p-3 rounded-xl text-blue-500 bg-blue-50 dark:bg-blue-500/10 border border-zen-border dark:border-zen-border-dark shadow-sm font-bold text-sm transition-colors no-underline">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          Profil Saya
        </a>
      </nav>

      <div class="p-6 border-t border-zen-border dark:border-zen-border-dark">
        <div class="p-4 rounded-2xl bg-zen-surface dark:bg-zen-surface-dark backdrop-blur-md border border-zen-border dark:border-zen-border-dark flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-full bg-zen-text dark:bg-zen-text-dark text-zen-bg dark:text-zen-bg-dark flex items-center justify-center font-extrabold" id="sidebar-avatar">U</div>
          <div class="flex flex-col">
            <span class="font-extrabold text-sm" id="sidebar-name">Memuat...</span>
            <span class="text-[11px] font-extrabold text-blue-500" id="sidebar-points">0 PTS</span>
          </div>
        </div>
        <button id="btn-logout-desktop" class="w-full flex items-center justify-center gap-2.5 p-3 bg-transparent border border-zen-border dark:border-zen-border-dark rounded-xl text-zen-text-secondary dark:text-zen-text-secondary-dark font-bold text-[13px] cursor-pointer transition-colors hover:bg-zen-bg dark:hover:bg-zen-bg-dark">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>
          Keluar Sesi
        </button>
      </div>
    </aside>

    <!-- Mobile Header -->
    <header class="md:hidden flex justify-between items-center p-4 px-5 bg-white/80 dark:bg-black/80 backdrop-blur-md border-b border-zen-border dark:border-zen-border-dark sticky top-0 z-[1000]">
      <a href="/" class="block hover:opacity-80 transition-opacity">
        <img src="/logo.svg" alt="SovraEquitara" class="h-12 w-auto dark:brightness-0 dark:invert" />
      </a>
      <div class="flex items-center gap-2.5 px-3 py-1 bg-white dark:bg-black rounded-full font-extrabold text-xs text-blue-500 shadow-sm border border-zen-border dark:border-zen-border-dark">
        <span id="mobile-points">0 PTS</span>
        <div class="w-8 h-8 rounded-full bg-zen-text dark:bg-zen-text-dark text-white flex items-center justify-center text-xs" id="mobile-avatar">U</div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto pb-24 md:pb-0">
      <div class="max-w-[1200px] mx-auto p-6 md:p-10 lg:p-12">
        
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10 animate-up">
          <div>
            <h1 class="text-[32px] font-extrabold tracking-tight mb-1">Pengaturan <span class="bg-gradient-to-r from-blue-500 to-emerald-500 text-transparent bg-clip-text">Profil</span></h1>
            <p class="text-[15px] text-zen-text-secondary dark:text-zen-text-secondary-dark">Kelola identitas dan keamanan akun Anda.</p>
          </div>
          <div>
             <div class="px-4 py-2 rounded-full font-extrabold text-xs bg-white dark:bg-black text-zen-text dark:text-zen-text-dark uppercase tracking-wide border border-zen-border dark:border-zen-border-dark" id="hero-role">Warga</div>
          </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          
          <!-- Hero Profile Info -->
          <div class="md:col-span-2 bg-zen-surface dark:bg-zen-surface-dark backdrop-blur-md border border-zen-border dark:border-zen-border-dark rounded-[28px] p-8 shadow-zen animate-up" style="animation-delay: 0.1s;">
            <div class="flex items-center gap-8">
              <div class="w-[80px] h-[80px] md:w-[120px] md:h-[120px] rounded-[28px] bg-zen-text dark:bg-zen-text-dark text-zen-bg dark:text-zen-bg-dark flex items-center justify-center text-3xl md:text-5xl font-black shadow-lg" id="avatar-circle">U</div>
              <div>
                <h2 id="display-name-hero" class="text-2xl md:text-4xl font-black tracking-tight m-0">Memuat...</h2>
                <p id="display-email-hero" class="text-lg font-medium text-zen-text-secondary dark:text-zen-text-secondary-dark mt-1">email@example.com</p>
              </div>
            </div>
          </div>

          <!-- Public Info Form -->
          <div class="bg-zen-surface dark:bg-zen-surface-dark backdrop-blur-md border border-zen-border dark:border-zen-border-dark rounded-[28px] p-8 shadow-zen animate-up" style="animation-delay: 0.15s;">
            <div class="flex justify-between items-center mb-8">
              <h3 class="text-base font-extrabold m-0">Informasi Publik</h3>
              <span class="text-[11px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase tracking-wide">Identitas Warga</span>
            </div>
            <form id="form-profile" class="flex flex-col gap-6">
              <div>
                <label class="block text-xs font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark mb-2.5 uppercase tracking-wide">Nama Lengkap / Nickname</label>
                <input type="text" id="full_name" placeholder="Contoh: Budi Santoso" required class="w-full p-3.5 px-4 rounded-2xl border border-zen-border dark:border-zen-border-dark !bg-zen-surface dark:!bg-black text-sm font-medium outline-none focus:border-zen-text dark:focus:border-zen-text-dark focus:ring-4 focus:ring-black/5 dark:focus:ring-white/5 transition-all appearance-none" />
                <p class="text-[11px] font-semibold text-zen-text-secondary dark:text-zen-text-secondary-dark mt-2">Nama ini akan terlihat pada laporan dan diskusi publik.</p>
              </div>
              <div>
                <label class="block text-xs font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark mb-2.5 uppercase tracking-wide">Nomor WhatsApp</label>
                <input type="tel" id="phone" placeholder="08xxxxxxxxxx" class="w-full p-3.5 px-4 rounded-2xl border border-zen-border dark:border-zen-border-dark !bg-zen-surface dark:!bg-black text-sm font-medium outline-none focus:border-zen-text dark:focus:border-zen-text-dark focus:ring-4 focus:ring-black/5 dark:focus:ring-white/5 transition-all appearance-none" />
              </div>
              <button type="submit" id="btn-save" class="w-full p-4 rounded-2xl bg-zen-text dark:bg-zen-text-dark text-zen-bg dark:text-zen-bg-dark font-extrabold flex items-center justify-center gap-2.5 hover:-translate-y-0.5 hover:shadow-lg transition-all cursor-pointer border-none">
                Simpan Perubahan
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </button>
            </form>
          </div>

          <!-- Security Settings -->
          <div class="bg-zen-surface dark:bg-zen-surface-dark backdrop-blur-md border border-zen-border dark:border-zen-border-dark rounded-[28px] p-8 shadow-zen animate-up" style="animation-delay: 0.2s;">
            <div class="flex justify-between items-center mb-8">
              <h3 class="text-base font-extrabold m-0">Keamanan Akun</h3>
              <span class="text-[11px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase tracking-wide">Akses & Privasi</span>
            </div>
            <div class="flex flex-col gap-4">
              <div class="p-6 rounded-2xl bg-white/40 dark:bg-black/40 border border-zen-border dark:border-zen-border-dark flex flex-col gap-4">
                <div>
                  <h4 class="text-[15px] font-extrabold m-0">Ganti Kata Sandi</h4>
                  <p class="text-[13px] font-medium text-zen-text-secondary dark:text-zen-text-secondary-dark mt-1 mb-0 leading-relaxed">Kirim instruksi reset ke email terdaftar.</p>
                </div>
                <button id="btn-reset-pw" class="w-full p-3 rounded-xl bg-white dark:bg-black border border-zen-border dark:border-zen-border-dark font-bold text-[13px] cursor-pointer hover:-translate-y-0.5 hover:shadow-sm transition-all">Reset via Email</button>
              </div>
              <div class="p-6 rounded-2xl bg-white/40 dark:bg-black/40 border border-zen-border dark:border-zen-border-dark flex flex-col gap-4">
                <div>
                  <h4 class="text-[15px] font-extrabold m-0">Hapus Sesi</h4>
                  <p class="text-[13px] font-medium text-zen-text-secondary dark:text-zen-text-secondary-dark mt-1 mb-0 leading-relaxed">Keluar dari akun Anda pada perangkat ini.</p>
                </div>
                <button id="btn-logout-main" class="w-full p-3 rounded-xl bg-red-50 dark:bg-red-500/10 text-red-500 border border-red-200 dark:border-red-500/20 font-bold text-[13px] cursor-pointer hover:bg-red-500 hover:text-white transition-all">Keluar Sesi</button>
              </div>
            </div>
          </div>

        </div>
      </div>
    </main>

    <!-- Mobile Nav -->
    <nav class="md:hidden flex justify-around items-center fixed bottom-0 left-0 right-0 h-[72px] bg-white/80 dark:bg-black/80 backdrop-blur-md border-t border-zen-border dark:border-zen-border-dark z-[1000] pb-safe">
      <a href="/dashboard" class="p-3 rounded-xl text-zen-text-secondary dark:text-zen-text-secondary-dark" id="mob-dashboard-link">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
      </a>
      <a href="/profile" class="p-3 rounded-xl text-zen-text dark:text-zen-text-dark bg-black/5 dark:bg-white/5">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <button id="btn-logout-mobile" class="p-3 rounded-xl text-red-500 bg-transparent border-none cursor-pointer">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>
      </button>
    </nav>

    <!-- Zen Toast -->
    <div id="toast" class="fixed bottom-24 left-1/2 -translate-x-1/2 bg-zen-text dark:bg-zen-text-dark text-white px-6 py-3 rounded-full font-extrabold text-[13px] z-[2000] shadow-2xl transition-all duration-300 hidden">
      <span id="toast-msg">Notifikasi</span>
    </div>
  </div>

  <script is:inline>
    const API_URL = 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('DOMContentLoaded', initProfile);
    }

    let user;

    async function initProfile() {
      user = JSON.parse(userRaw);
      setupUI();
      await fetchProfileData();
      setupListeners();
    }

    function setupUI() {
      const isAdmin = (user.role || '').toUpperCase() === 'ADMIN';
      const initial = (user.name || 'U')[0].toUpperCase();
      
      if (isAdmin) {
        document.getElementById('nav-section-title').textContent = 'ADMINISTRASI';
        document.getElementById('nav-dashboard-link').href = '/admin/dashboard';
        document.getElementById('nav-dashboard-text').textContent = 'Dashboard Admin';
        document.getElementById('mob-dashboard-link').href = '/admin/dashboard';
        document.getElementById('hero-role').textContent = 'Administrator';
        const roleEl = document.getElementById('hero-role');
        roleEl.classList.remove('bg-white', 'dark:bg-black', 'text-zen-text', 'dark:text-zen-text-dark');
        roleEl.classList.add('bg-zen-text', 'dark:bg-zen-text-dark', 'text-white');
      }

      document.getElementById('sidebar-name').textContent = user.name || 'Warga';
      document.getElementById('sidebar-avatar').textContent = initial;
      document.getElementById('mobile-avatar').textContent = initial;
      document.getElementById('sidebar-points').textContent = `${user.points || 0} PTS`;
      document.getElementById('mobile-points').textContent = `${user.points || 0} PTS`;
      
      document.getElementById('display-name-hero').textContent = user.name || (isAdmin ? 'Admin' : 'Warga');
      document.getElementById('display-email-hero').textContent = user.email;
      document.getElementById('avatar-circle').textContent = initial;
    }

    async function fetchProfileData() {
      try {
        const res = await fetch(`${API_URL}/api/profile`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        if (data.data) {
          const name = data.data.full_name || user.email.split('@')[0];
          document.getElementById('full_name').value = name;
          document.getElementById('phone').value = data.data.phone || '';
          updateDisplays(name);
        }
      } catch (e) {}
    }

    function updateDisplays(name) {
      const initial = name[0].toUpperCase();
      document.getElementById('display-name-hero').textContent = name;
      document.getElementById('avatar-circle').textContent = initial;
      document.getElementById('sidebar-name').textContent = name;
      document.getElementById('sidebar-avatar').textContent = initial;
      document.getElementById('mobile-avatar').textContent = initial;
    }

    function setupListeners() {
      document.getElementById('form-profile').onsubmit = handleProfileUpdate;
      document.getElementById('btn-reset-pw').onclick = handleResetPassword;
      const logout = () => { localStorage.clear(); window.location.href = '/'; };
      document.getElementById('btn-logout-desktop').onclick = logout;
      document.getElementById('btn-logout-mobile').onclick = logout;
      document.getElementById('btn-logout-main').onclick = logout;
    }

    async function handleProfileUpdate(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      const payload = {
        full_name: document.getElementById('full_name').value,
        phone: document.getElementById('phone').value
      };

      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify(payload)
        });
        if (res.ok) {
          showToast('Profil Diperbarui!');
          user.name = payload.full_name;
          localStorage.setItem('user', JSON.stringify(user));
          updateDisplays(payload.full_name);
        }
      } catch (e) {}
      btn.disabled = false;
    }

    async function handleResetPassword() {
      const btn = document.getElementById('btn-reset-pw');
      btn.disabled = true;
      try {
        const res = await fetch(`${API_URL}/api/auth/forgot-password`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: user.email })
        });
        if (res.ok) {
          showToast('Email Terkirim!');
          setTimeout(() => window.location.href = `/reset-password?email=${user.email}`, 1500);
        }
      } catch (e) {}
      btn.disabled = false;
    }

    function showToast(msg) {
      const t = document.getElementById('toast');
      document.getElementById('toast-msg').textContent = msg;
      t.classList.remove('hidden');
      setTimeout(() => t.classList.add('hidden'), 3000);
    }
  </script>


</Layout>
