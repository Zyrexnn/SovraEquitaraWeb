---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Profil Saya — SovraEquitara">
  <div class="saas-layout">
    <!-- Desktop Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <img src="/logo.svg" alt="SovraEquitara" style="height: 48px; width: auto;" />
        </div>
      </div>
      
      <nav class="nav-menu">
        <div class="nav-section" id="nav-section-title">MENU UTAMA</div>
        <a href="/dashboard" class="nav-item" id="nav-dashboard-link">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          <span id="nav-dashboard-text">Dashboard</span>
        </a>
        <a href="/history" class="nav-item nav-history">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Riwayat Laporan
        </a>
        <a href="/profile" class="nav-item active">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          <span id="nav-profile-text">Profil Saya</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-profile">
          <div class="avatar" id="sidebar-avatar">U</div>
          <div class="user-info">
            <span class="user-name" id="sidebar-name">Warga</span>
            <span class="user-points" id="sidebar-points">0 PTS</span>
          </div>
        </div>
        <button id="btn-logout-desktop" class="btn-logout">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Keluar
        </button>
      </div>
    </aside>

    <!-- Mobile Top Bar -->
    <header class="mobile-header">
      <div class="logo">
        <img src="/logo.svg" alt="SovraEquitara" style="height: 32px; width: auto;" />
      </div>
      <div class="user-profile-mobile">
        <span class="points-badge" id="mobile-points">0 PTS</span>
        <div class="avatar-small" id="mobile-avatar">U</div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <div class="content-wrapper">
        
        <!-- Welcome Section -->
        <section class="welcome-section fade-in">
          <div>
            <h1 id="greeting">Profil Saya</h1>
            <p class="subtitle">Kelola informasi publik dan keamanan akun Anda.</p>
          </div>
        </section>

        <div class="profile-layout">
          <!-- Profile Header Block -->
          <div class="bento-card profile-hero-card fade-in" style="animation-delay: 0.1s;">
            <div class="profile-header-main">
              <div class="profile-avatar-large" id="avatar-circle">
                <span id="avatar-text">U</span>
              </div>
              <div class="profile-meta-text">
                <h1 id="display-name-hero">Memuat...</h1>
                <p id="display-email-hero">email@example.com</p>
                <div class="badge-role mt-2">Warga</div>
              </div>
            </div>
          </div>

          <div class="bento-grid profile-grid">
            <!-- Edit Information -->
            <div class="bento-card info-card fade-in" style="animation-delay: 0.2s;">
              <div class="card-header">
                <h2>Informasi Publik</h2>
              </div>
              <form id="form-profile" class="saas-form">
                <div class="form-group">
                  <label>Nama / Nickname (Publik)</label>
                  <input type="text" id="full_name" placeholder="Nama yang akan tampil di diskusi" required />
                  <p class="help-text mt-1">Nama ini akan digunakan pada semua laporan dan komentar Anda.</p>
                </div>
                <div class="form-group">
                  <label>Nomor Telepon</label>
                  <input type="tel" id="phone" placeholder="08xxxxxxxxxx" />
                </div>
                <button type="submit" id="btn-save" class="btn-primary w-full mt-4">Simpan Perubahan</button>
              </form>
            </div>

            <!-- Security Card -->
            <div class="bento-card security-card fade-in" style="animation-delay: 0.3s;">
              <div class="card-header">
                <h2>Keamanan & Akses</h2>
              </div>
              <div class="security-list">
                <div class="security-item">
                  <div class="s-info">
                    <h4>Ganti Kata Sandi</h4>
                    <p>Atur ulang password Anda melalui email verifikasi.</p>
                  </div>
                  <button id="btn-reset-pw" class="btn-outline-v2 mt-2">Kirim Email Reset</button>
                </div>
                <div class="security-item danger-item mt-4">
                  <div class="s-info">
                    <h4 class="text-danger">Keluar Sesi</h4>
                    <p>Keluar dari akun Anda di perangkat ini.</p>
                  </div>
                  <button id="btn-logout-main" class="btn-danger-v2 mt-2">Keluar Sekarang</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <a href="/dashboard" class="m-nav-item" id="mob-dashboard-link">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
      </a>
      <a href="/history" class="m-nav-item mob-history">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <a href="/profile" class="m-nav-item active">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
    </nav>

    <!-- Toast Notification -->
    <div id="toast" class="toast-notification hidden">
      <span id="toast-icon">✓</span>
      <span id="toast-msg">Berhasil!</span>
    </div>
  </div>

  <script is:inline>
    const API_URL = 'http://localhost:3000';
    
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('DOMContentLoaded', initProfile);
    }

    let user;

    function initProfile() {
      try {
        user = JSON.parse(userRaw);
        const initial = (user.name || 'U')[0].toUpperCase();
        const isAdmin = (user.role || '').toUpperCase() === 'ADMIN';
        
        // Role-based UI Adjustments
        if (isAdmin) {
          document.getElementById('nav-section-title').textContent = 'PANEL KONTROL';
          document.getElementById('nav-dashboard-link').href = '/admin/dashboard';
          document.getElementById('nav-dashboard-text').textContent = 'Antrean Laporan';
          document.getElementById('nav-profile-text').textContent = 'Profil Admin';
          document.querySelector('.badge-role').textContent = 'Administrator';
          document.querySelector('.badge-role').style.background = '#0F172A';
          document.querySelector('.badge-role').style.color = 'white';
          
          // Hide History link for admin if not needed, or keep it. Let's hide it to be consistent with admin dashboard.
          document.querySelector('.nav-history').style.display = 'none';
          document.querySelector('.mob-history').style.display = 'none';
          document.getElementById('mob-dashboard-link').href = '/admin/dashboard';
        }

        // Sidebar Setup
        document.getElementById('sidebar-name').textContent = user.name;
        document.getElementById('sidebar-avatar').textContent = initial;
        document.getElementById('mobile-avatar').textContent = initial;
        document.getElementById('sidebar-points').textContent = `${user.points || 0} PTS`;
        document.getElementById('mobile-points').textContent = `${user.points || 0} PTS`;

        // Profile Setup
        document.getElementById('display-email-hero').textContent = user.email;
        document.getElementById('avatar-text').textContent = initial;
        document.getElementById('display-name-hero').textContent = user.name || (isAdmin ? 'Admin' : 'Warga');

        fetchProfileData();

        document.getElementById('form-profile').addEventListener('submit', handleProfileUpdate);
        document.getElementById('btn-reset-pw').addEventListener('click', handleResetPassword);

        const doLogout = () => { localStorage.clear(); window.location.href = '/login'; };
        document.getElementById('btn-logout-desktop').addEventListener('click', doLogout);
        document.getElementById('btn-logout-main').addEventListener('click', doLogout);
        
      } catch(e) {
        console.error("Profile Init Error: ", e);
      }
    }

    async function fetchProfileData() {
      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if (data.data) {
          const name = data.data.full_name || user.email.split('@')[0];
          document.getElementById('full_name').value = name;
          document.getElementById('phone').value = data.data.phone || '';
          document.getElementById('display-name-hero').textContent = name;
          document.getElementById('avatar-text').textContent = name[0].toUpperCase();
          document.getElementById('sidebar-name').textContent = name;
          document.getElementById('sidebar-avatar').textContent = name[0].toUpperCase();
          document.getElementById('mobile-avatar').textContent = name[0].toUpperCase();
        }
      } catch (err) { console.error('Gagal ambil profil'); }
    }

    async function handleProfileUpdate(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-save');
      btn.disabled = true;
      btn.textContent = 'Menyimpan...';

      const payload = {
        full_name: document.getElementById('full_name').value,
        phone: document.getElementById('phone').value
      };

      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          method: 'PUT',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify(payload)
        });
        if (res.ok) {
          showToast('Profil berhasil diperbarui!');
          user.name = payload.full_name;
          localStorage.setItem('user', JSON.stringify(user));
          
          const initial = payload.full_name[0].toUpperCase();
          document.getElementById('display-name-hero').textContent = payload.full_name;
          document.getElementById('avatar-text').textContent = initial;
          document.getElementById('sidebar-name').textContent = payload.full_name;
          document.getElementById('sidebar-avatar').textContent = initial;
          document.getElementById('mobile-avatar').textContent = initial;
        } else { 
          showToast('Gagal menyimpan profil', 'error'); 
        }
      } catch (err) { 
        showToast('Terjadi kesalahan jaringan', 'error'); 
      }
      finally { 
        btn.disabled = false; 
        btn.textContent = 'Simpan Perubahan';
      }
    }

    async function handleResetPassword() {
      const btn = document.getElementById('btn-reset-pw');
      btn.disabled = true;
      btn.textContent = 'Mengirim...';
      try {
        const res = await fetch(`${API_URL}/api/auth/forgot-password`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: user.email })
        });
        if (res.ok) {
          showToast('Email reset berhasil dikirim!');
          setTimeout(() => window.location.href = `/reset-password?email=${user.email}`, 1500);
        } else { 
          showToast('Gagal mengirim email reset', 'error'); 
        }
      } catch (err) { 
        showToast('Terjadi kesalahan', 'error'); 
      }
      finally { 
        btn.disabled = false; 
        btn.textContent = 'Kirim Email Reset';
      }
    }

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      const i = document.getElementById('toast-icon');
      const m = document.getElementById('toast-msg');
      
      t.className = `toast-notification ${type}`;
      i.textContent = type === 'error' ? '!' : '✓';
      m.textContent = msg;
      
      t.classList.remove('hidden');
      setTimeout(() => t.classList.add('hidden'), 3000);
    }
  </script>

  <style is:global>
    /* =========================================
       Zen SaaS Architecture (Profile)
       ========================================= */
    
    :root {
      --c-bg: #F8FAFC;
      --c-surface: #FFFFFF;
      --c-text: #0F172A;
      --c-text-soft: #64748B;
      --c-border: #E2E8F0;
      --c-brand: #0F172A;
      --c-accent: #3B82F6;
      --c-danger: #EF4444;
      --c-success: #10B981;
      --c-warning: #F59E0B;
      
      --radius-sm: 8px;
      --radius-md: 16px;
      --radius-lg: 24px;
      
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.05);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', system-ui, sans-serif; }
    body { background: var(--c-bg); color: var(--c-text); -webkit-font-smoothing: antialiased; }

    /* Layout */
    .saas-layout { display: flex; height: 100vh; overflow: hidden; }
    
    /* Sidebar Desktop */
    .sidebar { display: none; width: 280px; background: var(--c-surface); border-right: 1px solid var(--c-border); flex-direction: column; z-index: 100; }
    .sidebar-header { padding: 32px 24px; }
    .logo { display: flex; align-items: center; gap: 12px; }
    .logo-text { font-weight: 800; font-size: 20px; letter-spacing: -0.03em; }
    
    .nav-menu { flex: 1; padding: 0 16px; display: flex; flex-direction: column; gap: 4px; }
    .nav-section { font-size: 11px; font-weight: 700; color: var(--c-text-soft); padding: 16px 12px 8px; letter-spacing: 0.05em; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: var(--radius-sm); color: var(--c-text-soft); text-decoration: none; font-size: 14px; font-weight: 600; transition: 0.2s; }
    .nav-item:hover { background: var(--c-bg); color: var(--c-text); }
    .nav-item.active { background: var(--c-bg); color: var(--c-brand); }
    
    .sidebar-footer { padding: 24px 16px; border-top: 1px solid var(--c-border); }
    .user-profile { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; padding: 0 8px; }
    .avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--c-bg); border: 1px solid var(--c-border); display: flex; align-items: center; justify-content: center; font-weight: 700; }
    .user-info { display: flex; flex-direction: column; }
    .user-name { font-weight: 600; font-size: 14px; }
    .user-points { font-size: 12px; font-weight: 700; color: var(--c-accent); }
    
    .btn-logout { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; background: transparent; border: 1px solid var(--c-border); border-radius: var(--radius-sm); color: var(--c-danger); font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-logout:hover { background: #FEF2F2; border-color: #FECACA; }

    /* Mobile Nav */
    .mobile-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: var(--c-surface); border-bottom: 1px solid var(--c-border); position: sticky; top: 0; z-index: 90; }
    .user-profile-mobile { display: flex; align-items: center; gap: 12px; }
    .points-badge { background: #EFF6FF; color: var(--c-accent); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    .avatar-small { width: 32px; height: 32px; background: var(--c-bg); border: 1px solid var(--c-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; }
    
    .mobile-nav { display: flex; justify-content: space-around; align-items: center; position: fixed; bottom: 0; left: 0; right: 0; height: 64px; background: var(--c-surface); border-top: 1px solid var(--c-border); z-index: 100; padding-bottom: env(safe-area-inset-bottom); }
    .m-nav-item { padding: 8px 24px; color: var(--c-text-soft); border-radius: 12px; border: none; background: none; }
    .m-nav-item.active { color: var(--c-brand); background: var(--c-bg); }
    .text-danger { color: var(--c-danger) !important; }

    /* Main Area */
    .main-content { flex: 1; overflow-y: auto; background: var(--c-bg); padding-bottom: 80px; }
    .content-wrapper { max-width: 1200px; margin: 0 auto; padding: 24px 20px; }
    
    @media (min-width: 768px) {
      .sidebar { display: flex; }
      .mobile-header, .mobile-nav { display: none; }
      .main-content { padding-bottom: 0; }
      .content-wrapper { padding: 40px 48px; }
    }

    /* Typography & Core */
    .welcome-section { margin-bottom: 32px; }
    h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px; }
    .subtitle { color: var(--c-text-soft); font-size: 15px; }

    /* Profile Specific */
    .profile-layout { display: flex; flex-direction: column; gap: 24px; max-width: 900px; margin: 0 auto; }
    .profile-hero-card { margin-bottom: 8px; }
    .profile-header-main { display: flex; align-items: center; gap: 32px; }
    .profile-avatar-large { width: 100px; height: 100px; background: var(--c-brand); color: white; border-radius: 32px; display: flex; align-items: center; justify-content: center; font-size: 36px; font-weight: 900; }
    .profile-meta-text h1 { font-size: 32px; font-weight: 900; letter-spacing: -0.03em; margin-bottom: 4px; }
    .profile-meta-text p { color: var(--c-text-soft); font-size: 16px; font-weight: 600; }
    .badge-role { display: inline-block; background: #EFF6FF; color: var(--c-accent); padding: 4px 12px; border-radius: 6px; font-size: 12px; font-weight: 700; text-transform: uppercase; }

    .bento-grid.profile-grid { grid-template-columns: 1fr; }
    @media (min-width: 1024px) { .bento-grid.profile-grid { grid-template-columns: 1.5fr 1fr; } }
    
    .bento-card { background: var(--c-surface); border-radius: var(--radius-lg); border: 1px solid var(--c-border); padding: 32px; box-shadow: var(--shadow-sm); }
    .card-header { margin-bottom: 24px; }
    .card-header h2 { font-size: 18px; font-weight: 700; margin: 0; }

    /* Forms */
    .form-group { margin-bottom: 20px; }
    label { display: block; font-size: 13px; font-weight: 600; color: var(--c-text); margin-bottom: 8px; }
    input[type="text"], input[type="tel"] { width: 100%; background: var(--c-bg); border: 1px solid var(--c-border); padding: 12px 16px; border-radius: var(--radius-sm); font-size: 14px; transition: 0.2s; outline: none; }
    input:focus { border-color: var(--c-brand); background: var(--c-surface); box-shadow: 0 0 0 3px rgba(15,23,42,0.05); }
    .help-text { font-size: 12px; color: var(--c-text-soft); }

    .security-list { display: flex; flex-direction: column; gap: 16px; }
    .security-item { padding: 20px; background: #F8FAFC; border-radius: 16px; border: 1px solid var(--c-border); }
    .s-info h4 { font-size: 15px; font-weight: 700; margin-bottom: 4px; }
    .s-info p { font-size: 13px; color: var(--c-text-soft); }
    
    .btn-outline-v2 { width: 100%; padding: 10px; background: white; border: 1px solid var(--c-border); border-radius: var(--radius-sm); color: var(--c-text); font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-outline-v2:hover { background: var(--c-bg); border-color: #CBD5E1; }
    
    .btn-danger-v2 { width: 100%; padding: 10px; background: #FEF2F2; color: var(--c-danger); border: 1px solid #FECACA; border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-danger-v2:hover { background: #FEE2E2; }
    
    .btn-primary { padding: 14px; background: var(--c-brand); color: white; border: none; border-radius: var(--radius-sm); font-size: 15px; font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-primary:hover { opacity: 0.9; }
    .btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }

    /* Utilities */
    .mt-1 { margin-top: 4px; }
    .mt-2 { margin-top: 12px; }
    .mt-4 { margin-top: 24px; }
    .w-full { width: 100%; }
    .text-danger { color: var(--c-danger); }

    .scroll-slim::-webkit-scrollbar { width: 6px; }
    .scroll-slim::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 10px; }
    
    .toast-notification { position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--c-brand); color: white; padding: 12px 24px; border-radius: 100px; display: flex; align-items: center; gap: 12px; font-size: 14px; font-weight: 600; z-index: 9999; opacity: 0; transition: 0.3s; box-shadow: var(--shadow-lg); }
    .toast-notification:not(.hidden) { transform: translateX(-50%) translateY(0); opacity: 1; }
    .toast-notification.error { background: var(--c-danger); }
    #toast-icon { width: 20px; height: 20px; background: rgba(255,255,255,0.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; }

    .fade-in { animation: fadeIn 0.4s ease-out forwards; opacity: 0; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) {
      .profile-header-main { flex-direction: column; text-align: center; }
      .profile-avatar-large { width: 80px; height: 80px; font-size: 28px; border-radius: 24px; }
      .profile-meta-text h1 { font-size: 24px; }
      .bento-card { padding: 24px; }
    }
  </style>
</Layout>
