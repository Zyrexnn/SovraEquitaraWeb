---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Dashboard Warga — SovraEquitara">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  
  <div class="saas-layout">
    <!-- Desktop Sidebar -->
    <aside class="sidebar glass-nav">
      <div class="sidebar-header flex items-center justify-between">
        <a href="/" class="logo block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="user-logo dark:brightness-0 dark:invert" />
        </a>
        <ThemeToggle client:load />
      </div>
      
      <nav class="nav-menu">
        <div class="nav-section">NAVIGASI</div>
        <a href="/dashboard" class="nav-item active">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          Dashboard Warga
        </a>
        <a href="/profile" class="nav-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          Profil Saya
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-card glass">
          <div class="avatar-large" id="sidebar-avatar">U</div>
          <div class="user-details">
            <span class="u-name" id="sidebar-name">Memuat...</span>
            <span class="u-points" id="sidebar-points">0 PTS</span>
          </div>
        </div>
        <button id="btn-logout-desktop" class="btn-logout-zen">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>
          Keluar Sesi
        </button>
      </div>
    </aside>

    <!-- Mobile Header -->
    <header class="mobile-header glass-bright">
      <button id="btn-menu-mobile" class="mobile-menu-toggle">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2.5"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <a href="/" class="logo block">
        <img src="/logo.svg" alt="Sovra" style="height: 24px;" class="dark:brightness-0 dark:invert" />
      </a>
      <div class="user-pill glass">
        <span id="mobile-points">0 PTS</span>
        <div class="avatar-sm" id="mobile-avatar">U</div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <div class="content-wrapper">
        
        <header class="page-header fade-in">
          <div class="header-left">
            <h1 class="font-display">Suara <span class="text-gradient">Warga</span></h1>
            <p class="subtitle" id="greeting">Selamat beraktivitas, Warga.</p>
          </div>
          <div class="header-right">
            <div id="current-date" class="date-badge glass">Memuat...</div>
          </div>
        </header>

        <div class="bento-grid-user">
          
          <!-- Report Creation (Bento Main) -->
          <div class="bento-card card-form glass animate-up" style="animation-delay: 0.1s;">
            <div class="card-head">
              <h3>Aspirasi Infrastruktur</h3>
              <span class="head-hint">Laporkan Kerusakan</span>
            </div>
            
            <form id="form-report" class="zen-form">
              <div class="input-group">
                <label>Kategori Masalah</label>
                <div class="chip-container" id="category-chips">
                  <!-- Chips injected -->
                </div>
                <input type="hidden" id="category_id" />
              </div>

              <div class="grid-2">
                <div class="input-group">
                  <label>Deskripsi Detail</label>
                  <textarea id="description" placeholder="Deskripsikan kerusakan atau keluhan Anda..." required></textarea>
                </div>
                
                <div class="input-group">
                  <label>Bukti Visual</label>
                  <div class="drop-zone" id="drop-zone">
                    <div class="drop-icon">📸</div>
                    <p>Klik atau Tarik Gambar</p>
                    <input type="file" id="image-upload" accept="image/*" hidden />
                  </div>
                  <div id="image-preview" class="preview-box hidden">
                    <img id="preview-img" src="" alt="Preview" />
                    <button type="button" class="btn-clear" id="btn-remove-image">&times;</button>
                  </div>
                </div>
              </div>

              <div class="input-group">
                <label>Lokasi Kejadian</label>
                <div class="loc-input-wrap">
                  <div class="search-loc-group">
                    <input type="text" id="location_detail" placeholder="Detail Lokasi (Contoh: Depan Halte)" required />
                    <div class="search-box">
                      <input type="text" id="search-address" placeholder="Cari Alamat atau Area..." />
                      <button type="button" id="btn-search-loc" class="btn-search-icon">🔍</button>
                    </div>
                  </div>
                  <div id="map" class="zen-map"></div>
                </div>
                <input type="hidden" id="lat" /><input type="hidden" id="lng" />
              </div>

              <button type="submit" id="btn-submit" class="btn-zen-primary w-full">
                Kirim Laporan
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="3"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </button>
            </form>
          </div>

          <!-- Quick Stats -->
          <div class="bento-card card-stats glass animate-up" style="animation-delay: 0.15s;">
            <div class="stat-item">
              <span class="s-label">Total Laporan</span>
              <h2 id="stat-total">0</h2>
            </div>
            <div class="stat-item">
              <span class="s-label">Diproses</span>
              <h2 id="stat-pending" class="text-yellow">0</h2>
            </div>
            <div class="stat-item">
              <span class="s-label">Terselesaikan</span>
              <h2 id="stat-resolved" class="text-green">0</h2>
            </div>
          </div>

          <!-- Leaderboard -->
          <div class="bento-card card-leaderboard glass animate-up" style="animation-delay: 0.2s;">
            <div class="card-head">
              <h3>Warga Teladan</h3>
              <span class="badge-new">TOP 10</span>
            </div>
            <div class="leader-list scroll-slim" id="leaderboard-list">
              <!-- Leaderboard items -->
            </div>
          </div>

          <!-- Feed (Bento Wide Bottom) -->
          <div class="bento-card card-feed glass animate-up" style="animation-delay: 0.25s;">
            <div class="feed-header">
              <h3>Pantauan Kota</h3>
              <div class="feed-filters">
                <select id="feed-sort" class="zen-select-sm">
                  <option value="recent">Terbaru</option>
                  <option value="votes">Populer</option>
                  <option value="comments">Diskusi</option>
                </select>
              </div>
            </div>
            <div id="reports-list" class="zen-feed">
              <!-- Reports injected -->
            </div>
          </div>

        </div>
      </div>
    </main>

    <!-- Mobile Nav -->
    <nav class="mobile-nav glass-bright">
      <a href="/dashboard" class="m-item active">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
      </a>
      <a href="/profile" class="m-item">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <button id="btn-logout-mobile" class="m-item text-danger">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" fill="none" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>
      </button>
    </nav>

    <!-- Detail Modal -->
    <div id="detail-modal" class="modal-overlay hidden">
      <div class="modal-card glass-modal">
        <div class="modal-head">
          <h3>Detail Laporan</h3>
          <button id="close-detail" class="btn-close">&times;</button>
        </div>
        <div class="modal-body scroll-slim">
          <div class="modal-grid">
            <div class="modal-info">
              <div id="detail-img-box" class="detail-img hidden">
                <img id="detail-img" src="" alt="Bukti" />
              </div>
              <div class="report-content">
                <div class="badge-row">
                  <span id="detail-cat" class="cat-pill"></span>
                  <span id="detail-status" class="status-pill"></span>
                </div>
                <h2 id="detail-desc" class="font-display"></h2>
                <div class="loc-box glass">
                  <div class="loc-header">
                    <span>📍 <span id="detail-loc"></span></span>
                    <div class="loc-actions">
                      <button id="btn-view-map-modal" class="btn-sm-outline">Lihat Peta</button>
                      <a id="btn-gmaps-modal" href="#" target="_blank" class="btn-sm-outline">Google Maps</a>
                    </div>
                  </div>
                  <div id="modal-map" class="modal-map hidden"></div>
                </div>
                <div class="meta-row">
                  <span id="detail-date"></span>
                  <div class="meta-stats">
                    <button class="btn-vote" id="btn-vote-modal">
                      🔥 <b id="detail-votes">0</b> Dukungan
                    </button>
                  </div>
                </div>
              </div>
            </div>
            <div class="modal-comments">
              <div class="comments-header">Diskusi & Solusi</div>
              <div id="comments-list" class="comments-feed scroll-slim"></div>
              <form id="form-comment" class="comment-input glass">
                <input type="hidden" id="active-report-id" />
                <input type="text" id="comment-input" placeholder="Tulis pendapat Anda..." required />
                <button type="submit" class="btn-send">
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="modal-overlay hidden">
      <div class="lightbox-content">
        <img id="lightbox-img" src="" alt="Full view" />
        <button id="lightbox-close" class="btn-close-lg">&times;</button>
      </div>
    </div>

    <!-- Zen Toast -->
    <div id="toast" class="zen-toast hidden">
      <span id="toast-msg">Notifikasi</span>
    </div>
  </div>

  <!-- Scripts -->
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  
  <script is:inline define:vars={{ PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL || 'http://localhost:3000' }}>
    const API_URL = PUBLIC_API_URL;
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('DOMContentLoaded', initZenDashboard);
    }

    let user, categories = [], selectedFile = null, map, marker, allReports = [];

    async function initZenDashboard() {
      user = JSON.parse(userRaw);
      setupUI();
      setupMap();
      setupUpload();
      await loadCategories();
      await fetchData();
      setupListeners();
    }

    function setupUI() {
      const initial = (user.name || 'U')[0].toUpperCase();
      document.getElementById('sidebar-name').textContent = user.name || 'Warga';
      document.getElementById('sidebar-avatar').textContent = initial;
      document.getElementById('mobile-avatar').textContent = initial;
      document.getElementById('sidebar-points').textContent = `${user.points || 0} PTS`;
      document.getElementById('mobile-points').textContent = `${user.points || 0} PTS`;
      document.getElementById('greeting').textContent = `Selamat ${getTimeGreeting()}, ${user.name?.split(' ')[0] || 'Warga'}.`;
      document.getElementById('current-date').textContent = new Date().toLocaleDateString('id-ID', { weekday:'long', day:'numeric', month:'short' });
    }

    function getTimeGreeting() {
      const hrs = new Date().getHours();
      if(hrs < 11) return 'Pagi';
      if(hrs < 15) return 'Siang';
      if(hrs < 19) return 'Sore';
      return 'Malam';
    }

    function setupMap() {
      const def = { lat: -6.2000, lng: 106.8166 };
      map = L.map('map', { zoomControl: false }).setView([def.lat, def.lng], 13);
      const isDark = document.documentElement.classList.contains('dark');
      L.tileLayer(isDark ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png' : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
      marker = L.marker([def.lat, def.lng], { draggable: true }).addTo(map);
      
      const setCoords = (ll) => {
        document.getElementById('lat').value = ll.lat;
        document.getElementById('lng').value = ll.lng;
      };
      setCoords(def);
      marker.on('dragend', (e) => setCoords(e.target.getLatLng()));
      map.on('click', (e) => { marker.setLatLng(e.latlng); setCoords(e.latlng); });

      // Search Location Logic
      const searchBtn = document.getElementById('btn-search-loc');
      const searchInput = document.getElementById('search-address');
      
      const doSearch = async () => {
        const query = searchInput.value;
        if(!query) return;
        try {
          const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`);
          const data = await res.json();
          if(data.length > 0) {
            const first = data[0];
            const ll = { lat: parseFloat(first.lat), lng: parseFloat(first.lon) };
            map.setView(ll, 16);
            marker.setLatLng(ll);
            setCoords(ll);
          } else {
            showToast('Lokasi tidak ditemukan', 'error');
          }
        } catch(e) {
          showToast('Gagal mencari lokasi', 'error');
        }
      };

      searchBtn.onclick = doSearch;
      searchInput.onkeydown = (e) => { if(e.key === 'Enter') { e.preventDefault(); doSearch(); } };

      if(navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(p => {
          const ll = { lat: p.coords.latitude, lng: p.coords.longitude };
          map.setView(ll, 15); marker.setLatLng(ll); setCoords(ll);
        });
      }
    }

    function setupUpload() {
      const zone = document.getElementById('drop-zone');
      const input = document.getElementById('image-upload');
      zone.onclick = () => input.click();
      input.onchange = (e) => handleFile(e.target.files[0]);
      zone.ondragover = (e) => { e.preventDefault(); zone.classList.add('active'); };
      zone.ondragleave = () => zone.classList.remove('active');
      zone.ondrop = (e) => { e.preventDefault(); handleFile(e.dataTransfer.files[0]); };
      document.getElementById('btn-remove-image').onclick = () => {
        selectedFile = null; input.value = '';
        document.getElementById('image-preview').classList.add('hidden');
        zone.classList.remove('hidden');
      };
    }

    function handleFile(file) {
      if(!file || !file.type.startsWith('image/')) return showToast('Pilih file gambar!', 'error');
      selectedFile = file;
      const reader = new FileReader();
      reader.onload = (e) => {
        document.getElementById('preview-img').src = e.target.result;
        document.getElementById('image-preview').classList.remove('hidden');
        document.getElementById('drop-zone').classList.add('hidden');
      };
      reader.readAsDataURL(file);
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
        const container = document.getElementById('category-chips');
        container.innerHTML = categories.map(c => `<div class="chip" data-id="${c.id}">${c.name}</div>`).join('');
        container.querySelectorAll('.chip').forEach(c => c.onclick = () => {
          container.querySelectorAll('.chip').forEach(x => x.classList.remove('active'));
          c.classList.add('active');
          document.getElementById('category_id').value = c.dataset.id;
        });
      } catch(e) {}
    }

    async function fetchData() {
      fetchStats();
      fetchFeed('recent');
      fetchLeaderboard();
    }

    
    async function fetchStats() {
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        const r = data.data || [];
        document.getElementById('stat-total').textContent = r.length;
        document.getElementById('stat-pending').textContent = r.filter(x => x.status === 'PENDING').length;
        document.getElementById('stat-resolved').textContent = r.filter(x => x.status === 'RESOLVED').length;
      } catch(e) {}
    }

    async function fetchFeed(sort) {
      const list = document.getElementById('reports-list');
      list.innerHTML = '<div class="zen-loader"></div>';
      try {
        const res = await fetch(`${API_URL}/api/public-reports?sort=${sort}`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        allReports = data.data || [];
        if(allReports.length === 0) { list.innerHTML = '<div class="empty-zen">Belum ada laporan.</div>'; return; }
        
        list.innerHTML = allReports.map(r => {
          const cat = categories.find(c => c.id === r.category_id)?.name || 'Umum';
          const img = r.image_url ? `<div class="f-img"><img src="${API_URL}${r.image_url}" /></div>` : '';
          return `
            <div class="feed-card-item glass clickable" onclick="window.openDetail('${r.id}')">
              ${img}
              <div class="f-body">
                <div class="f-meta"><span class="cat">${cat}</span> <span class="status ${r.status.toLowerCase()}">${r.status}</span></div>
                <h4>${r.description}</h4>
                <p>📍 ${r.location_detail}</p>
                <div class="f-footer">
                  <button class="vote-btn" onclick="event.stopPropagation(); window.doVote('${r.id}')">🔥 ${r.vote_count}</button>
                  <span>💬 ${r.comment_count} Diskusi</span>
                </div>
              </div>
            </div>
          `;
        }).join('');
      } catch(e) {}
    }

    async function fetchLeaderboard() {
      const list = document.getElementById('leaderboard-list');
      try {
        const res = await fetch(`${API_URL}/api/leaderboard`);
        const data = await res.json();
        const users = data.data || [];
        if (users.length === 0) {
          list.innerHTML = '<div class="empty-zen">Belum ada data warga.</div>';
          return;
        }
        list.innerHTML = users.slice(0, 5).map((u, i) => {
          const rankClass = i === 0 ? "rank-1" : i === 1 ? "rank-2" : i === 2 ? "rank-3" : "";
          const rankIcon = i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : i + 1;
          const initial = (u.full_name || "U")[0].toUpperCase();
          return `
            <div class="leader-row-zen">
              <div class="leader-rank-box ${rankClass}">${rankIcon}</div>
              <div class="leader-avatar-zen">${initial}</div>
              <div class="leader-info-zen">
                <strong>${u.full_name}</strong>
                <span class="pts-tag">${u.points} PTS</span>
              </div>
            </div>
          `;
        }).join('');
      } catch(e) {
        list.innerHTML = '<div class="empty-zen">Gagal memuat leaderboard.</div>';
      }
    }

    function setupListeners() {
      document.getElementById('form-report').onsubmit = handleReportSubmit;
      document.getElementById('feed-sort').onchange = (e) => fetchFeed(e.target.value);
      document.getElementById('close-detail').onclick = () => document.getElementById('detail-modal').classList.add('hidden');
      document.getElementById('lightbox-close').onclick = () => document.getElementById('lightbox').classList.add('hidden');
      document.getElementById('form-comment').onsubmit = handleCommentSubmit;
      document.getElementById('btn-logout-desktop').onclick = logout;
      document.getElementById('btn-logout-mobile').onclick = logout;
      
      const mobileMenuBtn = document.getElementById('btn-menu-mobile');
      const sidebar = document.querySelector('.sidebar');
      if (mobileMenuBtn && sidebar) {
        mobileMenuBtn.onclick = () => sidebar.classList.toggle('mobile-open');
      }
      
      // Close sidebar when clicking outside
      document.addEventListener('click', (e) => {
        if (sidebar && sidebar.classList.contains('mobile-open') && !sidebar.contains(e.target) && !mobileMenuBtn.contains(e.target)) {
          sidebar.classList.remove('mobile-open');
        }
      });
    }

    function logout() { localStorage.clear(); window.location.href = '/'; }

    async function handleReportSubmit(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      const cat = document.getElementById('category_id').value;
      if(!cat) return showToast('Pilih kategori!', 'error');

      btn.disabled = true;
      const fd = new FormData();
      fd.append('category_id', cat);
      fd.append('description', document.getElementById('description').value);
      fd.append('location_detail', document.getElementById('location_detail').value);
      fd.append('latitude', document.getElementById('lat').value);
      fd.append('longitude', document.getElementById('lng').value);
      if(selectedFile) fd.append('image', selectedFile);

      try {
        const res = await fetch(`${API_URL}/api/reports`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: fd
        });
        if(res.ok) {
          showToast('Laporan Berhasil Terkirim!', 'success');
          document.getElementById('form-report').reset();
          if(selectedFile) document.getElementById('btn-remove-image').click();
          fetchData();
        } else {
          const err = await res.json();
          showToast(err.error || 'Gagal mengirim laporan', 'error');
        }
      } catch(e) {
        showToast('Terjadi kesalahan koneksi', 'error');
      }
      btn.disabled = false;
    }

    window.openDetail = (id) => {
      const r = allReports.find(x => x.id === id);
      if(!r) return;
      document.getElementById('active-report-id').value = id;
      
      const imgBox = document.getElementById('detail-img-box');
      if(r.image_url) {
        document.getElementById('detail-img').src = API_URL + r.image_url;
        imgBox.classList.remove('hidden');
        imgBox.onclick = () => window.openLightbox(API_URL + r.image_url);
      } else { imgBox.classList.add('hidden'); }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = categories.find(c => c.id === r.category_id)?.name || 'Umum';
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      document.getElementById('detail-status').textContent = r.status;
      document.getElementById('detail-status').className = `status-pill ${r.status.toLowerCase()}`;
      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('btn-vote-modal').onclick = () => window.doVote(id);

      // Google Maps Link
      const gLink = document.getElementById('btn-gmaps-modal');
      gLink.href = `https://www.google.com/maps?q=${r.latitude},${r.longitude}`;

      // Modal Map
      const modalMapContainer = document.getElementById('modal-map');
      const viewMapBtn = document.getElementById('btn-view-map-modal');
      modalMapContainer.classList.add('hidden');
      viewMapBtn.textContent = 'Lihat Peta';
      
      viewMapBtn.onclick = () => {
        const isHidden = modalMapContainer.classList.toggle('hidden');
        viewMapBtn.textContent = isHidden ? 'Lihat Peta' : 'Tutup Peta';
        if (!isHidden) {
          setTimeout(() => {
            if (window.mMap) window.mMap.remove();
            window.mMap = L.map('modal-map', { zoomControl: true }).setView([r.latitude, r.longitude], 16);
            const isDark = document.documentElement.classList.contains('dark');
            L.tileLayer(isDark ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png' : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(window.mMap);
            L.marker([r.latitude, r.longitude]).addTo(window.mMap);
          }, 100);
        }
      };

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openLightbox = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    window.doVote = async (id) => {
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/vote`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ vote_type: 1 })
        });
        if(res.ok) {
          fetchFeed(document.getElementById('feed-sort').value);
          const r = allReports.find(x => x.id === id);
          if(r && document.getElementById('active-report-id').value === id) {
             document.getElementById('detail-votes').textContent = r.vote_count + 1;
          }
        }
      } catch(e) {}
    };

    async function loadComments(id) {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="zen-loader"></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const c = data.data || [];
        if(c.length === 0) { list.innerHTML = '<div class="empty-chat">Belum ada diskusi.</div>'; return; }
        list.innerHTML = c.map(x => `
          <div class="chat-bubble ${x.user?.role === 'admin' ? 'admin' : ''}">
            <div class="chat-meta"><strong>${x.user?.full_name || 'Warga'}</strong></div>
            <p>${x.content}</p>
          </div>
        `).join('');
        list.scrollTop = list.scrollHeight;
      } catch(e) {}
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('active-report-id').value;
      const input = document.getElementById('comment-input');
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) { input.value = ''; loadComments(id); fetchFeed(document.getElementById('feed-sort').value); }
      } catch(e) {}
    }

    function showToast(msg, type = 'info') {
      const t = document.getElementById('toast');
      document.getElementById('toast-msg').textContent = msg;
      t.className = `zen-toast ${type}`;
      t.classList.remove('hidden');
      setTimeout(() => {
        t.classList.add('hidden');
        t.className = 'zen-toast hidden';
      }, 3000);
    }
  </script>

