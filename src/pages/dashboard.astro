---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard Warga — SovraEquitara">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  
  <div class="saas-layout">
    <!-- Desktop Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <img src="/logo.svg" alt="SovraEquitara" style="height: 48px; width: auto;" />
        </div>
      </div>
      
      <nav class="nav-menu">
        <div class="nav-section">MENU UTAMA</div>
        <a href="/dashboard" class="nav-item active">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          Dashboard
        </a>
        <a href="/history" class="nav-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Riwayat Laporan
        </a>
        <a href="/profile" class="nav-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          Profil Saya
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-profile">
          <div class="avatar" id="sidebar-avatar">U</div>
          <div class="user-info">
            <span class="user-name" id="sidebar-name">Warga</span>
            <span class="user-points" id="sidebar-points">0 PTS</span>
          </div>
        </div>
        <button id="btn-logout-desktop" class="btn-logout">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Keluar
        </button>
      </div>
    </aside>

    <!-- Mobile Top Bar -->
    <header class="mobile-header">
      <div class="logo">
        <img src="/logo.svg" alt="SovraEquitara" style="height: 32px; width: auto;" />
      </div>
      <div class="user-profile-mobile">
        <span class="points-badge" id="mobile-points">0 PTS</span>
        <div class="avatar-small" id="mobile-avatar">U</div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <div class="content-wrapper">
        
        <!-- Welcome Section -->
        <section class="welcome-section fade-in">
          <div>
            <h1 id="greeting">Selamat Datang</h1>
            <p class="subtitle">Mari bersama wujudkan fasilitas kota yang lebih baik.</p>
          </div>
        </section>

        <!-- Bento Grid -->
        <div class="bento-grid">
          
          <!-- Left Column -->
          <div class="left-column fade-in" style="animation-delay: 0.1s; display: flex; flex-direction: column; gap: 24px;">
            <!-- Create Report Form -->
            <div class="bento-card form-card">
              <div class="card-header">
                <h2>Buat Laporan</h2>
                <span class="card-badge">Baru</span>
              </div>
              
              <form id="form-report" class="saas-form">
                <div class="form-group">
                  <label>Kategori Masalah</label>
                  <div class="chip-group" id="category-chips">
                    <div class="chip skeleton"></div>
                    <div class="chip skeleton"></div>
                    <div class="chip skeleton"></div>
                  </div>
                  <input type="hidden" id="category_id" />
                </div>

                <div class="form-group">
                  <label>Deskripsi Kerusakan</label>
                  <textarea id="description" placeholder="Ceritakan secara detail kerusakan yang terjadi..." rows="3" required></textarea>
                </div>

                <div class="form-group">
                  <label>Bukti Foto</label>
                  <div class="upload-zone" id="drop-zone">
                    <div class="upload-icon">
                      <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                    </div>
                    <p>Tarik & Lepas gambar atau <span class="upload-link">Pilih File</span></p>
                    <p class="upload-hint">Maks. 2MB (JPG/PNG)</p>
                    <input type="file" id="image-upload" accept="image/jpeg, image/png" hidden />
                  </div>
                  <div id="image-preview" class="preview-zone hidden">
                    <img id="preview-img" src="" alt="Preview" />
                    <button type="button" class="btn-remove" id="btn-remove-image">&times;</button>
                  </div>
                </div>

                <div class="form-group">
                  <label>Titik Lokasi</label>
                  <input type="text" id="location_detail" placeholder="Cth: Depan SDN 01 Pagi" required />
                  <div class="map-container mt-2">
                    <div id="map"></div>
                  </div>
                  <input type="hidden" id="lat" />
                  <input type="hidden" id="lng" />
                </div>

                <button type="submit" id="btn-submit" class="btn-primary w-full">
                  Kirim Laporan
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
              </form>
            </div>

            <!-- Leaderboard Card -->
            <div class="bento-card leaderboard-card">
              <div class="card-header" style="margin-bottom: 16px;">
                <h2 style="font-size: 16px;">Pahlawan Warga (Top 10)</h2>
              </div>
              <div class="leaderboard-list" id="leaderboard-list">
                <div class="feed-loading"><div class="spinner-small"></div><p>Memuat klasemen...</p></div>
              </div>
            </div>
          </div>

          <!-- Feed Section (Right Column) -->
          <div class="feed-column fade-in" style="animation-delay: 0.2s;">
            <!-- Stats -->
            <div class="stats-grid">
              <div class="stat-box">
                <span class="stat-label">Total Laporanmu</span>
                <span class="stat-value" id="stat-total">0</span>
              </div>
              <div class="stat-box">
                <span class="stat-label">Sedang Diproses</span>
                <span class="stat-value text-warning" id="stat-pending">0</span>
              </div>
              <div class="stat-box">
                <span class="stat-label">Telah Selesai</span>
                <span class="stat-value text-success" id="stat-resolved">0</span>
              </div>
            </div>

            <!-- Feed -->
            <div class="bento-card feed-card">
              <div class="feed-controls">
                <h2>Laporan Publik</h2>
                <div class="filter-dropdown">
                  <select id="feed-sort" class="select-minimal">
                    <option value="recent">Terbaru</option>
                    <option value="votes">Terpopuler</option>
                    <option value="comments">Teramai</option>
                  </select>
                </div>
              </div>
              
              <div class="feed-list scroll-slim" id="reports-list">
                <div class="feed-loading">
                  <div class="spinner"></div>
                  <p>Memuat laporan...</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <a href="/dashboard" class="m-nav-item active">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
      </a>
      <a href="/history" class="m-nav-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <a href="/profile" class="m-nav-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
    </nav>

    <!-- Detail Modal -->
    <div id="detail-modal" class="modal-overlay hidden">
      <div class="modal-content large-modal">
        <div class="modal-header">
          <h3>Detail Laporan</h3>
          <button id="close-detail" class="btn-close-modal">&times;</button>
        </div>
        <div class="modal-body scroll-slim" style="padding: 0;">
          <div class="detail-layout">
            <div class="detail-info">
              <div id="detail-img-container" class="detail-img-box hidden">
                <img id="detail-img" src="" alt="Bukti Foto" />
              </div>
              <div class="detail-text">
                <div class="d-meta">
                  <span id="detail-cat" class="badge-cat"></span>
                  <span id="detail-status" class="badge-status"></span>
                  <span id="detail-date" class="text-date" style="margin-left:auto;"></span>
                </div>
                <h2 id="detail-desc"></h2>
                <div class="d-location">📍 <span id="detail-loc"></span></div>
                
                <div class="d-stats mt-4">
                  <div class="stat-pill">🔥 <span id="detail-votes">0</span> Dukungan</div>
                  <div class="stat-pill">💬 <span id="detail-comment-count">0</span> Diskusi</div>
                </div>
              </div>
            </div>
            
            <div class="detail-comments">
              <h4>Diskusi</h4>
              <div id="comments-list" class="comments-container scroll-slim">
                <!-- Comments -->
              </div>
              <div class="comment-input-wrapper">
                <form id="form-comment" class="comment-input-group">
                  <input type="hidden" id="comment-report-id" />
                  <input type="text" id="comment-input" placeholder="Balas atau diskusi..." required autocomplete="off" />
                  <button type="submit" class="btn-send">
                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="modal-overlay hidden">
      <div class="lightbox-wrapper">
        <button id="lightbox-close" class="btn-close-modal">&times;</button>
        <img id="lightbox-img" src="" alt="Full view" />
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast-notification hidden">
      <span id="toast-icon">✓</span>
      <span id="toast-msg">Berhasil!</span>
    </div>
  </div>

  <!-- JavaScript Logic -->
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  
  <script is:inline>
    const API_URL = 'http://localhost:3000'; // Make sure this matches your backend
    
    // Auth Check
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('DOMContentLoaded', initDashboard);
    }

    let user, categories = [], selectedFile = null, map, marker;
    let allReportsList = [];

    function initDashboard() {
      try {
        user = JSON.parse(userRaw);
        
        // Setup UI User Profile
        document.getElementById('greeting').textContent = `Halo, ${user.name || 'Warga'}!`;
        const initial = (user.name || 'U')[0].toUpperCase();
        document.getElementById('sidebar-name').textContent = user.name;
        document.getElementById('sidebar-avatar').textContent = initial;
        document.getElementById('mobile-avatar').textContent = initial;
        updatePointsUI(user.points || 0);

        // Setup Map
        setupMap();

        // Setup File Upload
        setupImageUpload();

        // Load Initial Data
        loadCategories();
        fetchMyStats();
        fetchFeed('recent');
        fetchLeaderboard();

        // Setup Listeners
        document.getElementById('form-report').addEventListener('submit', handleReportSubmit);
        document.getElementById('feed-sort').addEventListener('change', (e) => fetchFeed(e.target.value));
        
        // Modals
        document.getElementById('lightbox-close').addEventListener('click', () => document.getElementById('lightbox').classList.add('hidden'));
        document.getElementById('close-detail').addEventListener('click', () => document.getElementById('detail-modal').classList.add('hidden'));
        document.getElementById('form-comment').addEventListener('submit', handleCommentSubmit);
        
        // Logout
        const doLogout = () => { localStorage.clear(); window.location.href = '/login'; };
        document.getElementById('btn-logout-desktop').addEventListener('click', doLogout);
        document.getElementById('btn-logout-mobile2').addEventListener('click', doLogout);

      } catch(e) {
        console.error("Dashboard Init Error: ", e);
      }
    }

    function updatePointsUI(pts) {
      document.getElementById('sidebar-points').textContent = `${pts} PTS`;
      document.getElementById('mobile-points').textContent = `${pts} PTS`;
    }

    function setupMap() {
      try {
        if(typeof L !== 'undefined') {
          const defaultLoc = { lat: -6.2000, lng: 106.8166 };
          map = L.map('map', { zoomControl: false }).setView([defaultLoc.lat, defaultLoc.lng], 13);
          L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
          marker = L.marker([defaultLoc.lat, defaultLoc.lng], { draggable: true }).addTo(map);
          
          const updateLoc = (latlng) => {
            document.getElementById('lat').value = latlng.lat;
            document.getElementById('lng').value = latlng.lng;
          };
          
          updateLoc(defaultLoc);
          
          marker.on('dragend', (e) => updateLoc(e.target.getLatLng()));
          
          map.on('click', (e) => {
            marker.setLatLng(e.latlng);
            updateLoc(e.latlng);
          });
          
          if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(pos => {
              const ll = { lat: pos.coords.latitude, lng: pos.coords.longitude };
              map.setView(ll, 15); marker.setLatLng(ll); updateLoc(ll);
            });
          }
        }
      } catch(e) { console.error("Map Error", e); }
    }

    function setupImageUpload() {
      const dropZone = document.getElementById('drop-zone');
      const fileInput = document.getElementById('image-upload');
      const previewDiv = document.getElementById('image-preview');
      const previewImg = document.getElementById('preview-img');
      const btnRemove = document.getElementById('btn-remove-image');

      if(!dropZone || !fileInput) return;

      dropZone.addEventListener('click', () => fileInput.click());
      dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.style.borderColor = '#111827'; });
      dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = '#E5E7EB'; });
      dropZone.addEventListener('drop', (e) => {
        e.preventDefault();
        dropZone.style.borderColor = '#E5E7EB';
        if (e.dataTransfer.files.length > 0) handleFileSelect(e.dataTransfer.files[0], previewImg, dropZone, previewDiv);
      });
      fileInput.addEventListener('change', (e) => {
        if (e.target.files.length > 0) handleFileSelect(e.target.files[0], previewImg, dropZone, previewDiv);
      });

      btnRemove.addEventListener('click', () => {
        selectedFile = null;
        fileInput.value = '';
        previewImg.src = '';
        dropZone.classList.remove('hidden');
        previewDiv.classList.add('hidden');
      });
    }

    function handleFileSelect(file, imgEl, dropZ, prevZ) {
      if (!file.type.startsWith('image/')) {
        showToast('Hanya file gambar yang diizinkan', 'error');
        return;
      }
      if (file.size > 2 * 1024 * 1024) {
        showToast('Ukuran gambar maksimal 2MB', 'error');
        return;
      }
      selectedFile = file;
      const reader = new FileReader();
      reader.onload = (e) => {
        imgEl.src = e.target.result;
        dropZ.classList.add('hidden');
        prevZ.classList.remove('hidden');
      };
      reader.readAsDataURL(file);
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
        
        if (categories.length === 0) {
          categories = [
            {id: 1, name: 'Infrastruktur'},
            {id: 2, name: 'Lingkungan'},
            {id: 3, name: 'Fasilitas Umum'},
            {id: 4, name: 'Keamanan'}
          ];
        }

        const container = document.getElementById('category-chips');
        container.innerHTML = categories.map(c => `
          <div class="chip" data-id="${c.id}">${c.name}</div>
        `).join('');

        container.querySelectorAll('.chip').forEach(chip => {
          chip.addEventListener('click', () => {
            container.querySelectorAll('.chip').forEach(x => x.classList.remove('active'));
            chip.classList.add('active');
            document.getElementById('category_id').value = chip.dataset.id;
          });
        });
      } catch (err) { 
        console.error("Categories Error", err); 
        categories = [
          {id: 1, name: 'Infrastruktur'},
          {id: 2, name: 'Lingkungan'},
          {id: 3, name: 'Fasilitas Umum'},
          {id: 4, name: 'Keamanan'}
        ];
        const container = document.getElementById('category-chips');
        container.innerHTML = categories.map(c => `
          <div class="chip" data-id="${c.id}">${c.name}</div>
        `).join('');
        container.querySelectorAll('.chip').forEach(chip => {
          chip.addEventListener('click', () => {
            container.querySelectorAll('.chip').forEach(x => x.classList.remove('active'));
            chip.classList.add('active');
            document.getElementById('category_id').value = chip.dataset.id;
          });
        });
      }
    }

    async function fetchMyStats() {
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        const reports = data.data || [];
        
        document.getElementById('stat-total').textContent = reports.length;
        document.getElementById('stat-pending').textContent = reports.filter(r => r.status === 'PENDING').length;
        document.getElementById('stat-resolved').textContent = reports.filter(r => r.status === 'RESOLVED').length;
      } catch (err) { console.error(err); }
    }

    async function fetchFeed(sort) {
      const list = document.getElementById('reports-list');
      list.innerHTML = '<div class="feed-loading"><div class="spinner"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/public-reports?sort=${sort}`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        allReportsList = data.data || [];
        
        if(allReportsList.length === 0) {
          list.innerHTML = '<div class="empty-state">Belum ada laporan publik.</div>';
          return;
        }

        list.innerHTML = allReportsList.map(r => {
          const catName = categories.find(c => c.id === r.category_id)?.name || 'Umum';
          const statusClass = r.status.toLowerCase();
          const imgHtml = r.image_url 
            ? `<div class="feed-img" onclick="event.stopPropagation(); window.openImg('${API_URL}${r.image_url}')"><img src="${API_URL}${r.image_url}" alt="Bukti"/></div>` 
            : '';

          return `
            <div class="feed-item clickable" onclick="window.openDetail('${r.id}')">
              <div class="feed-item-header">
                <span class="badge-cat">${catName}</span>
                <span class="badge-status ${statusClass}">${r.status}</span>
              </div>
              <div class="feed-item-body">
                ${imgHtml}
                <div class="feed-info">
                  <h4 class="feed-desc">${r.description}</h4>
                  <div class="feed-meta">📍 ${r.location_detail}</div>
                  <div class="feed-meta">🕒 ${new Date(r.created_at).toLocaleDateString('id-ID')}</div>
                </div>
              </div>
              <div class="feed-item-actions">
                <button class="action-btn" onclick="event.stopPropagation(); window.doVote('${r.id}')">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><polyline points="18 15 12 9 6 15"></polyline></svg>
                  <span>${r.vote_count}</span>
                </button>
                <div class="action-btn">
                  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                  <span>${r.comment_count} Diskusi</span>
                </div>
              </div>
            </div>
          `;
        }).join('');
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat feed.</div>';
      }
    }

    async function fetchLeaderboard() {
      const list = document.getElementById('leaderboard-list');
      try {
        const res = await fetch(`${API_URL}/api/leaderboard`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        const profiles = data.data || [];
        
        if (profiles.length === 0) {
          list.innerHTML = '<div class="empty-state" style="padding: 20px;">Belum ada pahlawan warga.</div>';
          return;
        }

        list.innerHTML = profiles.map((p, index) => {
          let rankMedal = '';
          if(index === 0) rankMedal = '🥇';
          else if(index === 1) rankMedal = '🥈';
          else if(index === 2) rankMedal = '🥉';
          else rankMedal = `<span style="font-size:12px;color:#64748B;">#${index+1}</span>`;

          const initial = (p.full_name || p.email)[0].toUpperCase();

          return `
            <div style="display:flex; justify-content:space-between; align-items:center; padding:12px 0; border-bottom:1px solid var(--c-border);">
              <div style="display:flex; align-items:center; gap:12px;">
                <div style="width:32px;text-align:center;">${rankMedal}</div>
                <div style="width:32px;height:32px;border-radius:50%;background:var(--c-bg);border:1px solid var(--c-border);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;">${initial}</div>
                <div style="font-size:13px;font-weight:600;">${p.full_name || 'Warga'}</div>
              </div>
              <div style="font-size:12px;font-weight:800;color:var(--c-accent);">${p.points} PTS</div>
            </div>
          `;
        }).join('');
      } catch (err) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat klasemen.</div>';
      }
    }

    async function handleReportSubmit(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      const catId = document.getElementById('category_id').value;
      const desc = document.getElementById('description').value;
      const loc = document.getElementById('location_detail').value;
      const lat = document.getElementById('lat').value;
      const lng = document.getElementById('lng').value;

      if(!catId) { showToast('Silakan pilih kategori!', 'error'); return; }
      if(!lat || !lng) { showToast('Lokasi peta belum didapatkan!', 'error'); return; }

      btn.disabled = true;
      btn.innerHTML = '<div class="spinner-small"></div> Mengirim...';

      const formData = new FormData();
      formData.append('category_id', catId);
      formData.append('description', desc);
      formData.append('location_detail', loc);
      formData.append('latitude', lat);
      formData.append('longitude', lng);
      if (selectedFile) formData.append('image', selectedFile);

      try {
        const res = await fetch(`${API_URL}/api/reports`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: formData
        });
        
        if (res.ok) {
          showToast('Laporan berhasil dikirim!');
          document.getElementById('form-report').reset();
          document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
          document.getElementById('category_id').value = '';
          if(selectedFile) document.getElementById('btn-remove-image').click();
          fetchMyStats();
          fetchFeed(document.getElementById('feed-sort').value);
        } else {
          const err = await res.json();
          showToast(err.error || 'Gagal mengirim', 'error');
        }
      } catch (err) {
        showToast('Kesalahan jaringan', 'error');
      }
      
      btn.disabled = false;
      btn.innerHTML = 'Kirim Laporan <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>';
    }

    // Global Functions for inline onclick
    window.openDetail = (id) => {
      const r = allReportsList.find(x => x.id === id);
      if(!r) return;

      document.getElementById('comment-report-id').value = id;

      if(r.image_url) {
        document.getElementById('detail-img').src = API_URL + r.image_url;
        document.getElementById('detail-img-container').classList.remove('hidden');
      } else {
        document.getElementById('detail-img-container').classList.add('hidden');
      }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = categories.find(c => c.id === r.category_id)?.name || 'Umum';
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      
      const st = document.getElementById('detail-status');
      st.textContent = r.status;
      st.className = `badge-status ${r.status.toLowerCase()}`;

      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('detail-comment-count').textContent = r.comment_count;

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openImg = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    window.doVote = async (id) => {
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/vote`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ vote_type: 1 })
        });
        if(res.ok) {
          fetchFeed(document.getElementById('feed-sort').value);
          // If modal is open, refresh comments to show updated vote
          const currentModalId = document.getElementById('comment-report-id').value;
          if (currentModalId === id) {
            const updatedReportRes = await fetch(`${API_URL}/api/public-reports?sort=${document.getElementById('feed-sort').value}`, { headers: { 'Authorization': `Bearer ${token}` }});
            const data = await updatedReportRes.json();
            const r = (data.data || []).find(x => x.id === id);
            if (r) {
              document.getElementById('detail-votes').textContent = r.vote_count;
            }
          }
        }
      } catch(e) {}
    };

    async function loadComments(id) {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="feed-loading"><div class="spinner"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const comments = data.data || [];
        if(comments.length === 0) {
          list.innerHTML = '<div class="empty-state">Jadilah yang pertama berdiskusi!</div>';
          return;
        }
        list.innerHTML = comments.map(c => `
          <div class="comment-bubble">
            <div class="c-head">
              <strong>${c.user?.full_name || (c.user?.role === 'admin' ? 'Admin' : 'Warga')}</strong> 
              <span>${new Date(c.created_at).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'})}</span>
            </div>
            <div class="c-body">${c.content}</div>
          </div>
        `).join('');
        // scroll to bottom
        list.scrollTop = list.scrollHeight;
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat diskusi.</div>';
      }
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('comment-report-id').value;
      const input = document.getElementById('comment-input');
      if(!input.value.trim() || !id) return;

      const btn = e.target.querySelector('.btn-send');
      btn.disabled = true;
      
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) {
          input.value = '';
          loadComments(id);
          fetchFeed(document.getElementById('feed-sort').value);
          // Update comment count in modal
          const currentCount = parseInt(document.getElementById('detail-comment-count').textContent || "0");
          document.getElementById('detail-comment-count').textContent = currentCount + 1;
        }
      } catch(err) {}
      btn.disabled = false;
    }

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      const i = document.getElementById('toast-icon');
      const m = document.getElementById('toast-msg');
      
      t.className = `toast-notification ${type}`;
      i.textContent = type === 'error' ? '!' : '✓';
      m.textContent = msg;
      
      t.classList.remove('hidden');
      setTimeout(() => t.classList.add('hidden'), 3000);
    }
  </script>

  <style is:global>
    /* =========================================
       Zen SaaS Architecture
       ========================================= */
    
    :root {
