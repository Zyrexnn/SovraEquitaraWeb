    input[type="text"], textarea, .select-minimal { width: 100%; background: var(--c-bg); border: 1px solid var(--c-border); padding: 12px 16px; border-radius: var(--radius-sm); font-size: 14px; transition: 0.2s; outline: none; resize: none; }
    input:focus, textarea:focus, .select-minimal:focus { border-color: var(--c-brand); background: var(--c-surface); box-shadow: 0 0 0 3px rgba(15,23,42,0.05); }

