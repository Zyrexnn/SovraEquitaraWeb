---
import Layout from '../layouts/Layout.astro';
import '../styles/dashboard-shared.css';
---

<Layout title="Dashboard — SovraEquitara">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  
  <div class="app-container">
    <!-- Desktop Sidebar -->
    <aside class="desktop-sidebar">
      <div class="sidebar-brand">
        <img src="/logo.svg" alt="SovraEquitara" class="brand-img" />
      </div>
      <nav   class="sidebar-nav-v2">
        <a href="/dashboard" class="side-item active">
          <svg viewBox="0 0 24 24" class="s-icon"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          <span>Dashboard</span>
        </a>
        <a href="/profile" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          <span>Profil Saya</span>
        </a>
        <a href="/history" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
          <span>Riwayat</span>
        </a>
      </nav>
      <div class="sidebar-bottom">
        <button id="btn-logout-desktop" class="side-item logout">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>
          <span>Keluar</span>
        </button>
      </div>
    </aside>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <a href="/dashboard" class="mob-item active">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 22"></polyline></svg>
      </a>
      <a href="/profile" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a href="/history" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <button id="btn-logout-mobile" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
      </button>
    </nav>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <header class="app-header">
        <div class="header-left">
          <div class="mobile-logo-only">
            <img src="/logo.svg" alt="Sovra" />
          </div>
          <div class="desktop-breadcrumb">
            <span class="crumb">App</span> / <span class="crumb active">Dashboard</span>
          </div>
        </div>
        <div class="header-right">
          <div class="user-pill-v2">
            <span class="points-val" id="profile-points">0 PTS</span>
            <div class="u-avatar" id="u-initial">U</div>
          </div>
        </div>
      </header>

      <div class="content-inner fade-in">
        <section class="hero-header-v2">
          <div class="welcome-block">
            <h1 id="user-greeting">Halo, Warga!</h1>
            <p>Berikan laporan Anda untuk infrastruktur yang lebih baik.</p>
          </div>
          <div class="hero-actions">
            <button class="btn-saas btn-saas-primary">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              Jelajahi Peta
            </button>
          </div>
        </section>

        <!-- Bento Layout V2 -->
        <div class="dashboard-grid">
          <!-- Stats Card -->
          <div class="card-zen stats-card-v2">
            <div class="card-p">
              <div class="card-h-flex">
                <h3>Ikhtisar Kontribusi</h3>
                <span class="rank-badge-v2" id="profile-rank">Pemula</span>
              </div>
              <div class="stats-content-v2">
                <div class="main-stat-v2">
                  <div class="v-circle">
                    <span class="v-val" id="count-total">0</span>
                    <span class="v-lbl">Laporan</span>
                  </div>
                </div>
                <div class="sub-stats-v2">
                  <div class="s-row">
                    <span class="s-lbl">Sedang Diproses</span>
                    <span class="s-val text-pending" id="count-pending">0</span>
                  </div>
                  <div class="s-row">
                    <span class="s-lbl">Telah Selesai</span>
                    <span class="s-val text-success" id="count-resolved">0</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Report Form Card -->
          <div class="card-zen report-form-v2">
            <div class="card-p">
              <h3>Lapor Cepat</h3>
              <form id="form-report" class="form-zen">
                <div class="input-group">
                  <label>Detail Kerusakan</label>
                  <input type="text" id="details" placeholder="Apa yang rusak?" required />
                </div>
                <div class="input-group">
                  <label>Lokasi Spesifik</label>
                  <input type="text" id="location_detail" placeholder="Cth: Depan SDN 01" required />
                </div>
                <div class="map-box">
                  <div id="map"></div>
                  <input type="hidden" id="lat" /><input type="hidden" id="lng" />
                </div>
                <button type="submit" id="btn-submit" class="btn-saas btn-saas-primary w-full">Kirim Laporan</button>
              </form>
            </div>
          </div>

          <!-- Leaderboard Card -->
          <div class="card-zen dark-card-v2">
            <div class="card-p">
              <h3>Leaderboard Warga</h3>
              <div id="leaderboard-list" class="list-dark-v2">
                <!-- Injected -->
              </div>
            </div>
          </div>

          <!-- Recent Reports Card -->
          <div class="card-zen activity-card-v2">
            <div class="card-p">
              <h3>Laporan Terbaru</h3>
              <div id="reports-list" class="activity-list-v2">
                <!-- Injected -->
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <div id="toast" class="saas-toast"></div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) window.location.href = '/login';

    const user = JSON.parse(userRaw);
    document.getElementById('user-greeting').textContent = `Halo, ${user.name || 'Warga'}!`;
    document.getElementById('u-initial').textContent = (user.name || 'U')[0].toUpperCase();

    // Map Setup
    const map = L.map('map', { zoomControl: false }).setView([-6.2000, 106.8166], 13);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
    const marker = L.marker([-6.2000, 106.8166], { draggable: true }).addTo(map);
    
    function updateLoc(latlng) {
      document.getElementById('lat').value = latlng.lat;
      document.getElementById('lng').value = latlng.lng;
    }
    marker.on('dragend', (e) => updateLoc(e.target.getLatLng()));
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(pos => {
        const ll = { lat: pos.coords.latitude, lng: pos.coords.longitude };
        map.setView(ll, 15); marker.setLatLng(ll); updateLoc(ll);
      });
    }

    async function refreshData() {
      try {
        const [repRes, leadRes] = await Promise.all([
          fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` } }),
          fetch(`${API_URL}/api/leaderboard`, { headers: { 'Authorization': `Bearer ${token}` } })
        ]);
        const reps = await repRes.json();
        const leads = await leadRes.json();
        renderReports(reps.data || []);
        renderLeaderboard(leads.data || []);
        updateStats(reps.data || []);
      } catch (err) { console.error(err); }
    }

    function updateStats(reports) {
      const pending = reports.filter(r => r.status === 'PENDING').length;
      const resolved = reports.filter(r => r.status === 'RESOLVED').length;
      document.getElementById('count-pending').textContent = pending;
      document.getElementById('count-resolved').textContent = resolved;
      document.getElementById('count-total').textContent = reports.length;
      document.getElementById('profile-points').textContent = `${user.points || 0} PTS`;
      
      let rank = 'Pemula';
      if(user.points >= 20) rank = 'Pemerhati';
      if(user.points >= 50) rank = 'Aktivis';
      document.getElementById('profile-rank').textContent = rank;
    }

    function renderReports(items) {
      const list = document.getElementById('reports-list');
      if(items.length === 0) {
        list.innerHTML = '<div class="empty-msg">Belum ada laporan yang Anda buat.</div>';
        return;
      }
      list.innerHTML = items.slice(0, 5).map(r => `
        <div class="activity-v2">
          <div class="a-indicator ${r.status.toLowerCase()}"></div>
          <div class="a-body">
            <span class="a-title">${r.description}</span>
            <span class="a-meta">${r.location_detail} • ${new Date(r.created_at).toLocaleDateString('id-ID')}</span>
          </div>
          <span class="a-pill ${r.status.toLowerCase()}">${r.status}</span>
        </div>
      `).join('');
    }

    function renderLeaderboard(items) {
      const list = document.getElementById('leaderboard-list');
      list.innerHTML = items.slice(0, 5).map((l, i) => `
        <div class="dark-item-v2">
          <span class="i-rank">${i+1}</span>
          <span class="i-name">${l.full_name || 'Warga'}</span>
          <span class="i-pts">${l.points} PTS</span>
        </div>
      `).join('');
    }

    document.getElementById('form-report').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      btn.disabled = true;
      const payload = {
        description: document.getElementById('details').value,
        location_detail: document.getElementById('location_detail').value,
        latitude: parseFloat(document.getElementById('lat').value),
        longitude: parseFloat(document.getElementById('lng').value)
      };
      const res = await fetch(`${API_URL}/api/reports`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(payload)
      });
      if (res.ok) { 
        showToast('Laporan Terkirim!'); 
        document.getElementById('form-report').reset(); 
        refreshData(); 
      } else { showToast('Gagal mengirim', 'error'); }
      btn.disabled = false;
    });

    const logout = () => { localStorage.clear(); window.location.href = '/login'; };
    document.getElementById('btn-logout-desktop').onclick = logout;
    document.getElementById('btn-logout-mobile').onclick = logout;
    
    refreshData();
  </script>
</Layout>

<style>
  /* Local Dashboard Overrides */
  .sidebar-brand { margin-bottom: 48px; padding: 0 12px; }
  .brand-img { height: 48px; width: auto; filter: invert(1); }
  
  .sidebar-nav-v2 { display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .side-item { display: flex; align-items: center; gap: 16px; padding: 14px 20px; border-radius: 14px; color: rgba(255,255,255,0.6); text-decoration: none; font-weight: 600; font-size: 15px; transition: 0.2s; }
  .side-item:hover { background: rgba(255,255,255,0.05); color: white; }
  .side-item.active { background: var(--color-saas-accent); color: #111827; }
  .side-item.logout { color: #F87171; margin-top: auto; }
  .s-icon { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; }

  .mob-item { color: var(--saas-text-muted); padding: 12px; border-radius: 12px; }
  .mob-item.active { color: #111827; background: #F9FAFB; }
  .m-icon { width: 24px; height: 24px; stroke: currentColor; fill: none; stroke-width: 2.5; }

  .mobile-logo-only { display: none; }
  @media (max-width: 767px) {
    .mobile-logo-only { display: block; height: 32px; }
    .mobile-logo-only img { height: 100%; }
    .desktop-breadcrumb { display: none; }
  }

  .user-pill-v2 { display: flex; align-items: center; gap: 12px; background: #F3F4F6; padding: 6px 14px; border-radius: 99px; }
  .points-val { font-size: 12px; font-weight: 800; color: #111827; background: var(--color-saas-accent); padding: 4px 10px; border-radius: 99px; }
  .u-avatar { width: 32px; height: 32px; background: #111827; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 12px; }

  .hero-header-v2 { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 40px; }
  .welcome-block h1 { font-size: 32px; font-weight: 900; letter-spacing: -0.03em; margin-bottom: 8px; }
  .welcome-block p { color: var(--color-saas-text-muted); font-size: 16px; }

  .dashboard-grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: 24px; }
  .card-p { padding: 32px; }
  
  .stats-card-v2 { grid-column: span 7; }
  .card-h-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px; }
  .rank-badge-v2 { background: #F3F4F6; padding: 6px 14px; border-radius: 10px; font-size: 13px; font-weight: 700; color: var(--color-saas-text-muted); }
  
  .stats-content-v2 { display: flex; align-items: center; gap: 64px; }
  .v-circle { width: 150px; height: 140px; border: 8px solid var(--color-saas-accent); border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #FFFBEB; }
  .v-val { font-size: 40px; font-weight: 900; color: #111827; line-height: 1; }
  .v-lbl { font-size: 11px; font-weight: 700; color: var(--color-saas-text-muted); text-transform: uppercase; margin-top: 4px; }
  
  .sub-stats-v2 { flex: 1; display: flex; flex-direction: column; gap: 16px; }
  .s-row { display: flex; justify-content: space-between; align-items: center; padding: 18px 24px; background: #F9FAFB; border-radius: 20px; }
  .s-lbl { font-size: 14px; font-weight: 600; color: var(--color-saas-text-muted); }
  .s-val { font-size: 24px; font-weight: 900; }
  .text-pending { color: #EF4444; }
  .text-success { color: #10B981; }

  .report-form-v2 { grid-column: span 5; }
  .map-box { height: 160px; border-radius: 20px; overflow: hidden; margin-bottom: 24px; border: 1.5px solid var(--color-saas-border); }
  #map { height: 100%; }

  .dark-card-v2 { grid-column: span 4; background: #111827; color: white; border: none; }
  .dark-card-v2 h3 { color: white; margin-bottom: 24px; }
  .list-dark-v2 { display: flex; flex-direction: column; gap: 12px; }
  .dark-item-v2 { display: flex; align-items: center; gap: 16px; padding: 16px 20px; background: rgba(255,255,255,0.05); border-radius: 16px; border: 1px solid rgba(255,255,255,0.03); }
  .i-rank { width: 30px; height: 30px; background: var(--color-saas-accent); color: #111827; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 900; }
  .i-name { flex: 1; font-weight: 600; font-size: 15px; }
  .i-pts { font-weight: 800; color: var(--color-saas-accent); font-size: 13px; }

  .activity-card-v2 { grid-column: span 8; }
  .activity-list-v2 { display: flex; flex-direction: column; gap: 12px; }
  .activity-v2 { display: flex; align-items: center; gap: 16px; padding: 20px 24px; background: #F9FAFB; border-radius: 20px; border: 1px solid transparent; transition: 0.2s; }
  .activity-v2:hover { border-color: var(--color-saas-accent); background: white; transform: scale(1.01); }
  .a-indicator { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
  .a-indicator.pending { background: #EF4444; }
  .a-indicator.resolved { background: #10B981; }
  .a-body { flex: 1; }
  .a-title { display: block; font-weight: 700; color: #111827; margin-bottom: 2px; font-size: 15px; }
  .a-meta { font-size: 13px; color: var(--color-saas-text-muted); }
  .a-pill { font-size: 11px; font-weight: 800; padding: 6px 12px; border-radius: 8px; text-transform: uppercase; }
  .a-pill.pending { background: #FEE2E2; color: #EF4444; }
  .a-pill.resolved { background: #D1FAE5; color: #10B981; }

  .w-full { width: 100%; }
  .saas-toast { position: fixed; bottom: 90px; right: 24px; left: 24px; padding: 16px; background: #111827; color: white; border-radius: 16px; text-align: center; font-weight: 700; transform: translateY(20px); opacity: 0; transition: 0.3s; z-index: 1000; }
  @media (min-width: 768px) { .saas-toast { left: auto; width: 300px; bottom: 32px; } }
  .saas-toast.show { transform: translateY(0); opacity: 1; }
  .saas-toast.error { background: #EF4444; }

  @media (max-width: 1024px) {
    .stats-card-v2, .report-form-v2, .dark-card-v2, .activity-card-v2 { grid-column: span 12; }
    .stats-content-v2 { flex-direction: column; gap: 32px; }
    .v-circle { width: 100%; border-radius: 24px; height: 120px; }
    .hero-header-v2 { flex-direction: column; align-items: flex-start; gap: 24px; }
    .hero-actions { width: 100%; }
    .hero-actions button { width: 100%; }
  }
</style>
