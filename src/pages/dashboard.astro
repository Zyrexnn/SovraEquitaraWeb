---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="Dashboard Warga — SovraEquitara">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  
  <div class="flex transition-colors duration-300">
    <Sidebar activePage="dashboard" />

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto lg:ml-[280px] p-6 pt-24 lg:pt-10 max-w-[1600px] w-full mx-auto pb-24 lg:pb-10">
      <div class="max-w-[1200px] mx-auto">
        
        <header class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-8 lg:mb-10 gap-4 animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]">
          <div>
            <h1 class="text-[28px] lg:text-[32px] font-extrabold tracking-tight m-0 text-zen-text dark:text-zen-text-dark">Suara <span class="bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">Warga</span></h1>
            <p class="text-sm lg:text-base font-semibold text-zen-muted dark:text-zen-muted-dark mt-1" id="greeting">Selamat beraktivitas, Warga.</p>
          </div>
          <div>
            <div id="current-date" class="px-4 py-2 rounded-full font-bold text-[13px] bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-zen-text dark:text-zen-text-dark">Memuat...</div>
          </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          
          <!-- Report Creation (Bento Main) -->
          <div class="md:col-span-2 lg:col-span-2 md:row-span-2 p-6 lg:p-8 rounded-[24px] lg:rounded-[2rem] border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark shadow-zen animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]" style="animation-delay: 0.1s;">
            <div class="flex justify-between items-center mb-6">
              <h3 class="text-base font-extrabold m-0">Aspirasi Infrastruktur</h3>
              <span class="text-[11px] font-extrabold text-zen-muted dark:text-zen-muted-dark uppercase tracking-wider">Laporkan Kerusakan</span>
            </div>
            
            <form id="form-report" class="flex flex-col gap-6">
              <div>
                <label class="block text-xs font-extrabold text-zen-muted dark:text-zen-muted-dark mb-2.5 uppercase tracking-wider">Kategori Masalah</label>
                <div class="flex overflow-x-auto sm:flex-wrap gap-2 pb-2 sm:pb-0 -mx-1 sm:mx-0 px-1 sm:px-0 scrollbar-hide" id="category-chips">
                  <!-- Chips injected -->
                </div>
                <input type="hidden" id="category_id" />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-extrabold text-zen-muted dark:text-zen-muted-dark mb-2.5 uppercase tracking-wider">Deskripsi Detail</label>
                  <textarea id="description" class="w-full p-3.5 lg:p-4 rounded-2xl border border-zen-border dark:border-zen-border-dark !bg-zen-surface dark:!bg-zen-surface-dark outline-none text-sm font-medium transition-colors duration-300 text-zen-text dark:text-zen-text-dark placeholder:text-zen-muted dark:placeholder:text-zen-muted-dark resize-none min-h-[120px] focus:ring-4 focus:ring-brand/5 dark:focus:ring-white/5 focus:border-brand dark:focus:border-white appearance-none" placeholder="Deskripsikan kerusakan atau keluhan Anda..." required></textarea>
                </div>
                
                <div>
                  <label class="block text-xs font-extrabold text-zen-muted dark:text-zen-muted-dark mb-2.5 uppercase tracking-wider">Bukti Visual</label>
                  <div class="h-[100px] border-2 border-dashed border-zen-border dark:border-zen-border-dark rounded-2xl flex flex-col items-center justify-center gap-2 cursor-pointer bg-zen-surface dark:bg-zen-surface-dark transition-colors duration-300 hover:border-brand hover:bg-black/5 dark:hover:bg-white/5" id="drop-zone">
                    <div class="text-xl">📸</div>
                    <p class="text-xs font-bold text-zen-muted dark:text-zen-muted-dark m-0">Klik atau Tarik Gambar</p>
                    <input type="file" id="image-upload" accept="image/*" class="hidden" />
                  </div>
                  <div id="image-preview" class="relative h-[100px] rounded-2xl overflow-hidden hidden">
                    <img id="preview-img" src="" alt="Preview" class="w-full h-full object-cover" />
                    <button type="button" class="absolute top-2 right-2 bg-black/50 text-white border-none w-6 h-6 rounded-full cursor-pointer flex items-center justify-center hover:bg-black/70" id="btn-remove-image">&times;</button>
                  </div>
                </div>
              </div>

              <div>
                <label class="block text-xs font-extrabold text-zen-muted dark:text-zen-muted-dark mb-2.5 uppercase tracking-wider">Lokasi Kejadian</label>
                <div class="flex flex-col gap-3">
                  <div class="flex flex-col gap-2.5">
                    <input type="text" id="location_detail" class="w-full p-3.5 lg:p-4 rounded-2xl border border-zen-border dark:border-zen-border-dark !bg-zen-surface dark:!bg-zen-surface-dark outline-none text-sm font-medium transition-colors duration-300 text-zen-text dark:text-zen-text-dark placeholder:text-zen-muted dark:placeholder:text-zen-muted-dark focus:ring-4 focus:ring-brand/5 dark:focus:ring-white/5 focus:border-brand dark:focus:border-white appearance-none" placeholder="Detail Lokasi (Contoh: Depan Halte)" required />
                    <div class="flex gap-2">
                      <input type="text" id="search-address" class="flex-1 p-3.5 lg:p-4 rounded-2xl border border-zen-border dark:border-zen-border-dark !bg-zen-surface dark:!bg-zen-surface-dark outline-none text-sm font-medium transition-colors duration-300 text-zen-text dark:text-zen-text-dark placeholder:text-zen-muted dark:placeholder:text-zen-muted-dark focus:ring-4 focus:ring-brand/5 dark:focus:ring-white/5 focus:border-brand dark:focus:border-white appearance-none" placeholder="Cari Alamat atau Area..." />
                      <button type="button" id="btn-search-loc" class="px-4 bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark rounded-xl cursor-pointer transition-colors duration-200 text-zen-text dark:text-zen-text-dark hover:border-brand flex items-center justify-center">🔍</button>
                    </div>
                  </div>
                  <div id="map" class="h-[250px] rounded-2xl border border-zen-border dark:border-zen-border-dark z-10 shadow-soft"></div>
                </div>
                <input type="hidden" id="lat" /><input type="hidden" id="lng" />
              </div>

              <button type="submit" id="btn-submit" class="w-full p-4 rounded-2xl bg-brand dark:bg-white text-white dark:text-brand border-none font-extrabold cursor-pointer transition-all duration-300 flex items-center justify-center gap-2.5 hover:-translate-y-0.5 hover:shadow-lg dark:hover:shadow-white/5 disabled:opacity-50 disabled:cursor-not-allowed">
                Kirim Laporan
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="3"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </button>
            </form>
          </div>

          <!-- Quick Stats -->
          <div class="lg:col-span-1 grid grid-cols-1 gap-4 lg:gap-4 p-6 lg:p-8 rounded-[24px] lg:rounded-[2rem] border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark shadow-zen animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]" style="animation-delay: 0.15s;">
            <div class="p-5 rounded-2xl bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-center flex flex-col justify-center">
              <span class="text-[11px] font-extrabold text-zen-muted dark:text-zen-muted-dark uppercase tracking-wider">Total Laporan</span>
              <h2 id="stat-total" class="text-[32px] font-extrabold m-0 mt-2 tracking-tight text-zen-text dark:text-zen-text-dark">0</h2>
            </div>
            <div class="p-5 rounded-2xl bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-center flex flex-col justify-center">
              <span class="text-[11px] font-extrabold text-zen-muted dark:text-zen-muted-dark uppercase tracking-wider">Diproses</span>
              <h2 id="stat-pending" class="text-[32px] font-extrabold m-0 mt-2 tracking-tight text-zen-yellow">0</h2>
            </div>
            <div class="p-5 rounded-2xl bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-center flex flex-col justify-center">
              <span class="text-[11px] font-extrabold text-zen-muted dark:text-zen-muted-dark uppercase tracking-wider">Terselesaikan</span>
              <h2 id="stat-resolved" class="text-[32px] font-extrabold m-0 mt-2 tracking-tight text-zen-green">0</h2>
            </div>
          </div>

          <!-- Leaderboard -->
          <div class="lg:col-span-1 p-6 lg:p-8 rounded-[24px] lg:rounded-[2rem] border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark shadow-zen animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]" style="animation-delay: 0.2s;">
            <div class="flex justify-between items-center mb-6">
              <h3 class="text-base font-extrabold m-0">Warga Teladan</h3>
              <span class="text-[11px] font-extrabold text-white bg-blue-500 px-2 py-1 rounded-md uppercase tracking-wider">TOP 10</span>
            </div>
            <div class="flex flex-col gap-2 overflow-y-auto max-h-[300px] lg:max-h-none pr-1" id="leaderboard-list">
              <!-- Leaderboard items -->
            </div>
          </div>

          <!-- Feed (Bento Wide Bottom) -->
          <div class="md:col-span-2 lg:col-span-3 p-6 lg:p-8 rounded-[24px] lg:rounded-[2rem] border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark shadow-zen animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]" style="animation-delay: 0.25s;">
            <div class="flex justify-between items-center mb-6">
              <h3 class="text-base font-extrabold m-0">Pantauan Kota</h3>
              <div>
                <select id="feed-sort" class="px-3 py-1.5 rounded-lg border border-zen-border dark:border-zen-border-dark bg-zen-surface dark:bg-zen-surface-dark text-xs font-bold outline-none cursor-pointer text-zen-text dark:text-zen-text-dark">
                  <option value="recent">Terbaru</option>
                  <option value="votes">Populer</option>
                  <option value="comments">Diskusi</option>
                </select>
              </div>
            </div>
            <div id="reports-list" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
              <!-- Reports injected -->
            </div>
          </div>

        </div>
      </div>
    </main>

    <!-- Empty space for mobile bottom (previously nav) -->
    <div class="lg:hidden h-6"></div>

    <!-- Detail Modal -->
    <div id="detail-modal" class="fixed inset-0 bg-black/60 dark:bg-black/80 backdrop-blur-sm z-[1000] flex items-center justify-center p-5 hidden">
      <div class="w-full max-w-[1000px] max-h-[90vh] rounded-[32px] overflow-hidden flex flex-col bg-zen-bg dark:bg-zen-bg-dark shadow-2xl border border-zen-border dark:border-zen-border-dark">
        <div class="px-8 py-6 border-b border-zen-border dark:border-zen-border-dark flex justify-between items-center bg-zen-surface dark:bg-zen-surface-dark text-zen-text dark:text-zen-text-dark">
          <h3 class="m-0 text-lg font-extrabold">Detail Laporan</h3>
          <div class="flex items-center gap-3">
            <button id="btn-delete-report" class="hidden px-3 py-1.5 bg-red-50 text-red-500 hover:bg-red-100 hover:text-red-600 dark:bg-red-500/10 dark:text-red-400 dark:border-red-500/20 rounded-lg text-xs font-bold border border-red-200 transition-colors cursor-pointer flex items-center gap-1">
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
              Hapus
            </button>
            <button id="close-detail" class="bg-transparent border-none text-[32px] cursor-pointer text-zen-muted dark:text-zen-muted-dark hover:text-zen-text dark:text-zen-text-dark leading-none">&times;</button>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto scrollbar-thin bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark">
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px]">
            <div class="p-6 lg:p-8 lg:border-r border-zen-border dark:border-zen-border-dark">
              <div id="detail-img-box" class="h-[250px] lg:h-[300px] rounded-2xl overflow-hidden mb-6 cursor-zoom-in bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark hidden shadow-soft">
                <img id="detail-img" src="" alt="Bukti" class="w-full h-full object-cover" />
              </div>
              <div>
                <div class="flex flex-wrap gap-2 mb-4">
                  <span id="detail-cat" class="text-[11px] font-extrabold bg-zen-surface dark:bg-zen-surface-dark px-3 py-1.5 rounded-lg border border-zen-border dark:border-zen-border-dark"></span>
                  <span id="detail-status" class="text-[11px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider"></span>
                </div>
                <h2 id="detail-desc" class="text-xl lg:text-2xl font-extrabold m-0 tracking-tight leading-tight mb-6"></h2>
                <div class="p-4 rounded-2xl my-6 bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-sm">
                  <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3">
                    <span class="font-medium">📍 <span id="detail-loc"></span></span>
                    <div class="flex gap-2">
                      <button id="btn-view-map-modal" class="px-3 py-1.5 text-[11px] font-extrabold border border-zen-border dark:border-zen-border-dark rounded-lg bg-zen-surface dark:bg-zen-surface-dark text-zen-text dark:text-zen-text-dark cursor-pointer transition-colors hover:bg-zen-bg dark:hover:bg-zen-bg-dark hover:border-brand dark:hover:border-white">Lihat Peta</button>
                      <a id="btn-gmaps-modal" href="#" target="_blank" class="px-3 py-1.5 text-[11px] font-extrabold border border-zen-border dark:border-zen-border-dark rounded-lg bg-zen-surface dark:bg-zen-surface-dark cursor-pointer transition-colors text-zen-text dark:text-zen-text-dark no-underline hover:bg-zen-bg dark:hover:bg-zen-bg-dark hover:border-brand dark:hover:border-white">Google Maps</a>
                    </div>
                  </div>
                  <div id="modal-map" class="h-[200px] rounded-xl mt-3 border border-zen-border dark:border-zen-border-dark hidden z-10 shadow-soft"></div>
                </div>
                <div class="flex flex-wrap justify-between items-center gap-4 mt-6">
                  <span id="detail-date" class="text-sm font-semibold text-zen-muted dark:text-zen-muted-dark"></span>
                  <div>
                    <button class="bg-zen-surface dark:bg-zen-surface-dark text-zen-text dark:text-zen-text-dark border border-zen-border dark:border-zen-border-dark px-5 py-3 rounded-xl font-extrabold cursor-pointer transition-all duration-200 hover:scale-105 hover:bg-zen-bg dark:hover:bg-zen-bg-dark hover:border-brand dark:hover:border-white" id="btn-vote-modal">
                      🔥 <b id="detail-votes">0</b> Dukungan
                    </button>
                  </div>
                </div>
              </div>
            </div>
            <div class="bg-zen-surface dark:bg-zen-surface-dark flex flex-col border-t lg:border-t-0 lg:border-l border-zen-border dark:border-zen-border-dark">
              <div class="p-6 border-b border-zen-border dark:border-zen-border-dark font-extrabold text-xs uppercase tracking-wider">Diskusi & Solusi</div>
              <div id="comments-list" class="flex-1 p-6 flex flex-col gap-4 overflow-y-auto scrollbar-thin h-[300px] lg:h-[400px]"></div>
              <form id="form-comment" class="p-5 flex gap-3 border-t border-zen-border dark:border-zen-border-dark bg-zen-surface dark:bg-zen-surface-dark">
                <input type="hidden" id="active-report-id" />
                <input type="text" id="comment-input" class="flex-1 p-3.5 rounded-xl border border-zen-border dark:border-zen-border-dark !bg-zen-bg dark:!bg-zen-bg-dark text-zen-text dark:text-zen-text-dark text-sm font-medium outline-none transition-colors focus:ring-2 focus:ring-brand/20 dark:focus:ring-white/20 focus:border-brand dark:focus:border-white appearance-none placeholder:text-zen-muted dark:placeholder:text-zen-muted-dark" placeholder="Tulis pendapat Anda..." required />
                <button type="submit" class="w-12 h-12 rounded-xl bg-brand dark:bg-white text-white dark:text-brand border-none flex items-center justify-center cursor-pointer transition-transform hover:-translate-y-0.5">
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox -->
    <div id="lightbox" class="fixed inset-0 bg-black/90 z-[2000] flex items-center justify-center hidden backdrop-blur-sm">
      <div class="relative w-full h-full p-8 flex items-center justify-center">
        <img id="lightbox-img" src="" alt="Full view" class="max-w-full max-h-full object-contain rounded-lg shadow-2xl" />
        <button id="lightbox-close" class="absolute top-6 right-6 lg:top-10 lg:right-10 bg-white/10 hover:bg-white/20 text-white border-none w-12 h-12 rounded-full text-2xl cursor-pointer flex items-center justify-center transition-colors backdrop-blur-md">&times;</button>
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  
  <script is:inline define:vars={{ PUBLIC_API_URL: import.meta.env.PUBLIC_API_URL || 'http://localhost:3000' }}>
    const API_URL = PUBLIC_API_URL;
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('astro:page-load', initZenDashboard);
      if (document.readyState === 'complete') initZenDashboard();
    }

    let user, categories = [], selectedFile = null, map, marker, allReports = [];

    async function initZenDashboard() {
      user = JSON.parse(userRaw);
      setupUI();
      setupMap();
      setupUpload();
      await loadCategories();
      await fetchData();
      setupListeners();

      setInterval(async () => {
        if(!token) return;
        const currentSort = document.getElementById('feed-sort').value;
        await fetchFeed(currentSort, true);
        const activeReportId = document.getElementById('active-report-id').value;
        if(activeReportId && !document.getElementById('detail-modal').classList.contains('hidden')) {
           const r = allReports.find(x => x.id === activeReportId);
           if(r) {
             document.getElementById('detail-votes').textContent = r.vote_count;
             loadComments(activeReportId, true);
           }
        }
      }, 5000);
    }

    function setupUI() {
      document.getElementById('greeting').textContent = `Selamat ${getTimeGreeting()}, ${user.name?.split(' ')[0] || 'Warga'}.`;
      document.getElementById('current-date').textContent = new Date().toLocaleDateString('id-ID', { weekday:'long', day:'numeric', month:'short' });
    }

    function getTimeGreeting() {
      const hrs = new Date().getHours();
      if(hrs < 11) return 'Pagi';
      if(hrs < 15) return 'Siang';
      if(hrs < 19) return 'Sore';
      return 'Malam';
    }

    function setupMap() {
      const def = { lat: -6.2000, lng: 106.8166 };
      map = L.map('map', { zoomControl: false }).setView([def.lat, def.lng], 13);
      const isDark = document.documentElement.classList.contains('dark');
      L.tileLayer(isDark ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png' : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
      marker = L.marker([def.lat, def.lng], { draggable: true }).addTo(map);
      
      const setCoords = (ll) => {
        document.getElementById('lat').value = ll.lat;
        document.getElementById('lng').value = ll.lng;
      };
      setCoords(def);
      marker.on('dragend', (e) => setCoords(e.target.getLatLng()));
      map.on('click', (e) => { marker.setLatLng(e.latlng); setCoords(e.latlng); });

      // Search Location Logic
      const searchBtn = document.getElementById('btn-search-loc');
      const searchInput = document.getElementById('search-address');
      
      const doSearch = async () => {
        const query = searchInput.value;
        if(!query) return;
        try {
          const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`);
          const data = await res.json();
          if(data.length > 0) {
            const first = data[0];
            const ll = { lat: parseFloat(first.lat), lng: parseFloat(first.lon) };
            map.setView(ll, 16);
            marker.setLatLng(ll);
            setCoords(ll);
          } else {
            window.showToast('Lokasi tidak ditemukan', 'error');
          }
        } catch(e) {
          window.showToast('Gagal mencari lokasi', 'error');
        }
      };

      searchBtn.onclick = doSearch;
      searchInput.onkeydown = (e) => { if(e.key === 'Enter') { e.preventDefault(); doSearch(); } };

      if(navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(p => {
          const ll = { lat: p.coords.latitude, lng: p.coords.longitude };
          map.setView(ll, 15); marker.setLatLng(ll); setCoords(ll);
        });
      }
    }

    function setupUpload() {
      const zone = document.getElementById('drop-zone');
      const input = document.getElementById('image-upload');
      zone.onclick = () => input.click();
      input.onchange = (e) => handleFile(e.target.files[0]);
      zone.ondragover = (e) => { 
        e.preventDefault(); 
        zone.classList.add('border-brand', 'bg-black/5', 'dark:bg-white/5'); 
      };
      zone.ondragleave = () => {
        zone.classList.remove('border-brand', 'bg-black/5', 'dark:bg-white/5');
      };
      zone.ondrop = (e) => { 
        e.preventDefault(); 
        zone.classList.remove('border-brand', 'bg-black/5', 'dark:bg-white/5');
        handleFile(e.dataTransfer.files[0]); 
      };
      document.getElementById('btn-remove-image').onclick = () => {
        selectedFile = null; input.value = '';
        document.getElementById('image-preview').classList.add('hidden');
        zone.classList.remove('hidden');
      };
    }

    function handleFile(file) {
      if(!file || !file.type.startsWith('image/')) return window.showToast('Pilih file gambar!', 'error');
      selectedFile = file;
      const reader = new FileReader();
      reader.onload = (e) => {
        document.getElementById('preview-img').src = e.target.result;
        document.getElementById('image-preview').classList.remove('hidden');
        document.getElementById('drop-zone').classList.add('hidden');
      };
      reader.readAsDataURL(file);
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
        const container = document.getElementById('category-chips');
        container.innerHTML = categories.map(c => `<div class="px-3.5 py-2 sm:px-4 sm:py-2.5 rounded-xl bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-xs sm:text-[13px] font-bold cursor-pointer transition-colors duration-200 text-zen-text dark:text-zen-text-dark whitespace-nowrap category-chip" data-id="${c.id}">${c.name}</div>`).join('');
        container.querySelectorAll('.category-chip').forEach(c => c.onclick = () => {
          container.querySelectorAll('.category-chip').forEach(x => {
             x.classList.remove('bg-brand', 'text-white', 'border-brand', 'dark:text-zen-bg');
             x.classList.add('bg-zen-surface', 'dark:bg-zen-surface-dark', 'text-zen-text', 'dark:text-zen-text-dark', 'border-zen-border', 'dark:border-zen-border-dark');
          });
          c.classList.remove('bg-zen-surface', 'dark:bg-zen-surface-dark', 'text-zen-text', 'dark:text-zen-text-dark', 'border-zen-border', 'dark:border-zen-border-dark');
          c.classList.add('bg-brand', 'text-white', 'border-brand', 'dark:text-zen-bg');
          document.getElementById('category_id').value = c.dataset.id;
        });
      } catch(e) {}
    }

    async function fetchData() {
      fetchStats();
      fetchFeed('recent');
      fetchLeaderboard();
    }

    
    async function fetchStats() {
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        const r = data.data || [];
        document.getElementById('stat-total').textContent = r.length;
        document.getElementById('stat-pending').textContent = r.filter(x => x.status === 'PENDING').length;
        document.getElementById('stat-resolved').textContent = r.filter(x => x.status === 'RESOLVED').length;
      } catch(e) {}
    }

    async function fetchFeed(sort, silent = false) {
      const list = document.getElementById('reports-list');
      if (!silent) list.innerHTML = '<div class="col-span-full py-12 flex justify-center"><div class="w-8 h-8 border-4 border-zen-border dark:border-zen-border-dark border-t-brand dark:border-t-white rounded-full animate-spin"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/public-reports?sort=${sort}`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        allReports = data.data || [];
        if(allReports.length === 0) { list.innerHTML = '<div class="col-span-full py-12 text-center text-zen-muted dark:text-zen-muted-dark font-bold text-sm">Belum ada laporan.</div>'; return; }

        list.innerHTML = allReports.map(r => {
          const cat = categories.find(c => c.id === r.category_id)?.name || 'Umum';
          const img = r.image_url ? `<div class="h-40 overflow-hidden"><img src="${API_URL}${r.image_url}" class="w-full h-full object-cover" /></div>` : '';
          const statusClass = r.status.toLowerCase() === 'pending' ? 'bg-amber-500/10 text-amber-600 dark:text-amber-400' : r.status.toLowerCase() === 'resolved' ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' : 'bg-gray-500/10 text-gray-600 dark:text-gray-400';
          return `
            <div class="rounded-3xl overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(0,0,0,0.05)] bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark cursor-pointer group" onclick="window.openDetail('${r.id}')">
              ${img}
              <div class="p-6">
                <div class="flex gap-2.5 mb-3">
                  <span class="text-[10px] font-extrabold px-2 py-1 rounded-md bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark">${cat}</span>
                  <span class="text-[10px] font-black px-2 py-1 rounded-md uppercase ${statusClass}">${r.status}</span>
                </div>
                <h4 class="text-base font-extrabold m-0 mb-2 leading-tight">${r.description}</h4>
                <p class="text-xs text-zen-muted dark:text-zen-muted-dark m-0">📍 ${r.location_detail}</p>
                <div class="mt-5 pt-4 border-t border-zen-border dark:border-zen-border-dark flex justify-between items-center text-xs font-bold">
                  <button class="bg-transparent border-none font-extrabold cursor-pointer text-zen-text dark:text-zen-text-dark flex items-center hover:text-brand transition-colors" onclick="event.stopPropagation(); window.doVote('${r.id}')">🔥 ${r.vote_count}</button>
                  <span class="text-zen-muted dark:text-zen-muted-dark">💬 ${r.comment_count} Diskusi</span>
                </div>
              </div>
            </div>
          `;
        }).join('');
      } catch(e) {}
    }

    async function fetchLeaderboard() {      const list = document.getElementById('leaderboard-list');
      try {
        const res = await fetch(`${API_URL}/api/leaderboard`);
        const data = await res.json();
        const users = data.data || [];
        if (users.length === 0) {
          list.innerHTML = '<div class="py-8 text-center text-zen-muted dark:text-zen-muted-dark font-bold text-sm">Belum ada data warga.</div>';
          return;
        }
        list.innerHTML = users.slice(0, 5).map((u, i) => {
          const rankClass = i === 0 ? "bg-amber-100 text-amber-900 border-amber-200 dark:bg-amber-400/10 dark:text-amber-400 dark:border-amber-400/20" : i === 1 ? "bg-slate-100 text-slate-600 border-slate-200 dark:bg-slate-400/10 dark:text-slate-400 dark:border-slate-400/20" : i === 2 ? "bg-orange-100 text-orange-900 border-orange-200 dark:bg-orange-400/10 dark:text-orange-400 dark:border-orange-400/20" : "bg-zen-bg dark:bg-zen-bg-dark border-zen-border dark:border-zen-border-dark text-zen-text dark:text-zen-text-dark";
          const rankIcon = i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : i + 1;
          const initial = (u.full_name || "U")[0].toUpperCase();
          const avatarHtml = u.avatar_url ? `<img src="${u.avatar_url.startsWith('http') ? u.avatar_url : API_URL + u.avatar_url}" class="w-full h-full object-cover rounded-xl" />` : initial;
          return `
            <div class="flex items-center gap-3 p-3 rounded-2xl bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark transition-all duration-200 hover:border-brand hover:translate-x-1">
              <div class="w-7 h-7 rounded-lg flex items-center justify-center text-xs font-black border ${rankClass} shrink-0">${rankIcon}</div>
              <div class="w-8 h-8 rounded-xl bg-brand text-white flex items-center justify-center font-extrabold text-xs dark:text-zen-bg shrink-0 border border-white/10 overflow-hidden">${avatarHtml}</div>
              <div class="flex-1 min-w-0">
                <strong class="text-[13px] font-extrabold block whitespace-nowrap overflow-hidden text-ellipsis text-zen-text dark:text-zen-text-dark">${u.full_name}</strong>
                <span class="text-[10px] font-extrabold text-zen-blue tracking-wider">${u.points} PTS</span>
              </div>
            </div>
          `;
        }).join('');
      } catch(e) {
        list.innerHTML = '<div class="py-8 text-center text-red-500 font-bold text-sm">Gagal memuat leaderboard.</div>';
      }
    }

    function setupListeners() {
      const safeSetClick = (id, fn) => {
        const el = document.getElementById(id);
        if (el) el.onclick = fn;
      };

      const formReport = document.getElementById('form-report');
      if (formReport) formReport.onsubmit = handleReportSubmit;

      const feedSort = document.getElementById('feed-sort');
      if (feedSort) feedSort.onchange = (e) => fetchFeed(e.target.value);

      safeSetClick('close-detail', () => document.getElementById('detail-modal').classList.add('hidden'));
      safeSetClick('lightbox-close', () => document.getElementById('lightbox').classList.add('hidden'));
      
      const formComment = document.getElementById('form-comment');
      if (formComment) formComment.onsubmit = handleCommentSubmit;
    }

    function logout() { localStorage.clear(); window.location.href = '/'; }

    async function handleReportSubmit(e) {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      const cat = document.getElementById('category_id').value;
      if(!cat) return window.showToast('Pilih kategori!', 'error');

      btn.disabled = true;
      const fd = new FormData();
      fd.append('category_id', cat);
      fd.append('description', document.getElementById('description').value);
      fd.append('location_detail', document.getElementById('location_detail').value);
      fd.append('latitude', document.getElementById('lat').value);
      fd.append('longitude', document.getElementById('lng').value);
      if(selectedFile) fd.append('image', selectedFile);

      try {
        const res = await fetch(`${API_URL}/api/reports`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: fd
        });
        if(res.ok) {
          window.showToast('Laporan Berhasil Terkirim!', 'success');
          document.getElementById('form-report').reset();
          if(selectedFile) document.getElementById('btn-remove-image').click();
          fetchData();
        } else {
          const err = await res.json();
          window.showToast(err.error || 'Gagal mengirim laporan', 'error');
        }
      } catch(e) {
        window.showToast('Terjadi kesalahan koneksi', 'error');
      }
      btn.disabled = false;
    }

    window.openDetail = (id) => {
      const r = allReports.find(x => x.id === id);
      if(!r) return;
      document.getElementById('active-report-id').value = id;
      
      const imgBox = document.getElementById('detail-img-box');
      if(r.image_url) {
        document.getElementById('detail-img').src = API_URL + r.image_url;
        imgBox.classList.remove('hidden');
        imgBox.onclick = () => window.openLightbox(API_URL + r.image_url);
      } else { imgBox.classList.add('hidden'); }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = categories.find(c => c.id === r.category_id)?.name || 'Umum';
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      document.getElementById('detail-status').textContent = r.status;
      
      const statusClass = r.status.toLowerCase() === 'pending' ? 'bg-amber-500/10 text-amber-600 dark:text-amber-400' : r.status.toLowerCase() === 'resolved' ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' : 'bg-gray-500/10 text-gray-600 dark:text-gray-400';
      document.getElementById('detail-status').className = `text-[11px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider ${statusClass}`;
      
      // Delete Button Logic
      const btnDelete = document.getElementById('btn-delete-report');
      if (r.profile_id === user.id && r.status === 'PENDING') {
        btnDelete.classList.remove('hidden');
        btnDelete.onclick = () => window.deleteReport(id);
      } else {
        btnDelete.classList.add('hidden');
      }

      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('btn-vote-modal').onclick = () => window.doVote(id);

      // Google Maps Link
      const gLink = document.getElementById('btn-gmaps-modal');
      gLink.href = `https://www.google.com/maps?q=${r.latitude},${r.longitude}`;

      // Modal Map
      const modalMapContainer = document.getElementById('modal-map');
      const viewMapBtn = document.getElementById('btn-view-map-modal');
      modalMapContainer.classList.add('hidden');
      viewMapBtn.textContent = 'Lihat Peta';
      
      viewMapBtn.onclick = () => {
        const isHidden = modalMapContainer.classList.toggle('hidden');
        viewMapBtn.textContent = isHidden ? 'Lihat Peta' : 'Tutup Peta';
        if (!isHidden) {
          setTimeout(() => {
            if (window.mMap) window.mMap.remove();
            window.mMap = L.map('modal-map', { zoomControl: true }).setView([r.latitude, r.longitude], 16);
            const isDark = document.documentElement.classList.contains('dark');
            L.tileLayer(isDark ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png' : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(window.mMap);
            L.marker([r.latitude, r.longitude]).addTo(window.mMap);
          }, 100);
        }
      };

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openLightbox = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    window.deleteReport = async (id) => {
      if(!confirm('Apakah Anda yakin ingin menghapus laporan ini?')) return;
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if(res.ok) {
          window.showToast('Laporan berhasil dihapus', 'success');
          document.getElementById('detail-modal').classList.add('hidden');
          fetchData();
        } else {
          const err = await res.json();
          window.showToast(err.error || 'Gagal menghapus laporan', 'error');
        }
      } catch(e) {
        window.showToast('Terjadi kesalahan koneksi', 'error');
      }
    };

    window.doVote = async (id) => {
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/vote`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ vote_type: 1 })
        });
        if(res.ok) {
          window.showToast({ message: 'Dukungan berhasil ditambahkan!', type: 'success' });
          fetchFeed(document.getElementById('feed-sort').value);
          const r = allReports.find(x => x.id === id);
          if(r && document.getElementById('active-report-id').value === id) {
             document.getElementById('detail-votes').textContent = r.vote_count + 1;
          }
        } else {
          const err = await res.json();
          window.showToast({ message: err.error || 'Gagal menambahkan dukungan', type: 'info' });
        }
      } catch(e) {
        window.showToast({ message: 'Terjadi kesalahan koneksi', type: 'error' });
      }
    };

    async function loadComments(id, silent = false) {
      const list = document.getElementById('comments-list');
      if(!silent) list.innerHTML = '<div class="py-10 flex justify-center"><div class="w-8 h-8 border-4 border-zen-border dark:border-zen-border-dark border-t-brand dark:border-t-white rounded-full animate-spin"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const c = data.data || [];
        if(c.length === 0) { list.innerHTML = '<div class="py-10 flex justify-center text-zen-muted dark:text-zen-muted-dark font-bold text-sm">Belum ada diskusi.</div>'; return; }
        list.innerHTML = c.map(x => {
          const initial = (x.user?.full_name || 'W')[0].toUpperCase();
          const avatarHtml = x.user?.avatar_url ? `<img src="${x.user.avatar_url.startsWith('http') ? x.user.avatar_url : API_URL + x.user.avatar_url}" class="w-full h-full object-cover" />` : initial;
          const isAdmin = x.user?.role === 'admin' || x.user?.role === 'super_admin';
          const badgeHtml = x.user?.role === 'super_admin' ? `<svg class="inline-block ml-1 w-3.5 h-3.5 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : (x.user?.role === 'admin' ? `<svg class="inline-block ml-1 w-3.5 h-3.5 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : '');
          
          return `
          <div class="flex gap-3 max-w-[90%] ${isAdmin ? 'self-end flex-row-reverse' : ''}">
            <div class="w-8 h-8 rounded-xl overflow-hidden shrink-0 flex items-center justify-center font-black text-xs ${isAdmin ? 'bg-brand text-white dark:text-zen-bg' : 'bg-stone-900 dark:bg-white text-white dark:text-black'} border border-white/10">
              ${avatarHtml}
            </div>
            <div class="p-4 rounded-[20px] border flex-1 min-w-0 ${isAdmin ? 'bg-brand text-white border-brand dark:text-zen-bg' : 'bg-zen-bg dark:bg-zen-bg-dark border-zen-border dark:border-zen-border-dark text-zen-text dark:text-zen-text-dark'}">
              <div class="mb-1 text-xs flex items-center"><strong>${x.user?.full_name || 'Warga'}</strong>${badgeHtml}</div>
              <p class="m-0 text-sm leading-relaxed">${x.content}</p>
            </div>
          </div>
        `}).join('');
        if(!silent) list.scrollTop = list.scrollHeight;
      } catch(e) {}
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('active-report-id').value;
      const input = document.getElementById('comment-input');
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) { 
          input.value = ''; 
          loadComments(id); 
          fetchFeed(document.getElementById('feed-sort').value); 
          window.showToast({ message: 'Komentar berhasil ditambahkan!', type: 'success' });
        } else {
          window.showToast({ message: 'Gagal mengirim komentar', type: 'error' });
        }
      } catch(e) {
        window.showToast({ message: 'Terjadi kesalahan koneksi', type: 'error' });
      }
    }
  </script>
</Layout>