    /* File Upload */
    .upload-zone { border: 2px dashed var(--c-border); border-radius: var(--radius-md); padding: 32px 20px; text-align: center; cursor: pointer; transition: 0.2s; background: #FAFAFA; display: flex; flex-direction: column; align-items: center; gap: 8px; }
