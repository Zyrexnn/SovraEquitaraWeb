---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard — SovraEquitara">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  
  <div class="dashboard-wrapper">
    <!-- Sidebar -->
    <aside class="sidebar-nav">
      <div class="nav-brand">
        <div class="brand-logo-pill">
          <img src="/logo.svg" alt="Sovra" />
        </div>
      </div>
      <nav class="nav-links">
        <a href="/dashboard" class="nav-link active" title="Dashboard">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        </a>
        <a href="/profile" class="nav-link" title="Profil">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </a>
        <a href="/history" class="nav-link" title="Riwayat">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
        </a>
      </nav>
      <div class="nav-footer">
        <button id="btn-logout" class="nav-link logout-link" title="Keluar">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-viewport scroll-slim">
      <header class="top-nav">
        <div class="welcome-msg">
          <h1 id="user-greeting">Halo, Amanda!</h1>
          <p>Yuk, lihat kontribusi infrastrukturmu hari ini.</p>
        </div>
        <div class="top-actions">
          <div class="search-bar">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" placeholder="Cari laporan..." />
          </div>
          <button class="btn btn-primary btn-upgrade">Lihat Peta</button>
        </div>
      </header>

      <div class="bento-container">
        <!-- Hero Stats Card -->
        <div class="bento-item glass card-hero animate-up" style="grid-column: span 8; grid-row: span 2;">
          <div class="hero-header">
            <h3>Statistik Aktivitas</h3>
            <p>Data kontribusi terbaru Anda</p>
          </div>
          
          <div class="zen-visual">
            <div class="blob blob-main">
              <span class="blob-val" id="profile-points">0</span>
              <span class="blob-label">PTS</span>
            </div>
            <div class="blob blob-sub-1">
              <span class="blob-val" id="count-resolved">0</span>
              <span class="blob-label">Selesai</span>
            </div>
            <div class="blob blob-sub-2">
              <span class="blob-val" id="count-pending">0</span>
              <span class="blob-label">Pending</span>
            </div>
          </div>

          <div class="hero-legend">
            <div class="legend-item"><span class="dot pts"></span> Poin Akumulasi</div>
            <div class="legend-item"><span class="dot resolved"></span> Laporan Selesai</div>
            <div class="legend-item"><span class="dot pending"></span> Masih Proses</div>
          </div>
        </div>

        <!-- Leaderboard Card -->
        <div class="bento-item glass card-dark animate-up delay-1" style="grid-column: span 4; grid-row: span 2;">
          <div class="card-header-flex">
            <h3>Warga Aktif</h3>
            <div class="month-select">Mei <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg></div>
          </div>
          
          <div id="leaderboard-list" class="zen-list-dark">
            <!-- Items injected by script -->
          </div>

          <div class="card-footer-center">
            <div class="pts-status">
              <span class="dot current"></span> Peringkat: <strong id="profile-rank">Pemula</strong>
            </div>
          </div>
        </div>

        <!-- Report Form Card -->
        <div class="bento-item glass animate-up delay-2" style="grid-column: span 4;">
          <div class="card-header-simple">
            <h3>Lapor Cepat</h3>
            <p>Laporkan masalah infrastruktur</p>
          </div>
          <form id="form-report" class="zen-form">
            <input type="text" id="details" placeholder="Apa masalahnya?" required />
            <div class="map-mini glass">
              <div id="map"></div>
              <input type="hidden" id="lat" /><input type="hidden" id="lng" />
            </div>
            <button type="submit" id="btn-submit" class="btn btn-primary w-full">Kirim Laporan</button>
          </form>
        </div>

        <!-- Progress Card -->
        <div class="bento-item glass animate-up delay-3" style="grid-column: span 8;">
          <div class="card-header-flex">
            <h3>Laporan Terbaru</h3>
            <button class="btn-icon-plus" title="Tambah Baru">+</button>
          </div>
          
          <div id="reports-list" class="zen-activity-list">
            <!-- Items injected by script -->
          </div>
        </div>
      </div>
    </main>

    <div id="toast" class="toast-bento"></div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) window.location.href = '/login';

    const user = JSON.parse(userRaw);
    document.getElementById('user-greeting').textContent = `Halo, ${user.name || 'Warga'}!`;

    // Map Init
    const map = L.map('map', { zoomControl: false }).setView([-6.2000, 106.8166], 13);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
    const marker = L.marker([-6.2000, 106.8166], { draggable: true }).addTo(map);
    
    function updateLoc(latlng) {
      document.getElementById('lat').value = latlng.lat;
      document.getElementById('lng').value = latlng.lng;
    }
    marker.on('dragend', (e) => updateLoc(e.target.getLatLng()));
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(pos => {
        const ll = { lat: pos.coords.latitude, lng: pos.coords.longitude };
        map.setView(ll, 15); marker.setLatLng(ll); updateLoc(ll);
      });
    }

    async function refreshData() {
      try {
        const [repRes, leadRes] = await Promise.all([
          fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` } }),
          fetch(`${API_URL}/api/leaderboard`, { headers: { 'Authorization': `Bearer ${token}` } })
        ]);
        const reps = await repRes.json();
        const leads = await leadRes.json();
        renderReports(reps.data || []);
        renderLeaderboard(leads.data || []);
        updateStats(reps.data || []);
      } catch (err) { console.error(err); }
    }

    function updateStats(reports) {
      const pending = reports.filter(r => r.status === 'PENDING').length;
      const resolved = reports.filter(r => r.status === 'RESOLVED').length;
      document.getElementById('count-pending').textContent = pending;
      document.getElementById('count-resolved').textContent = resolved;
      document.getElementById('profile-points').textContent = user.points || 0;
      
      let rank = 'Pemula';
      if(user.points >= 20) rank = 'Pemerhati';
      if(user.points >= 50) rank = 'Aktivis';
      document.getElementById('profile-rank').textContent = rank;
    }

    function renderReports(items) {
      const list = document.getElementById('reports-list');
      list.innerHTML = items.slice(0, 4).map(r => `
        <div class="zen-row">
          <div class="zen-icon"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg></div>
          <div class="zen-info">
            <h4>${r.description}</h4>
            <p>${r.location_detail || 'Lokasi Terdeteksi'}</p>
          </div>
          <div class="zen-status">
            <span class="status-indicator ${r.status.toLowerCase()}"></span>
            ${r.status}
          </div>
        </div>
      `).join('');
    }

    function renderLeaderboard(items) {
      const list = document.getElementById('leaderboard-list');
      list.innerHTML = items.slice(0, 5).map((l, i) => `
        <div class="zen-dark-row">
          <div class="dark-rank">${i+1}</div>
          <div class="dark-name">${l.full_name || 'Warga'}</div>
          <div class="dark-pts">${l.points} PTS</div>
        </div>
      `).join('');
    }

    document.getElementById('form-report').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('btn-submit');
      btn.disabled = true;
      const payload = {
        description: document.getElementById('details').value,
        latitude: parseFloat(document.getElementById('lat').value),
        longitude: parseFloat(document.getElementById('lng').value)
      };
      const res = await fetch(`${API_URL}/api/reports`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
        body: JSON.stringify(payload)
      });
      if (res.ok) { showToast('Laporan Terkirim!'); document.getElementById('form-report').reset(); refreshData(); }
      else { showToast('Gagal mengirim', 'error'); }
      btn.disabled = false;
    });

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.textContent = msg; t.className = `toast-bento show ${type}`;
      setTimeout(() => t.className = 'toast-bento', 3000);
    }

    document.getElementById('btn-logout').onclick = () => { localStorage.clear(); window.location.href = '/login'; };
    refreshData();
  </script>
</Layout>

<style>
  /* Page Specific Layout */
  .hero-header h3 { font-size: 20px; font-weight: 800; }
  .hero-header p { font-size: 13px; color: var(--color-text-muted); }

  .zen-visual {
    height: 240px;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    margin-top: var(--space-xl);
  }

  .blob {
    position: absolute;
    border-radius: 50%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    backdrop-filter: blur(40px);
    transition: all 0.5s var(--transition-smooth);
    animation: float 6s infinite ease-in-out;
  }

  .blob-main {
    width: 180px; height: 180px;
    background: rgba(249, 212, 35, 0.4);
    z-index: 2;
    box-shadow: 0 20px 40px rgba(249, 212, 35, 0.2);
  }
  .blob-sub-1 {
    width: 120px; height: 120px;
    background: rgba(26, 26, 26, 0.6);
    color: white;
    top: 20px; left: 20%;
    animation-delay: -2s;
  }
  .blob-sub-2 {
    width: 100px; height: 100px;
    background: rgba(242, 139, 130, 0.5);
    bottom: 20px; right: 25%;
    animation-delay: -4s;
  }

  .blob-val { font-size: 24px; font-weight: 800; line-height: 1; }
  .blob-label { font-size: 10px; font-weight: 700; text-transform: uppercase; margin-top: 4px; opacity: 0.8; }

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-15px) scale(1.02); }
  }

  .hero-legend {
    display: flex; justify-content: center; gap: var(--space-xl);
    margin-top: var(--space-xl);
  }
  .legend-item { font-size: 11px; font-weight: 700; color: var(--color-text-muted); display: flex; align-items: center; gap: 6px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot.pts { background: var(--color-accent); }
  .dot.resolved { background: var(--color-brand); }
  .dot.pending { background: var(--color-secondary); }

  /* Dark Card (Leaderboard) */
  .card-dark { background: var(--color-brand); color: white; border: none; }
  .card-dark h3 { color: white; font-size: 18px; }
  .month-select { font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.5); display: flex; align-items: center; gap: 4px; }
  
  .zen-list-dark { margin-top: var(--space-xl); display: flex; flex-direction: column; gap: 12px; }
  .zen-dark-row {
    display: flex; align-items: center; gap: 16px;
    padding: 12px 16px; background: rgba(255,255,255,0.05);
    border-radius: 16px; transition: background 0.3s;
  }
  .zen-dark-row:hover { background: rgba(255,255,255,0.1); }
  .dark-rank { width: 24px; height: 24px; background: var(--color-accent); color: var(--color-brand); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 12px; }
  .dark-name { flex: 1; font-size: 14px; font-weight: 600; }
  .dark-pts { font-size: 12px; font-weight: 800; color: var(--color-accent); }

  .pts-status { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.6); margin-top: var(--space-xl); text-align: center; }
  .pts-status strong { color: white; }

  /* Form & Activity */
  .zen-form input {
    width: 100%; padding: 14px 20px; border-radius: 16px;
    border: 1px solid var(--color-border); background: var(--color-bg);
    font-family: inherit; font-size: 14px; margin-bottom: var(--space-md);
  }
  .map-mini { height: 160px; border-radius: 20px; overflow: hidden; margin-bottom: var(--space-lg); }
  #map { height: 100%; width: 100%; }

  .zen-activity-list { margin-top: var(--space-lg); display: flex; flex-direction: column; gap: 8px; }
  .zen-row {
    display: flex; align-items: center; gap: 16px;
    padding: 16px; background: var(--color-bg);
    border-radius: 20px; border: 1px solid transparent;
    transition: all 0.3s;
  }
  .zen-row:hover { border-color: var(--color-accent); transform: translateX(5px); }
  .zen-icon { width: 44px; height: 44px; background: white; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: var(--color-brand); box-shadow: var(--shadow-soft); }
  .zen-info h4 { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
  .zen-info p { font-size: 12px; color: var(--color-text-muted); }
  .zen-status { margin-left: auto; font-size: 11px; font-weight: 800; color: var(--color-text-muted); display: flex; align-items: center; gap: 6px; text-transform: uppercase; }
  .status-indicator { width: 6px; height: 6px; border-radius: 50%; }
  .status-indicator.pending { background: var(--color-secondary); }
  .status-indicator.resolved { background: var(--color-brand); }

  .btn-icon-plus {
    width: 32px; height: 32px; border-radius: 10px; background: var(--color-brand);
    color: white; border: none; font-size: 20px; font-weight: 300; cursor: pointer;
  }

  .card-header-flex { display: flex; justify-content: space-between; align-items: center; }

  @media (max-width: 1024px) {
    .bento-container { grid-template-columns: 1fr; display: flex; flex-direction: column; }
    .bento-item { grid-column: span 1 !important; }
    .top-actions { width: 100%; display: flex; flex-direction: column; gap: 12px; }
    .search-bar { width: 100%; }
    .btn-upgrade { width: 100%; }
  }
</style>
