    .comment-input-wrapper { padding: 16px 24px; border-top: 1px solid var(--c-border); background: var(--c-surface); }
    .comment-input-group { display: flex; gap: 12px; }
    .comment-input-group input { flex: 1; padding: 12px 16px; border: 1px solid var(--c-border); border-radius: var(--radius-sm); font-size: 14px; outline: none; }
    .comment-input-group input:focus { border-color: var(--c-brand); }
    .btn-send { background: var(--c-brand); color: white; border: none; width: 44px; height: 44px; border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s; }
    .btn-send:hover { background: var(--c-accent); }

    /* Utilities */
    .scroll-slim::-webkit-scrollbar { width: 6px; }
