---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import ReportMap from '../components/ReportMap.tsx';

// Load API URL from env or fallback
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Peta Laporan Warga — SovraEquitara">
  <div class="flex transition-colors duration-300">
    <Sidebar activePage="map" />

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto lg:ml-[280px] p-4 sm:p-6 pt-24 lg:pt-10 w-full min-h-screen pb-24 lg:pb-10">
      <div class="max-w-[1400px] mx-auto flex flex-col h-full lg:h-[calc(100vh-100px)] min-h-[700px]">
        
        <header class="flex flex-col xl:flex-row xl:justify-between xl:items-center mb-6 lg:mb-8 gap-4 animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]">
          <div>
            <h1 class="text-[28px] lg:text-[32px] font-extrabold tracking-tight m-0 text-zen-text dark:text-zen-text-dark">Peta <span class="bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">Laporan</span></h1>
            <p class="text-sm lg:text-base font-medium text-zen-muted dark:text-zen-muted-dark mt-1">
              Jelajahi laporan infrastruktur berdasarkan lokasi.
            </p>
          </div>
          <div class="flex flex-wrap items-center gap-2 sm:gap-3">
             <div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm font-bold text-zen-muted dark:text-zen-muted-dark bg-zen-surface dark:bg-zen-surface-dark px-2.5 sm:px-3 py-1.5 rounded-xl border border-zen-border dark:border-zen-border-dark">
               <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-blue-500"></span> Valid
             </div>
             <div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm font-bold text-zen-muted dark:text-zen-muted-dark bg-zen-surface dark:bg-zen-surface-dark px-2.5 sm:px-3 py-1.5 rounded-xl border border-zen-border dark:border-zen-border-dark">
               <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-amber-500"></span> Diproses
             </div>
             <div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm font-bold text-zen-muted dark:text-zen-muted-dark bg-zen-surface dark:bg-zen-surface-dark px-2.5 sm:px-3 py-1.5 rounded-xl border border-zen-border dark:border-zen-border-dark">
               <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-purple-500"></span> Menunggu
             </div>
             <div class="flex items-center gap-1.5 sm:gap-2 text-xs sm:text-sm font-bold text-zen-muted dark:text-zen-muted-dark bg-zen-surface dark:bg-zen-surface-dark px-2.5 sm:px-3 py-1.5 rounded-xl border border-zen-border dark:border-zen-border-dark">
               <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-emerald-500"></span> Selesai
             </div>
          </div>
        </header>

        <div class="flex-1 w-full relative min-h-[500px] h-[60vh] lg:h-auto">
          <ReportMap client:only="react" apiUrl={apiUrl} />
        </div>

      </div>
    </main>
  </div>

  <script is:inline>
    // Ensure auth validation and user init logic
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    }
  </script>
</Layout>
