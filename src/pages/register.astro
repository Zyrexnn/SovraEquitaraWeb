---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Daftar — SovraEquitara">
  <div class="fixed top-6 right-6 z-50">
    <ThemeToggle client:load />
  </div>

  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-8 bg-zen-bg dark:bg-zen-bg-dark transition-colors duration-300">
    <div class="w-full max-w-md animate-fade-in">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-20 sm:h-24 mx-auto mb-6 dark:brightness-0 dark:invert" />
        </a>
        <h1 class="text-3xl sm:text-4xl font-display font-bold mb-2 text-stone-900 dark:text-white">Buat Akun</h1>
        <p class="text-base text-stone-600 dark:text-gray-400 font-medium">Langkah pertama untuk kota yang lebih baik</p>
      </div>

      <!-- Form Card -->
      <div class="card shadow-xl dark:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
        <form id="form-register" class="space-y-5">
          <!-- Name -->
          <div>
            <label for="name" class="block text-sm font-bold text-stone-700 dark:text-gray-300 mb-2 uppercase tracking-widest">
              Nama Lengkap
            </label>
            <input
              type="text"
              id="name"
              placeholder="Masukkan nama lengkap"
              required
              class="input"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-bold text-stone-700 dark:text-gray-300 mb-2 uppercase tracking-widest">
              Email
            </label>
            <input
              type="email"
              id="email"
              placeholder="nama@email.com"
              required
              class="input"
            />
          </div>

          <!-- Password -->
          <div>
            <label for="password" class="block text-sm font-bold text-stone-700 dark:text-gray-300 mb-2 uppercase tracking-widest">
              Kata Sandi
            </label>
            <input
              type="password"
              id="password"
              placeholder="Minimal 6 karakter"
              required
              minlength="6"
              class="input"
            />
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="btn-submit"
            class="btn-primary w-full py-4 text-lg mt-4"
          >
            Daftar Sekarang
          </button>
        </form>

        <!-- Divider -->
        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-stone-200 dark:border-white/10"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase tracking-widest font-bold">
            <span class="bg-zen-card dark:bg-zen-card-dark px-4 text-zen-text-secondary dark:text-zen-text-secondary-dark rounded-full">Atau</span>
          </div>
        </div>

        <!-- Login Link -->
        <p class="text-center text-sm font-medium text-stone-600 dark:text-gray-400">
          Sudah punya akun?
          <a href="/login" class="text-stone-900 dark:text-white font-bold hover:underline ml-1">Masuk di sini</a>
        </p>
      </div>

      <!-- Footer Info -->
      <p class="text-center mt-12 text-xs font-bold text-stone-400 dark:text-gray-600 tracking-widest uppercase">
        &copy; 2026 SovraEquitara &bull; Aman & Transparan
      </p>
    </div>
  </main>

  <script>
    const API_URL = 'http://localhost:3000';
    const form = document.getElementById('form-register') as HTMLFormElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const name = (document.getElementById('name') as HTMLInputElement).value;
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      btnSubmit.disabled = true;
      btnSubmit.innerText = 'Memproses...';

      try {
        const res = await fetch(`${API_URL}/api/auth/register`, {
          method: 'POST',
          headers:   { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, password })
        });

        const data = await res.json();

        if (res.ok) {
          alert('Pendaftaran berhasil! Silakan masuk ke akun Anda.');
          window.location.href = '/login';
        } else {
          alert(data.message || 'Pendaftaran gagal. Email mungkin sudah terdaftar.');
        }
      } catch (err) {
        console.error('Register error:', err);
        alert('Terjadi kesalahan koneksi. Pastikan server backend berjalan.');
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Daftar Sekarang';
      }
    });
  </script>
</Layout>
