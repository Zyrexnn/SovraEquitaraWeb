---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lupa Password — SovraEquitara">
  <main class="min-h-screen flex items-center justify-center bg-zen-bg dark:bg-zen-bg-dark p-6 md:p-8">
    <div class="w-full max-w-[440px] animate-up">
      <header class="text-center mb-10">
        <div class="w-[280px] mx-auto mb-10 flex items-center justify-center">
          <img src="/logo.svg" alt="Sovra" class="w-full h-auto object-contain dark:brightness-0 dark:invert" />
        </div>
        <h1 class="text-[32px] font-extrabold text-zen-text dark:text-zen-text-dark mb-2">Lupa Password</h1>
        <p class="text-[15px] text-zen-text-secondary dark:text-zen-text-secondary-dark font-medium">Masukkan email Anda untuk menerima kode OTP reset password.</p>
      </header>

      <div class="p-8 md:p-10 rounded-3xl bg-zen-card dark:bg-zen-card-dark shadow-zen border border-zen-border dark:border-zen-border-dark">
        <form id="form-forgot" class="flex flex-col gap-6">
          <div class="flex flex-col gap-2">
            <label for="email" class="text-[13px] font-extrabold text-zen-text dark:text-zen-text-dark">Alamat Email Terdaftar</label>
            <div>
              <input type="email" id="email" placeholder="nama@email.com" required class="w-full !bg-zen-bg dark:!bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark rounded-2xl p-4 px-5 text-zen-text dark:text-zen-text-dark font-display text-[15px] transition-all duration-300 outline-none focus:border-blue-500 focus:ring-4 focus:ring-black/5 dark:focus:ring-white/5 appearance-none" />
            </div>
          </div>

          <button type="submit" class="w-full bg-zen-text dark:bg-zen-text-dark text-zen-bg dark:text-zen-bg-dark border-none rounded-2xl py-4 font-extrabold text-base cursor-pointer transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed" id="btn-submit">
            Kirim Kode OTP
          </button>
        </form>
        
        <div class="text-center mt-6">
          <a href="/login" class="text-blue-500 font-extrabold no-underline border-b-2 border-blue-500/30 pb-0.5 transition-colors hover:border-blue-500">Kembali ke Login</a>
        </div>
      </div>
    </div>
    </main>
    </Layout>

    <script>
    import { showToast } from '../lib/toast';
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';

    document.getElementById('form-forgot').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-submit') as HTMLButtonElement;
    const email = (document.getElementById('email') as HTMLInputElement).value;

    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Memproses...';
    }

    try {
      const res = await fetch(`${API_URL}/api/auth/forgot-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      if (res.ok) {
        showToast({ message: 'Kode OTP telah dikirim!', type: 'success' });
        setTimeout(() => {
          window.location.href = `/reset-password?email=${email}`;
        }, 1500);
      } else {
        const data = await res.json();
        showToast({ message: data.error || 'Email tidak ditemukan', type: 'error' });
      }
    } catch (err) {
      showToast({ message: 'Kesalahan koneksi', type: 'error' });
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Kirim Kode OTP';
      }
    }
    });
    </script>

