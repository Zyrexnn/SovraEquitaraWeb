---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Chat Admin — SovraEquitara">
  <script is:inline define:vars={{ API_URL }}>
    window.API_URL = API_URL;
  </script>

  <div class="flex transition-colors duration-300 min-h-screen" id="chat-root" data-api-url={API_URL}>
    <Sidebar activePage="chat" />

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto lg:ml-[280px] p-6 pt-24 lg:pt-10 max-w-[1200px] w-full mx-auto pb-24 lg:pb-10">
      <header class="mb-8">
        <h1 class="text-[28px] lg:text-[32px] font-extrabold tracking-tight">Chat <span class="bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">Admin</span></h1>
        <p class="text-sm font-semibold text-zen-muted dark:text-zen-muted-dark mt-1">Kirim pesan langsung ke Admin.</p>
      </header>

      <!-- Chat Window -->
      <div class="rounded-[2rem] border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark shadow-sm overflow-hidden flex flex-col min-h-[500px] h-[75vh]">
        <!-- Header -->
        <div class="px-6 py-5 border-b border-zen-border dark:border-zen-border-dark flex items-center gap-4 bg-white/50 dark:bg-zen-bg-dark/50 backdrop-blur-md">
          <div id="chat-header-avatar" class="w-12 h-12 rounded-[1rem] overflow-hidden bg-brand dark:bg-white text-white dark:text-brand flex items-center justify-center font-black text-base shadow-sm">AD</div>
          <div>
            <div id="chat-header-name" class="font-extrabold text-base text-zen-text dark:text-zen-text-dark">Admin</div>
            <div id="chat-header-role" class="text-[11px] font-bold text-emerald-500 flex items-center gap-1.5 mt-0.5 tracking-wide uppercase"><span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span> Online</div>
          </div>
        </div>

        <!-- Messages Area -->
        <div id="chat-messages" class="flex-1 p-6 overflow-y-auto space-y-6 scrollbar-hide bg-stone-50/50 dark:bg-[#151515]">
          <div class="flex items-center justify-center h-32 text-zen-muted dark:text-zen-muted-dark font-bold text-sm">Memuat pesan...</div>
        </div>

        <!-- Input Area -->
        <div class="p-4 sm:p-6 bg-white dark:bg-zen-card-dark border-t border-zen-border dark:border-zen-border-dark">
          <form id="chat-form" class="flex items-end gap-3 relative">
            <div class="flex-1 relative">
              <textarea id="chat-input" rows="1" placeholder="Tulis pesan ke Admin..." class="w-full pl-5 pr-14 py-3.5 bg-stone-100 dark:bg-stone-900 border-none rounded-[1.25rem] text-sm font-semibold outline-none focus:ring-2 focus:ring-brand/30 dark:focus:ring-white/20 resize-none min-h-[52px] max-h-32 text-zen-text dark:text-zen-text-dark scrollbar-hide transition-all"></textarea>
              <button type="submit" class="absolute right-2 bottom-2 p-2.5 bg-brand dark:bg-white text-white dark:text-brand rounded-xl hover:scale-105 transition-transform shadow-md cursor-pointer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
              </button>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>

  <script>
    import { showToast } from '../lib/toast';
    
    let pollInterval = null;

    function init() {
      const root = document.getElementById("chat-root");
      if (!root) return;
      
      const API_URL = root.dataset.apiUrl || "http://localhost:3000";
      const token = localStorage.getItem('access_token');
      const userRaw = localStorage.getItem('user');
      if (!token || !userRaw) { 
        window.location.href = '/login'; 
        return;
      }
      
      const user = JSON.parse(userRaw);
      
      setupEvents(API_URL, token);
      loadMessages(API_URL, token, user, false);
      
      if (pollInterval) clearInterval(pollInterval);
      pollInterval = setInterval(() => loadMessages(API_URL, token, user, true), 4000);
    }

    async function loadMessages(API_URL, token, user, silent) {
      const container = document.getElementById('chat-messages');
      if (!container) return;
      try {
        const res = await fetch(`${API_URL}/api/chat/messages`, { headers: { 'Authorization': `Bearer ${token}` } });
        const json = await res.json();
        const messages = json.data || [];

        if (messages.length === 0) {
          container.innerHTML = '<div class="flex flex-col items-center justify-center h-full gap-3 text-center"><div class="flex justify-center mb-2"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-stone-300 dark:text-stone-700"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></div><p class="text-zen-muted font-bold text-sm">Belum ada pesan. Mulai percakapan!</p></div>';
          return;
        }

        const lastAdminMsg = [...messages].reverse().find(m => m.sender_id !== user.id);
        if (lastAdminMsg && lastAdminMsg.sender) {
          const adminName = lastAdminMsg.sender.full_name || 'Admin';
          const headerName = document.getElementById('chat-header-name');
          const headerAvatar = document.getElementById('chat-header-avatar');
          
          if (headerName) {
            const role = lastAdminMsg.sender.role;
            const badgeHtml = role === 'super_admin' ? `<svg class="inline-block ml-1.5 w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : (role === 'admin' ? `<svg class="inline-block ml-1.5 w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : '');
            headerName.innerHTML = `<span class="flex items-center">${adminName}${badgeHtml}</span>`;
          }
          
          if (headerAvatar) {
            if (lastAdminMsg.sender.avatar_url) {
              const url = lastAdminMsg.sender.avatar_url.startsWith('http') ? lastAdminMsg.sender.avatar_url : API_URL + lastAdminMsg.sender.avatar_url;
              headerAvatar.innerHTML = `<img src="${url}" class="w-full h-full object-cover" />`;
            } else {
              headerAvatar.innerHTML = adminName[0].toUpperCase();
            }
          }
        }

        container.innerHTML = messages.map(function(m) {
          var isMine = m.sender_id === user.id;
          var senderName = m.sender?.full_name || 'Unknown';
          var time = new Date(m.created_at).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
          var initial = senderName[0].toUpperCase();
          var avatarHtml = m.sender?.avatar_url ? `<img src="${m.sender.avatar_url.startsWith('http') ? m.sender.avatar_url : API_URL + m.sender.avatar_url}" class="w-full h-full object-cover rounded-full" />` : initial;
          const isAdmin = m.sender?.role === 'admin' || m.sender?.role === 'super_admin';
          const badgeHtml = m.sender?.role === 'super_admin' ? `<svg class="inline-block ml-1 w-3.5 h-3.5 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : (m.sender?.role === 'admin' ? `<svg class="inline-block ml-1 w-3.5 h-3.5 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : '');
          
          return '<div class="flex gap-3.5 max-w-[85%] ' + (isMine ? 'self-end flex-row-reverse ml-auto' : '') + '">' +
            '<div class="w-9 h-9 rounded-full ' + (isMine ? 'bg-brand text-white dark:text-zen-bg' : 'bg-stone-200 dark:bg-stone-800 text-stone-700 dark:text-stone-300') + ' flex items-center justify-center font-black text-xs shrink-0 overflow-hidden shadow-sm border border-black/5 dark:border-white/5">' + avatarHtml + '</div>' +
            '<div class="flex flex-col">' +
            '<div class="flex items-center gap-2 mb-1.5 ' + (isMine ? 'flex-row-reverse' : '') + '"><span class="text-[11px] font-bold text-zen-muted flex items-center">' + senderName + badgeHtml + '</span><span class="text-[10px] font-semibold text-stone-400 dark:text-stone-500">' + time + '</span></div>' +
            '<div class="px-4 py-3 text-sm font-medium leading-relaxed ' + (isMine ? 'bg-gradient-to-br from-blue-500 to-blue-600 dark:from-white dark:to-stone-200 text-white dark:text-black rounded-[1.25rem] rounded-tr-sm shadow-sm' : 'bg-white dark:bg-stone-800 text-stone-800 dark:text-stone-100 rounded-[1.25rem] rounded-tl-sm border border-stone-200/50 dark:border-white/5 shadow-sm') + '">' + m.content + '</div>' +
            '</div></div>';
        }).join('');

        if (!silent) container.scrollTo({ top: container.scrollHeight, behavior: 'smooth' });
      } catch(e) { console.error(e); }
    }

    function setupEvents(API_URL, token) {
      const chatForm = document.getElementById('chat-form');
      if (chatForm) {
        chatForm.onsubmit = async function(e) {
          e.preventDefault();
          var input = document.getElementById('chat-input');
          var val = input.value.trim();
          if (!val) return;

          try {
            var res = await fetch(API_URL + '/api/chat/send', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
              body: JSON.stringify({ content: val })
            });
            if (res.ok) { 
              input.value = ''; 
              const userRaw = localStorage.getItem('user');
              if (userRaw) await loadMessages(API_URL, token, JSON.parse(userRaw), false); 
            }
            else { showToast('Gagal mengirim pesan', 'error'); }
          } catch(e) { showToast('Koneksi gagal', 'error'); }
        };
      }

      const chatInput = document.getElementById('chat-input');
      if (chatInput) {
        chatInput.oninput = function() {
          this.style.height = 'auto';
          this.style.height = this.scrollHeight + 'px';
        };
        chatInput.onkeydown = function(e) {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            chatForm?.dispatchEvent(new Event("submit"));
          }
        };
      }
    }

    document.addEventListener('astro:page-load', init);
    if (document.readyState === 'complete') init();
  </script>
</Layout>
