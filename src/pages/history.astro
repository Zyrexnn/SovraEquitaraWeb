---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Riwayat Laporan — SovraEquitara">
  <div class="flex h-screen overflow-hidden bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark font-display">
    <!-- Desktop Sidebar -->
    <aside class="hidden md:flex w-[280px] bg-zen-card dark:bg-zen-card-dark border-r border-zen-border dark:border-zen-border-dark flex-col z-[100]">
      <div class="p-8 pb-6">
        <div class="flex items-center gap-3">
          <img src="/logo.svg" alt="SovraEquitara" class="h-12 w-auto dark:brightness-0 dark:invert" />
        </div>
      </div>
      
      <nav class="flex-1 px-4 flex flex-col gap-1">
        <div class="text-[11px] font-bold text-zen-text-secondary dark:text-zen-text-secondary-dark px-3 py-4 tracking-wider">MENU UTAMA</div>
        <a href="/dashboard" class="flex items-center gap-3 p-3 rounded-xl text-zen-text-secondary dark:text-zen-text-secondary-dark hover:bg-zen-bg hover:text-zen-text dark:hover:bg-zen-bg-dark dark:hover:text-zen-text-dark font-semibold text-sm transition-colors no-underline">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          Dashboard
        </a>
        <a href="/history" class="flex items-center gap-3 p-3 rounded-xl text-blue-500 bg-blue-50 dark:bg-blue-500/10 font-bold text-sm transition-colors no-underline">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Riwayat Laporan
        </a>
        <a href="/profile" class="flex items-center gap-3 p-3 rounded-xl text-zen-text-secondary dark:text-zen-text-secondary-dark hover:bg-zen-bg hover:text-zen-text dark:hover:bg-zen-bg-dark dark:hover:text-zen-text-dark font-semibold text-sm transition-colors no-underline">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          Profil Saya
        </a>
      </nav>

      <div class="p-6 border-t border-zen-border dark:border-zen-border-dark">
        <div class="flex items-center gap-3 mb-4 px-2">
          <div class="w-10 h-10 rounded-full bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark flex items-center justify-center font-bold" id="sidebar-avatar">U</div>
          <div class="flex flex-col">
            <span class="font-semibold text-sm" id="sidebar-name">Warga</span>
            <span class="text-xs font-bold text-blue-500" id="sidebar-points">0 PTS</span>
          </div>
        </div>
        <button id="btn-logout-desktop" class="w-full flex items-center justify-center gap-2 p-2.5 bg-transparent border border-zen-border dark:border-zen-border-dark rounded-xl text-red-500 font-semibold cursor-pointer transition-colors hover:bg-red-50 hover:border-red-200 dark:hover:bg-red-500/10 dark:hover:border-red-500/30">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Keluar
        </button>
      </div>
    </aside>

    <!-- Mobile Top Bar -->
    <header class="md:hidden flex justify-between items-center p-4 px-5 bg-zen-card dark:bg-zen-card-dark border-b border-zen-border dark:border-zen-border-dark sticky top-0 z-[90]">
      <div class="flex items-center">
        <img src="/logo.svg" alt="SovraEquitara" class="h-8 w-auto dark:brightness-0 dark:invert" />
      </div>
      <div class="flex items-center gap-3">
        <span class="bg-blue-50 text-blue-500 dark:bg-blue-500/10 px-2.5 py-1 rounded-full text-xs font-bold" id="mobile-points">0 PTS</span>
        <div class="w-8 h-8 bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark rounded-full flex items-center justify-center font-bold text-xs" id="mobile-avatar">U</div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto bg-zen-bg dark:bg-zen-bg-dark pb-20 md:pb-0 scroll-smooth">
      <div class="max-w-[1200px] mx-auto p-6 md:p-10 lg:p-12">
        
        <!-- Welcome Section -->
        <section class="mb-8 animate-up">
          <div class="flex flex-col md:flex-row md:justify-between md:items-end gap-5">
            <div>
              <h1 id="greeting" class="text-[28px] font-extrabold tracking-tight mb-2">Riwayat Laporan</h1>
              <p class="text-zen-text-secondary dark:text-zen-text-secondary-dark text-[15px]">Pantau status laporan yang pernah Anda ajukan.</p>
            </div>
            <div class="flex gap-4">
              <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark p-3 px-5 rounded-xl flex flex-col min-w-[120px] shadow-zen">
                <span class="text-[11px] font-bold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase">Total</span>
                <span class="text-2xl font-extrabold leading-tight text-zen-text dark:text-zen-text-dark" id="stat-total">0</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Table View -->
        <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark rounded-3xl shadow-zen overflow-hidden flex flex-col max-h-[800px] mt-6 animate-up" style="animation-delay: 0.1s;">
          <div class="hidden md:flex p-4 px-6 bg-zen-bg dark:bg-zen-bg-dark border-b border-zen-border dark:border-zen-border-dark text-xs font-bold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase tracking-wide">
            <div class="flex-[2]">Deskripsi & Lokasi</div>
            <div class="flex-1">Kategori</div>
            <div class="flex-1">Status</div>
            <div class="w-[140px] text-right">Tanggal</div>
          </div>
          
          <div class="flex-1 overflow-y-auto" id="history-list">
            <div class="flex flex-col items-center justify-center p-10 gap-3 text-[13px] text-zen-text-secondary dark:text-zen-text-secondary-dark">
              <div class="w-6 h-6 border-4 border-zen-border dark:border-zen-border-dark border-t-blue-500 rounded-full animate-spin"></div>
              <p>Mengambil riwayat...</p>
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="md:hidden flex justify-around items-center fixed bottom-0 left-0 right-0 h-16 bg-zen-card dark:bg-zen-card-dark border-t border-zen-border dark:border-zen-border-dark z-[100] pb-safe">
      <a href="/dashboard" class="p-2 px-6 text-zen-text-secondary dark:text-zen-text-secondary-dark rounded-xl">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
      </a>
      <a href="/history" class="p-2 px-6 text-blue-500 bg-zen-bg dark:bg-zen-bg-dark rounded-xl">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <a href="/profile" class="p-2 px-6 text-zen-text-secondary dark:text-zen-text-secondary-dark rounded-xl">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
    </nav>

    <!-- Detail Modal -->
    <div id="detail-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[999] hidden items-center justify-center p-5">
      <div class="bg-zen-card dark:bg-zen-card-dark w-full max-w-[900px] rounded-3xl flex flex-col max-h-[90vh] overflow-hidden shadow-2xl">
        <div class="p-5 px-6 border-b border-zen-border dark:border-zen-border-dark flex justify-between items-center">
          <h3 class="text-lg font-bold m-0 text-zen-text dark:text-zen-text-dark">Detail Laporan</h3>
          <button id="close-detail" class="bg-transparent border-none text-2xl leading-none text-zen-text-secondary dark:text-zen-text-secondary-dark cursor-pointer p-0 hover:text-zen-text dark:hover:text-zen-text-dark">&times;</button>
        </div>
        <div class="flex-1 overflow-hidden p-0">
          <div class="flex flex-col md:flex-row h-full">
            <div class="flex-1 p-6 border-b md:border-b-0 md:border-r border-zen-border dark:border-zen-border-dark overflow-y-auto md:w-[60%]">
              <div id="detail-img-container" class="w-full h-[240px] rounded-xl overflow-hidden mb-5 bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark hidden">
                <img id="detail-img" src="" alt="Bukti Foto" onclick="window.openImg(this.src)" class="w-full h-full object-cover cursor-pointer" />
              </div>
              <div class="">
                <div class="flex items-center gap-2 mb-3">
                  <span id="detail-cat" class="text-[11px] font-bold bg-zen-bg dark:bg-zen-bg-dark px-2 py-1 rounded text-zen-text dark:text-zen-text-dark border border-zen-border dark:border-zen-border-dark"></span>
                  <span id="detail-status" class="text-[10px] font-extrabold px-3 py-1.5 rounded-md uppercase"></span>
                  <span id="detail-date" class="text-[13px] font-medium text-zen-text-secondary dark:text-zen-text-secondary-dark ml-auto"></span>
                </div>
                <h2 id="detail-desc" class="text-xl font-bold mb-3 leading-snug text-zen-text dark:text-zen-text-dark"></h2>
                <div class="text-sm text-zen-text-secondary dark:text-zen-text-secondary-dark mb-5 p-3 bg-zen-bg dark:bg-zen-bg-dark rounded-xl">📍 <span id="detail-loc"></span></div>
                
                <div class="flex gap-3 mt-4">
                  <div class="text-[13px] font-semibold px-4 py-2 bg-zen-bg dark:bg-zen-bg-dark rounded-xl border border-zen-border dark:border-zen-border-dark text-zen-text dark:text-zen-text-dark">🔥 <span id="detail-votes">0</span> Dukungan</div>
                  <div class="text-[13px] font-semibold px-4 py-2 bg-zen-bg dark:bg-zen-bg-dark rounded-xl border border-zen-border dark:border-zen-border-dark text-zen-text dark:text-zen-text-dark">💬 <span id="detail-comment-count">0</span> Diskusi</div>
                </div>
              </div>
            </div>
            
            <div class="flex-1 flex flex-col bg-zen-bg dark:bg-zen-bg-dark md:w-[40%]">
              <h4 class="p-5 px-6 m-0 text-[15px] border-b border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark text-zen-text dark:text-zen-text-dark">Diskusi</h4>
              <div id="comments-list" class="flex-1 overflow-y-auto p-5 px-6 flex flex-col gap-4">
                <!-- Comments -->
              </div>
              <div class="p-4 px-6 border-t border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark">
                <form id="form-comment" class="flex gap-3">
                  <input type="hidden" id="comment-report-id" />
                  <input type="text" id="comment-input" placeholder="Balas atau diskusi..." required autocomplete="off" class="flex-1 p-3 px-4 border border-zen-border dark:border-zen-border-dark rounded-xl text-sm outline-none bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark focus:border-blue-500" />
                  <button type="submit" class="bg-zen-text dark:bg-zen-text-dark text-zen-bg dark:text-zen-bg-dark border-none w-11 h-11 rounded-xl flex items-center justify-center cursor-pointer transition-colors hover:bg-zen-text-secondary disabled:opacity-50">
                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[10000] hidden items-center justify-center p-5">
      <div class="relative max-w-full max-h-full">
        <button id="lightbox-close" class="absolute -top-10 right-0 bg-transparent border-none text-3xl leading-none text-white cursor-pointer p-0 hover:text-gray-300">&times;</button>
        <img id="lightbox-img" src="" alt="Full view" class="max-w-full max-h-[85vh] rounded-xl shadow-2xl" />
      </div>
    </div>

  </div>

  <!-- JavaScript Logic -->
  <script is:inline>
    const API_URL = 'http://localhost:3000';
    
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('DOMContentLoaded', initHistory);
    }

    let user, categories = [];
    let allReportsList = [];

    function initHistory() {
      try {
        user = JSON.parse(userRaw);
        const initial = (user.name || 'U')[0].toUpperCase();
        
        document.getElementById('sidebar-name').textContent = user.name;
        document.getElementById('sidebar-avatar').textContent = initial;
        document.getElementById('mobile-avatar').textContent = initial;
        document.getElementById('sidebar-points').textContent = `${user.points || 0} PTS`;
        document.getElementById('mobile-points').textContent = `${user.points || 0} PTS`;

        loadCategories().then(() => fetchHistory());

        document.getElementById('close-detail').addEventListener('click', () => document.getElementById('detail-modal').classList.add('hidden'));
        document.getElementById('lightbox-close').addEventListener('click', () => document.getElementById('lightbox').classList.add('hidden'));
        document.getElementById('form-comment').addEventListener('submit', handleCommentSubmit);

        const doLogout = () => { localStorage.clear(); window.location.href = '/login'; };
        document.getElementById('btn-logout-desktop').addEventListener('click', doLogout);
        document.getElementById('btn-logout-mobile2').addEventListener('click', doLogout);

      } catch(e) {
        console.error("History Init Error: ", e);
      }
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
      } catch (err) { 
        console.error("Categories Error", err); 
        categories = [
          {id: 1, name: 'Infrastruktur'},
          {id: 2, name: 'Lingkungan'},
          {id: 3, name: 'Fasilitas Umum'},
          {id: 4, name: 'Keamanan'}
        ];
      }
    }

    function getCategoryName(id) {
      if(!id) return 'Umum';
      const cat = categories.find(c => c.id === id);
      return cat ? cat.name : 'Umum';
    }

    async function fetchHistory() {
      const list = document.getElementById('history-list');
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        allReportsList = data.data || [];
        
        document.getElementById('stat-total').textContent = allReportsList.length;
        renderHistory(allReportsList);
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat riwayat.</div>';
      }
    }

    function renderHistory(items) {
      const list = document.getElementById('history-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="text-center p-10 text-zen-text-secondary dark:text-zen-text-secondary-dark text-sm font-medium">Belum ada riwayat laporan yang diajukan.</div>';
        return;
      }
      
      list.innerHTML = items.map(r => {
        const catName = getCategoryName(r.category_id);
        const statusClass = r.status.toLowerCase();

        let statusStyles = "";
        if (statusClass === "pending") statusStyles = "bg-red-50 text-red-500 dark:bg-red-500/10 dark:text-red-400";
        else if (statusClass === "valid") statusStyles = "bg-yellow-50 text-yellow-600 dark:bg-yellow-500/10 dark:text-yellow-500";
        else if (statusClass === "resolved") statusStyles = "bg-green-50 text-green-500 dark:bg-green-500/10 dark:text-green-400";

        return `
          <div class="flex flex-col md:flex-row p-4 md:p-5 px-4 md:px-6 border-b border-zen-border dark:border-zen-border-dark md:items-center gap-4 transition-colors hover:bg-zen-bg dark:hover:bg-zen-bg-dark cursor-pointer last:border-0" onclick="window.openDetail('${r.id}')">
            <div class="flex-[2] flex gap-4 items-center">
              <div>
                <h4 class="text-[15px] font-semibold mb-1 leading-snug text-zen-text dark:text-zen-text-dark">${r.description}</h4>
                <p class="text-[13px] text-zen-text-secondary dark:text-zen-text-secondary-dark">📍 ${r.location_detail}</p>
                <div class="md:hidden mt-2">
                  <span class="text-[11px] font-bold bg-zen-bg dark:bg-zen-bg-dark px-2 py-1 rounded text-zen-text dark:text-zen-text-dark border border-zen-border dark:border-zen-border-dark inline-block">${catName}</span>
                  <span class="text-[10px] font-extrabold px-3 py-1.5 rounded-md uppercase inline-block mt-1 ${statusStyles}">${r.status}</span>
                  <div class="text-xs text-zen-text-secondary dark:text-zen-text-secondary-dark mt-2">${new Date(r.created_at).toLocaleDateString('id-ID')}</div>
                </div>
              </div>
            </div>
            <div class="flex-1 hidden md:block"><span class="text-[11px] font-bold bg-zen-bg dark:bg-zen-bg-dark px-2 py-1 rounded text-zen-text dark:text-zen-text-dark border border-zen-border dark:border-zen-border-dark inline-block">${catName}</span></div>
            <div class="flex-1 hidden md:block">
              <span class="text-[10px] font-extrabold px-3 py-1.5 rounded-md uppercase inline-block ${statusStyles}">${r.status}</span>
            </div>
            <div class="w-[140px] text-right hidden md:block">
              <span class="text-[13px] font-medium text-zen-text-secondary dark:text-zen-text-secondary-dark">${new Date(r.created_at).toLocaleDateString('id-ID')}</span>
            </div>
          </div>
        `;
      }).join('');
    }

    window.openDetail = (id) => {
      const r = allReportsList.find(x => x.id === id);
      if(!r) return;

      document.getElementById('comment-report-id').value = id;

      if(r.image_url) {
        document.getElementById('detail-img').src = API_URL + r.image_url;
        document.getElementById('detail-img-container').classList.remove('hidden');
      } else {
        document.getElementById('detail-img-container').classList.add('hidden');
      }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = getCategoryName(r.category_id);
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      
      const st = document.getElementById('detail-status');
      st.textContent = r.status;
      const statusClass = r.status.toLowerCase();
      let statusStyles = "";
      if (statusClass === "pending") statusStyles = "bg-red-50 text-red-500 dark:bg-red-500/10 dark:text-red-400";
      else if (statusClass === "valid") statusStyles = "bg-yellow-50 text-yellow-600 dark:bg-yellow-500/10 dark:text-yellow-500";
      else if (statusClass === "resolved") statusStyles = "bg-green-50 text-green-500 dark:bg-green-500/10 dark:text-green-400";
      st.className = `text-[10px] font-extrabold px-3 py-1.5 rounded-md uppercase inline-block ${statusStyles}`;

      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('detail-comment-count').textContent = r.comment_count;

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openImg = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    async function loadComments(id) {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="feed-loading"><div class="spinner"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const comments = data.data || [];
        if(comments.length === 0) {
          list.innerHTML = '<div class="text-center p-10 text-zen-text-secondary dark:text-zen-text-secondary-dark text-sm font-medium">Belum ada diskusi.</div>';
          return;
        }
        list.innerHTML = comments.map(c => `
          <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark p-3 px-4 rounded-2xl rounded-tr-none shadow-sm">
            <div class="flex justify-between mb-1 text-xs">
              <strong class="text-zen-text dark:text-zen-text-dark">${c.user?.full_name || (c.user?.role === 'admin' ? 'Admin' : 'Warga')}</strong> 
              <span class="text-zen-text-secondary dark:text-zen-text-secondary-dark">${new Date(c.created_at).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'})}</span>
            </div>
            <div class="text-sm text-zen-text dark:text-zen-text-dark leading-relaxed">${c.content}</div>
          </div>
        `).join('');
        list.scrollTop = list.scrollHeight;
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat diskusi.</div>';
      }
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('comment-report-id').value;
      const input = document.getElementById('comment-input');
      if(!input.value.trim() || !id) return;

      const btn = e.target.querySelector('.btn-send');
      btn.disabled = true;
      
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) {
          input.value = '';
          loadComments(id);
          const currentCount = parseInt(document.getElementById('detail-comment-count').textContent || "0");
          document.getElementById('detail-comment-count').textContent = currentCount + 1;
        }
      } catch(err) {}
      btn.disabled = false;
    }
  </script>


</Layout>