---
import Layout from '../layouts/Layout.astro';
import '../styles/dashboard-shared.css';
---

<Layout title="Riwayat Laporan — SovraEquitara">
  <div class="app-container">
    <!-- Desktop Sidebar -->
    <aside class="desktop-sidebar">
      <div class="sidebar-brand">
        <img src="/logo.svg" alt="Sovra" class="brand-img" />
      </div>
      <nav class="sidebar-nav-v2">
        <a href="/dashboard" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
          <span>Dashboard</span>
        </a>
        <a href="/profile" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          <span>Profil Saya</span>
        </a>
        <a href="/history" class="side-item active">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
          <span>Riwayat</span>
        </a>
      </nav>
      <div class="sidebar-bottom">
        <button id="btn-logout-desktop" class="side-item logout">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
          <span>Keluar</span>
        </button>
      </div>
    </aside>

    <!-- Mobile Nav -->
    <nav class="mobile-nav">
      <a href="/dashboard" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
      </a>
      <a href="/profile" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <a href="/history" class="mob-item active">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <button id="btn-logout-mobile" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
      </button>
    </nav>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <header class="app-header">
        <div class="header-left">
          <div class="mobile-logo-only">
            <img src="/logo.svg" alt="Sovra" />
          </div>
          <div class="desktop-breadcrumb">
            <span class="crumb">App</span> / <span class="crumb active">Riwayat Laporan</span>
          </div>
        </div>
      </header>

      <div class="content-inner fade-in">
        <section class="history-hero">
          <h1>Riwayat Laporan Anda</h1>
          <p>Daftar lengkap kontribusi infrastruktur yang telah Anda ajukan.</p>
        </section>

        <div class="card-zen list-wrapper-v2">
          <div class="table-header-v2">
            <div class="th-col">Laporan</div>
            <div class="th-col d-hide">Lokasi</div>
            <div class="th-col d-hide">Status</div>
            <div class="th-col t-right">Tanggal</div>
          </div>
          <div id="history-list">
            <div class="loading-state">Memuat data riwayat...</div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');

    if (!token) window.location.href = '/login';

    async function fetchHistory() {
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        renderHistory(data.data || []);
      } catch (err) { console.error('Gagal ambil riwayat'); }
    }

    function renderHistory(items) {
      const list = document.getElementById('history-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="empty-msg">Belum ada riwayat laporan.</div>';
        return;
      }
      list.innerHTML = items.map(r => `
        <div class="history-row-v2">
          <div class="row-main">
            <div class="r-info">
              <span class="r-title">${r.description}</span>
              <span class="r-meta m-show">${r.location_detail} • ${r.status}</span>
            </div>
            <div class="r-loc d-hide">${r.location_detail}</div>
            <div class="r-status d-hide">
              <span class="a-pill ${r.status.toLowerCase()}">${r.status}</span>
            </div>
            <div class="r-date t-right">
              ${new Date(r.created_at).toLocaleDateString('id-ID')}
            </div>
          </div>
        </div>
      `).join('');
    }

    const logout = () => { localStorage.clear(); window.location.href = '/login'; };
    document.getElementById('btn-logout-desktop').onclick = logout;
    document.getElementById('btn-logout-mobile').onclick = logout;

    fetchHistory();
  </script>
</Layout>

<style>
  /* History Specific */
  .history-hero { margin-bottom: 40px; }
  .history-hero h1 { font-size: 32px; font-weight: 900; margin-bottom: 8px; }
  .history-hero p { color: var(--color-saas-text-muted); }

  .table-header-v2 { display: flex; padding: 16px 24px; background: #F9FAFB; border-bottom: 1px solid var(--color-saas-border); }
  .th-col { flex: 1; font-size: 12px; font-weight: 800; color: var(--color-saas-text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
  .t-right { text-align: right; }

  .history-row-v2 { border-bottom: 1px solid var(--color-saas-border); transition: 0.2s; }
  .history-row-v2:hover { background: #F9FAFB; }
  .row-main { display: flex; align-items: center; padding: 24px; }
  
  .r-info { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .r-title { font-weight: 700; color: #111827; font-size: 16px; }
  .r-meta { font-size: 13px; color: var(--color-saas-text-muted); }
  
  .r-loc { flex: 1; font-size: 14px; color: var(--color-saas-text-main); }
  .r-status { flex: 1; }
  .r-date { flex: 1; font-size: 14px; color: var(--color-saas-text-muted); font-weight: 600; }

  .a-pill { font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; }
  .a-pill.pending { background: #FEE2E2; color: #EF4444; }
  .a-pill.resolved { background: #D1FAE5; color: #10B981; }

  .m-show { display: none; }
  @media (max-width: 767px) {
    .d-hide { display: none; }
    .m-show { display: block; }
    .row-main { padding: 16px; }
    .r-date { text-align: left; margin-top: 8px; font-size: 12px; }
  }

  /* Shared Sidebar overrides */
  .sidebar-brand { margin-bottom: 48px; padding: 0 12px; }
  .brand-img { height: 48px; width: auto; filter: invert(1); }
  .sidebar-nav-v2 { display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .side-item { display: flex; align-items: center; gap: 16px; padding: 14px 20px; border-radius: 14px; color: rgba(255,255,255,0.6); text-decoration: none; font-weight: 600; font-size: 15px; transition: 0.2s; }
  .side-item:hover { background: rgba(255,255,255,0.05); color: white; }
  .side-item.active { background: var(--color-saas-accent); color: #111827; }
  .side-item.logout { color: #F87171; margin-top: auto; }
  .s-icon { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; }
  .mob-item { color: var(--color-saas-text-muted); padding: 12px; border-radius: 12px; }
  .mob-item.active { color: #111827; background: #F9FAFB; }
  .m-icon { width: 24px; height: 24px; stroke: currentColor; fill: none; stroke-width: 2.5; }
  .mobile-logo-only { display: none; }
  @media (max-width: 767px) { .mobile-logo-only { display: block; height: 32px; } .mobile-logo-only img { height: 100%; } }
</style>
