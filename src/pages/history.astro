---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Riwayat Laporan — SovraEquitara">
  <div class="saas-layout">
    <!-- Desktop Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <img src="/logo.svg" alt="SovraEquitara" style="height: 48px; width: auto;" />
        </div>
      </div>
      
      <nav class="nav-menu">
        <div class="nav-section">MENU UTAMA</div>
        <a href="/dashboard" class="nav-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
          Dashboard
        </a>
        <a href="/history" class="nav-item active">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
          Riwayat Laporan
        </a>
        <a href="/profile" class="nav-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          Profil Saya
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="user-profile">
          <div class="avatar" id="sidebar-avatar">U</div>
          <div class="user-info">
            <span class="user-name" id="sidebar-name">Warga</span>
            <span class="user-points" id="sidebar-points">0 PTS</span>
          </div>
        </div>
        <button id="btn-logout-desktop" class="btn-logout">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Keluar
        </button>
      </div>
    </aside>

    <!-- Mobile Top Bar -->
    <header class="mobile-header">
      <div class="logo">
        <img src="/logo.svg" alt="SovraEquitara" style="height: 32px; width: auto;" />
      </div>
      <div class="user-profile-mobile">
        <span class="points-badge" id="mobile-points">0 PTS</span>
        <div class="avatar-small" id="mobile-avatar">U</div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <div class="content-wrapper">
        
        <!-- Welcome Section -->
        <section class="welcome-section fade-in">
          <div class="hero-flex">
            <div>
              <h1 id="greeting">Riwayat Laporan</h1>
              <p class="subtitle">Pantau status laporan yang pernah Anda ajukan.</p>
            </div>
            <div class="stats-mini">
              <div class="s-box">
                <span class="s-lbl">Total</span>
                <span class="s-val text-brand" id="stat-total">0</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Table View -->
        <div class="table-card fade-in" style="animation-delay: 0.1s;">
          <div class="table-header">
            <div class="col-main">Deskripsi & Lokasi</div>
            <div class="col-cat desktop-only">Kategori</div>
            <div class="col-stats desktop-only">Status</div>
            <div class="col-actions">Tanggal</div>
          </div>
          
          <div class="table-body scroll-slim" id="history-list">
            <div class="feed-loading">
              <div class="spinner"></div>
              <p>Mengambil riwayat...</p>
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <a href="/dashboard" class="m-nav-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect></svg>
      </a>
      <a href="/history" class="m-nav-item active">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path></svg>
      </a>
      <a href="/profile" class="m-nav-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
    </nav>

    <!-- Detail Modal -->
    <div id="detail-modal" class="modal-overlay hidden">
      <div class="modal-content large-modal">
        <div class="modal-header">
          <h3>Detail Laporan</h3>
          <button id="close-detail" class="btn-close-modal">&times;</button>
        </div>
        <div class="modal-body scroll-slim" style="padding: 0;">
          <div class="detail-layout">
            <div class="detail-info">
              <div id="detail-img-container" class="detail-img-box hidden">
                <img id="detail-img" src="" alt="Bukti Foto" onclick="window.openImg(this.src)" style="cursor:pointer;" />
              </div>
              <div class="detail-text">
                <div class="d-meta">
                  <span id="detail-cat" class="badge-cat"></span>
                  <span id="detail-status" class="badge-status"></span>
                  <span id="detail-date" class="text-date" style="margin-left:auto;"></span>
                </div>
                <h2 id="detail-desc"></h2>
                <div class="d-location">📍 <span id="detail-loc"></span></div>
                
                <div class="d-stats mt-4">
                  <div class="stat-pill">🔥 <span id="detail-votes">0</span> Dukungan</div>
                  <div class="stat-pill">💬 <span id="detail-comment-count">0</span> Diskusi</div>
                </div>
              </div>
            </div>
            
            <div class="detail-comments">
              <h4>Diskusi</h4>
              <div id="comments-list" class="comments-container scroll-slim">
                <!-- Comments -->
              </div>
              <div class="comment-input-wrapper">
                <form id="form-comment" class="comment-input-group">
                  <input type="hidden" id="comment-report-id" />
                  <input type="text" id="comment-input" placeholder="Balas atau diskusi..." required autocomplete="off" />
                  <button type="submit" class="btn-send">
                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="modal-overlay hidden" style="z-index:10000;">
      <div class="lightbox-wrapper">
        <button id="lightbox-close" class="btn-close-modal">&times;</button>
        <img id="lightbox-img" src="" alt="Full view" />
      </div>
    </div>

  </div>

  <!-- JavaScript Logic -->
  <script is:inline>
    const API_URL = 'http://localhost:3000';
    
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('DOMContentLoaded', initHistory);
    }

    let user, categories = [];
    let allReportsList = [];

    function initHistory() {
      try {
        user = JSON.parse(userRaw);
        const initial = (user.name || 'U')[0].toUpperCase();
        
        document.getElementById('sidebar-name').textContent = user.name;
        document.getElementById('sidebar-avatar').textContent = initial;
        document.getElementById('mobile-avatar').textContent = initial;
        document.getElementById('sidebar-points').textContent = `${user.points || 0} PTS`;
        document.getElementById('mobile-points').textContent = `${user.points || 0} PTS`;

        loadCategories().then(() => fetchHistory());

        document.getElementById('close-detail').addEventListener('click', () => document.getElementById('detail-modal').classList.add('hidden'));
        document.getElementById('lightbox-close').addEventListener('click', () => document.getElementById('lightbox').classList.add('hidden'));
        document.getElementById('form-comment').addEventListener('submit', handleCommentSubmit);

        const doLogout = () => { localStorage.clear(); window.location.href = '/login'; };
        document.getElementById('btn-logout-desktop').addEventListener('click', doLogout);
        document.getElementById('btn-logout-mobile2').addEventListener('click', doLogout);

      } catch(e) {
        console.error("History Init Error: ", e);
      }
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
      } catch (err) { 
        console.error("Categories Error", err); 
        categories = [
          {id: 1, name: 'Infrastruktur'},
          {id: 2, name: 'Lingkungan'},
          {id: 3, name: 'Fasilitas Umum'},
          {id: 4, name: 'Keamanan'}
        ];
      }
    }

    function getCategoryName(id) {
      if(!id) return 'Umum';
      const cat = categories.find(c => c.id === id);
      return cat ? cat.name : 'Umum';
    }

    async function fetchHistory() {
      const list = document.getElementById('history-list');
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        allReportsList = data.data || [];
        
        document.getElementById('stat-total').textContent = allReportsList.length;
        renderHistory(allReportsList);
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat riwayat.</div>';
      }
    }

    function renderHistory(items) {
      const list = document.getElementById('history-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="empty-state">Belum ada riwayat laporan yang diajukan.</div>';
        return;
      }
      
      list.innerHTML = items.map(r => {
        const catName = getCategoryName(r.category_id);
        const statusClass = r.status.toLowerCase();

        return `
          <div class="table-row clickable" onclick="window.openDetail('${r.id}')">
            <div class="col-main flex-gap">
              <div class="row-info">
                <h4>${r.description}</h4>
                <p>📍 ${r.location_detail}</p>
                <div class="mobile-only mt-1">
                  <span class="badge-cat">${catName}</span>
                  <span class="badge-status ${statusClass} mt-1">${r.status}</span>
                  <div class="date-mobile">${new Date(r.created_at).toLocaleDateString('id-ID')}</div>
                </div>
              </div>
            </div>
            <div class="col-cat desktop-only"><span class="badge-cat">${catName}</span></div>
            <div class="col-stats desktop-only">
              <span class="badge-status ${statusClass}">${r.status}</span>
            </div>
            <div class="col-actions desktop-only">
              <span class="text-date">${new Date(r.created_at).toLocaleDateString('id-ID')}</span>
            </div>
          </div>
        `;
      }).join('');
    }

    window.openDetail = (id) => {
      const r = allReportsList.find(x => x.id === id);
      if(!r) return;

      document.getElementById('comment-report-id').value = id;

      if(r.image_url) {
        document.getElementById('detail-img').src = API_URL + r.image_url;
        document.getElementById('detail-img-container').classList.remove('hidden');
      } else {
        document.getElementById('detail-img-container').classList.add('hidden');
      }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = getCategoryName(r.category_id);
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      
      const st = document.getElementById('detail-status');
      st.textContent = r.status;
      st.className = `badge-status ${r.status.toLowerCase()}`;

      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('detail-comment-count').textContent = r.comment_count;

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openImg = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    async function loadComments(id) {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="feed-loading"><div class="spinner"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const comments = data.data || [];
        if(comments.length === 0) {
          list.innerHTML = '<div class="empty-state">Belum ada diskusi.</div>';
          return;
        }
        list.innerHTML = comments.map(c => `
          <div class="comment-bubble">
            <div class="c-head">
              <strong>${c.user?.full_name || (c.user?.role === 'admin' ? 'Admin' : 'Warga')}</strong> 
              <span>${new Date(c.created_at).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'})}</span>
            </div>
            <div class="c-body">${c.content}</div>
          </div>
        `).join('');
        list.scrollTop = list.scrollHeight;
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat diskusi.</div>';
      }
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('comment-report-id').value;
      const input = document.getElementById('comment-input');
      if(!input.value.trim() || !id) return;

      const btn = e.target.querySelector('.btn-send');
      btn.disabled = true;
      
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) {
          input.value = '';
          loadComments(id);
          const currentCount = parseInt(document.getElementById('detail-comment-count').textContent || "0");
          document.getElementById('detail-comment-count').textContent = currentCount + 1;
        }
      } catch(err) {}
      btn.disabled = false;
    }
  </script>

  <style is:global>
    /* =========================================
       Zen SaaS Architecture (History)
       ========================================= */
    
    :root {
      --c-bg: #F8FAFC;
      --c-surface: #FFFFFF;
      --c-text: #0F172A;
      --c-text-soft: #64748B;
      --c-border: #E2E8F0;
      --c-brand: #0F172A;
      --c-accent: #3B82F6;
      --c-danger: #EF4444;
      --c-success: #10B981;
      --c-warning: #F59E0B;
      
      --radius-sm: 8px;
      --radius-md: 16px;
      --radius-lg: 24px;
      
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.05);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', system-ui, sans-serif; }
    body { background: var(--c-bg); color: var(--c-text); -webkit-font-smoothing: antialiased; }

    /* Layout */
    .saas-layout { display: flex; height: 100vh; overflow: hidden; }
    
    /* Sidebar Desktop */
    .sidebar { display: none; width: 280px; background: var(--c-surface); border-right: 1px solid var(--c-border); flex-direction: column; z-index: 100; }
    .sidebar-header { padding: 32px 24px; }
    .logo { display: flex; align-items: center; gap: 12px; }
    .logo-text { font-weight: 800; font-size: 20px; letter-spacing: -0.03em; }
    
    .nav-menu { flex: 1; padding: 0 16px; display: flex; flex-direction: column; gap: 4px; }
    .nav-section { font-size: 11px; font-weight: 700; color: var(--c-text-soft); padding: 16px 12px 8px; letter-spacing: 0.05em; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: var(--radius-sm); color: var(--c-text-soft); text-decoration: none; font-size: 14px; font-weight: 600; transition: 0.2s; }
    .nav-item:hover { background: var(--c-bg); color: var(--c-text); }
    .nav-item.active { background: var(--c-bg); color: var(--c-brand); }
    
    .sidebar-footer { padding: 24px 16px; border-top: 1px solid var(--c-border); }
    .user-profile { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; padding: 0 8px; }
    .avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--c-bg); border: 1px solid var(--c-border); display: flex; align-items: center; justify-content: center; font-weight: 700; }
    .user-info { display: flex; flex-direction: column; }
    .user-name { font-weight: 600; font-size: 14px; }
    .user-points { font-size: 12px; font-weight: 700; color: var(--c-accent); }
    
    .btn-logout { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; background: transparent; border: 1px solid var(--c-border); border-radius: var(--radius-sm); color: var(--c-danger); font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-logout:hover { background: #FEF2F2; border-color: #FECACA; }

    /* Mobile Nav */
    .mobile-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: var(--c-surface); border-bottom: 1px solid var(--c-border); position: sticky; top: 0; z-index: 90; }
    .user-profile-mobile { display: flex; align-items: center; gap: 12px; }
    .points-badge { background: #EFF6FF; color: var(--c-accent); padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; }
    .avatar-small { width: 32px; height: 32px; background: var(--c-bg); border: 1px solid var(--c-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 12px; }
    
    .mobile-nav { display: flex; justify-content: space-around; align-items: center; position: fixed; bottom: 0; left: 0; right: 0; height: 64px; background: var(--c-surface); border-top: 1px solid var(--c-border); z-index: 100; padding-bottom: env(safe-area-inset-bottom); }
    .m-nav-item { padding: 8px 24px; color: var(--c-text-soft); border-radius: 12px; border: none; background: none; }
    .m-nav-item.active { color: var(--c-brand); background: var(--c-bg); }
    .text-danger { color: var(--c-danger) !important; }

    /* Main Area */
    .main-content { flex: 1; overflow-y: auto; background: var(--c-bg); padding-bottom: 80px; }
    .content-wrapper { max-width: 1200px; margin: 0 auto; padding: 24px 20px; }
    
    @media (min-width: 768px) {
      .sidebar { display: flex; }
      .mobile-header, .mobile-nav { display: none; }
      .main-content { padding-bottom: 0; }
      .content-wrapper { padding: 40px 48px; }
    }

    /* Typography & Core */
    .welcome-section { margin-bottom: 32px; }
    .hero-flex { display: flex; flex-direction: column; gap: 20px; }
    @media (min-width: 768px) { .hero-flex { flex-direction: row; justify-content: space-between; align-items: flex-end; } }
    h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px; }
    .subtitle { color: var(--c-text-soft); font-size: 15px; }

    .stats-mini { display: flex; gap: 16px; }
    .s-box { background: var(--c-surface); border: 1px solid var(--c-border); padding: 12px 20px; border-radius: var(--radius-sm); display: flex; flex-direction: column; min-width: 120px; box-shadow: var(--shadow-sm); }
    .s-lbl { font-size: 11px; font-weight: 700; color: var(--c-text-soft); text-transform: uppercase; }
    .s-val { font-size: 24px; font-weight: 800; line-height: 1.2; }
    .text-brand { color: var(--c-brand); }

    /* Table View */
    .table-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; display: flex; flex-direction: column; max-height: 800px; margin-top: 24px; }
    .table-header { display: flex; padding: 16px 24px; background: #F8FAFC; border-bottom: 1px solid var(--c-border); font-size: 12px; font-weight: 700; color: var(--c-text-soft); text-transform: uppercase; letter-spacing: 0.05em; }
    .table-body { flex: 1; overflow-y: auto; }
    
    .table-row { display: flex; padding: 20px 24px; border-bottom: 1px solid var(--c-border); align-items: center; transition: 0.2s; }
    .table-row:hover { background: #FAFAFA; }
    .table-row:last-child { border-bottom: none; }
    .table-row.clickable { cursor: pointer; }

    .col-main { flex: 2; }
    .col-cat { flex: 1; }
    .col-stats { flex: 1; }
    .col-actions { width: 140px; text-align: right; }

    /* Table Row Content */
    .flex-gap { display: flex; gap: 16px; align-items: center; }
    
    .row-info h4 { font-size: 15px; font-weight: 600; margin-bottom: 4px; line-height: 1.4; color: var(--c-brand); }
    .row-info p { font-size: 13px; color: var(--c-text-soft); }

    .badge-cat { font-size: 11px; font-weight: 700; background: var(--c-bg); padding: 4px 8px; border-radius: 4px; color: var(--c-text); border: 1px solid var(--c-border); display: inline-block;}
    .badge-status { font-size: 10px; font-weight: 800; padding: 6px 12px; border-radius: 6px; text-transform: uppercase; display: inline-block; }
    .badge-status.pending { background: #FEF2F2; color: var(--c-danger); }
    .badge-status.valid { background: #FEFCE8; color: #CA8A04; }
    .badge-status.resolved { background: #ECFDF5; color: var(--c-success); }
    
    .text-date { font-size: 13px; font-weight: 500; color: var(--c-text-soft); }
    .date-mobile { font-size: 12px; color: var(--c-text-soft); margin-top: 8px; }

    /* Responsive Table */
    .desktop-only { display: block; }
    .mobile-only { display: none; }
    .mt-1 { margin-top: 8px; }
    .mt-4 { margin-top: 16px; }

    @media (max-width: 768px) {
      .desktop-only { display: none; }
      .mobile-only { display: block; }
      .table-header { display: none; }
      .table-row { flex-direction: column; align-items: flex-start; gap: 16px; padding: 16px; }
      .col-actions { width: 100%; text-align: left; }
    }

    /* Modals & Overlays */
    .hidden { display: none !important; }
