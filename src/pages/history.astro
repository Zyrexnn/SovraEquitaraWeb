---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="Riwayat Laporan — SovraEquitara">
  <link rel="stylesheet" href="/libs/leaflet/leaflet.css" />
  <div class="flex h-screen overflow-hidden bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark font-display">
    <Sidebar activePage="history" />

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto lg:ml-[280px] p-6 pt-24 lg:pt-10 max-w-[1600px] w-full mx-auto pb-24 lg:pb-10 scroll-smooth">
      <div class="max-w-[1200px] mx-auto">
        
        <header class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-8 lg:mb-10 gap-4 animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]">
          <div>
            <h1 class="text-[28px] lg:text-[32px] font-extrabold tracking-tight m-0 text-zen-text dark:text-zen-text-dark">Riwayat <span class="bg-gradient-to-r from-blue-500 to-emerald-500 bg-clip-text text-transparent">Laporan</span></h1>
            <p class="text-sm lg:text-base font-semibold text-zen-muted dark:text-zen-muted-dark mt-1">Pantau perkembangan aspirasi dan laporan Anda.</p>
          </div>
          <div class="flex gap-4">
            <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark p-4 px-6 rounded-2xl flex flex-col min-w-[140px] shadow-zen transition-transform hover:scale-[1.02]">
              <span class="text-[10px] font-extrabold text-zen-muted dark:text-zen-muted-dark uppercase tracking-widest mb-1">Total Laporan</span>
              <span class="text-3xl font-black leading-tight text-zen-text dark:text-zen-text-dark" id="stat-total">0</span>
            </div>
          </div>
        </header>

        <!-- Search & Filter -->
        <div class="mb-6 flex gap-3 animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]" style="animation-delay: 0.05s;">
           <div class="flex-1 relative">
             <input type="text" id="search-input" placeholder="Cari laporan..." class="w-full p-3.5 pl-11 rounded-2xl border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark text-sm font-semibold outline-none focus:ring-4 focus:ring-brand/5 transition-all text-zen-text dark:text-zen-text-dark" />
             <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-zen-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
           </div>
        </div>

        <!-- History List -->
        <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark rounded-[2rem] shadow-zen overflow-hidden animate-[slideUp_0.6s_cubic-bezier(0.22,1,0.36,1)_both]" style="animation-delay: 0.1s;">
          <div class="hidden lg:grid grid-cols-[1fr_180px_160px_140px] p-5 px-8 bg-zen-surface dark:bg-zen-surface-dark border-b border-zen-border dark:border-zen-border-dark text-[11px] font-black text-zen-muted dark:text-zen-muted-dark uppercase tracking-widest">
            <div>DESKRIPSI & LOKASI</div>
            <div>KATEGORI</div>
            <div>STATUS</div>
            <div class="text-right">TANGGAL</div>
          </div>
          
          <div id="history-list" class="flex flex-col">
            <div class="flex flex-col items-center justify-center p-20 gap-4 text-zen-muted dark:text-zen-muted-dark">
              <div class="w-8 h-8 border-4 border-zen-border dark:border-zen-border-dark border-t-brand rounded-full animate-spin"></div>
              <p class="text-sm font-bold tracking-tight">Menyelaraskan data...</p>
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- Detail Modal -->
    <div id="detail-modal" class="fixed inset-0 bg-black/60 dark:bg-black/80 backdrop-blur-sm z-[1000] flex items-center justify-center p-5 hidden">
      <div class="w-full max-w-[1000px] max-h-[90vh] rounded-[32px] overflow-hidden flex flex-col bg-zen-bg dark:bg-zen-bg-dark shadow-2xl border border-zen-border dark:border-zen-border-dark">
        <div class="px-8 py-6 border-b border-zen-border dark:border-zen-border-dark flex justify-between items-center bg-zen-surface dark:bg-zen-surface-dark text-zen-text dark:text-zen-text-dark">
          <h3 class="m-0 text-lg font-extrabold">Detail Laporan</h3>
          <div class="flex items-center gap-3">
            <button id="btn-approve-report" class="hidden px-3 py-1.5 bg-emerald-50 text-emerald-500 hover:bg-emerald-100 hover:text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400 dark:border-emerald-500/20 rounded-lg text-xs font-bold border border-emerald-200 transition-colors cursor-pointer flex items-center gap-1">
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              Setujui
            </button>
            <button id="btn-reject-report" class="hidden px-3 py-1.5 bg-orange-50 text-orange-500 hover:bg-orange-100 hover:text-orange-600 dark:bg-orange-500/10 dark:text-orange-400 dark:border-orange-500/20 rounded-lg text-xs font-bold border border-orange-200 transition-colors cursor-pointer flex items-center gap-1">
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
              Tolak
            </button>
            <button id="btn-delete-report" class="hidden px-3 py-1.5 bg-red-50 text-red-500 hover:bg-red-100 hover:text-red-600 dark:bg-red-500/10 dark:text-red-400 dark:border-red-500/20 rounded-lg text-xs font-bold border border-red-200 transition-colors cursor-pointer flex items-center gap-1">
              <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
              Hapus
            </button>
            <button id="close-detail" class="bg-transparent border-none text-[32px] cursor-pointer text-zen-muted dark:text-zen-muted-dark hover:text-zen-text dark:text-zen-text-dark leading-none">&times;</button>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto scrollbar-thin bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark">
          <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px]">
            <div class="p-6 lg:p-8 lg:border-r border-zen-border dark:border-zen-border-dark">
              <div id="detail-img-box" class="h-[250px] lg:h-[300px] rounded-2xl overflow-hidden mb-6 cursor-zoom-in bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark hidden shadow-soft">
                <img id="detail-img" src="" alt="Bukti" class="w-full h-full object-cover" />
              </div>
              <div>
                <div class="flex flex-wrap gap-2 mb-4">
                  <span id="detail-cat" class="text-[11px] font-extrabold bg-zen-surface dark:bg-zen-surface-dark px-3 py-1.5 rounded-lg border border-zen-border dark:border-zen-border-dark"></span>
                  <span id="detail-status" class="text-[11px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider"></span>
                </div>
                <h2 id="detail-desc" class="text-xl lg:text-2xl font-extrabold m-0 tracking-tight leading-tight mb-6"></h2>
                <div class="p-4 rounded-2xl my-6 bg-zen-surface dark:bg-zen-surface-dark border border-zen-border dark:border-zen-border-dark text-sm">
                  <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3">
                    <span class="font-medium">📍 <span id="detail-loc"></span></span>
                    <div class="flex gap-2">
                      <button id="btn-view-map-modal" class="px-3 py-1.5 text-[11px] font-extrabold border border-zen-border dark:border-zen-border-dark rounded-lg bg-zen-surface dark:bg-zen-surface-dark text-zen-text dark:text-zen-text-dark cursor-pointer transition-colors hover:bg-zen-bg dark:hover:bg-zen-bg-dark hover:border-brand dark:hover:border-white">Lihat Peta</button>
                      <a id="btn-gmaps-modal" href="#" target="_blank" class="px-3 py-1.5 text-[11px] font-extrabold border border-zen-border dark:border-zen-border-dark rounded-lg bg-zen-surface dark:bg-zen-surface-dark cursor-pointer transition-colors text-zen-text dark:text-zen-text-dark no-underline hover:bg-zen-bg dark:hover:bg-zen-bg-dark hover:border-brand dark:hover:border-white">Google Maps</a>
                    </div>
                  </div>
                  <div id="modal-map" class="h-[200px] rounded-xl mt-3 border border-zen-border dark:border-zen-border-dark hidden z-10 shadow-soft"></div>
                </div>
                <div class="flex flex-wrap justify-between items-center gap-4 mt-6">
                  <span id="detail-date" class="text-sm font-semibold text-zen-muted dark:text-zen-muted-dark"></span>
                  <div>
                    <button class="bg-zen-surface dark:bg-zen-surface-dark text-zen-text dark:text-zen-text-dark border border-zen-border dark:border-zen-border-dark px-5 py-3 rounded-xl font-extrabold cursor-pointer transition-all duration-200 hover:scale-105 hover:bg-zen-bg dark:hover:bg-zen-bg-dark hover:border-brand dark:hover:border-white" id="btn-vote-modal">
                      🔥 <b id="detail-votes">0</b> Dukungan
                    </button>
                  </div>
                </div>
              </div>
            </div>
            <div class="bg-zen-surface dark:bg-zen-surface-dark flex flex-col border-t lg:border-t-0 lg:border-l border-zen-border dark:border-zen-border-dark">
              <div class="p-6 border-b border-zen-border dark:border-zen-border-dark font-extrabold text-xs uppercase tracking-wider">Diskusi & Solusi</div>
              <div id="comments-list" class="flex-1 p-6 flex flex-col gap-4 overflow-y-auto scrollbar-thin h-[300px] lg:h-[400px]"></div>
              <form id="form-comment" class="p-5 flex gap-3 border-t border-zen-border dark:border-zen-border-dark bg-zen-surface dark:bg-zen-surface-dark">
                <input type="hidden" id="active-report-id" />
                <input type="text" id="comment-input" class="flex-1 p-3.5 rounded-xl border border-zen-border dark:border-zen-border-dark !bg-zen-bg dark:!bg-zen-bg-dark text-zen-text dark:text-zen-text-dark text-sm font-medium outline-none transition-colors focus:ring-2 focus:ring-brand/20 dark:focus:ring-white/20 focus:border-brand dark:focus:border-white appearance-none placeholder:text-zen-muted dark:placeholder:text-zen-muted-dark" placeholder="Tulis pendapat Anda..." required />
                <button type="submit" id="btn-send-comment" class="w-12 h-12 rounded-xl bg-brand dark:bg-white text-white dark:text-brand border-none flex items-center justify-center cursor-pointer transition-transform hover:-translate-y-0.5">
                  <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="fixed inset-0 bg-black/90 backdrop-blur-2xl z-[3000] hidden items-center justify-center p-5 transition-all">
      <div class="relative max-w-full max-h-full flex flex-col items-center">
        <button id="lightbox-close" class="absolute -top-12 right-0 bg-white/10 text-white border-none w-10 h-10 rounded-full flex items-center justify-center cursor-pointer hover:bg-white/20 transition-all">
          <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <img id="lightbox-img" src="" alt="Full view" class="max-w-full max-h-[80vh] rounded-2xl shadow-2xl animate-[zoomIn_0.3s_ease-out_both]" />
      </div>
    </div>
  </div>

  <!-- Scripts -->
  <script is:inline src="/libs/leaflet/leaflet.js"></script>
  
  <script is:inline>
    const API_URL = 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      document.addEventListener('astro:page-load', initHistory);
      if (document.readyState === 'complete') {
        initHistory();
      } else {
        window.addEventListener('load', initHistory);
      }
    }

    let user, categories = [];
    let allReportsList = [];
    let mainInterval;

    function initHistory() {
      try {
        user = JSON.parse(userRaw || "{}");
        // User info loading is now handled by Sidebar component
        loadCategories().then(() => fetchHistory());

        document.getElementById('close-detail')?.addEventListener('click', () => {
          document.getElementById('detail-modal').classList.add('hidden');
          document.body.style.overflow = 'auto';
          if (window.mMap) { window.mMap.remove(); window.mMap = null; }
        });
        document.getElementById('lightbox-close')?.addEventListener('click', () => document.getElementById('lightbox').classList.add('hidden'));
        document.getElementById('form-comment')?.addEventListener('submit', handleCommentSubmit);
        
        // Search functionality
        document.getElementById('search-input')?.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          const filtered = allReportsList.filter(r => 
            r.description.toLowerCase().includes(query) || 
            r.location_detail.toLowerCase().includes(query)
          );
          renderHistory(filtered);
        });

        if (mainInterval) clearInterval(mainInterval);
        mainInterval = setInterval(() => {
          if(!token || document.hidden) return;
          fetchHistory(true);
          const activeReportId = document.getElementById('active-report-id').value;
          if(activeReportId && !document.getElementById('detail-modal').classList.contains('hidden')) {
             const r = allReportsList.find(x => x.id === activeReportId);
             if(r) {
               document.getElementById('detail-votes').textContent = r.vote_count.toString();
               loadComments(activeReportId, true);
             }
          }
        }, 10000);

      } catch(e) {
        console.error("History Init Error: ", e);
      }

      // Handle deep linking from notifications
      const urlParams = new URLSearchParams(window.location.search);
      const openId = urlParams.get('open');
      if (openId) {
        // slight delay to ensure UI is fully rendered and data is fetched
        setTimeout(() => window.openDetail(openId), 300);
      }
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
      } catch (err) { categories = []; }
    }

    function getCategoryName(id) {
      const cat = categories.find(c => c.id === id);
      return cat ? cat.name : 'Umum';
    }

    async function fetchHistory(silent = false) {
      try {
        const res = await fetch(`${API_URL}/api/my-reports`, { headers: { 'Authorization': `Bearer ${token}` }});
        const data = await res.json();
        allReportsList = data.data || [];
        document.getElementById('stat-total').textContent = allReportsList.length;
        renderHistory(allReportsList);
      } catch(e) {
        if(!silent) document.getElementById('history-list').innerHTML = '<div class="p-10 text-center text-red-500 font-bold">Gagal memuat data.</div>';
      }
    }

    function renderHistory(items) {
      const list = document.getElementById('history-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="p-20 text-center text-zen-muted font-bold">Tidak ada laporan ditemukan.</div>';
        return;
      }
      
      list.innerHTML = items.map(r => {
        const catName = getCategoryName(r.category_id);
        const statusClass = r.status.toLowerCase();
        let statusStyles = "bg-stone-100 text-stone-600 dark:bg-white/5 dark:text-white/60";
        
        if (statusClass === "pending") statusStyles = "bg-red-50 text-red-500 dark:bg-red-500/10 dark:text-red-400 border border-red-200/50 dark:border-red-500/20";
        else if (statusClass === "valid") statusStyles = "bg-blue-50 text-blue-600 dark:bg-blue-500/10 dark:text-blue-400 border border-blue-200/50 dark:border-blue-500/20";
        else if (statusClass === "waiting_approval") statusStyles = "bg-purple-50 text-purple-600 dark:bg-purple-500/10 dark:text-purple-400 border border-purple-200/50 dark:border-purple-500/20";
        else if (statusClass === "resolved") statusStyles = "bg-emerald-50 text-emerald-600 dark:bg-emerald-500/10 dark:text-emerald-400 border border-emerald-200/50 dark:border-emerald-500/20";

        return `
          <div class="group grid grid-cols-1 lg:grid-cols-[1fr_180px_160px_140px] p-6 lg:p-5 lg:px-8 border-b border-zen-border dark:border-zen-border-dark lg:items-center gap-4 transition-all hover:bg-zen-surface dark:hover:bg-zen-surface-dark cursor-pointer last:border-0" onclick="window.openDetail('${r.id}')">
            <div class="flex gap-4 items-center">
              <div class="w-12 h-12 rounded-2xl bg-zen-surface dark:bg-zen-bg-dark flex items-center justify-center shrink-0 border border-zen-border dark:border-zen-border-dark overflow-hidden">
                ${r.image_urls && r.image_urls.length > 0 ? `<img src="${API_URL}${r.image_urls[0]}" class="w-full h-full object-cover" />` : `<span class="text-xl">📄</span>`}
              </div>
              <div class="min-w-0">
                <h4 class="text-[15px] font-black mb-1.5 leading-snug text-zen-text dark:text-zen-text-dark truncate">${r.description}</h4>
                <div class="flex items-center gap-2 text-xs font-bold text-zen-muted truncate">
                   <svg viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" fill="none" stroke-width="3"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                   ${r.location_detail}
                </div>
              </div>
            </div>
            <div class="flex items-center lg:block">
              <span class="lg:hidden text-[10px] font-black text-zen-muted uppercase tracking-widest mr-3">Kategori:</span>
              <span class="text-[10px] font-black bg-zen-bg dark:bg-black/20 px-2.5 py-1.5 rounded-lg text-zen-text dark:text-zen-text-dark border border-zen-border dark:border-zen-border-dark uppercase tracking-widest">${catName}</span>
            </div>
            <div class="flex items-center lg:block">
              <span class="lg:hidden text-[10px] font-black text-zen-muted uppercase tracking-widest mr-3">Status:</span>
              <span class="text-[9px] font-black px-3 py-1.5 rounded-lg uppercase tracking-[0.05em] ${statusStyles}">${r.status === 'WAITING_APPROVAL' ? 'MENUNGGU PERSETUJUAN' : r.status}</span>
            </div>
            <div class="lg:text-right flex items-center lg:block">
              <span class="lg:hidden text-[10px] font-black text-zen-muted uppercase tracking-widest mr-3">Dibuat:</span>
              <span class="text-xs font-bold text-zen-muted">${new Date(r.created_at).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'})}</span>
            </div>
          </div>
        `;
      }).join('');
    }

    window.openDetail = (id) => {
      const r = allReportsList.find(x => x.id === id);
      if(!r) return;
      document.getElementById('active-report-id').value = id;
      
      const imgBox = document.getElementById('detail-img-box');
      if(r.image_urls && r.image_urls.length > 0) {
        if(r.image_urls.length === 1) {
          imgBox.innerHTML = `<img src="${API_URL}${r.image_urls[0]}" class="w-full h-full object-cover cursor-zoom-in" onclick="window.openLightbox('${API_URL}${r.image_urls[0]}')" />`;
        } else if (r.image_urls.length === 2) {
          imgBox.innerHTML = `<div class="flex h-full w-full"><div class="w-1/2 border-r border-zen-border dark:border-zen-border-dark"><img src="${API_URL}${r.image_urls[0]}" class="w-full h-full object-cover cursor-zoom-in hover:opacity-90 transition-opacity" onclick="window.openLightbox('${API_URL}${r.image_urls[0]}')" /></div><div class="w-1/2"><img src="${API_URL}${r.image_urls[1]}" class="w-full h-full object-cover cursor-zoom-in hover:opacity-90 transition-opacity" onclick="window.openLightbox('${API_URL}${r.image_urls[1]}')" /></div></div>`;
        } else {
          imgBox.innerHTML = `<div class="flex h-full w-full"><div class="w-2/3 border-r border-zen-border dark:border-zen-border-dark"><img src="${API_URL}${r.image_urls[0]}" class="w-full h-full object-cover cursor-zoom-in hover:opacity-90 transition-opacity" onclick="window.openLightbox('${API_URL}${r.image_urls[0]}')" /></div><div class="w-1/3 flex flex-col"><div class="h-1/2 border-b border-zen-border dark:border-zen-border-dark"><img src="${API_URL}${r.image_urls[1]}" class="w-full h-full object-cover cursor-zoom-in hover:opacity-90 transition-opacity" onclick="window.openLightbox('${API_URL}${r.image_urls[1]}')" /></div><div class="h-1/2"><img src="${API_URL}${r.image_urls[2]}" class="w-full h-full object-cover cursor-zoom-in hover:opacity-90 transition-opacity" onclick="window.openLightbox('${API_URL}${r.image_urls[2]}')" /></div></div></div>`;
        }
        imgBox.classList.remove('hidden', 'cursor-zoom-in');
        imgBox.onclick = null;
      } else { imgBox.classList.add('hidden'); }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = categories.find(c => c.id === r.category_id)?.name || 'Umum';
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      document.getElementById('detail-status').textContent = r.status === 'WAITING_APPROVAL' ? 'MENUNGGU PERSETUJUAN' : r.status;
      
      const statusClass = r.status.toLowerCase() === 'pending' ? 'bg-amber-500/10 text-amber-600 dark:text-amber-400' : 
                          r.status.toLowerCase() === 'valid' ? 'bg-blue-500/10 text-blue-600 dark:text-blue-400' : 
                          r.status.toLowerCase() === 'waiting_approval' ? 'bg-purple-500/10 text-purple-600 dark:text-purple-400' :
                          r.status.toLowerCase() === 'resolved' ? 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' : 
                          'bg-gray-500/10 text-gray-600 dark:text-gray-400';
      document.getElementById('detail-status').className = `text-[11px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider ${statusClass}`;
      
      // Action Buttons Logic
      const btnDelete = document.getElementById('btn-delete-report');
      const btnApprove = document.getElementById('btn-approve-report');
      const btnReject = document.getElementById('btn-reject-report');
      
      btnDelete.classList.add('hidden');
      btnApprove.classList.add('hidden');
      btnReject.classList.add('hidden');

      const isOwner = r.profile_id && user && (user.id || user.ID) && String(r.profile_id).toLowerCase() === String(user.id || user.ID).toLowerCase();
      const statusUpper = (r.status || '').toUpperCase();

      if (isOwner) {
        if (statusUpper === 'PENDING') {
          btnDelete.classList.remove('hidden');
          btnDelete.onclick = () => window.deleteReport(id);
        } else if (statusUpper === 'WAITING_APPROVAL') {
          btnApprove.classList.remove('hidden');
          btnReject.classList.remove('hidden');
          btnApprove.onclick = () => window.approveResolution(id);
          btnReject.onclick = () => window.rejectResolution(id);
        }
      }

      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('btn-vote-modal').onclick = () => window.doVote(id);

      // Google Maps Link
      const gLink = document.getElementById('btn-gmaps-modal');
      gLink.href = `https://www.google.com/maps?q=${r.latitude},${r.longitude}`;

      // Modal Map
      const modalMapContainer = document.getElementById('modal-map');
      const viewMapBtn = document.getElementById('btn-view-map-modal');
      modalMapContainer.classList.add('hidden');
      viewMapBtn.textContent = 'Lihat Peta';
      
      viewMapBtn.onclick = () => {
        const isHidden = modalMapContainer.classList.toggle('hidden');
        viewMapBtn.textContent = isHidden ? 'Lihat Peta' : 'Tutup Peta';
        if (!isHidden) {
          setTimeout(() => {
            if (window.mMap) window.mMap.remove();
            const INDONESIA_BOUNDS = L.latLngBounds(L.latLng(-11.5, 94.0), L.latLng(7.0, 142.0));
            window.mMap = L.map('modal-map', {
              zoomControl: true,
              maxBounds: INDONESIA_BOUNDS,
              maxBoundsViscosity: 0.9,
              minZoom: 5
            }).setView([r.latitude, r.longitude], 15);
            const isDark = document.documentElement.classList.contains('dark');
            L.tileLayer(
              isDark
                ? 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png'
                : 'https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',
              { subdomains: 'abcd', crossOrigin: true }
            ).addTo(window.mMap);
            L.marker([r.latitude, r.longitude]).addTo(window.mMap);
          }, 150);
        }
      };

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openLightbox = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    window.doVote = async (id) => {
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/vote`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ vote_type: 1 })
        });
        if(res.ok) {
          window.showToast({ message: 'Dukungan berhasil ditambahkan!', type: 'success' });
          fetchHistory(true);
          const r = allReportsList.find(x => x.id === id);
          if(r && document.getElementById('active-report-id').value === id) {
             document.getElementById('detail-votes').textContent = r.vote_count + 1;
          }
        } else {
          const err = await res.json();
          window.showToast({ message: err.error || 'Gagal menambahkan dukungan', type: 'info' });
        }
      } catch(e) {
        window.showToast({ message: 'Terjadi kesalahan koneksi', type: 'error' });
      }
    };

    async function loadComments(id, silent = false) {
      const list = document.getElementById('comments-list');
      if(!silent) list.innerHTML = '<div class="flex-1 flex items-center justify-center py-20"><div class="w-6 h-6 border-4 border-zen-border border-t-brand rounded-full animate-spin"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const comments = data.data || [];
        if(comments.length === 0) {
          list.innerHTML = '<div class="text-center py-20"><p class="text-xs font-bold text-zen-muted uppercase tracking-widest">Belum ada diskusi</p></div>';
          return;
        }
        list.innerHTML = comments.map(x => {
          const initial = (x.user?.full_name || 'W')[0].toUpperCase();
          const avatarHtml = x.user?.avatar_url ? `<img src="${x.user.avatar_url.startsWith('http') ? x.user.avatar_url : API_URL + x.user.avatar_url}" class="w-full h-full object-cover" />` : initial;
          const isAdmin = x.user?.role === 'admin' || x.user?.role === 'super_admin';
          const badgeHtml = x.user?.role === 'super_admin' ? `<svg class="inline-block ml-1 w-3.5 h-3.5 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : (x.user?.role === 'admin' ? `<svg class="inline-block ml-1 w-3.5 h-3.5 text-blue-500" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-1.25 15L6 12.25l1.41-1.41L10.75 14.17l7.84-7.84L20 7.75 10.75 17z"/></svg>` : '');
          
          return `
          <div class="flex gap-3 max-w-[90%] ${isAdmin ? 'self-end flex-row-reverse' : ''}">
            <div class="w-8 h-8 rounded-xl overflow-hidden shrink-0 flex items-center justify-center font-black text-xs ${isAdmin ? 'bg-brand text-white dark:text-zen-bg' : 'bg-stone-900 dark:bg-white text-white dark:text-black'} border border-white/10">
              ${avatarHtml}
            </div>
            <div class="p-4 rounded-[20px] border flex-1 min-w-0 ${isAdmin ? 'bg-brand text-white border-brand dark:text-zen-bg' : 'bg-zen-bg dark:bg-zen-bg-dark border-zen-border dark:border-zen-border-dark text-zen-text dark:text-zen-text-dark'}">
              <div class="mb-1 text-xs flex items-center"><strong>${x.user?.full_name || 'Warga'}</strong>${badgeHtml}</div>
              <p class="m-0 text-sm leading-relaxed">${x.content}</p>
            </div>
          </div>
        `}).join('');
        if(!silent) list.scrollTop = list.scrollHeight;
      } catch(e) {}
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const id = document.getElementById('active-report-id').value;
      const input = document.getElementById('comment-input');
      const btn = document.getElementById('btn-send-comment');
      if(!input.value.trim() || !id) return;

      btn.disabled = true;
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) {
          input.value = '';
          loadComments(id);
          fetchHistory(true);
          window.showToast({ message: 'Komentar berhasil ditambahkan!', type: 'success' });
        } else {
          window.showToast({ message: 'Gagal mengirim komentar', type: 'error' });
        }
      } catch(err) {
        window.showToast({ message: 'Terjadi kesalahan koneksi', type: 'error' });
      }
      btn.disabled = false;
    }

    window.deleteReport = async (id) => {
      if(!confirm('Apakah Anda yakin ingin menghapus laporan ini?')) return;
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if(res.ok) {
          window.showToast('Laporan berhasil dihapus', 'success');
          document.getElementById('detail-modal').classList.add('hidden');
          fetchHistory();
        } else {
          const err = await res.json();
          window.showToast(err.error || 'Gagal menghapus laporan', 'error');
        }
      } catch(e) {
        window.showToast('Terjadi kesalahan koneksi', 'error');
      }
    };

    window.approveResolution = async (id) => {
      if(!confirm('Apakah Anda yakin setuju bahwa laporan ini telah selesai ditangani? Anda akan mendapatkan +50 poin!')) return;
      const btn = document.getElementById('btn-approve-report');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="animate-spin mr-1 inline-block border-2 border-t-transparent border-emerald-500 rounded-full w-3 h-3"></span> Setujui...';
      btn.disabled = true;

      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/approve-resolution`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if(res.ok) {
          window.showToast('Laporan berhasil diselesaikan!', 'success');
          document.getElementById('detail-modal').classList.add('hidden');
          fetchHistory();
          if (window.fetchProfileData) window.fetchProfileData();
        } else {
          const err = await res.json();
          window.showToast(err.error || 'Gagal menyetujui laporan', 'error');
        }
      } catch(e) {
        window.showToast('Terjadi kesalahan koneksi', 'error');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    };

    window.rejectResolution = async (id) => {
      if(!confirm('Apakah Anda menolak penyelesaian laporan ini? Laporan akan kembali berstatus Diproses.')) return;
      const btn = document.getElementById('btn-reject-report');
      const originalText = btn.innerHTML;
      btn.innerHTML = '<span class="animate-spin mr-1 inline-block border-2 border-t-transparent border-orange-500 rounded-full w-3 h-3"></span> Tolak...';
      btn.disabled = true;

      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/reject-resolution`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if(res.ok) {
          window.showToast('Penyelesaian laporan ditolak!', 'success');
          document.getElementById('detail-modal').classList.add('hidden');
          fetchHistory();
        } else {
          const err = await res.json();
          window.showToast(err.error || 'Gagal menolak laporan', 'error');
        }
      } catch(e) {
        window.showToast('Terjadi kesalahan koneksi', 'error');
      } finally {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }
    };
  </script>
</Layout>