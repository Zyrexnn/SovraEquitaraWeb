---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Reset Password — SovraEquitara">
  <div class="fixed top-6 right-6 z-50">
    <ThemeToggle client:load />
  </div>

  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-12 bg-canvas-bg transition-colors duration-300">
    <div class="w-full max-w-md animate-fade-in py-12">
      <header class="text-center mb-10">
        <a href="/" class="inline-block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-20 sm:h-24 mx-auto mb-8 dark:brightness-0 dark:invert" />
        </a>
        <h1 class="display-md mb-3">Reset Password</h1>
        <p id="instruction-text" class="text-base text-ink-muted font-medium">Masukkan kode OTP dan password baru Anda.</p>
      </header>

      <div class="card-zen">
        <form id="form-reset" class="space-y-6">
          <div>
            <label for="otp" class="block text-[11px] font-bold text-ink-tertiary mb-2 uppercase tracking-widest">
              Kode OTP (6 Digit)
            </label>
            <input type="text" id="otp" placeholder="000000" maxlength="6" required class="input-zen tracking-[0.2em] font-extrabold text-center text-lg" />
          </div>

          <div>
            <label for="new_password" class="block text-[11px] font-bold text-ink-tertiary mb-2 uppercase tracking-widest">
              Kata Sandi Baru
            </label>
            <input type="password" id="new_password" placeholder="••••••••" required class="input-zen" />
          </div>

          <div>
            <label for="confirm_password" class="block text-[11px] font-bold text-ink-tertiary mb-2 uppercase tracking-widest">
              Konfirmasi Kata Sandi Baru
            </label>
            <input type="password" id="confirm_password" placeholder="••••••••" required class="input-zen" />
          </div>

          <button type="submit" class="btn-pill-primary w-full py-4 mt-2" id="btn-submit">
            Update Password
          </button>
        </form>
        
        <div class="text-center mt-8">
          <a href="/login" class="text-[11px] font-bold text-ink hover:text-ink-muted transition-colors uppercase tracking-widest">Kembali ke Login</a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { showToast } from '../lib/toast';
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
  const urlParams = new URLSearchParams(window.location.search);
  const email = urlParams.get('email');

  if (!email) {
    window.location.href = '/login';
  }

  const instruction = document.getElementById('instruction-text');
  if (instruction) instruction.textContent = `Kode OTP telah dikirim ke ${email}`;

  document.getElementById('form-reset').addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const otp = (document.getElementById('otp') as HTMLInputElement).value;
    const newPassword = (document.getElementById('new_password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirm_password') as HTMLInputElement).value;

    if (newPassword.length < 6) {
      showToast({ message: 'Password baru minimal 6 karakter', type: 'error' });
      return;
    }

    if (newPassword !== confirmPassword) {
      showToast({ message: 'Konfirmasi password tidak cocok', type: 'error' });
      return;
    }

    const btn = document.getElementById('btn-submit') as HTMLButtonElement;
    
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Memproses...';
    }

    const payload = {
      email: email,
      token: otp,
      new_password: newPassword
    };

    try {
      const res = await fetch(`${API_URL}/api/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        showToast({ message: 'Password berhasil direset!', type: 'success' });
        setTimeout(() => {
          window.location.href = '/login';
        }, 2000);
      } else {
        const data = await res.json();
        showToast({ message: data.error || 'Gagal mereset password', type: 'error' });
      }
    } catch (err) {
      showToast({ message: 'Kesalahan koneksi', type: 'error' });
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Update Password';
      }
    }
  });
</script>


