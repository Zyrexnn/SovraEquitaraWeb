---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reset Password — SovraEquitara">
  <main class="auth-viewport glass-bg">
    <div class="auth-card glass animate-fade-in">
      <div class="auth-header">
        <div class="logo-circle">
          <img src="/logo.svg" alt="SovraEquitara Logo" />
        </div>
        <h1>Reset Password</h1>
        <p id="instruction-text">Masukkan kode OTP dan password baru Anda.</p>
      </div>

      <form id="form-reset" class="modern-form">
        <div class="form-group">
          <label for="otp">Kode OTP</label>
          <div class="otp-input-wrapper">
            <input type="text" id="otp" placeholder="6 Digit OTP" maxlength="6" required />
          </div>
        </div>

        <div class="form-group">
          <label for="new_password">Password Baru</label>
          <input type="password" id="new_password" placeholder="••••••••" required />
        </div>

        <button type="submit" class="btn-primary-auth" id="btn-submit">
          <span>Update Password</span>
        </button>
      </form>
      
      <div class="auth-footer">
        <a href="/login">Kembali ke Login</a>
      </div>
    </div>

    <div id="toast" class="toast-bento"></div>
  </main>
</Layout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
  const urlParams = new URLSearchParams(window.location.search);
  const email = urlParams.get('email');

  if (!email) {
    window.location.href = '/login';
  }

  document.getElementById('instruction-text').textContent = `Kode OTP telah dikirim ke ${email}`;

  document.getElementById('form-reset').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-submit');
    btn.disabled = true;
    btn.innerHTML = '<div class="spinner-small"></div> Memproses...';

    const payload = {
      email: email,
      token: document.getElementById('otp').value,
      new_password: document.getElementById('new_password').value
    };

    try {
      const res = await fetch(`${API_URL}/api/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        showToast('Password berhasil direset!');
        setTimeout(() => {
          window.location.href = '/login';
        }, 2000);
      } else {
        const data = await res.json();
        showToast(data.error || 'Gagal mereset password', 'error');
      }
    } catch (err) {
      showToast('Kesalahan koneksi', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Update Password';
    }
  });

  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.className = `toast-bento show ${type}`;
    setTimeout(() => toast.className = 'toast-bento', 3000);
  }
</script>

<style>
  .auth-viewport {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: var(--color-bg); padding: 20px;
  }
  .auth-card { width: 100%; max-width: 400px; padding: var(--space-2xl); text-align: center; }
  .logo-circle {
    width: 64px; height: 64px; background: linear-gradient(135deg, var(--color-brand), var(--color-brand-alt));
    border-radius: 20px; margin: 0 auto var(--space-xl); display: flex; align-items: center; justify-content: center;
    box-shadow: 0 10px 20px rgba(44, 62, 80, 0.3);
  }
  .logo-circle img { width: 40px; filter: brightness(0) invert(1); }
  
  h1 { font-size: 1.5rem; font-weight: 800; margin-bottom: 8px; color: var(--color-text-title); }
  p { font-size: 14px; opacity: 0.6; margin-bottom: var(--space-2xl); color: var(--color-text-body); }

  .modern-form { display: flex; flex-direction: column; gap: 20px; text-align: left; }
  .form-group label { display: block; font-size: 14px; font-weight: 700; margin-bottom: 8px; color: var(--color-text-muted); }
  input {
    width: 100%; background: rgba(44, 62, 80, 0.05); border: 1px solid rgba(44, 62, 80, 0.1);
    border-radius: 12px; padding: 14px 18px; color: var(--color-text-title); font-family: inherit;
    transition: all 0.3s;
  }
  input:focus { outline: none; border-color: var(--color-brand); background: rgba(44, 62, 80, 0.08); }

  .btn-primary-auth {
    padding: 16px; border-radius: 14px; border: none; margin-top: 10px;
    background: linear-gradient(135deg, var(--color-brand), var(--color-brand-alt));
    color: #fff; font-weight: 800; cursor: pointer; transition: all 0.3s;
  }
  .btn-primary-auth:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(44, 62, 80, 0.4); }

  .auth-footer { margin-top: var(--space-xl); font-size: 14px; }
  .auth-footer a { color: var(--color-brand); font-weight: 700; text-decoration: none; }

  .toast-bento {
    position: fixed; top: 24px; right: 24px; padding: 12px 24px; border-radius: 12px;
    background: var(--color-brand); color: #fff; font-weight: 700; font-size: 14px;
    transform: translateX(100%); opacity: 0; transition: all 0.4s; z-index: 1000;
    box-shadow: 0 10px 30px rgba(44, 62, 80, 0.3);
  }
  .toast-bento.show { transform: translateX(0); opacity: 1; }
  .toast-bento.error { border-left: 4px solid var(--color-danger); }
</style>
