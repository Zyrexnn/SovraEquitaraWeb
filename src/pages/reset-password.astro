---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reset Password — SovraEquitara">
  <main class="min-h-screen flex items-center justify-center bg-zen-bg dark:bg-zen-bg-dark p-6 md:p-8">
    <div class="w-full max-w-[440px] animate-up">
      <header class="text-center mb-10">
        <div class="w-[200px] mx-auto mb-10 flex items-center justify-center">
          <img src="/logo.svg" alt="Sovra" class="w-full h-auto object-contain dark:brightness-0 dark:invert" />
        </div>
        <h1 class="text-[32px] font-extrabold text-zen-text dark:text-zen-text-dark mb-2">Reset Password</h1>
        <p id="instruction-text" class="text-[15px] text-zen-text-secondary dark:text-zen-text-secondary-dark font-medium">Masukkan kode OTP dan password baru Anda.</p>
      </header>

      <div class="p-8 md:p-10 rounded-3xl bg-zen-card dark:bg-zen-card-dark shadow-zen border border-zen-border dark:border-zen-border-dark">
        <form id="form-reset" class="flex flex-col gap-6">
          <div class="flex flex-col gap-2">
            <label for="otp" class="text-[13px] font-extrabold text-zen-text dark:text-zen-text-dark">Kode OTP (6 Digit)</label>
            <div>
              <input type="text" id="otp" placeholder="000000" maxlength="6" required class="w-full bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark rounded-2xl p-4 px-5 text-zen-text dark:text-zen-text-dark font-display text-[20px] tracking-[0.2em] font-extrabold text-center transition-all duration-300 outline-none focus:border-blue-500 focus:ring-4 focus:ring-black/5 dark:focus:ring-white/5" />
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <label for="new_password" class="text-[13px] font-extrabold text-zen-text dark:text-zen-text-dark">Kata Sandi Baru</label>
            <div>
              <input type="password" id="new_password" placeholder="••••••••" required class="w-full bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark rounded-2xl p-4 px-5 text-zen-text dark:text-zen-text-dark font-display text-[15px] transition-all duration-300 outline-none focus:border-blue-500 focus:ring-4 focus:ring-black/5 dark:focus:ring-white/5" />
            </div>
          </div>

          <button type="submit" class="w-full bg-zen-text dark:bg-zen-text-dark text-zen-bg dark:text-zen-bg-dark border-none rounded-2xl py-4 font-extrabold text-base cursor-pointer transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed" id="btn-submit">
            Update Password
          </button>
        </form>
        
        <div class="text-center mt-6">
          <a href="/login" class="text-blue-500 font-extrabold no-underline border-b-2 border-blue-500/30 pb-0.5 transition-colors hover:border-blue-500">Kembali ke Login</a>
        </div>
      </div>
    </div>

    <div id="toast" class="fixed top-6 left-6 right-6 md:top-8 md:right-8 md:left-auto p-4 px-8 rounded-2xl text-white font-bold text-[15px] transition-all duration-500 z-[1000] shadow-zen text-center md:text-left -translate-y-[150%] md:translate-y-0 md:translate-x-[120%] opacity-0"></div>
  </main>
</Layout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
  const urlParams = new URLSearchParams(window.location.search);
  const email = urlParams.get('email');

  if (!email) {
    window.location.href = '/login';
  }

  const instruction = document.getElementById('instruction-text');
  if (instruction) instruction.textContent = `Kode OTP telah dikirim ke ${email}`;

  document.getElementById('form-reset').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-submit');
    
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Memproses...';
    }

    const payload = {
      email: email,
      token: (document.getElementById('otp') as HTMLInputElement).value,
      new_password: (document.getElementById('new_password') as HTMLInputElement).value
    };

    try {
      const res = await fetch(`${API_URL}/api/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        showToast('Password berhasil direset!');
        setTimeout(() => {
          window.location.href = '/login';
        }, 2000);
      } else {
        const data = await res.json();
        showToast(data.error || 'Gagal mereset password', 'error');
      }
    } catch (err) {
      showToast('Kesalahan koneksi', 'error');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Update Password';
      }
    }
  });

  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    
    // Set colors
    if (type === 'error') {
      toast.classList.add('bg-red-500');
      toast.classList.remove('bg-blue-500');
    } else {
      toast.classList.add('bg-blue-500');
      toast.classList.remove('bg-red-500');
    }

    // Show
    toast.classList.remove('-translate-y-[150%]', 'md:translate-x-[120%]', 'opacity-0');
    toast.classList.add('translate-y-0', 'translate-x-0', 'opacity-100');

    // Hide after 3s
    setTimeout(() => {
      toast.classList.remove('translate-y-0', 'translate-x-0', 'opacity-100');
      toast.classList.add('-translate-y-[150%]', 'md:translate-x-[120%]', 'opacity-0');
    }, 3000);
  }
</script>


