---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reset Password — SovraEquitara">
  <main class="auth-viewport">
    <div class="auth-container animate-up">
      <header class="auth-header">
        <div class="logo-pill">
          <img src="/logo.svg" alt="Sovra" />
        </div>
        <h1>Reset Password</h1>
        <p id="instruction-text">Masukkan kode OTP dan password baru Anda.</p>
      </header>

      <div class="auth-card glass">
        <form id="form-reset" class="auth-form">
          <div class="field-group">
            <label for="otp">Kode OTP (6 Digit)</label>
            <div class="input-wrapper">
              <input type="text" id="otp" placeholder="000000" maxlength="6" required class="otp-input-mini" />
            </div>
          </div>

          <div class="field-group">
            <label for="new_password">Kata Sandi Baru</label>
            <div class="input-wrapper">
              <input type="password" id="new_password" placeholder="••••••••" required />
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-full" id="btn-submit">
            Update Password
          </button>
        </form>
        
        <div class="auth-footer">
          <a href="/login">Kembali ke Login</a>
        </div>
      </div>
    </div>

    <div id="toast" class="toast-bento"></div>
  </main>
</Layout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
  const urlParams = new URLSearchParams(window.location.search);
  const email = urlParams.get('email');

  if (!email) {
    window.location.href = '/login';
  }

  const instruction = document.getElementById('instruction-text');
  if (instruction) instruction.textContent = `Kode OTP telah dikirim ke ${email}`;

  document.getElementById('form-reset').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btn-submit');
    
    if (btn) {
      btn.disabled = true;
      btn.textContent = 'Memproses...';
    }

    const payload = {
      email: email,
      token: (document.getElementById('otp') as HTMLInputElement).value,
      new_password: (document.getElementById('new_password') as HTMLInputElement).value
    };

    try {
      const res = await fetch(`${API_URL}/api/auth/reset-password`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        showToast('Password berhasil direset!');
        setTimeout(() => {
          window.location.href = '/login';
        }, 2000);
      } else {
        const data = await res.json();
        showToast(data.error || 'Gagal mereset password', 'error');
      }
    } catch (err) {
      showToast('Kesalahan koneksi', 'error');
    } finally {
      if (btn) {
        btn.disabled = false;
        btn.textContent = 'Update Password';
      }
    }
  });

  function showToast(msg, type = 'success') {
    const toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.className = `toast-bento show ${type}`;
    setTimeout(() => toast.className = 'toast-bento', 3000);
  }
</script>

<style>
  .auth-viewport {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    background: var(--color-bg); padding: var(--space-xl);
  }
  .auth-container { width: 100%; max-width: 440px; }

  .auth-header { text-align: center; margin-bottom: var(--space-2xl); }
  .logo-pill {
    width: 200px; height: auto;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 40px;
  }
  .logo-pill img { width: 100%; height: auto; object-fit: contain; }

  .auth-header h1 { font-size: 32px; font-weight: 800; color: var(--color-text-title); margin-bottom: 8px; }
  .auth-header p { font-size: 15px; color: var(--color-text-muted); font-weight: 500; }

  .auth-card { padding: var(--space-2xl); border-radius: var(--radius-lg); background: var(--color-surface); box-shadow: var(--shadow-premium); }

  .auth-form { display: flex; flex-direction: column; gap: var(--space-xl); }
  .field-group { display: flex; flex-direction: column; gap: 8px; }
  .field-group label { font-size: 13px; font-weight: 800; color: var(--color-text-title); }

  .input-wrapper input {
    width: 100%; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: 16px; padding: 16px 20px; color: var(--color-text-title);
    font-family: inherit; font-size: 15px; transition: all 0.3s;
  }
  .input-wrapper input:focus { outline: none; border-color: var(--color-brand); box-shadow: 0 0 0 4px rgba(26,26,26,0.05); }

  .otp-input-mini { text-align: center; font-size: 20px !important; letter-spacing: 0.2em; font-weight: 800; }

  .auth-footer { text-align: center; margin-top: var(--space-xl); }
  .auth-footer a { color: var(--color-brand); font-weight: 800; text-decoration: none; border-bottom: 2px solid var(--color-accent); }

  .w-full { width: 100%; }

  /* Toast Re-use */
  .toast-bento {
    position: fixed; top: 32px; right: 32px; padding: 16px 32px; border-radius: 20px;
    background: var(--color-brand); color: #fff; font-weight: 700; font-size: 15px;
    transform: translateX(120%); opacity: 0; transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    z-index: 1000; box-shadow: 0 15px 35px rgba(26, 26, 26, 0.2);
  }
  .toast-bento.show { transform: translateX(0); opacity: 1; }
  .toast-bento.error { background: var(--color-danger); }

  @media (max-width: 768px) {
    .auth-viewport { padding: var(--space-lg); }
    .auth-card { padding: var(--space-xl); }
    .toast-bento { left: 24px; right: 24px; top: 24px; transform: translateY(-150%); text-align: center; }
    .toast-bento.show { transform: translateY(0); }
  }
</style>
