---
import Layout from '../../layouts/Layout.astro';
import { ThemeToggle } from '../../components/ThemeToggle';
---

<Layout title="Admin Login — SovraEquitara">
  <div class="fixed top-6 right-6 z-50">
    <ThemeToggle client:load />
  </div>

  <main class="min-h-screen flex items-center justify-center bg-zen-bg dark:bg-zen-bg-dark p-6 relative overflow-hidden font-sans transition-colors duration-300">
    <!-- Sophisticated Background Accents -->
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-blue-500/5 rounded-full blur-[140px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-amber-500/5 rounded-full blur-[140px] animate-pulse" style="animation-delay: 2s;"></div>

    <div class="w-full max-w-[460px] z-10 animate-fade-in">
      <div class="card p-8 md:p-12 shadow-2xl dark:shadow-[0_40px_100px_rgba(0,0,0,0.6)]">
        <div class="text-center mb-12">
          <a href="/" class="inline-flex items-center justify-center p-5 rounded-[2rem] bg-zen-surface dark:bg-white/5 border border-zen-border dark:border-white/10 mb-8 group transition-all duration-700 hover:bg-zen-bg dark:hover:bg-white/10 hover:border-zen-border dark:hover:border-white/20">
            <img src="/logo.svg" alt="SovraEquitara" class="h-20 w-auto dark:brightness-0 dark:invert opacity-80 group-hover:opacity-100 transition-all duration-500 scale-95 group-hover:scale-105" />
          </a>
          <h1 class="text-4xl font-display font-extrabold text-stone-900 dark:text-white mb-3 tracking-tight leading-tight">
            Admin <span class="text-amber-600 dark:text-amber-400 drop-shadow-[0_0_15px_rgba(245,158,11,0.2)]">Portal</span>
          </h1>
          <p class="text-stone-500 dark:text-gray-400 font-medium text-lg">Pusat kendali infrastruktur kota.</p>
        </div>

        <form id="form-admin-login" class="space-y-7">
          <div class="space-y-2.5">
            <label for="email" class="text-[11px] font-black uppercase tracking-[0.2em] text-stone-400 dark:text-gray-500 ml-2">Identitas Admin</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none text-stone-400 dark:text-gray-500 group-focus-within:text-amber-600 dark:group-focus-within:text-amber-400 transition-colors duration-300">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              </div>
              <input 
                type="email" 
                id="email" 
                placeholder="Email Administrator" 
                required
                class="input pl-14 h-16 text-lg border-stone-200 dark:border-white/10 focus:ring-amber-500/20"
              />
            </div>
          </div>

          <div class="space-y-2.5">
            <label for="password" class="text-[11px] font-black uppercase tracking-[0.2em] text-stone-400 dark:text-gray-500 ml-2">Kunci Akses</label>
            <div class="relative group">
              <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none text-stone-400 dark:text-gray-500 group-focus-within:text-amber-600 dark:group-focus-within:text-amber-400 transition-colors duration-300">
                <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              </div>
              <input 
                type="password" 
                id="password" 
                placeholder="••••••••••••" 
                required
                class="input pl-14 h-16 text-lg border-stone-200 dark:border-white/10 focus:ring-amber-500/20"
              />
            </div>
          </div>

          <button 
            type="submit" 
            id="btn-login"
            class="w-full h-16 bg-stone-900 dark:bg-white text-white dark:text-black rounded-2xl font-black text-lg tracking-wide shadow-xl hover:shadow-2xl hover:-translate-y-1 active:scale-[0.98] transition-all duration-300 flex items-center justify-center gap-3 group"
          >
            <span>Autentikasi</span>
            <svg viewBox="0 0 24 24" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </button>
        </form>

        <div class="mt-12 pt-8 border-t border-stone-200 dark:border-white/10 flex flex-col items-center gap-4">
          <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-stone-100 dark:bg-white/5 border border-stone-200 dark:border-white/10">
            <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
            <span class="text-[10px] font-bold text-stone-500 dark:text-gray-400 uppercase tracking-widest">Enkripsi End-to-End Aktif</span>
          </div>
          <a href="/login" class="text-sm font-bold text-stone-400 dark:text-gray-500 hover:text-stone-600 dark:hover:text-white transition-colors">Beralih ke Portal Warga</a>
        </div>
      </div>
      
      <p class="text-center mt-12 text-[10px] font-black text-stone-400 dark:text-gray-700 uppercase tracking-[0.3em]">
        Proprietary Security Infrastructure &bull; v2.0.4
      </p>
    </div>
  </main>


  <script>
    import { showToast } from '../../lib/toast';
    const API_URL = 'http://localhost:3000';

    // Auto redirect if already logged in
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');
    if (token && userRaw) {
      try {
        const user = JSON.parse(userRaw);
        if (user.role === 'super_admin' || user.role === 'SUPER_ADMIN') window.location.href = '/superadmin/dashboard';
        else if (user.role === 'admin' || user.role === 'ADMIN') window.location.href = '/admin/dashboard';
      } catch (e) {}
    }

    const form = document.getElementById('form-admin-login') as HTMLFormElement;
    const btnLogin = document.getElementById('btn-login') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      btnLogin.disabled = true;
      btnLogin.innerHTML = '<span>Memproses...</span>';

      try {
        const res = await fetch(`${API_URL}/api/auth/admin-login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });

        const data = await res.json();

        if (res.ok) {
          localStorage.setItem('access_token', data.access_token);
          localStorage.setItem('user', JSON.stringify(data.user));
          showToast({ message: 'Login berhasil, mengalihkan...', type: 'success' });
          setTimeout(() => { 
            if (data.user.role === 'super_admin') {
              window.location.href = '/superadmin/dashboard';
            } else {
              window.location.href = '/admin/dashboard';
            }
          }, 1000);
        } else {
          showToast({ message: data.error || 'Login gagal. Periksa kembali email dan password Anda.', type: 'error' });
        }
      } catch (err) {
        console.error('Admin login error:', err);
        showToast({ message: 'Terjadi kesalahan koneksi ke server.', type: 'error' });
      } finally {
        btnLogin.disabled = false;
        btnLogin.innerHTML = '<span>Autentikasi</span><svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="3"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>';
      }
    });
  </script>
</Layout>
