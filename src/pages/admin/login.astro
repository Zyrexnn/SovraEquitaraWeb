---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Login — SovraEquitara">
  <main class="auth-page">
    <div class="auth-container glass animate-up">
      <div class="auth-header">
        <div class="logo-box admin-glow">
          <img src="/logo.svg" alt="Logo" />
        </div>
        <h1 class="display-text">Admin <span class="text-gradient">Portal</span></h1>
        <p class="auth-subtitle">Masuk ke pusat kendali infrastruktur kota.</p>
      </div>

      <form id="form-admin-login" class="auth-form">
        <div class="input-group">
          <label for="username">Username</label>
          <div class="field-wrapper">
            <svg viewBox="0 0 24 24" class="field-icon" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
            <input type="text" id="username" placeholder="admin_username" required />
          </div>
        </div>

        <div class="input-group">
          <label for="password">Kata Sandi</label>
          <div class="field-wrapper">
            <svg viewBox="0 0 24 24" class="field-icon" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
            <input type="password" id="password" placeholder="••••••••" required />
          </div>
        </div>

        <div id="error-box" class="error-box" style="display: none;"></div>

        <button type="submit" id="btn-submit" class="btn btn-primary btn-full">
          <span>Masuk Sekarang</span>
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>

        <a href="/login" class="link-secondary">Bukan Admin? Masuk sebagai Warga</a>
      </form>
    </div>
  </main>
</Layout>

<script>
  const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
  const form = document.getElementById('form-admin-login');
  const errorBox = document.getElementById('error-box');
  const btnSubmit = document.getElementById('btn-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(!errorBox || !btnSubmit) return;
    
    errorBox.style.display = 'none';
    btnSubmit.innerHTML = '<span class="loader"></span>';
    btnSubmit.classList.add('loading');

    const username = (document.getElementById('username') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const res = await fetch(`${API_URL}/api/auth/admin-login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password })
      });

      const data = await res.json();

      if (!res.ok) throw new Error(data.error || 'Login gagal');

      if (data.user.role !== 'admin' && data.user.role !== 'ADMIN') {
        throw new Error('Akun ini tidak memiliki hak akses admin.');
      }

      localStorage.setItem('access_token', data.access_token);
      localStorage.setItem('user', JSON.stringify(data.user));
      window.location.href = '/admin/dashboard';
    } catch (err: any) {
      errorBox.textContent = err.message;
      errorBox.style.display = 'block';
      btnSubmit.innerHTML = '<span>Masuk Sekarang</span><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>';
      btnSubmit.classList.remove('loading');
    }
  });
</script>

<style>
  .auth-page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: var(--space-lg); }
  .auth-container { width: 100%; max-width: 440px; padding: var(--space-2xl); border-radius: var(--radius-xl); text-align: center; }
  
  .auth-header { margin-bottom: var(--space-xl); }
  .logo-box { height: 76px; margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; }
  .logo-box img { height: 64px; width: auto; filter: brightness(0) sepia(1) hue-rotate(175deg) saturate(300%) brightness(0.3); }
  
  .display-text { font-size: 32px; margin-bottom: 8px; }
  .text-gradient { background: linear-gradient(to right, var(--color-danger), #fb7185); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .auth-subtitle { color: var(--color-text-muted); font-size: 14px; font-weight: 500; }

  .auth-form { display: flex; flex-direction: column; gap: var(--space-lg); text-align: left; }
  .input-group label { display: block; font-size: 12px; font-weight: 800; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: 8px; letter-spacing: 0.05em; }
  
  .field-wrapper { position: relative; display: flex; align-items: center; }
  .field-icon { position: absolute; left: 16px; width: 18px; height: 18px; color: var(--color-text-muted); }
  .field-wrapper input { width: 100%; padding: 14px 16px 14px 48px; background: rgba(44, 62, 80, 0.05); border: 1px solid var(--color-border); border-radius: 12px; color: var(--color-text-title); font-family: inherit; font-size: 15px; transition: all 0.3s; }
  .field-wrapper input:focus { border-color: var(--color-danger); background: rgba(44, 62, 80, 0.08); outline: none; box-shadow: 0 0 0 4px rgba(244, 63, 94, 0.1); }

  .btn-full { width: 100%; display: flex; justify-content: center; align-items: center; gap: 12px; padding: 16px; }
  .btn-primary { background: linear-gradient(to right, var(--color-danger), #be123c); }
  
  .link-secondary { margin-top: 8px; font-size: 13px; color: var(--color-text-muted); text-decoration: none; font-weight: 600; display: inline-block; width: 100%; text-align: center; }
  .link-secondary:hover { color: var(--color-danger); }

  .error-box { padding: 12px; border-radius: 10px; background: rgba(244, 63, 94, 0.1); color: var(--color-danger); font-size: 13px; font-weight: 700; border: 1px solid rgba(244, 63, 94, 0.2); }

  .loader { width: 20px; height: 20px; border: 3px solid rgba(44, 62, 80, 0.3); border-top-color: var(--color-brand); border-radius: 50%; animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
