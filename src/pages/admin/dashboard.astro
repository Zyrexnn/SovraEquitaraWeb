  ---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Panel — SovraEquitara">
  <div class="saas-layout">
    <!-- Desktop Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <div class="logo">
          <img src="/logo.svg" alt="SovraAdmin" style="height: 48px; width: auto;" />
        </div>
      </div>
      
      <nav class="nav-menu">
        <div class="nav-section">PANEL KONTROL</div>
        <a href="/admin/dashboard" class="nav-item active">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
          Antrean Laporan
        </a>
        <a href="/profile" class="nav-item">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          Profil Admin
        </a>
      </nav>

      <div class="sidebar-footer">
        <button id="btn-logout-desktop" class="btn-logout">
          <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
          Keluar (Admin)
        </button>
      </div>
    </aside>

    <!-- Mobile Top Bar -->
    <header class="mobile-header">
      <div class="logo">
        <img src="/logo.svg" alt="SovraAdmin" style="height: 32px; width: auto;" />
      </div>
      <div class="admin-badge">Admin Mode</div>
    </header>

    <!-- Main Content -->
    <main class="main-content scroll-slim">
      <div class="content-wrapper">
        
        <!-- Welcome Section -->
        <section class="welcome-section fade-in">
          <div class="hero-flex">
            <div>
              <h1 id="greeting">Antrean Verifikasi</h1>
              <p class="subtitle">Kelola dan validasi laporan warga secara real-time.</p>
            </div>
            <div class="stats-mini">
              <div class="s-box">
                <span class="s-lbl">Menunggu</span>
                <span class="s-val text-danger" id="stat-pending">0</span>
              </div>
              <div class="s-box">
                <span class="s-lbl">Selesai</span>
                <span class="s-val text-success" id="stat-resolved">0</span>
              </div>
            </div>
          </div>
        </section>

        <!-- Actions Row -->
        <div class="actions-row fade-in" style="animation-delay: 0.1s;">
          <div class="search-box">
            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" id="admin-search" placeholder="Cari berdasarkan lokasi atau masalah..." />
          </div>
          <div class="filters-group">
            <select id="category-filter" class="select-minimal">
              <option value="">Semua Kategori</option>
            </select>
            <select id="sort-select" class="select-minimal">
              <option value="recent">Waktu (Terbaru)</option>
              <option value="votes">Populer (Votes)</option>
              <option value="comments">Diskusi (Komentar)</option>
            </select>
          </div>
        </div>

        <!-- Table View -->
        <div class="table-card fade-in" style="animation-delay: 0.2s;">
          <div class="table-header">
            <div class="col-main">Laporan & Bukti</div>
            <div class="col-cat desktop-only">Kategori</div>
            <div class="col-stats desktop-only">Interaksi</div>
            <div class="col-actions">Tindakan</div>
          </div>
          
          <div class="table-body scroll-slim" id="admin-reports-list">
            <div class="feed-loading">
              <div class="spinner"></div>
              <p>Mengambil data...</p>
            </div>
          </div>
        </div>

      </div>
    </main>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <a href="/admin/dashboard" class="m-nav-item active">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
      </a>
      <a href="/profile" class="m-nav-item">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
      </a>
      <button id="btn-logout-mobile2" class="m-nav-item text-danger">
        <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline></svg>
      </button>
    </nav>

    <!-- Detail Modal -->
    <div id="detail-modal" class="modal-overlay hidden">
      <div class="modal-content large-modal">
        <div class="modal-header">
          <h3>Detail Laporan</h3>
          <button id="close-detail" class="btn-close-modal">&times;</button>
        </div>
        <div class="modal-body scroll-slim" style="padding: 0;">
          <div class="detail-layout">
            <div class="detail-info">
              <div id="detail-img-container" class="detail-img-box hidden">
                <img id="detail-img" src="" alt="Bukti Foto" />
              </div>
              <div class="detail-text">
                <div class="d-meta">
                  <span id="detail-cat" class="badge-cat"></span>
                  <span id="detail-status" class="badge-status"></span>
                  <span id="detail-date" class="text-date" style="margin-left:auto;"></span>
                </div>
                <h2 id="detail-desc"></h2>
                <div class="d-location">📍 <span id="detail-loc"></span></div>
                
                <div class="d-stats mt-4">
                  <div class="stat-pill">🔥 <span id="detail-votes">0</span> Dukungan</div>
                  <div class="stat-pill">💬 <span id="detail-comment-count">0</span> Diskusi</div>
                </div>

                <div class="admin-actions mt-4" id="detail-admin-actions">
                  <!-- Injected based on status -->
                </div>
              </div>
            </div>
            
            <div class="detail-comments">
              <h4>Diskusi</h4>
              <div id="comments-list" class="comments-container scroll-slim">
                <!-- Comments -->
              </div>
              <div class="comment-input-wrapper">
                <form id="form-comment" class="comment-input-group">
                  <input type="text" id="comment-input" placeholder="Balas sebagai Admin..." required autocomplete="off" />
                  <button type="submit" class="btn-send">
                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="modal-overlay hidden">
      <div class="lightbox-wrapper">
        <button id="lightbox-close" class="btn-close-modal">&times;</button>
        <img id="lightbox-img" src="" alt="Full view" />
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast-notification hidden">
      <span id="toast-icon">✓</span>
      <span id="toast-msg">Berhasil!</span>
    </div>
  </div>

  <!-- JavaScript Logic -->
  <script is:inline>
    const API_URL = 'http://localhost:3000';
    
    // Auth Check
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      const user = JSON.parse(userRaw);
      if ((user.role || '').toUpperCase() !== 'ADMIN') {
        window.location.href = '/dashboard';
      } else {
        document.addEventListener('DOMContentLoaded', initAdminDashboard);
      }
    }

    let allReports = [];
    let categories = [];
    let currentSearch = '';
    let currentCategory = '';
    let activeReportId = null;

    function initAdminDashboard() {
      loadCategories().then(() => fetchReports('recent'));

      document.getElementById('admin-search').addEventListener('input', (e) => {
        currentSearch = e.target.value.toLowerCase();
        applyFilters();
      });

      document.getElementById('category-filter').addEventListener('change', (e) => {
        currentCategory = e.target.value;
        applyFilters();
      });

      document.getElementById('sort-select').addEventListener('change', (e) => {
        fetchReports(e.target.value);
      });

      document.getElementById('lightbox-close').addEventListener('click', () => {
        document.getElementById('lightbox').classList.add('hidden');
      });

      document.getElementById('close-detail').addEventListener('click', () => {
        document.getElementById('detail-modal').classList.add('hidden');
      });

      document.getElementById('form-comment').addEventListener('submit', handleCommentSubmit);
      
      const doLogout = () => { localStorage.clear(); window.location.href = '/login'; };
      document.getElementById('btn-logout-desktop').addEventListener('click', doLogout);
      document.getElementById('btn-logout-mobile2').addEventListener('click', doLogout);
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
        
        const filterSelect = document.getElementById('category-filter');
        categories.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = c.name;
          filterSelect.appendChild(opt);
        });
      } catch (err) { console.error(err); }
    }

    function getCategoryName(id) {
      if(!id) return 'Umum';
      const cat = categories.find(c => c.id === id);
      return cat ? cat.name : 'Umum';
    }

    async function fetchReports(sort) {
      const list = document.getElementById('admin-reports-list');
      list.innerHTML = '<div class="feed-loading"><div class="spinner"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/admin/reports?sort=${sort}`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        allReports = data.data || [];
        applyFilters();
        updateStats(allReports);
      } catch (err) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat laporan.</div>';
      }
    }

    function applyFilters() {
      let filtered = allReports;
      if (currentSearch) {
        filtered = filtered.filter(r => 
          (r.description || '').toLowerCase().includes(currentSearch) || 
          (r.location_detail || '').toLowerCase().includes(currentSearch)
        );
      }
      if (currentCategory) {
        filtered = filtered.filter(r => String(r.category_id) === currentCategory);
      }
      renderReports(filtered);
    }

    function updateStats(reports) {
      document.getElementById('stat-pending').textContent = reports.filter(r => r.status === 'PENDING').length;
      document.getElementById('stat-resolved').textContent = reports.filter(r => r.status === 'RESOLVED').length;
    }

    function renderReports(items) {
      const list = document.getElementById('admin-reports-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="empty-state">Tidak ada laporan ditemukan.</div>';
        return;
      }
      list.innerHTML = items.map(r => {
        const catName = getCategoryName(r.category_id);
        const statusClass = r.status.toLowerCase();
        
        let actionBtn = `<span class="badge-status resolved">SELESAI</span>`;
        if (r.status === 'PENDING') {
          actionBtn = `<button class="btn-action btn-verify" onclick="event.stopPropagation(); window.doAction('${r.id}', 'verify')">Verifikasi</button>`;
        } else if (r.status === 'VALID') {
          actionBtn = `<button class="btn-action btn-resolve" onclick="event.stopPropagation(); window.doAction('${r.id}', 'resolve')">Selesaikan</button>`;
        }

        const imgBlock = r.image_url 
          ? `<div class="thumb" onclick="event.stopPropagation(); window.openImg('${API_URL}${r.image_url}')"><img src="${API_URL}${r.image_url}" alt="Img" /></div>`
          : `<div class="thumb empty"><svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg></div>`;

        return `
          <div class="table-row clickable" onclick="window.openDetail('${r.id}')">
            <div class="col-main flex-gap">
              ${imgBlock}
              <div class="row-info">
                <h4>${r.description}</h4>
                <p>📍 ${r.location_detail} • ${new Date(r.created_at).toLocaleDateString('id-ID')}</p>
                <div class="mobile-only mt-1">
                  <span class="badge-cat">${catName}</span>
                </div>
              </div>
            </div>
            <div class="col-cat desktop-only"><span class="badge-cat">${catName}</span></div>
            <div class="col-stats desktop-only">
              <span class="mini-stat">🔥 ${r.vote_count}</span>
              <span class="mini-stat">💬 ${r.comment_count}</span>
            </div>
            <div class="col-actions">
              ${actionBtn}
            </div>
          </div>
        `;
      }).join('');
    }

    window.openDetail = (id) => {
      activeReportId = id;
      const r = allReports.find(x => x.id === id);
      if(!r) return;

      if(r.image_url) {
        document.getElementById('detail-img').src = API_URL + r.image_url;
        document.getElementById('detail-img-container').classList.remove('hidden');
      } else {
        document.getElementById('detail-img-container').classList.add('hidden');
      }

      document.getElementById('detail-desc').textContent = r.description;
      document.getElementById('detail-loc').textContent = r.location_detail;
      document.getElementById('detail-cat').textContent = getCategoryName(r.category_id);
      document.getElementById('detail-date').textContent = new Date(r.created_at).toLocaleDateString('id-ID');
      
      const st = document.getElementById('detail-status');
      st.textContent = r.status;
      st.className = `badge-status ${r.status.toLowerCase()}`;

      document.getElementById('detail-votes').textContent = r.vote_count;
      document.getElementById('detail-comment-count').textContent = r.comment_count;

      // Admin Actions in Modal
      const actionsDiv = document.getElementById('detail-admin-actions');
      if(r.status === 'PENDING') {
        actionsDiv.innerHTML = `<button class="btn-primary w-full" style="background:#0F172A;" onclick="window.doAction('${r.id}', 'verify')">Verifikasi Laporan Ini</button>`;
      } else if (r.status === 'VALID') {
        actionsDiv.innerHTML = `<button class="btn-primary w-full" style="background:#3B82F6;" onclick="window.doAction('${r.id}', 'resolve')">Tandai Selesai</button>`;
      } else {
        actionsDiv.innerHTML = `<div class="badge-status resolved" style="display:block;text-align:center;padding:12px;">LAPORAN SELESAI DITANGANI</div>`;
      }

      document.getElementById('detail-modal').classList.remove('hidden');
      loadComments(id);
    };

    window.openImg = (url) => {
      document.getElementById('lightbox-img').src = url;
      document.getElementById('lightbox').classList.remove('hidden');
    };

    window.doAction = async (id, action) => {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports/${id}/${action}`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.ok) {
          showToast(`Laporan berhasil di${action === 'verify' ? 'verifikasi' : 'selesaikan'}`);
          fetchReports(document.getElementById('sort-select').value);
          // if modal is open and shows same report, update it
          if(activeReportId === id) {
             document.getElementById('detail-modal').classList.add('hidden');
          }
        } else {
          showToast('Gagal memproses', 'error');
        }
      } catch (err) {
        showToast('Kesalahan jaringan', 'error');
      }
    };

    async function loadComments(id) {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="feed-loading"><div class="spinner"></div></div>';
      try {
        const res = await fetch(`${API_URL}/api/reports/${id}/comments`);
        const data = await res.json();
        const comments = data.data || [];
        if(comments.length === 0) {
          list.innerHTML = '<div class="empty-state">Belum ada diskusi.</div>';
          return;
        }
        list.innerHTML = comments.map(c => `
          <div class="comment-bubble">
            <div class="c-head">
              <strong>${c.user?.full_name || (c.user?.role === 'admin' ? 'Admin' : 'Warga')}</strong> 
              <span>${new Date(c.created_at).toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'})}</span>
            </div>
            <div class="c-body">${c.content}</div>
          </div>
        `).join('');
        list.scrollTop = list.scrollHeight;
      } catch(e) {
        list.innerHTML = '<div class="empty-state text-danger">Gagal memuat diskusi.</div>';
      }
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      if(!activeReportId) return;
      const input = document.getElementById('comment-input');
      if(!input.value.trim()) return;

      const btn = e.target.querySelector('.btn-send');
      btn.disabled = true;
      
      try {
        const res = await fetch(`${API_URL}/api/reports/${activeReportId}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ content: input.value })
        });
        if(res.ok) {
          input.value = '';
          loadComments(activeReportId);
          fetchReports(document.getElementById('sort-select').value);
        }
      } catch(err) {}
      btn.disabled = false;
    }

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      const i = document.getElementById('toast-icon');
      const m = document.getElementById('toast-msg');
      
      t.className = `toast-notification ${type}`;
      i.textContent = type === 'error' ? '!' : '✓';
      m.textContent = msg;
      
      t.classList.remove('hidden');
      setTimeout(() => t.classList.add('hidden'), 3000);
    }
  </script>

  <style is:global>
    /* =========================================
       Zen SaaS Architecture (Admin)
       ========================================= */
    
    :root {
      --c-bg: #F8FAFC;
      --c-surface: #FFFFFF;
      --c-text: #0F172A;
      --c-text-soft: #64748B;
      --c-border: #E2E8F0;
      --c-brand: #0F172A;
      --c-accent: #3B82F6;
      --c-danger: #EF4444;
      --c-success: #10B981;
      
      --radius-sm: 8px;
      --radius-md: 16px;
      --radius-lg: 24px;
      
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,0.05);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', system-ui, sans-serif; }
    body { background: var(--c-bg); color: var(--c-text); -webkit-font-smoothing: antialiased; }

    /* Layout */
    .saas-layout { display: flex; height: 100vh; overflow: hidden; }
    
    /* Sidebar Desktop */
    .sidebar { display: none; width: 280px; background: var(--c-surface); border-right: 1px solid var(--c-border); flex-direction: column; z-index: 100; }
    .sidebar-header { padding: 32px 24px; }
    .logo { display: flex; align-items: center; gap: 12px; }
    .logo-text { font-weight: 800; font-size: 20px; letter-spacing: -0.03em; }
    
    .nav-menu { flex: 1; padding: 0 16px; display: flex; flex-direction: column; gap: 4px; }
    .nav-section { font-size: 11px; font-weight: 700; color: var(--c-text-soft); padding: 16px 12px 8px; letter-spacing: 0.05em; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 12px; border-radius: var(--radius-sm); color: var(--c-text-soft); text-decoration: none; font-size: 14px; font-weight: 600; transition: 0.2s; }
    .nav-item:hover { background: var(--c-bg); color: var(--c-text); }
    .nav-item.active { background: var(--c-bg); color: var(--c-brand); }
    
    .sidebar-footer { padding: 24px 16px; border-top: 1px solid var(--c-border); }
    .btn-logout { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; background: transparent; border: 1px solid var(--c-border); border-radius: var(--radius-sm); color: var(--c-danger); font-weight: 600; cursor: pointer; transition: 0.2s; }
    .btn-logout:hover { background: #FEF2F2; border-color: #FECACA; }

    /* Mobile Nav */
    .mobile-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; background: var(--c-surface); border-bottom: 1px solid var(--c-border); position: sticky; top: 0; z-index: 90; }
    .admin-badge { background: var(--c-brand); color: white; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; }
    
    .mobile-nav { display: flex; justify-content: space-around; align-items: center; position: fixed; bottom: 0; left: 0; right: 0; height: 64px; background: var(--c-surface); border-top: 1px solid var(--c-border); z-index: 100; padding-bottom: env(safe-area-inset-bottom); }
    .m-nav-item { padding: 8px 24px; color: var(--c-text-soft); border-radius: 12px; border: none; background: none; }
    .m-nav-item.active { color: var(--c-brand); background: var(--c-bg); }
    .text-danger { color: var(--c-danger) !important; }

    /* Main Area */
    .main-content { flex: 1; overflow-y: auto; background: var(--c-bg); padding-bottom: 80px; }
    .content-wrapper { max-width: 1200px; margin: 0 auto; padding: 24px 20px; }
    
    @media (min-width: 768px) {
      .sidebar { display: flex; }
      .mobile-header, .mobile-nav { display: none; }
      .main-content { padding-bottom: 0; }
      .content-wrapper { padding: 40px 48px; }
    }

    /* Typography & Core */
    .welcome-section { margin-bottom: 32px; }
    .hero-flex { display: flex; flex-direction: column; gap: 20px; }
    @media (min-width: 768px) { .hero-flex { flex-direction: row; justify-content: space-between; align-items: flex-end; } }
    h1 { font-size: 28px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px; }
    .subtitle { color: var(--c-text-soft); font-size: 15px; }

    .stats-mini { display: flex; gap: 16px; }
    .s-box { background: var(--c-surface); border: 1px solid var(--c-border); padding: 12px 20px; border-radius: var(--radius-sm); display: flex; flex-direction: column; min-width: 120px; box-shadow: var(--shadow-sm); }
    .s-lbl { font-size: 11px; font-weight: 700; color: var(--c-text-soft); text-transform: uppercase; }
    .s-val { font-size: 24px; font-weight: 800; line-height: 1.2; }
    .text-danger { color: var(--c-danger); }
    .text-success { color: var(--c-success); }

    /* Actions Row */
