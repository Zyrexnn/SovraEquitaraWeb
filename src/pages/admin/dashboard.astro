---
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — SovraEquitara</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  
  <style is:global>
    /* Admin Dashboard Styles - Zen Minimalist */
    :root {
      --zen-bg: #fbfbfb;
      --zen-sidebar-bg: #ffffff;
      --zen-card-bg: #ffffff;
      --zen-border: #f0f0f0;
      --zen-text-primary: #1a1a1a;
      --zen-text-secondary: #777777;
      --zen-accent: #000000;
      --zen-radius: 20px;
    }

    body {
      margin: 0;
      font-family: 'DM Sans', sans-serif;
      background: var(--zen-bg);
      color: var(--zen-text-primary);
      -webkit-font-smoothing: antialiased;
    }

    .zen-admin-root { display: flex; min-height: 100vh; }

    /* Sidebar */
    .zen-sidebar {
      width: 280px;
      background: var(--zen-sidebar-bg);
      border-right: 1px solid var(--zen-border);
      display: flex;
      flex-direction: column;
      position: fixed;
      height: 100vh;
      z-index: 100;
    }

    .sidebar-header { padding: 40px 32px; display: flex; justify-content: flex-start; }
    .logo-mark { height: 32px; }

    .sidebar-nav { padding: 0 16px; flex: 1; }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      text-decoration: none;
      color: var(--zen-text-secondary);
      font-weight: 600;
      font-size: 14px;
      border-radius: 14px;
      margin-bottom: 6px;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav-item:hover { background: #f5f5f5; color: var(--zen-text-primary); }
    .nav-item.active { background: #1a1a1a; color: white; box-shadow: 0 8px 20px rgba(0,0,0,0.1); }

    .sidebar-footer { padding: 24px; border-top: 1px solid var(--zen-border); }
    .admin-profile { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding: 12px; background: #fafafa; border-radius: 16px; }
    .profile-avatar { width: 40px; height: 40px; background: #eee; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 800; }
    .profile-info { flex: 1; }
    .profile-name { font-size: 14px; font-weight: 700; color: #1a1a1a; }
    .profile-status { font-size: 11px; color: #10b981; font-weight: 700; text-transform: uppercase; }

    .logout-btn {
      width: 100%;
      padding: 12px;
      border: 1px solid var(--zen-border);
      background: white;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 700;
      font-size: 13px;
      transition: 0.2s;
    }
    .logout-btn:hover { background: #fff5f5; border-color: #feb2b2; color: #e53e3e; }

    /* Main Content */
    .zen-main { flex: 1; margin-left: 280px; padding: 60px; }
    .main-container { max-width: 1100px; margin: 0 auto; }

    .page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 48px; }
    .page-title { font-size: 36px; font-weight: 800; margin: 0 0 8px 0; letter-spacing: -0.02em; }
    .page-subtitle { color: var(--zen-text-secondary); font-size: 16px; font-weight: 500; }

    .time-display {
      font-family: 'JetBrains Mono', monospace;
      font-size: 13px;
      font-weight: 700;
      background: #1a1a1a;
      color: white;
      padding: 10px 20px;
      border-radius: 99px;
    }

    /* Stats */
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 48px; }
    .stat-card { background: white; border: 1px solid var(--zen-border); border-radius: var(--zen-radius); padding: 32px; transition: 0.3s; }
    .stat-card:hover { border-color: #1a1a1a; transform: translateY(-4px); }
    .stat-label { font-size: 11px; font-weight: 800; color: #aaa; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 16px; }
    .stat-value { font-size: 40px; font-weight: 800; margin-bottom: 4px; line-height: 1; }
    
    .stat-pending .stat-value { color: #d97706; }
    .stat-verified .stat-value { color: #2563eb; }
    .stat-resolved .stat-value { color: #16a34a; }

    /* Data Table */
    .data-table-container { background: white; border: 1px solid var(--zen-border); border-radius: var(--zen-radius); overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.03); }
    .table-controls { padding: 24px; border-bottom: 1px solid var(--zen-border); display: flex; gap: 20px; align-items: center; background: #fafafa; }
    
    .search-input-wrapper { flex: 1; position: relative; }
    .search-input-wrapper svg { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #999; }
    .search-input-wrapper input {
      width: 100%; padding: 14px 16px 14px 48px; border: 1px solid var(--zen-border);
      border-radius: 14px; font-size: 14px; font-weight: 500; outline: none; transition: 0.2s;
    }
    .search-input-wrapper input:focus { border-color: #1a1a1a; background: white; box-shadow: 0 0 0 4px rgba(0,0,0,0.03); }

    .filter-select { padding: 14px 20px; border: 1px solid var(--zen-border); border-radius: 14px; font-size: 14px; font-weight: 600; background: white; cursor: pointer; outline: none; }

    .zen-table { width: 100%; border-collapse: collapse; }
    .zen-table th { text-align: left; padding: 20px 24px; font-size: 11px; font-weight: 800; text-transform: uppercase; color: #999; letter-spacing: 0.1em; border-bottom: 1px solid var(--zen-border); }
    .zen-table td { padding: 24px; border-bottom: 1px solid var(--zen-border); vertical-align: middle; }
    .zen-table tr { transition: 0.2s; cursor: pointer; }
    .zen-table tr:hover { background: #fafafa; }

    .thumb-preview { width: 56px; height: 56px; background: #f0f0f0; border-radius: 12px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid #eee; }
    .thumb-preview img { width: 100%; height: 100%; object-fit: contain; }

    .report-desc { display: block; font-weight: 700; font-size: 16px; margin-bottom: 6px; color: #1a1a1a; }
    .report-meta { display: flex; align-items: center; gap: 16px; font-size: 12px; color: #999; font-weight: 500; }
    .zen-cat-tag { color: #1a1a1a; font-weight: 700; text-transform: uppercase; font-size: 10px; padding: 2px 8px; background: #eee; border-radius: 4px; }

    .zen-status-pill { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 99px; font-size: 11px; font-weight: 800; text-transform: uppercase; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
    .status-pending { background: #fffbeb; color: #d97706; }
    .status-valid { background: #eff6ff; color: #2563eb; }
    .status-resolved { background: #f0fdf4; color: #16a34a; }

    .vote-badge { padding: 6px 12px; background: #f0f0f0; border-radius: 8px; font-size: 14px; font-weight: 800; }

    /* Modal */
    .modal { position: fixed; inset: 0; z-index: 1000; display: none; align-items: center; justify-content: center; padding: 40px; }
    .modal.active { display: flex; }
    .modal-backdrop { position: absolute; inset: 0; background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(10px); }
    .modal-dialog { position: relative; width: 100%; max-width: 1000px; max-height: 90vh; background: white; border-radius: 32px; display: flex; flex-direction: column; overflow: hidden; box-shadow: 0 40px 100px rgba(0,0,0,0.3); }
    .modal-header { padding: 32px; border-bottom: 1px solid var(--zen-border); display: flex; justify-content: space-between; align-items: center; }
    .modal-body { flex: 1; overflow-y: auto; padding: 40px; }
    .modal-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
    .detail-img-container { width: 100%; aspect-ratio: 1; background: #f5f5f5; border-radius: 20px; display: flex; align-items: center; justify-content: center; overflow: hidden; border: 1px solid #eee; }
    .detail-img-container img { max-width: 90%; max-height: 90%; object-fit: contain; }
    .detail-label { font-size: 11px; font-weight: 800; color: #999; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; display: block; }
    .detail-text { font-size: 18px; font-weight: 600; color: #1a1a1a; line-height: 1.6; margin-bottom: 32px; }

    @media (max-width: 1024px) {
      .zen-sidebar { transform: translateX(-100%); }
      .zen-sidebar.mobile-open { transform: translateX(0); }
      .zen-main { margin-left: 0; padding: 32px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
  <div class="zen-admin-root" id="admin-root" data-api-url={API_URL}>
    
    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="mobile-menu-btn">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Zen Sidebar -->
    <aside class="zen-sidebar">
      <div class="sidebar-header">
        <img src="/logo.svg" alt="SovraEquitara" class="logo-mark" />
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item active">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          </svg>
          <span>Dashboard</span>
        </a>
        <a href="/admin/profile" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>Profile</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="admin-profile">
          <div class="profile-avatar">A</div>
          <div class="profile-info">
            <div class="profile-name">Admin</div>
            <div class="profile-status">Online</div>
          </div>
        </div>
        <button id="logout-btn" class="logout-btn">Logout</button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="zen-main">
      <div class="main-container">
        
        <header class="page-header">
          <div>
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Pusat Kendali Pelaporan Kota</p>
          </div>
          <div id="live-time" class="time-display">--:--:-- WIB</div>
        </header>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-label">TOTAL REPORTS</div>
            <div id="stat-total" class="stat-value">0</div>
          </div>
          <div class="stat-card stat-pending">
            <div class="stat-label">PENDING REVIEW</div>
            <div id="stat-pending" class="stat-value">0</div>
          </div>
          <div class="stat-card stat-verified">
            <div class="stat-label">VERIFIED</div>
            <div id="stat-verified" class="stat-value">0</div>
          </div>
          <div class="stat-card stat-resolved">
            <div class="stat-label">RESOLVED</div>
            <div id="stat-resolved" class="stat-value">0</div>
          </div>
        </div>

        <div class="data-table-container">
          <div class="table-controls">
            <div class="search-input-wrapper">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
              </svg>
              <input type="text" id="search-input" placeholder="Cari laporan berdasarkan deskripsi atau lokasi..." />
            </div>
            <div class="filter-group">
              <select id="category-filter" class="filter-select">
                <option value="">Semua Kategori</option>
              </select>
              <select id="status-filter" class="filter-select">
                <option value="">Semua Status</option>
                <option value="PENDING">Pending</option>
                <option value="VALID">Verified</option>
                <option value="RESOLVED">Resolved</option>
              </select>
            </div>
          </div>

          <table class="zen-table">
            <thead>
              <tr>
                <th>Prev</th>
                <th>Laporan & Lokasi</th>
                <th>Status</th>
                <th>Dukungan</th>
                <th style="text-align: right;">Tanggal</th>
              </tr>
            </thead>
            <tbody id="reports-tbody">
              <!-- Rendered by JS -->
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>

  <!-- Report Modal -->
  <div id="report-modal" class="modal">
    <div class="modal-backdrop" onclick="closeModal()"></div>
    <div class="modal-dialog">
      <div class="modal-header">
        <h3 id="modal-title" class="modal-title">Detail Laporan</h3>
        <button class="modal-close" onclick="closeModal()">×</button>
      </div>
      <div class="modal-body">
        <div class="modal-grid">
          <div class="detail-img-container">
            <img id="detail-img" src="/placeholder-report.png" alt="Report Image" />
          </div>
          <div class="detail-info">
            <div class="detail-section">
              <label class="detail-label">DESKRIPSI</label>
              <p id="detail-desc" class="detail-text"></p>
            </div>
            <div class="detail-section">
              <label class="detail-label">LOKASI</label>
              <p id="detail-loc" class="detail-text"></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    let API_URL = '';
    let allReports = [];
    let categories = [];

    async function initDashboard(apiUrl) {
      API_URL = apiUrl;
      
      // Initial fetch
      await loadData();
      
      // UI Updates
      updateTime();
      setInterval(updateTime, 1000);

      // Event Listeners
      document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
        document.querySelector('.zen-sidebar')?.classList.toggle('mobile-open');
      });

      document.getElementById('logout-btn')?.addEventListener('click', () => {
        localStorage.removeItem('access_token');
        localStorage.removeItem('user');
        window.location.href = '/admin/login';
      });

      const filterInputs = ['search-input', 'category-filter', 'status-filter'];
      filterInputs.forEach(id => {
        document.getElementById(id)?.addEventListener('input', filterReports);
      });
    }

    function updateTime() {
      const el = document.getElementById('live-time');
      if (el) {
        el.innerText = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) + ' WIB';
      }
    }

    async function loadData() {
      try {
        const token = localStorage.getItem('access_token');
        if (!token) {
          window.location.href = '/admin/login';
          return;
        }

        const [catRes, reportRes] = await Promise.all([
          fetch(`${API_URL}/api/categories`),
          fetch(`${API_URL}/api/admin/reports`, {
            headers: { 'Authorization': `Bearer ${token}` }
          })
        ]);

        const catData = await catRes.json();
        const reportData = await reportRes.json();

        categories = catData.data || [];
        allReports = reportData.data || [];

        renderCategories();
        renderStats();
        renderReports(allReports);
      } catch (err) {
        console.error('Data load error:', err);
      }
    }

    function renderCategories() {
      const filter = document.getElementById('category-filter');
      if (filter) {
        filter.innerHTML = '<option value="">Semua Kategori</option>' + 
          categories.map(c => `<option value="${c.id}">${c.name}</option>`).join('');
      }
    }

    function renderStats() {
      document.getElementById('stat-total').innerText = allReports.length;
      document.getElementById('stat-pending').innerText = allReports.filter(r => r.status === 'PENDING').length;
      document.getElementById('stat-verified').innerText = allReports.filter(r => r.status === 'VALID').length;
      document.getElementById('stat-resolved').innerText = allReports.filter(r => r.status === 'RESOLVED').length;
    }

    function renderReports(reports) {
      const tbody = document.getElementById('reports-tbody');
      if (!tbody) return;

      if (reports.length === 0) {
        tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding: 60px; color: #999; font-weight: 600;">Belum ada laporan masuk</td></tr>';
        return;
      }

      tbody.innerHTML = reports.map(report => {
        const cat = categories.find(c => c.id === report.category_id);
        const catName = cat ? cat.name : 'Umum';
        const statusClass = report.status.toLowerCase();
        const date = new Date(report.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' });
        const imageUrl = report.image_url ? `${API_URL}${report.image_url}` : null;

        return `
          <tr onclick="openReportModal('${report.id}')">
            <td>
              <div class="thumb-preview">
                ${imageUrl ? `<img src="${imageUrl}" alt="Preview" onerror="this.style.display='none'; this.parentElement.innerHTML='🖼️'" />` : '🖼️'}
              </div>
            </td>
            <td>
              <span class="report-desc">${report.description}</span>
              <div class="report-meta">
                <span class="zen-cat-tag">${catName}</span>
                <span>${report.location_detail}</span>
              </div>
            </td>
            <td>
              <div class="zen-status-pill status-${statusClass}">
                <span class="status-dot"></span>
                ${report.status}
              </div>
            </td>
            <td><div class="vote-badge">${report.vote_count}</div></td>
            <td style="text-align: right; color: #bbb; font-weight: 600;">${date}</td>
          </tr>
        `;
      }).join('');
    }

    function filterReports() {
      const searchTerm = document.getElementById('search-input').value.toLowerCase();
      const categoryId = document.getElementById('category-filter').value;
      const status = document.getElementById('status-filter').value;

      const filtered = allReports.filter(report => {
        const matchSearch = report.description.toLowerCase().includes(searchTerm) || report.location_detail.toLowerCase().includes(searchTerm);
        const matchCategory = !categoryId || String(report.category_id) === categoryId;
        const matchStatus = !status || report.status === status;
        return matchSearch && matchCategory && matchStatus;
      });

      renderReports(filtered);
    }

    window.openReportModal = (id) => {
      const modal = document.getElementById('report-modal');
      const report = allReports.find(r => r.id === id);
      if (!report || !modal) return;
      
      modal.classList.add('active');
      document.getElementById('detail-desc').innerText = report.description;
      document.getElementById('detail-loc').innerText = report.location_detail;
      const img = document.getElementById('detail-img');
      if (img) img.src = report.image_url ? `${API_URL}${report.image_url}` : '';
    };

    window.closeModal = () => {
      document.getElementById('report-modal')?.classList.remove('active');
    };
  </script>

  <script define:vars={{ API_URL }}>
    initDashboard(API_URL);
  </script>
</body>
</html>
