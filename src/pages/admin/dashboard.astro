---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Panel — SovraEquitara">
  <div class="dashboard-wrapper">
    <!-- Sidebar -->
    <aside class="sidebar-nav">
      <div class="nav-brand">
        <div class="brand-logo-pill">
          <img src="/logo.svg" alt="Sovra" />
        </div>
      </div>
      <nav class="nav-links">
        <a href="/admin/dashboard" class="nav-link active" title="Admin Dashboard">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        </a>
      </nav>
      <div class="nav-footer">
        <button id="btn-logout" class="nav-link logout-link" title="Keluar">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="main-viewport scroll-slim">
      <header class="top-nav">
        <div class="welcome-msg">
          <h1>Panel Verifikasi</h1>
          <p>Tinjau kontribusi infrastruktur dari seluruh warga.</p>
        </div>
        <div class="top-actions">
          <div class="admin-badge">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
            ADMIN MODE
          </div>
        </div>
      </header>

      <div class="bento-container">
        <!-- Admin Stats Card -->
        <div class="bento-item glass card-hero animate-up" style="grid-column: span 12;">
          <div class="hero-header-flex">
            <div>
              <h3>Ikhtisar Laporan</h3>
              <p>Status distribusi seluruh laporan masuk</p>
            </div>
          </div>
          
          <div class="zen-visual admin-visual">
            <div class="blob blob-main">
              <span class="blob-val" id="stat-pending">0</span>
              <span class="blob-label">Menunggu</span>
            </div>
            <div class="blob blob-sub-1">
              <span class="blob-val" id="stat-valid">0</span>
              <span class="blob-label">Valid</span>
            </div>
            <div class="blob blob-sub-2">
              <span class="blob-val" id="stat-resolved">0</span>
              <span class="blob-label">Selesai</span>
            </div>
          </div>
        </div>

        <!-- Reports Queue -->
        <div class="bento-item glass animate-up delay-1" style="grid-column: span 12;">
          <div class="card-header-flex">
            <h3>Antrean Verifikasi</h3>
            <div class="search-mini">
              <input type="text" placeholder="Filter..." />
            </div>
          </div>
          
          <div class="zen-table-wrapper scroll-slim">
            <table class="zen-table">
              <thead>
                <tr>
                  <th>Informasi Laporan</th>
                  <th>Lokasi</th>
                  <th>Status</th>
                  <th>Tindakan</th>
                </tr>
              </thead>
              <tbody id="reports-tbody">
                <tr><td colspan="4" class="empty-state">Memuat data verifikasi...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <div id="toast" class="toast-bento"></div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/login';
    } else {
      const user = JSON.parse(userRaw);
      if (user.role !== 'admin' && user.role !== 'ADMIN') window.location.href = '/dashboard';
    }

    async function fetchReports() {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        renderReports(data.data || []);
      } catch (err) { showToast('Gagal memuat data', 'error'); }
    }

    function renderReports(reports) {
      const tbody = document.getElementById('reports-tbody');
      
      document.getElementById('stat-pending').textContent = reports.filter(r => r.status === 'PENDING').length;
      document.getElementById('stat-valid').textContent = reports.filter(r => r.status === 'VALID').length;
      document.getElementById('stat-resolved').textContent = reports.filter(r => r.status === 'RESOLVED').length;

      if(reports.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="empty-state">Belum ada laporan masuk.</td></tr>';
        return;
      }

      tbody.innerHTML = reports.map(r => `
        <tr class="zen-row-admin">
          <td>
            <div class="admin-cell-main">
              <span class="id-tag">#${String(r.id).substring(0,6)}</span>
              <h4>${r.description}</h4>
            </div>
          </td>
          <td>
            <a href="https://maps.google.com/?q=${r.latitude},${r.longitude}" target="_blank" class="zen-loc-btn">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path></svg>
              Peta
            </a>
          </td>
          <td>
            <span class="zen-status-pill ${r.status.toLowerCase()}">${r.status}</span>
          </td>
          <td>
            <div class="zen-action-group">
              ${r.status === 'PENDING' ? 
                `<button class="zen-btn-action valid" onclick="updateStatus('${r.id}', 'verify')">Validasi</button>` : ''}
              ${r.status === 'VALID' ? 
                `<button class="zen-btn-action finish" onclick="updateStatus('${r.id}', 'resolve')">Selesai</button>` : ''}
              ${r.status === 'RESOLVED' ? 
                `<span class="zen-done-tag"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg> Selesai</span>` : ''}
            </div>
          </td>
        </tr>
      `).join('');
    }

    window.updateStatus = async (id, action) => {
      const res = await fetch(`${API_URL}/api/admin/reports/${id}/${action}`, {
        method: 'PATCH',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      if (res.ok) { showToast('Status Diperbarui!'); fetchReports(); }
      else { showToast('Gagal update', 'error'); }
    };

    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast');
      t.textContent = msg; t.className = `toast-bento show ${type}`;
      setTimeout(() => t.className = 'toast-bento', 3000);
    }

    document.getElementById('btn-logout').onclick = () => { localStorage.clear(); window.location.href = '/login'; };
    fetchReports();
  </script>
</Layout>

<style>
  .admin-badge {
    background: var(--color-brand); color: white;
    padding: 10px 20px; border-radius: 99px; font-size: 11px; font-weight: 800;
    display: flex; align-items: center; gap: 8px; letter-spacing: 0.1em;
  }

  .hero-header-flex { display: flex; justify-content: space-between; align-items: flex-start; }
  .hero-header-flex h3 { font-size: 20px; font-weight: 800; }
  .hero-header-flex p { font-size: 13px; color: var(--color-text-muted); }

  .admin-visual { height: 260px; margin-top: var(--space-xl); }
  .blob-main { background: rgba(255, 118, 117, 0.4); } /* Pending uses danger/coral */
  .blob-sub-1 { background: rgba(249, 212, 35, 0.4); color: var(--color-brand); left: 30%; } /* Valid uses accent */
  .blob-sub-2 { background: rgba(26, 26, 26, 0.5); color: white; right: 30%; } /* Resolved uses brand */

  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }
  .blob { animation: float 8s infinite ease-in-out; }

  /* Table Styles */
  .zen-table-wrapper { margin-top: var(--space-xl); overflow-x: auto; }
  .zen-table { width: 100%; border-collapse: collapse; text-align: left; min-width: 600px; }
  .zen-table th { padding: 12px 16px; font-size: 11px; font-weight: 800; color: var(--color-text-muted); text-transform: uppercase; border-bottom: 1px solid var(--color-border); }
  .zen-table td { padding: 20px 16px; border-bottom: 1px solid var(--color-border); vertical-align: middle; }

  .admin-cell-main .id-tag { font-size: 10px; font-weight: 800; color: var(--color-text-muted); display: block; margin-bottom: 4px; }
  .admin-cell-main h4 { font-size: 14px; font-weight: 700; color: var(--color-text-title); }

  .zen-loc-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 8px; background: var(--color-bg);
    color: var(--color-text-body); text-decoration: none; font-size: 12px; font-weight: 700;
  }
  .zen-loc-btn:hover { background: var(--color-accent); color: var(--color-brand); }

  .zen-status-pill { font-size: 10px; font-weight: 800; padding: 4px 10px; border-radius: 6px; text-transform: uppercase; }
  .zen-status-pill.pending { background: rgba(255, 118, 117, 0.1); color: var(--color-danger); }
  .zen-status-pill.valid { background: rgba(249, 212, 35, 0.1); color: var(--color-brand); }
  .zen-status-pill.resolved { background: rgba(26, 26, 26, 0.05); color: var(--color-brand); }

  .zen-action-group { display: flex; gap: 8px; }
  .zen-btn-action {
    padding: 8px 16px; border-radius: 10px; border: none; cursor: pointer;
    font-size: 11px; font-weight: 800; transition: all 0.3s;
  }
  .zen-btn-action.valid { background: var(--color-accent); color: var(--color-brand); }
  .zen-btn-action.finish { background: var(--color-brand); color: white; }
  .zen-btn-action:hover { transform: scale(1.05); box-shadow: var(--shadow-soft); }

  .zen-done-tag { font-size: 12px; font-weight: 700; color: var(--color-text-muted); display: flex; align-items: center; gap: 4px; }

  .search-mini input {
    background: var(--color-bg); border: 1px solid var(--color-border);
    padding: 8px 16px; border-radius: 10px; font-size: 12px; font-family: inherit;
  }

  @media (max-width: 1024px) {
    .zen-table td { padding: 16px 8px; }
    .zen-btn-action { padding: 6px 10px; font-size: 10px; }
    .admin-visual { height: 200px; }
    .blob-main { width: 140px; height: 140px; }
    .blob-sub-1, .blob-sub-2 { width: 90px; height: 90px; }
  }
</style>
