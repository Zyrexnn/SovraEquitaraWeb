---
// Admin Dashboard - Zen Minimalist SaaS Design
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard — SovraEquitara</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="zen-admin-root">
    
    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="mobile-menu-btn">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Zen Sidebar -->
    <aside class="zen-sidebar">
      <div class="sidebar-header">
        <img src="/logo.svg" alt="SovraEquitara" class="logo-mark" />
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item active">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          </svg>
          <span>Dashboard</span>
        </a>
        <a href="/admin/profile" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>Profile</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="admin-profile">
          <div class="profile-avatar">A</div>
          <div class="profile-info">
            <div class="profile-name">Admin</div>
            <div class="profile-status">Online</div>
          </div>
        </div>
        <button id="logout-btn" class="logout-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          Logout
        </button>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="zen-main">
      <div class="main-container">
        
        <!-- Header -->
        <header class="page-header">
          <div>
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Monitor dan kelola laporan infrastruktur kota</p>
          </div>
          <div class="header-actions">
            <div id="live-time" class="time-display"></div>
          </div>
        </header>

        <!-- Stats Grid -->
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-label">Total Laporan</div>
            <div id="stat-total" class="stat-value">0</div>
            <div class="stat-change">Semua waktu</div>
          </div>
          <div class="stat-card stat-pending">
            <div class="stat-label">Pending</div>
            <div id="stat-pending" class="stat-value">0</div>
            <div class="stat-change">Perlu review</div>
          </div>
          <div class="stat-card stat-verified">
            <div class="stat-label">Verified</div>
            <div id="stat-verified" class="stat-value">0</div>
            <div class="stat-change">Dalam proses</div>
          </div>
          <div class="stat-card stat-resolved">
            <div class="stat-label">Resolved</div>
            <div id="stat-resolved" class="stat-value">0</div>
            <div class="stat-change">Selesai</div>
          </div>
        </div>

        <!-- Charts Section -->
        <div class="charts-grid">
          <div class="chart-card">
            <div class="card-header">
              <h3 class="card-title">Laporan Mingguan</h3>
              <div class="live-indicator">
                <span class="pulse-dot"></span>
                Live
              </div>
            </div>
            <div class="chart-wrapper">
              <canvas id="weeklyChart"></canvas>
            </div>
          </div>
          
          <div class="chart-card">
            <div class="card-header">
              <h3 class="card-title">Kategori</h3>
            </div>
            <div class="chart-wrapper chart-center">
              <canvas id="categoryChart"></canvas>
              <div id="no-category-data" class="empty-chart hidden">Tidak ada data</div>
            </div>
          </div>
        </div>

        <!-- Filters -->
        <div class="filters-bar">
          <div class="search-box">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
            <input type="text" id="search-input" placeholder="Cari laporan..." />
          </div>
          <div class="filter-group">
            <select id="category-filter" class="filter-select">
              <option value="">Semua Kategori</option>
            </select>
            <select id="status-filter" class="filter-select">
              <option value="">Semua Status</option>
              <option value="PENDING">Pending</option>
              <option value="VALID">Verified</option>
              <option value="RESOLVED">Resolved</option>
            </select>
            <select id="sort-select" class="filter-select">
              <option value="recent">Terbaru</option>
              <option value="votes">Populer</option>
            </select>
          </div>
        </div>

        <!-- Reports List -->
        <div class="reports-section">
          <div class="section-header">
            <h2 class="section-title">Laporan</h2>
            <div class="live-badge">
              <span class="pulse-dot"></span>
              Live Monitor
            </div>
          </div>
          <div id="reports-list" class="reports-list">
            <!-- Reports will be injected here -->
          </div>
        </div>

      </div>
    </main>

    <!-- Modal -->
    <div id="detail-modal" class="modal hidden">
      <div class="modal-backdrop"></div>
      <div class="modal-dialog">
        <div class="modal-header">
          <h2 class="modal-title">Detail Laporan</h2>
          <button id="close-modal" class="modal-close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <div class="modal-body">
          <div class="modal-content-grid">
            <!-- Left: Report Details -->
            <div class="report-details">
              <div id="report-image-container" class="report-image hidden">
                <img id="report-image" src="" alt="Report" />
              </div>
              
              <div class="detail-section">
                <div class="badge-group">
                  <span id="detail-category" class="badge badge-category"></span>
                  <span id="detail-status" class="badge badge-status"></span>
                </div>
                <h3 id="detail-description" class="detail-title"></h3>
              </div>

              <div class="detail-section">
                <div class="detail-label">Lokasi</div>
                <div id="detail-location" class="detail-text"></div>
              </div>

              <div class="detail-section">
                <div class="detail-label">Koordinat</div>
                <div id="detail-coordinates" class="detail-text mono"></div>
              </div>

              <div class="detail-meta">
                <div class="meta-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  <span id="detail-date"></span>
                </div>
                <div class="meta-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
                  </svg>
                  <span id="detail-votes">0 votes</span>
                </div>
              </div>

              <div id="action-buttons" class="action-buttons">
                <!-- Action buttons will be injected -->
              </div>
            </div>

            <!-- Right: Comments -->
            <div class="comments-panel">
              <div class="comments-header">
                <h4>Komentar</h4>
              </div>
              <div id="comments-list" class="comments-list">
                <!-- Comments will be injected -->
              </div>
              <form id="comment-form" class="comment-form">
                <input type="text" id="comment-input" placeholder="Tulis komentar..." required />
                <button type="submit" class="btn-send">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"></line>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                  </svg>
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="toast hidden"></div>

  </div>

  <!-- Chart.js -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>


  <script>
    const API_URL = 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    // Auth check
    if (!token || !userRaw) {
      window.location.href = '/admin/login';
    } else {
      const user = JSON.parse(userRaw);
      if ((user.role || '').toUpperCase() !== 'ADMIN') {
        window.location.href = '/dashboard';
      }
    }

    let allReports = [];
    let categories = [];
    let weeklyChart, categoryChart;
    let currentReportId = null;

    // Initialize
    document.addEventListener('DOMContentLoaded', async () => {
      updateTime();
      setInterval(updateTime, 1000);
      
      await loadCategories();
      await loadReports();
      
      setupEventListeners();
    });

    function updateTime() {
      const now = new Date();
      const timeStr = now.toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
      const dateStr = now.toLocaleDateString('id-ID', { weekday: 'short', day: 'numeric', month: 'short' });
      document.getElementById('live-time').textContent = `${timeStr} • ${dateStr}`;
    }

    function setupEventListeners() {
      document.getElementById('logout-btn').addEventListener('click', () => {
        localStorage.clear();
        window.location.href = '/admin/login';
      });

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const sidebar = document.querySelector('.zen-sidebar');
      
      if (mobileMenuBtn && sidebar) {
        mobileMenuBtn.addEventListener('click', () => {
          sidebar.classList.toggle('mobile-open');
        });

        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', (e) => {
          if (window.innerWidth <= 1024) {
            if (!sidebar.contains(e.target) && !mobileMenuBtn.contains(e.target)) {
              sidebar.classList.remove('mobile-open');
            }
          }
        });
      }

      document.getElementById('search-input').addEventListener('input', filterReports);
      document.getElementById('category-filter').addEventListener('change', filterReports);
      document.getElementById('status-filter').addEventListener('change', filterReports);
      document.getElementById('sort-select').addEventListener('change', (e) => {
        loadReports(e.target.value);
      });

      document.getElementById('close-modal').addEventListener('click', closeModal);
      document.getElementById('detail-modal').addEventListener('click', (e) => {
        if (e.target.classList.contains('modal-backdrop')) closeModal();
      });

      document.getElementById('comment-form').addEventListener('submit', handleCommentSubmit);
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
        
        const select = document.getElementById('category-filter');
        categories.forEach(cat => {
          const option = document.createElement('option');
          option.value = cat.id;
          option.textContent = cat.name;
          select.appendChild(option);
        });
      } catch (err) {
        console.error('Failed to load categories:', err);
      }
    }

    async function loadReports(sort = 'recent') {
      const list = document.getElementById('reports-list');
      list.innerHTML = '<div class="loading">Memuat data...</div>';
      
      try {
        const res = await fetch(`${API_URL}/api/admin/reports?sort=${sort}`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        allReports = data.data || [];
        
        updateStats();
        updateCharts();
        renderReports(allReports);
      } catch (err) {
        list.innerHTML = '<div class="error">Gagal memuat data</div>';
        console.error('Failed to load reports:', err);
      }
    }

    function updateStats() {
      const total = allReports.length;
      const pending = allReports.filter(r => r.status === 'PENDING').length;
      const verified = allReports.filter(r => r.status === 'VALID').length;
      const resolved = allReports.filter(r => r.status === 'RESOLVED').length;

      document.getElementById('stat-total').textContent = total;
      document.getElementById('stat-pending').textContent = pending;
      document.getElementById('stat-verified').textContent = verified;
      document.getElementById('stat-resolved').textContent = resolved;
    }

    function updateCharts() {
      // Weekly Chart
      const now = new Date();
      const labels = [];
      const data = [];
      
      for (let i = 6; i >= 0; i--) {
        const d = new Date();
        d.setDate(now.getDate() - i);
        labels.push(d.toLocaleDateString('id-ID', { weekday: 'short' }));
        
        const count = allReports.filter(r => {
          const reportDate = new Date(r.created_at);
          return reportDate.toDateString() === d.toDateString();
        }).length;
        data.push(count);
      }

      const weeklyCtx = document.getElementById('weeklyChart').getContext('2d');
      if (weeklyChart) weeklyChart.destroy();
      
      weeklyChart = new Chart(weeklyCtx, {
        type: 'line',
        data: {
          labels,
          datasets: [{
            data,
            borderColor: '#1a1a1a',
            backgroundColor: 'rgba(26, 26, 26, 0.05)',
            borderWidth: 2,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#1a1a1a',
            fill: true
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            y: {
              beginAtZero: true,
              ticks: { stepSize: 1 }
            }
          }
        }
      });

      // Category Chart
      const categoryCounts = {};
      allReports.forEach(r => {
        const cat = categories.find(c => c.id === r.category_id);
        const name = cat ? cat.name : 'Lainnya';
        categoryCounts[name] = (categoryCounts[name] || 0) + 1;
      });

      const catLabels = Object.keys(categoryCounts);
      const catData = Object.values(categoryCounts);
      const noCatData = document.getElementById('no-category-data');

      if (catData.length === 0) {
        noCatData.classList.remove('hidden');
      } else {
        noCatData.classList.add('hidden');
        
        const catCtx = document.getElementById('categoryChart').getContext('2d');
        if (categoryChart) categoryChart.destroy();
        
        categoryChart = new Chart(catCtx, {
          type: 'doughnut',
          data: {
            labels: catLabels,
            datasets: [{
              data: catData,
              backgroundColor: ['#1a1a1a', '#3b82f6', '#10b981', '#f59e0b', '#ef4444'],
              borderWidth: 0
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  padding: 16,
                  font: { size: 12, weight: '600' }
                }
              }
            }
          }
        });
      }
    }

    function renderReports(reports) {
      const list = document.getElementById('reports-list');
      
      if (reports.length === 0) {
        list.innerHTML = '<div class="empty-state">Tidak ada laporan</div>';
        return;
      }

      list.innerHTML = reports.map(report => {
        const cat = categories.find(c => c.id === report.category_id);
        const catName = cat ? cat.name : 'Umum';
        const statusClass = report.status.toLowerCase();
        const statusText = report.status === 'VALID' ? 'VERIFIED' : report.status;
        const date = new Date(report.created_at).toLocaleDateString('id-ID', { 
          day: 'numeric', 
          month: 'short'
        });

        return `
          <div class="report-card" onclick="window.location.href='/admin/report-detail?id=${report.id}'">
            ${report.image_url ? `
              <div class="report-image">
                <img src="${API_URL}${report.image_url}" alt="Report" />
              </div>
            ` : ''}
            <div class="report-content">
              <div class="report-badges">
                <span class="badge badge-category">${catName}</span>
                <span class="badge badge-status status-${statusClass}">${statusText}</span>
              </div>
              <h3 class="report-title">${report.description}</h3>
              <div class="report-meta">
                <span class="meta-item">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                  <span>${report.location_detail}</span>
                </span>
                <span class="meta-item">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
                  <span>${date}</span>
                </span>
              </div>
            </div>
          </div>
        `;
      }).join('');
    }

    function filterReports() {
      const searchTerm = document.getElementById('search-input').value.toLowerCase();
      const categoryId = document.getElementById('category-filter').value;
      const status = document.getElementById('status-filter').value;

      const filtered = allReports.filter(report => {
        const matchSearch = report.description.toLowerCase().includes(searchTerm) ||
                          report.location_detail.toLowerCase().includes(searchTerm);
        const matchCategory = !categoryId || String(report.category_id) === categoryId;
        const matchStatus = !status || report.status === status;
        
        return matchSearch && matchCategory && matchStatus;
      });

      renderReports(filtered);
    }

    // Make functions globally accessible
    window.openReportDetail = openReportDetail;
    window.verifyReport = verifyReport;
    window.resolveReport = resolveReport;

    async function openReportDetail(reportId) {
      currentReportId = reportId;
      const report = allReports.find(r => r.id === reportId);
      if (!report) return;

      const cat = categories.find(c => c.id === report.category_id);
      const catName = cat ? cat.name : 'Umum';
      const statusClass = report.status.toLowerCase();
      const statusText = report.status === 'VALID' ? 'VERIFIED' : report.status;

      // Update modal content
      if (report.image_url) {
        document.getElementById('report-image').src = `${API_URL}${report.image_url}`;
        document.getElementById('report-image-container').classList.remove('hidden');
      } else {
        document.getElementById('report-image-container').classList.add('hidden');
      }

      document.getElementById('detail-category').textContent = catName;
      document.getElementById('detail-status').textContent = statusText;
      document.getElementById('detail-status').className = `badge badge-status status-${statusClass}`;
      document.getElementById('detail-description').textContent = report.description;
      document.getElementById('detail-location').textContent = report.location_detail;
      document.getElementById('detail-coordinates').textContent = `${report.latitude}, ${report.longitude}`;
      document.getElementById('detail-date').textContent = new Date(report.created_at).toLocaleDateString('id-ID', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      });
      document.getElementById('detail-votes').textContent = `${report.vote_count} votes`;

      // Action buttons
      const actionButtons = document.getElementById('action-buttons');
      if (report.status === 'PENDING') {
        actionButtons.innerHTML = `
          <button class="btn btn-primary" onclick="verifyReport('${report.id}')">
            Verifikasi Laporan
          </button>
        `;
      } else if (report.status === 'VALID') {
        actionButtons.innerHTML = `
          <button class="btn btn-success" onclick="resolveReport('${report.id}')">
            Tandai Selesai
          </button>
        `;
      } else {
        actionButtons.innerHTML = `
          <div class="status-complete">✓ Laporan telah selesai</div>
        `;
      }

      // Load comments
      await loadComments(reportId);

      // Show modal
      document.getElementById('detail-modal').classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      document.getElementById('detail-modal').classList.add('hidden');
      document.body.style.overflow = '';
      currentReportId = null;
    }

    async function loadComments(reportId) {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="loading-comments">Memuat komentar...</div>';

      try {
        const res = await fetch(`${API_URL}/api/reports/${reportId}/comments`);
        const data = await res.json();
        const comments = data.data || [];

        if (comments.length === 0) {
          list.innerHTML = '<div class="no-comments">Belum ada komentar</div>';
          return;
        }

        list.innerHTML = comments.map(comment => {
          const isAdmin = comment.user?.role === 'admin' || comment.user?.role === 'ADMIN';
          return `
            <div class="comment ${isAdmin ? 'comment-admin' : ''}">
              <div class="comment-author">${comment.user?.full_name || 'User'}</div>
              <div class="comment-text">${comment.content}</div>
            </div>
          `;
        }).join('');

        list.scrollTop = list.scrollHeight;
      } catch (err) {
        list.innerHTML = '<div class="error-comments">Gagal memuat komentar</div>';
      }
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const input = document.getElementById('comment-input');
      const content = input.value.trim();
      
      if (!content || !currentReportId) return;

      try {
        const res = await fetch(`${API_URL}/api/reports/${currentReportId}/comments`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ content })
        });

        if (res.ok) {
          input.value = '';
          await loadComments(currentReportId);
        } else {
          showToast('Gagal mengirim komentar');
        }
      } catch (err) {
        showToast('Gagal mengirim komentar');
      }
    }

    async function verifyReport(reportId) {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports/${reportId}/verify`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
          showToast('Laporan berhasil diverifikasi');
          closeModal();
          await loadReports();
        } else {
          showToast('Gagal memverifikasi laporan');
        }
      } catch (err) {
        showToast('Gagal memverifikasi laporan');
      }
    }

    async function resolveReport(reportId) {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports/${reportId}/resolve`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
          showToast('Laporan berhasil diselesaikan');
          closeModal();
          await loadReports();
        } else {
          showToast('Gagal menyelesaikan laporan');
        }
      } catch (err) {
        showToast('Gagal menyelesaikan laporan');
      }
    }

    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 3000);
    }
  </script>

