---
// Admin Report Detail Page
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detail Laporan — Admin SovraEquitara</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="detail-page">
    <div class="detail-header">
      <button id="back-btn" class="back-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Kembali
      </button>
    </div>

    <div class="detail-container">
      <div class="detail-main">
        <div id="report-image-container" class="report-image-large hidden">
          <img id="report-image" src="" alt="Report" />
        </div>
        
        <div class="detail-info">
          <div class="badge-group">
            <span id="detail-category" class="badge badge-category"></span>
            <span id="detail-status" class="badge badge-status"></span>
          </div>
          <h1 id="detail-description" class="detail-title"></h1>
        </div>

        <div class="info-section">
          <div class="info-label">Lokasi</div>
          <div id="detail-location" class="info-text"></div>
        </div>

        <div class="info-section">
          <div class="info-label">Koordinat</div>
          <div id="detail-coordinates" class="info-text mono"></div>
        </div>

        <div class="detail-meta">
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
            <span id="detail-date"></span>
          </div>
          <div class="meta-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"></path>
            </svg>
            <span id="detail-votes">0 votes</span>
          </div>
        </div>

        <div id="action-buttons" class="action-buttons"></div>
      </div>

      <div class="comments-sidebar">
        <div class="comments-header">
          <h3>Komentar</h3>
        </div>
        <div id="comments-list" class="comments-list"></div>
        <form id="comment-form" class="comment-form">
          <input type="text" id="comment-input" placeholder="Tulis komentar..." required />
          <button type="submit" class="btn-send">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </form>
      </div>
    </div>

    <div id="toast" class="toast hidden"></div>
  </div>

  <script>
    const API_URL = 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/admin/login';
    } else {
      const user = JSON.parse(userRaw);
      if ((user.role || '').toUpperCase() !== 'ADMIN') {
        window.location.href = '/dashboard';
      }
    }

    const urlParams = new URLSearchParams(window.location.search);
    const reportId = urlParams.get('id');

    if (!reportId) {
      window.location.href = '/admin/dashboard';
    }

    let categories = [];

    document.addEventListener('DOMContentLoaded', async () => {
      await loadCategories();
      await loadReportDetail();
      setupEventListeners();
    });

    function setupEventListeners() {
      document.getElementById('back-btn').addEventListener('click', () => {
        window.location.href = '/admin/dashboard';
      });

      document.getElementById('comment-form').addEventListener('submit', handleCommentSubmit);
    }

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
      } catch (err) {
        console.error('Failed to load categories:', err);
      }
    }

    async function loadReportDetail() {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        const reports = data.data || [];
        const report = reports.find(r => r.id === reportId);

        if (!report) {
          window.location.href = '/admin/dashboard';
          return;
        }

        displayReport(report);
        await loadComments();
      } catch (err) {
        console.error('Failed to load report:', err);
        window.location.href = '/admin/dashboard';
      }
    }

    function displayReport(report) {
      const cat = categories.find(c => c.id === report.category_id);
      const catName = cat ? cat.name : 'Umum';
      const statusClass = report.status.toLowerCase();
      const statusText = report.status === 'VALID' ? 'VERIFIED' : report.status;

      if (report.image_url) {
        document.getElementById('report-image').src = `${API_URL}${report.image_url}`;
        document.getElementById('report-image-container').classList.remove('hidden');
      }

      document.getElementById('detail-category').textContent = catName;
      document.getElementById('detail-status').textContent = statusText;
      document.getElementById('detail-status').className = `badge badge-status status-${statusClass}`;
      document.getElementById('detail-description').textContent = report.description;
      document.getElementById('detail-location').textContent = report.location_detail;
      document.getElementById('detail-coordinates').textContent = `${report.latitude}, ${report.longitude}`;
      document.getElementById('detail-date').textContent = new Date(report.created_at).toLocaleDateString('id-ID', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      });
      document.getElementById('detail-votes').textContent = `${report.vote_count} votes`;

      const actionButtons = document.getElementById('action-buttons');
      if (report.status === 'PENDING') {
        actionButtons.innerHTML = `
          <button class="btn btn-primary" onclick="verifyReport('${report.id}')">
            Verifikasi Laporan
          </button>
        `;
      } else if (report.status === 'VALID') {
        actionButtons.innerHTML = `
          <button class="btn btn-success" onclick="resolveReport('${report.id}')">
            Tandai Selesai
          </button>
        `;
      } else {
        actionButtons.innerHTML = `
          <div class="status-complete">✓ Laporan telah selesai</div>
        `;
      }
    }

    async function loadComments() {
      const list = document.getElementById('comments-list');
      list.innerHTML = '<div class="loading-comments">Memuat komentar...</div>';

      try {
        const res = await fetch(`${API_URL}/api/reports/${reportId}/comments`);
        const data = await res.json();
        const comments = data.data || [];

        if (comments.length === 0) {
          list.innerHTML = '<div class="no-comments">Belum ada komentar</div>';
          return;
        }

        list.innerHTML = comments.map(comment => {
          const isAdmin = comment.user?.role === 'admin' || comment.user?.role === 'ADMIN';
          return `
            <div class="comment ${isAdmin ? 'comment-admin' : ''}">
              <div class="comment-author">${comment.user?.full_name || 'User'}</div>
              <div class="comment-text">${comment.content}</div>
            </div>
          `;
        }).join('');

        list.scrollTop = list.scrollHeight;
      } catch (err) {
        list.innerHTML = '<div class="error-comments">Gagal memuat komentar</div>';
      }
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const input = document.getElementById('comment-input');
      const content = input.value.trim();
      
      if (!content) return;

      try {
        const res = await fetch(`${API_URL}/api/reports/${reportId}/comments`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ content })
        });

        if (res.ok) {
          input.value = '';
          await loadComments();
        } else {
          showToast('Gagal mengirim komentar');
        }
      } catch (err) {
        showToast('Gagal mengirim komentar');
      }
    }

    async function verifyReport(id) {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports/${id}/verify`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
          showToast('Laporan berhasil diverifikasi');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('Gagal memverifikasi laporan');
        }
      } catch (err) {
        showToast('Gagal memverifikasi laporan');
      }
    }

    async function resolveReport(id) {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports/${id}/resolve`, {
          method: 'PATCH',
          headers: { 'Authorization': `Bearer ${token}` }
        });

        if (res.ok) {
          showToast('Laporan berhasil diselesaikan');
          setTimeout(() => window.location.reload(), 1000);
        } else {
          showToast('Gagal menyelesaikan laporan');
        }
      } catch (err) {
        showToast('Gagal menyelesaikan laporan');
      }
    }

    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 3000);
    }

    window.verifyReport = verifyReport;
    window.resolveReport = resolveReport;
  </script>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #fafafa;
      color: #1a1a1a;
    }

    .mono {
      font-family: 'JetBrains Mono', monospace;
    }

    .hidden {
      display: none !important;
    }

    .detail-page {
      min-height: 100vh;
      padding: 24px;
    }

    .detail-header {
      max-width: 1200px;
      margin: 0 auto 24px;
    }

    .back-btn {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: white;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      color: #1a1a1a;
      cursor: pointer;
      transition: all 0.2s;
    }

    .back-btn:hover {
      border-color: #1a1a1a;
    }

    .detail-container {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 24px;
      background: white;
      border: 1px solid #e5e5e5;
      border-radius: 12px;
      overflow: hidden;
    }

    .detail-main {
      padding: 32px;
    }

    .report-image-large {
      width: 100%;
      max-width: 600px;
      height: 320px;
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 24px;
      background: #f5f5f5;
    }

    .report-image-large img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .badge-group {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
    }

    .badge {
      padding: 4px 10px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
    }

    .badge-category {
      background: #f5f5f5;
      color: #666;
    }

    .badge-status {
      background: #e5e5e5;
      color: #1a1a1a;
    }

    .status-pending {
      background: #fef3c7;
      color: #92400e;
    }

    .status-valid {
      background: #dbeafe;
      color: #1e40af;
    }

    .status-resolved {
      background: #d1fae5;
      color: #065f46;
    }

    .detail-title {
      font-size: 28px;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 24px;
    }

    .info-section {
      margin-bottom: 20px;
    }

    .info-label {
      font-size: 11px;
      font-weight: 600;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    .info-text {
      font-size: 15px;
      font-weight: 500;
      color: #1a1a1a;
    }

    .detail-meta {
      display: flex;
      gap: 24px;
      padding: 16px 0;
      border-top: 1px solid #e5e5e5;
      border-bottom: 1px solid #e5e5e5;
      margin-bottom: 24px;
    }

    .meta-item {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 14px;
      color: #666;
    }

    .action-buttons {
      display: flex;
      gap: 12px;
    }

    .btn {
      flex: 1;
      padding: 14px 24px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }

    .btn-primary {
      background: #1a1a1a;
      color: white;
    }

    .btn-primary:hover {
      background: #000;
    }

    .btn-success {
      background: #10b981;
      color: white;
    }

    .btn-success:hover {
      background: #059669;
    }

    .status-complete {
      padding: 14px 24px;
      background: #d1fae5;
      color: #065f46;
      border-radius: 8px;
      text-align: center;
      font-weight: 600;
    }

    .comments-sidebar {
      background: #fafafa;
      display: flex;
      flex-direction: column;
      border-left: 1px solid #e5e5e5;
    }

    .comments-header {
      padding: 24px;
      border-bottom: 1px solid #e5e5e5;
    }

    .comments-header h3 {
      font-size: 16px;
      font-weight: 600;
    }

    .comments-list {
      flex: 1;
      padding: 24px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 16px;
      max-height: 500px;
    }

    .comment {
      background: white;
      border: 1px solid #e5e5e5;
      border-radius: 10px;
      padding: 14px;
    }

    .comment-admin {
      background: #1a1a1a;
      color: white;
      border-color: #1a1a1a;
      align-self: flex-end;
      max-width: 85%;
    }

    .comment-author {
      font-size: 11px;
      font-weight: 600;
      margin-bottom: 6px;
      opacity: 0.7;
    }

    .comment-text {
      font-size: 14px;
      line-height: 1.5;
    }

    .no-comments, .loading-comments, .error-comments {
      text-align: center;
      padding: 40px 20px;
      color: #999;
      font-size: 13px;
    }

    .comment-form {
      padding: 20px;
      border-top: 1px solid #e5e5e5;
      display: flex;
      gap: 12px;
      background: white;
    }

    .comment-form input {
      flex: 1;
      padding: 12px 16px;
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
    }

    .comment-form input:focus {
      border-color: #1a1a1a;
    }

    .btn-send {
      width: 44px;
      height: 44px;
      background: #1a1a1a;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.2s;
    }

    .btn-send:hover {
      background: #000;
    }

    .toast {
      position: fixed;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      background: #1a1a1a;
      color: white;
      padding: 14px 24px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      z-index: 2000;
    }

    @media (max-width: 1024px) {
      .detail-container {
        grid-template-columns: 1fr;
      }

      .comments-sidebar {
        border-left: none;
        border-top: 1px solid #e5e5e5;
      }
    }

    @media (max-width: 768px) {
      .detail-page {
        padding: 16px;
      }

      .detail-main {
        padding: 20px;
      }

      .report-image-large {
        height: 220px;
      }

      .detail-title {
        font-size: 22px;
      }
    }
  </style>
</body>
</html>
