---
// Admin Report Detail Page
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detail Laporan — Admin SovraEquitara</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
  
  <style is:global>
    :root {
      --zen-bg: #f8f9fa;
      --zen-card: #ffffff;
      --zen-border: rgba(0,0,0,0.06);
      --zen-text-main: #1a1a1a;
      --zen-text-muted: #71717a;
      --zen-brand: #1a1a1a;
      --zen-radius: 24px;
      --zen-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
    }

    body {
      margin: 0;
      font-family: 'Plus Jakarta Sans', sans-serif;
      background: var(--zen-bg);
      color: var(--zen-text-main);
      -webkit-font-smoothing: antialiased;
    }

    .zen-detail-root {
      max-width: 1300px;
      margin: 0 auto;
      padding: 40px 24px;
    }

    .top-nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
    }

    .back-btn {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px 20px;
      background: white;
      border: 1px solid var(--zen-border);
      border-radius: 14px;
      font-size: 14px;
      font-weight: 700;
      color: var(--zen-text-main);
      cursor: pointer;
      transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
    }

    .back-btn:hover {
      transform: translateX(-4px);
      box-shadow: var(--zen-shadow);
      border-color: var(--zen-brand);
    }

    .page-indicator {
      font-size: 13px;
      font-weight: 800;
      color: var(--zen-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    /* Layout Grid */
    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 420px;
      gap: 32px;
      align-items: start;
    }

    /* Left Column */
    .main-content {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    .content-card {
      background: var(--zen-card);
      border: 1px solid var(--zen-border);
      border-radius: var(--zen-radius);
      padding: 32px;
      box-shadow: var(--zen-shadow);
    }

    .image-preview-box {
      width: 100%;
      border-radius: 20px;
      overflow: hidden;
      margin-bottom: 24px;
      background: #f0f0f0;
      border: 1px solid var(--zen-border);
    }

    .image-preview-box img {
      width: 100%;
      height: auto;
      max-height: 500px;
      object-fit: cover;
      display: block;
    }

    .report-title {
      font-size: 32px;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.2;
      margin: 0 0 16px 0;
    }

    .section-label {
      font-size: 11px;
      font-weight: 800;
      color: var(--zen-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 12px;
      display: block;
    }

    .loc-info {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 20px;
      background: #fafafa;
      border-radius: 18px;
      margin-bottom: 20px;
    }

    .loc-text {
      font-size: 16px;
      font-weight: 600;
      color: var(--zen-text-main);
    }

    .map-container {
      height: 350px;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--zen-border);
      margin-bottom: 20px;
    }

    .map-action-group { display: flex; gap: 12px; margin-bottom: 16px; }
    .btn-map-mode {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 20px;
      background: white;
      border: 1px solid var(--zen-border);
      border-radius: 16px;
      font-size: 13px;
      font-weight: 700;
      color: var(--zen-text-main);
      text-decoration: none;
      cursor: pointer;
      transition: 0.2s;
    }
    .btn-map-mode:hover { border-color: var(--zen-brand); background: #fafafa; }
    .btn-map-mode.active { background: #1a1a1a; color: white; border-color: #1a1a1a; }

    /* Right Column / Sidebar */
    .meta-sidebar {
      display: flex;
      flex-direction: column;
      gap: 24px;
      position: sticky;
      top: 40px;
    }

    .meta-card {
      background: white;
      border: 1px solid var(--zen-border);
      border-radius: var(--zen-radius);
      padding: 28px;
      box-shadow: var(--zen-shadow);
    }

    .status-section {
      text-align: center;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--zen-border);
      margin-bottom: 24px;
    }

    .zen-status-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 24px;
      border-radius: 99px;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; }
    
    .status-pending { background: #fffbeb; color: #d97706; }
    .status-valid { background: #eff6ff; color: #2563eb; }
    .status-resolved { background: #f0fdf4; color: #16a34a; }

    .meta-list { display: flex; flex-direction: column; gap: 20px; }
    .meta-row { display: flex; justify-content: space-between; align-items: center; }
    .meta-label { font-size: 12px; font-weight: 700; color: var(--zen-text-muted); }
    .meta-value { font-size: 14px; font-weight: 800; color: var(--zen-text-main); }

    .action-group { margin-top: 32px; display: flex; flex-direction: column; gap: 12px; }
    .btn-action {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 16px;
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      transition: 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .btn-verify { background: #1a1a1a; color: white; }
    .btn-verify:hover { background: #000; transform: translateY(-2px); }
    
    .btn-resolve { background: #10b981; color: white; }
    .btn-resolve:hover { background: #059669; transform: translateY(-2px); }

    .status-complete-box {
      padding: 16px;
      background: #f0fdf4;
      border: 1px solid #dcfce7;
      border-radius: 16px;
      color: #16a34a;
      font-weight: 700;
      text-align: center;
      font-size: 14px;
    }

    .vote-card-premium {
      background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
      border: 1px solid var(--zen-border);
      border-radius: 20px;
      padding: 24px;
      text-align: center;
      margin-bottom: 24px;
    }
    .vote-count-big { font-size: 48px; font-weight: 800; color: var(--zen-brand); line-height: 1; margin-bottom: 4px; }
    .vote-label-big { font-size: 12px; font-weight: 700; color: var(--zen-text-muted); text-transform: uppercase; letter-spacing: 0.1em; }

    /* Discussion / Comments */
    .discussion-card {
      display: flex;
      flex-direction: column;
      height: 500px;
    }

    .comments-view {
      flex: 1;
      overflow-y: auto;
      padding: 4px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 24px;
    }

    .comment-bubble {
      padding: 16px;
      border-radius: 20px;
      background: #f8f9fa;
      border: 1px solid var(--zen-border);
      max-width: 85%;
    }

    .comment-bubble.admin {
      background: #1a1a1a;
      color: white;
      align-self: flex-end;
      border-color: #1a1a1a;
    }

    .author-tag { font-size: 11px; font-weight: 800; opacity: 0.6; margin-bottom: 6px; display: block; }
    .comment-txt { font-size: 14px; font-weight: 500; line-height: 1.5; margin: 0; }

    .comment-form {
      display: flex;
      gap: 12px;
    }

    .zen-input {
      flex: 1;
      padding: 14px 20px;
      border: 1px solid var(--zen-border);
      border-radius: 16px;
      font-size: 14px;
      font-weight: 600;
      outline: none;
      transition: 0.2s;
    }
    .zen-input:focus { border-color: var(--zen-brand); box-shadow: 0 0 0 4px rgba(0,0,0,0.03); }

    .btn-send {
      width: 48px;
      height: 48px;
      background: var(--zen-brand);
      color: white;
      border: none;
      border-radius: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: 0.2s;
    }
    .btn-send:hover { transform: scale(1.05); }

    .hidden { display: none !important; }

    .toast {
      position: fixed;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      background: #1a1a1a;
      color: white;
      padding: 14px 28px;
      border-radius: 99px;
      font-weight: 700;
      font-size: 14px;
      z-index: 2000;
      box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    @media (max-width: 1100px) {
      .detail-grid { grid-template-columns: 1fr; }
      .meta-sidebar { position: static; }
    }
  </style>
</head>
<body>
  <div class="zen-detail-root" id="detail-root" data-api-url={API_URL}>
    
    <nav class="top-nav">
      <a href="/admin/dashboard" class="back-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        Kembali ke Dashboard
      </a>
      <span class="page-indicator">Report Analysis</span>
    </nav>

    <div class="detail-grid">
      <!-- Main Content -->
      <main class="main-content">
        <div class="content-card">
          <div id="img-container" class="image-preview-box hidden">
            <img id="report-image" src="" alt="Laporan" />
          </div>
          
          <span id="detail-category" class="section-label">Category Name</span>
          <h1 id="detail-desc" class="report-title">Memuat Deskripsi...</h1>
          
          <div class="info-section">
            <label class="section-label">Lokasi & Visualisasi</label>
            <div class="loc-info">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <span id="detail-loc" class="loc-text">--</span>
            </div>
            
            <div class="map-action-group">
              <button id="btn-toggle-map" class="btn-map-mode">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"></polygon><line x1="8" y1="2" x2="8" y2="18"></line><line x1="16" y1="6" x2="16" y2="22"></line></svg>
                Lihat Peta Interaktif
              </button>
              <a id="gmaps-link" href="#" target="_blank" class="btn-map-mode">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                Buka Google Maps
              </a>
            </div>

            <div id="detail-map" class="map-container hidden"></div>
          </div>
        </div>

        <div class="content-card discussion-card">
          <span class="section-label">Discussion & Log</span>
          <div id="comments-list" class="comments-view">
            <!-- Rendered JS -->
          </div>
          <form id="comment-form" class="comment-form">
            <input type="text" id="comment-input" class="zen-input" placeholder="Balas atau beri catatan internal..." required />
            <button type="submit" class="btn-send">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            </button>
          </form>
        </div>
      </main>

      <!-- Sidebar -->
      <aside class="meta-sidebar">
        <div class="meta-card">
          <div class="status-section">
            <div id="status-pill" class="zen-status-pill">
              <span class="status-dot"></span>
              <span id="status-text">--</span>
            </div>
          </div>

          <div class="meta-list">
            <div class="vote-card-premium">
              <div class="vote-count-big" id="detail-votes">0</div>
              <span class="vote-label-big">Dukungan Warga</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">ID Laporan</span>
              <span id="detail-id" class="meta-value">--</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Tanggal Masuk</span>
              <span id="detail-date" class="meta-value">--</span>
            </div>
            <div class="meta-row">
              <span class="meta-label">Koordinat</span>
              <span id="detail-coords" class="meta-value" style="font-family: 'JetBrains Mono'; font-size: 12px;">--</span>
            </div>
          </div>

          <div id="action-buttons" class="action-group">
            <!-- Rendered JS -->
          </div>
        </div>

        <div class="meta-card" style="background: #1a1a1a; color: white;">
          <span class="section-label" style="color: rgba(255,255,255,0.5);">Admin Note</span>
          <p style="font-size: 13px; font-weight: 500; margin-top: 10px; line-height: 1.6; opacity: 0.8;">
            Pastikan verifikasi dilakukan setelah meninjau lokasi melalui peta dan bukti foto yang tersedia. Semua tindakan akan tercatat dalam sistem.
          </p>
        </div>
      </aside>
    </div>

    <div id="toast" class="toast hidden"></div>
  </div>

  <script is:inline>
    const API_URL = document.getElementById('detail-root').dataset.apiUrl;
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token || !userRaw) {
      window.location.href = '/admin/login';
    } else {
      const user = JSON.parse(userRaw);
      if ((user.role || '').toUpperCase() !== 'ADMIN') {
        window.location.href = '/dashboard';
      }
    }

    const urlParams = new URLSearchParams(window.location.search);
    const reportId = urlParams.get('id');

    if (!reportId) window.location.href = '/admin/dashboard';

    let categories = [];

    document.addEventListener('DOMContentLoaded', async () => {
      await loadCategories();
      await loadReportDetail();
      document.getElementById('comment-form').addEventListener('submit', handleCommentSubmit);
    });

    async function loadCategories() {
      try {
        const res = await fetch(`${API_URL}/api/categories`);
        const data = await res.json();
        categories = data.data || [];
      } catch (err) {}
    }

    async function loadReportDetail() {
      try {
        const res = await fetch(`${API_URL}/api/admin/reports`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        const reports = data.data || [];
        const report = reports.find(r => r.id === reportId);

        if (!report) { window.location.href = '/admin/dashboard'; return; }

        displayReport(report);
        await loadComments();
      } catch (err) {
        window.location.href = '/admin/dashboard';
      }
    }

    function displayReport(report) {
      const cat = categories.find(c => c.id === report.category_id);
      const catName = cat ? cat.name : 'Umum';
      const statusClass = report.status.toLowerCase();
      const statusText = report.status === 'VALID' ? 'VERIFIED' : report.status;

      document.getElementById('detail-id').textContent = report.id.substring(0, 8);
      document.getElementById('detail-category').textContent = catName;
      document.getElementById('detail-desc').textContent = report.description;
      document.getElementById('detail-loc').textContent = report.location_detail;
      document.getElementById('detail-coords').textContent = `${report.latitude.toFixed(4)}, ${report.longitude.toFixed(4)}`;
      document.getElementById('detail-votes').textContent = report.vote_count;
      document.getElementById('detail-date').textContent = new Date(report.created_at).toLocaleDateString('id-ID', {
        day: 'numeric', month: 'long', year: 'numeric'
      });

      // Image
      if (report.image_url) {
        document.getElementById('report-image').src = `${API_URL}${report.image_url}`;
        document.getElementById('img-container').classList.remove('hidden');
      }

      // Status Pill
      const pill = document.getElementById('status-pill');
      pill.className = `zen-status-pill status-${statusClass}`;
      document.getElementById('status-text').textContent = statusText;

      // GMaps
      document.getElementById('gmaps-link').href = `https://www.google.com/maps?q=${report.latitude},${report.longitude}`;

      // Map Toggle Logic
      const toggleBtn = document.getElementById('btn-toggle-map');
      const mapContainer = document.getElementById('detail-map');
      
      toggleBtn.onclick = () => {
        const isHidden = mapContainer.classList.toggle('hidden');
        toggleBtn.textContent = isHidden ? 'Lihat Peta Interaktif' : 'Tutup Peta';
        toggleBtn.classList.toggle('active', !isHidden);
        
        if (!isHidden) {
          setTimeout(() => {
            if (window.adminMap) window.adminMap.remove();
            window.adminMap = L.map('detail-map', { zoomControl: true }).setView([report.latitude, report.longitude], 16);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(window.adminMap);
            L.marker([report.latitude, report.longitude]).addTo(window.adminMap);
          }, 100);
        }
      };

      // Actions
      const actionButtons = document.getElementById('action-buttons');
      if (report.status === 'PENDING') {
        actionButtons.innerHTML = `<button class="btn-action btn-verify" onclick="verifyReport('${report.id}')">Verifikasi Laporan</button>`;
      } else if (report.status === 'VALID') {
        actionButtons.innerHTML = `<button class="btn-action btn-resolve" onclick="resolveReport('${report.id}')">Tandai Selesai</button>`;
      } else {
        actionButtons.innerHTML = `<div class="status-complete-box">✓ Laporan Selesai Ditangani</div>`;
      }
    }

    async function loadComments() {
      const list = document.getElementById('comments-list');
      try {
        const res = await fetch(`${API_URL}/api/reports/${reportId}/comments`);
        const data = await res.json();
        const comments = data.data || [];

        if (comments.length === 0) {
          list.innerHTML = '<div style="text-align:center; padding: 40px; color: #999; font-size: 13px;">Belum ada diskusi atau catatan.</div>';
          return;
        }

        list.innerHTML = comments.map(comment => {
          const isAdmin = comment.user?.role?.toLowerCase() === 'admin';
          return `
            <div class="comment-bubble ${isAdmin ? 'admin' : ''}">
              <span class="author-tag">${comment.user?.full_name || 'User'}</span>
              <p class="comment-txt">${comment.content}</p>
            </div>
          `;
        }).join('');
        list.scrollTop = list.scrollHeight;
      } catch (err) {}
    }

    async function handleCommentSubmit(e) {
      e.preventDefault();
      const input = document.getElementById('comment-input');
      const content = input.value.trim();
      if (!content) return;
      try {
        const res = await fetch(`${API_URL}/api/reports/${reportId}/comments`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
          body: JSON.stringify({ content })
        });
        if (res.ok) { input.value = ''; await loadComments(); }
      } catch (err) {}
    }

    async function verifyReport(id) {
      const res = await fetch(`${API_URL}/api/admin/reports/${id}/verify`, { method: 'PATCH', headers: { 'Authorization': `Bearer ${token}` } });
      if (res.ok) { showToast('Laporan diverifikasi'); setTimeout(() => window.location.reload(), 800); }
    }

    async function resolveReport(id) {
      const res = await fetch(`${API_URL}/api/admin/reports/${id}/resolve`, { method: 'PATCH', headers: { 'Authorization': `Bearer ${token}` } });
      if (res.ok) { showToast('Laporan diselesaikan'); setTimeout(() => window.location.reload(), 800); }
    }

    function showToast(message) {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 3000);
    }

    window.verifyReport = verifyReport;
    window.resolveReport = resolveReport;
  </script>
</body>
</html>
