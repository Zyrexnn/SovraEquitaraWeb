---
import Layout from '../../layouts/Layout.astro';
import { ThemeToggle } from '../../components/ThemeToggle';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Peringkat Warga — SovraEquitara">
  <div class="flex min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark font-display" id="admin-root" data-api-url={API_URL}>
    <button id="mobile-menu-btn" class="lg:hidden fixed top-5 left-5 z-[1100] bg-zen-sidebar-bg dark:bg-zen-sidebar-bg-dark text-white border-none p-2.5 rounded-xl">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <aside class="w-[280px] bg-zen-sidebar-bg dark:bg-zen-sidebar-bg-dark border-r border-zen-border dark:border-zen-border-dark flex flex-col fixed h-screen z-[1000] transition-transform duration-300 lg:translate-x-0 -translate-x-full" id="sidebar">
      <div class="p-10 flex items-center justify-between">
        <img src="/logo.svg" alt="Sovra" class="h-14 dark:brightness-0 dark:invert">
        <ThemeToggle client:load />
      </div>
      
      <nav class="flex-1 px-4">
        <a href="/admin/dashboard" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-zen-text-secondary dark:text-zen-text-secondary-dark no-underline text-sm font-bold transition-all duration-300 mb-1 hover:text-white hover:bg-white/5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          </svg>
          <span>Dashboard</span>
        </a>
        <a href="/admin/leaderboard" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-white bg-blue-500 shadow-[0_8px_20px_rgba(59,130,246,0.25)] no-underline text-sm font-bold transition-all duration-300 mb-1">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          <span>Peringkat Warga</span>
        </a>
        <a href="/admin/profile" class="flex items-center gap-3 px-4 py-3.5 rounded-2xl text-zen-text-secondary dark:text-zen-text-secondary-dark no-underline text-sm font-bold transition-all duration-300 mb-1 hover:text-white hover:bg-white/5">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>Profile</span>
        </a>
      </nav>

      <div class="p-6 border-t border-white/5">
        <div class="flex items-center gap-3 mb-5 px-2">
          <div class="w-10 h-10 rounded-xl bg-blue-500 text-white flex items-center justify-center font-extrabold text-lg">A</div>
          <div class="flex-1">
            <div class="text-sm font-extrabold text-white" id="admin-name-sidebar">Administrator</div>
            <div class="text-[11px] text-[#10B981] font-bold">Online</div>
          </div>
        </div>
        <button id="logout-btn" class="w-full flex items-center justify-center gap-2 p-3 bg-white/5 border-none rounded-xl text-[#ff4444] font-bold text-[13px] cursor-pointer transition-all duration-300">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          <span>Logout Portal</span>
        </button>
      </div>
    </aside>

    <main class="flex-1 lg:ml-[280px] p-10 lg:pt-10 pt-20">
      <div class="max-w-[1200px] mx-auto">
        <header class="mb-12">
          <div>
            <h1 class="text-[32px] font-extrabold m-0 tracking-tight">Peringkat Warga</h1>
            <p class="text-zen-text-secondary dark:text-zen-text-secondary-dark mt-2 font-semibold">Kontribusi Masyarakat SovraEquitara</p>
          </div>
        </header>

        <div>
          <div class="mb-8">
            <input type="text" id="leader-search" placeholder="Cari nama warga..." class="w-full max-w-[400px] p-4 px-6 rounded-2xl border border-zen-border dark:border-zen-border-dark bg-zen-card dark:bg-zen-card-dark text-zen-text dark:text-zen-text-dark font-semibold outline-none">
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6" id="leader-list">
            <!-- Loading -->
            <div class="col-span-full p-10 text-center text-zen-text-secondary dark:text-zen-text-secondary-dark">Memuat data peringkat...</div>
          </div>
        </div>
      </div>
    </main>
  </div>



  <script is:inline define:vars={{ API_URL }}>
    let leaderData = [];
    
    async function init() {
      const token = localStorage.getItem("access_token");
      const user = JSON.parse(localStorage.getItem("user") || "{}");
      if (!token || user.role !== "admin") return window.location.href = "/admin/login";

      const adminNameEl = document.getElementById("admin-name-sidebar");
      if(adminNameEl) adminNameEl.innerText = user.full_name || "Admin";

      try {
        const res = await fetch(`${API_URL}/api/leaderboard`);
        const json = await res.json();
        leaderData = json.data || [];
        renderLeaderboard(leaderData);
      } catch (err) {
        console.error(err);
      }
    }

    function renderLeaderboard(data) {
      const container = document.getElementById("leader-list");
      if (!container) return;
      
      if (data.length === 0) {
        container.innerHTML = '<div class="col-span-full p-10 text-center text-zen-text-secondary dark:text-zen-text-secondary-dark">Tidak ada data warga ditemukan.</div>';
        return;
      }

      container.innerHTML = data.map((u, i) => {
        const initial = (u.full_name || "U")[0].toUpperCase();
        const rank = i + 1;
        return `
          <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark rounded-3xl p-6 flex items-center gap-5 transition-transform duration-300 relative overflow-hidden hover:-translate-y-1 hover:border-blue-500 shadow-zen group">
            ${rank <= 3 ? `<div class="absolute top-0 right-0 px-4 py-2 rounded-bl-2xl text-[11px] font-extrabold uppercase tracking-wider ${rank === 1 ? 'bg-[#FFD700] text-[#8B4513]' : rank === 2 ? 'bg-[#C0C0C0] text-[#4F4F4F]' : 'bg-[#CD7F32] text-white'}">RANK ${rank}</div>` : ''}
            <div class="w-16 h-16 rounded-2xl bg-zen-bg dark:bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark flex items-center justify-center text-2xl font-extrabold text-blue-500">${initial}</div>
            <div class="flex-1">
              <div class="font-extrabold text-lg mb-1 text-zen-text dark:text-zen-text-dark">${u.full_name}</div>
              <div class="flex items-center gap-1.5 text-blue-500 font-extrabold text-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                ${u.points} POINTS
              </div>
            </div>
          </div>
        `;
      }).join("");
    }

    document.getElementById("leader-search")?.addEventListener("input", (e) => {
      const search = e.target.value.toLowerCase();
      const filtered = leaderData.filter(u => u.full_name.toLowerCase().includes(search));
      renderLeaderboard(filtered);
    });

    document.getElementById("mobile-menu-btn")?.addEventListener("click", () => document.getElementById("sidebar").classList.toggle("-translate-x-full"));
    document.getElementById("logout-btn")?.addEventListener("click", () => { localStorage.clear(); window.location.href = "/admin/login"; });

    init();
  </script>
</Layout>
