---
import Layout from '../../layouts/Layout.astro';
import { ThemeToggle } from '../../components/ThemeToggle';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Peringkat Warga — SovraEquitara">
  <div class="zen-admin-root" id="admin-root" data-api-url={API_URL}>
    <button id="mobile-menu-btn" class="mobile-menu-btn">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <aside class="zen-sidebar" id="sidebar">
      <div class="sidebar-header">
        <img src="/logo.svg" alt="Sovra" class="logo-mark dark:brightness-0 dark:invert">
        <ThemeToggle client:load />
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          </svg>
          <span>Dashboard</span>
        </a>
        <a href="/admin/leaderboard" class="nav-item active">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
            <circle cx="9" cy="7" r="4"></circle>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
          </svg>
          <span>Peringkat Warga</span>
        </a>
        <a href="/admin/profile" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>Profile</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="admin-profile">
          <div class="profile-avatar">A</div>
          <div class="profile-info">
            <div class="profile-name" id="admin-name-sidebar">Administrator</div>
            <div class="profile-status">Online</div>
          </div>
        </div>
        <button id="logout-btn" class="logout-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
            <polyline points="16 17 21 12 16 7"></polyline>
            <line x1="21" y1="12" x2="9" y2="12"></line>
          </svg>
          <span>Logout Portal</span>
        </button>
      </div>
    </aside>

    <main class="zen-main">
      <div class="main-container">
        <header class="page-header">
          <div>
            <h1 class="page-title">Peringkat Warga</h1>
            <p class="page-subtitle">Kontribusi Masyarakat SovraEquitara</p>
          </div>
        </header>

        <div class="leaderboard-full">
          <div class="search-bar">
            <input type="text" id="leader-search" placeholder="Cari nama warga...">
          </div>
          
          <div class="leader-grid" id="leader-list">
            <!-- Loading -->
            <div style="padding:40px;text-align:center;color:var(--zen-text-secondary);">Memuat data peringkat...</div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <style is:global>
    :root {
      --zen-bg: #fbfbfb;
      --zen-sidebar-bg: #111111;
      --zen-card: #ffffff;
      --zen-border: rgba(0,0,0,0.06);
      --zen-text: #111111;
      --zen-text-secondary: #666666;
      --zen-accent: #3B82F6;
      --zen-sidebar-text: #888888;
      --zen-sidebar-active: #ffffff;
    }
    .dark {
      --zen-bg: #050505;
      --zen-sidebar-bg: #0A0A0A;
      --zen-card: #0E0E0E;
      --zen-border: rgba(255,255,255,0.08);
      --zen-text: #eeeeee;
      --zen-text-secondary: #999999;
      --zen-accent: #3B82F6;
    }

    body { background: var(--zen-bg); color: var(--zen-text); font-family: 'Plus Jakarta Sans', sans-serif; margin: 0; }
    .zen-admin-root { display: flex; min-height: 100vh; }
    
    .zen-sidebar { width: 280px; background: var(--zen-sidebar-bg); border-right: 1px solid var(--zen-border); display: flex; flex-direction: column; position: fixed; height: 100vh; z-index: 1000; }
    .sidebar-header { padding: 40px 24px; display: flex; align-items: center; justify-content: space-between; }
    .logo-mark { height: 28px; }
    
    .sidebar-nav { flex: 1; padding: 0 16px; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border-radius: 14px; color: var(--zen-sidebar-text); text-decoration: none; font-size: 14px; font-weight: 700; transition: 0.3s; margin-bottom: 4px; }
    .nav-item:hover { color: var(--zen-sidebar-active); background: rgba(255,255,255,0.05); }
    .nav-item.active { color: var(--zen-sidebar-active); background: var(--zen-accent); box-shadow: 0 8px 20px rgba(59, 130, 246, 0.25); }
    
    .sidebar-footer { padding: 24px; border-top: 1px solid rgba(255,255,255,0.05); }
    .admin-profile { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; padding: 0 8px; }
    .profile-avatar { width: 40px; height: 40px; border-radius: 12px; background: var(--zen-accent); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 18px; }
    .profile-name { font-size: 14px; font-weight: 800; color: white; }
    .profile-status { font-size: 11px; color: #10B981; font-weight: 700; }
    .logout-btn { width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 12px; background: rgba(255,255,255,0.05); border: none; border-radius: 12px; color: #ff4444; font-weight: 700; font-size: 13px; cursor: pointer; transition: 0.3s; }

    .zen-main { flex: 1; margin-left: 280px; padding: 40px; }
    .main-container { max-width: 1200px; margin: 0 auto; }
    .page-header { margin-bottom: 48px; }
    .page-title { font-size: 32px; font-weight: 800; margin: 0; letter-spacing: -0.03em; }
    .page-subtitle { color: var(--zen-text-secondary); margin: 8px 0 0 0; font-weight: 600; }

    .search-bar { margin-bottom: 32px; }
    .search-bar input { width: 100%; max-width: 400px; padding: 16px 24px; border-radius: 16px; border: 1px solid var(--zen-border); background: var(--zen-card); color: var(--zen-text); font-weight: 600; outline: none; }

    .leader-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    .citizen-card { background: var(--zen-card); border: 1px solid var(--zen-border); border-radius: 24px; padding: 24px; display: flex; align-items: center; gap: 20px; transition: 0.3s; position: relative; overflow: hidden; }
    .citizen-card:hover { transform: translateY(-4px); border-color: var(--zen-accent); }
    
    .rank-badge { position: absolute; top: 0; right: 0; padding: 8px 16px; border-bottom-left-radius: 16px; font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; }
    .rank-1 .rank-badge { background: #FFD700; color: #8B4513; }
    .rank-2 .rank-badge { background: #C0C0C0; color: #4F4F4F; }
    .rank-3 .rank-badge { background: #CD7F32; color: #ffffff; }

    .citizen-avatar { width: 64px; height: 64px; border-radius: 20px; background: var(--zen-bg); border: 1px solid var(--zen-border); display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 800; color: var(--zen-accent); }
    .citizen-info { flex: 1; }
    .citizen-name { font-weight: 800; font-size: 18px; margin-bottom: 4px; }
    .citizen-points { display: flex; align-items: center; gap: 6px; color: var(--zen-accent); font-weight: 800; font-size: 14px; }

    .mobile-menu-btn { display: none; position: fixed; top: 20px; left: 20px; z-index: 1100; background: var(--zen-sidebar-bg); color: white; border: none; padding: 10px; border-radius: 12px; }
    @media (max-width: 1024px) {
      .zen-sidebar { transform: translateX(-100%); transition: transform 0.3s; }
      .zen-sidebar.mobile-open { transform: translateX(0); }
      .zen-main { margin-left: 0; padding: 80px 20px 40px 20px; }
      .mobile-menu-btn { display: block; }
    }
  </style>

  <script is:inline define:vars={{ API_URL }}>
    let leaderData = [];
    
    async function init() {
      const token = localStorage.getItem("access_token");
      const user = JSON.parse(localStorage.getItem("user") || "{}");
      if (!token || user.role !== "admin") return window.location.href = "/admin/login";

      const adminNameEl = document.getElementById("admin-name-sidebar");
      if(adminNameEl) adminNameEl.innerText = user.full_name || "Admin";

      try {
        const res = await fetch(`${API_URL}/api/leaderboard`);
        const json = await res.json();
        leaderData = json.data || [];
        renderLeaderboard(leaderData);
      } catch (err) {
        console.error(err);
      }
    }

    function renderLeaderboard(data) {
      const container = document.getElementById("leader-list");
      if (!container) return;
      
      if (data.length === 0) {
        container.innerHTML = '<div style="grid-column: 1/-1; padding:60px; text-align:center; color:var(--zen-text-secondary);">Tidak ada data warga ditemukan.</div>';
        return;
      }

      container.innerHTML = data.map((u, i) => {
        const initial = (u.full_name || "U")[0].toUpperCase();
        const rank = i + 1;
        const rankClass = rank === 1 ? "rank-1" : rank === 2 ? "rank-2" : rank === 3 ? "rank-3" : "";
        return `
          <div class="citizen-card ${rankClass}">
            ${rank <= 3 ? `<div class="rank-badge">RANK ${rank}</div>` : ''}
            <div class="citizen-avatar">${initial}</div>
            <div class="citizen-info">
              <div class="citizen-name">${u.full_name}</div>
              <div class="citizen-points">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                ${u.points} POINTS
              </div>
            </div>
          </div>
        `;
      }).join("");
    }

    document.getElementById("leader-search")?.addEventListener("input", (e) => {
      const search = e.target.value.toLowerCase();
      const filtered = leaderData.filter(u => u.full_name.toLowerCase().includes(search));
      renderLeaderboard(filtered);
    });

    document.getElementById("mobile-menu-btn")?.addEventListener("click", () => document.getElementById("sidebar").classList.toggle("mobile-open"));
    document.getElementById("logout-btn")?.addEventListener("click", () => { localStorage.clear(); window.location.href = "/admin/login"; });

    init();
  </script>
</Layout>
