---
import Layout from '../../layouts/Layout.astro';
import '../../styles/dashboard-shared.css';
---

<Layout title="Kelola Pengguna — SovraEquitara Admin">
  <div class="app-container">
    <!-- Desktop Sidebar -->
    <aside class="desktop-sidebar">
      <div class="sidebar-brand">
        <img src="/logo.svg" alt="Sovra" class="brand-img" />
      </div>
      <nav class="sidebar-nav-v2">
        <a href="/admin/dashboard" class="side-item">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
          <span>Antrean Laporan</span>
        </a>
        <a href="/admin/users" class="side-item active">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          <span>Kelola Pengguna</span>
        </a>
      </nav>
      <div class="sidebar-bottom">
        <button id="btn-logout-desktop" class="side-item logout">
          <svg viewBox="0 0 24 24" class="s-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
          <span>Keluar</span>
        </button>
      </div>
    </aside>

    <!-- Mobile Bottom Nav -->
    <nav class="mobile-nav">
      <a href="/admin/dashboard" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
      </a>
      <a href="/admin/users" class="mob-item active">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
      </a>
      <button id="btn-logout-mobile" class="mob-item">
        <svg viewBox="0 0 24 24" class="m-icon"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path></svg>
      </button>
    </nav>

    <!-- Main Viewport -->
    <main class="main-content scroll-slim">
      <header class="app-header">
        <div class="header-left">
          <div class="mobile-logo-only">
            <img src="/logo.svg" alt="Sovra" />
          </div>
          <div class="desktop-breadcrumb">
            <span class="crumb">Panel Admin</span> / <span class="crumb active">Kelola Pengguna</span>
          </div>
        </div>
        <div class="header-right">
          <div class="admin-badge">Admin Access</div>
        </div>
      </header>

      <div class="content-inner fade-in">
        <section class="admin-hero">
          <div class="hero-text">
            <h1>Manajemen Pengguna</h1>
            <p>Daftar warga yang terdaftar dalam platform SovraEquitara.</p>
          </div>
        </section>

        <div class="card-zen list-wrapper-v2">
          <div class="table-header-v2">
            <div class="th-col">Warga</div>
            <div class="th-col d-hide">Role</div>
            <div class="th-col d-hide">Poin</div>
            <div class="th-col t-right">Terdaftar</div>
          </div>
          <div id="users-list">
            <div class="loading-state">Memuat data pengguna...</div>
          </div>
        </div>
      </div>
    </main>

    <div id="toast" class="saas-toast"></div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');

    if (!token) window.location.href = '/login';
    const user = userRaw ? JSON.parse(userRaw) : {};
    const role = (user.role || '').toUpperCase();
    if (role !== 'ADMIN') window.location.href = '/dashboard';

    async function fetchUsers() {
      try {
        const res = await fetch(`${API_URL}/api/admin/users`, {
          headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        renderUsers(data.data || []);
      } catch (err) { console.error(err); }
    }

    function renderUsers(items) {
      const list = document.getElementById('users-list');
      if (items.length === 0) {
        list.innerHTML = '<div class="empty-msg">Tidak ada pengguna terdaftar.</div>';
        return;
      }
      list.innerHTML = items.map(u => `
        <div class="admin-row-v2">
          <div class="row-main">
            <div class="r-info">
              <span class="r-title">${u.full_name || u.name || 'Warga'}</span>
              <span class="r-meta">${u.email}</span>
            </div>
            <div class="r-loc d-hide">${u.role}</div>
            <div class="r-status d-hide">
              <span class="pts-badge">${u.points || 0} PTS</span>
            </div>
            <div class="r-date t-right">
              ${new Date(u.created_at).toLocaleDateString('id-ID')}
            </div>
          </div>
        </div>
      `).join('');
    }

    const logout = () => { localStorage.clear(); window.location.href = '/login'; };
    document.getElementById('btn-logout-desktop').onclick = logout;
    document.getElementById('btn-logout-mobile').onclick = logout;

    fetchUsers();
  </script>
</Layout>

<style>
  /* Reuse styles from admin dashboard */
  .sidebar-brand { margin-bottom: 48px; padding: 0 12px; }
  .brand-img { height: 48px; width: auto; filter: invert(1); }
  .sidebar-nav-v2 { display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .side-item { display: flex; align-items: center; gap: 16px; padding: 14px 20px; border-radius: 14px; color: rgba(255,255,255,0.6); text-decoration: none; font-weight: 600; font-size: 15px; transition: 0.2s; }
  .side-item:hover { background: rgba(255,255,255,0.05); color: white; }
  .side-item.active { background: var(--color-saas-accent); color: #111827; }
  .side-item.logout { color: #F87171; margin-top: auto; }
  .s-icon { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; }
  .admin-badge { background: #111827; color: white; padding: 6px 14px; border-radius: 8px; font-size: 12px; font-weight: 800; text-transform: uppercase; }
  .admin-hero { margin-bottom: 40px; }
  .hero-text h1 { font-size: 32px; font-weight: 900; margin-bottom: 8px; }
  .hero-text p { color: var(--color-saas-text-muted); }
  .table-header-v2 { display: flex; padding: 16px 24px; background: #F9FAFB; border-bottom: 1px solid var(--color-saas-border); }
  .th-col { flex: 1; font-size: 12px; font-weight: 800; color: var(--color-saas-text-muted); text-transform: uppercase; }
  .t-right { text-align: right; }
  .admin-row-v2 { border-bottom: 1px solid var(--color-saas-border); transition: 0.2s; }
  .admin-row-v2:hover { background: #F9FAFB; }
  .row-main { display: flex; align-items: center; padding: 24px; }
  .r-info { flex: 1; display: flex; flex-direction: column; gap: 4px; }
  .r-title { font-weight: 700; color: #111827; font-size: 16px; }
  .r-meta { font-size: 13px; color: var(--color-saas-text-muted); }
  .pts-badge { background: #FEF3C7; color: #D97706; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 800; }
  .mobile-logo-only { display: none; }
  @media (max-width: 767px) {
    .mobile-logo-only { display: block; height: 32px; }
    .mobile-logo-only img { height: 100%; }
    .d-hide { display: none; }
    .row-main { padding: 16px; }
  }
</style>
