---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
---

<Layout title="Profile Admin — SovraEquitara">
  <div class="flex min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark transition-all duration-300 font-display">
    <button id="mobile-menu-btn" class="lg:hidden fixed top-6 right-6 z-50 p-3 bg-white dark:bg-stone-900 border border-stone-200 dark:border-white/10 rounded-2xl shadow-xl">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    
    <Sidebar activePage="profile" />

    <main class="flex-1 lg:ml-[280px] p-8 lg:p-[60px]">
      <div class="max-w-[900px] mx-auto">
        <header class="mb-12">
          <div>
            <h1 class="text-3xl font-extrabold m-0 mb-1">Profil Admin</h1>
            <p class="text-zen-text-secondary dark:text-zen-text-secondary-dark text-[15px]">Kelola informasi akun administrator</p>
          </div>
        </header>

        <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark rounded-3xl p-10 shadow-zen">
          <div class="flex items-center gap-8 mb-12">
            <div class="w-20 h-20 bg-zen-border dark:bg-zen-border-dark rounded-3xl flex items-center justify-center text-3xl font-extrabold">A</div>
            <div class="header-info">
              <h2 id="display-name" class="text-2xl font-bold">Administrator</h2>
              <p id="display-email" class="text-stone-500">admin@sovra.com</p>
            </div>
          </div>

          <div class="profile-form">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
              <div class="form-group">
                <label class="block text-[11px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase mb-2 tracking-wide">Nama Lengkap</label>
                <input type="text" id="input-name" value="Administrator" class="w-full p-3.5 border border-zen-border dark:border-zen-border-dark rounded-xl !bg-zen-bg dark:!bg-zen-bg-dark text-zen-text dark:text-zen-text-dark outline-none text-sm font-medium transition-colors focus:border-zen-accent dark:focus:border-zen-accent-dark appearance-none" />
              </div>
              <div class="form-group">
                <label class="block text-[11px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase mb-2 tracking-wide">Email</label>
                <input type="email" id="input-email" value="admin@sovra.com" disabled class="w-full p-3.5 border border-zen-border dark:border-zen-border-dark rounded-xl !bg-zen-bg dark:!bg-zen-bg-dark text-zen-text dark:text-zen-text-dark outline-none text-sm font-medium transition-colors opacity-70 cursor-not-allowed appearance-none" />
              </div>
            </div>
            <button class="px-8 py-3.5 bg-zen-accent dark:bg-zen-accent-dark text-zen-sidebar-bg dark:text-zen-sidebar-bg-dark border-none rounded-xl font-bold cursor-pointer transition-transform hover:opacity-90 hover:-translate-y-px">Simpan Perubahan</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    const user = JSON.parse(localStorage.getItem("user") || "{}");
    if (!user || (user.role !== "admin" && user.role !== "super_admin")) {
      window.location.href = "/admin/login";
    } else {
      const nameEl = document.getElementById("display-name");
      const sidebarNameEl = document.getElementById("admin-name-sidebar");
      const emailEl = document.getElementById("display-email");
      const nameInput = document.getElementById("input-name") as HTMLInputElement;
      const emailInput = document.getElementById("input-email") as HTMLInputElement;
      
      if(nameEl) nameEl.innerText = user.full_name || "Admin";
      if(emailEl) emailEl.innerText = user.email || "";
      if(nameInput) nameInput.value = user.full_name || "";
      if(emailInput) emailInput.value = user.email || "";
    }

    document.getElementById("mobile-menu-btn")?.addEventListener("click", () => document.getElementById("sidebar")?.classList.toggle("-translate-x-full"));

    document.getElementById("logout-btn")?.addEventListener("click", () => {
      localStorage.clear();
      window.location.href = "/admin/login";
    });
  </script>
</Layout>
