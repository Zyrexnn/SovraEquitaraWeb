---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Profile Admin — SovraEquitara">
  <script is:inline define:vars={{ API_URL }}>
    window.API_URL = API_URL;
  </script>

  <div class="flex min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark transition-all duration-300 font-display">
    <Sidebar activePage="profile" />

    <main class="flex-1 lg:ml-[280px] p-8 lg:p-[60px]">
      <div class="max-w-[900px] mx-auto">
        <header class="mb-12">
          <div>
            <h1 class="text-3xl font-extrabold m-0 mb-1">Profil Admin</h1>
            <p class="text-zen-text-secondary dark:text-zen-text-secondary-dark text-[15px]">Kelola informasi akun administrator</p>
          </div>
        </header>

        <div class="bg-zen-card dark:bg-zen-card-dark border border-zen-border dark:border-zen-border-dark rounded-3xl p-10 shadow-zen">
          <div class="flex items-center gap-8 mb-12">
            <div class="relative group">
              <div class="w-20 h-20 bg-zen-border dark:bg-zen-border-dark rounded-3xl flex items-center justify-center text-3xl font-extrabold overflow-hidden" id="avatar-container">
                <span id="avatar-initial">A</span>
                <img id="avatar-img" src="" class="w-full h-full object-cover hidden" alt="Profile" />
              </div>
              <label for="avatar-upload" title="Ubah Foto Profil" class="absolute -bottom-2 -right-2 w-8 h-8 bg-emerald-500 border-2 border-zen-card dark:border-zen-card-dark rounded-full shadow-lg flex items-center justify-center text-white cursor-pointer hover:scale-110 transition-transform z-10">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="3"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
              </label>
              <input type="file" id="avatar-upload" accept="image/jpeg,image/png,image/webp" class="hidden" />
            </div>
            <div class="header-info">
              <h2 id="display-name" class="text-2xl font-bold">Administrator</h2>
              <p id="display-email" class="text-stone-500">admin@sovra.com</p>
            </div>
          </div>

          <form id="admin-profile-form" class="profile-form">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
              <div class="form-group">
                <label class="block text-[11px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase mb-2 tracking-wide">Nama Lengkap</label>
                <input type="text" id="input-name" value="Administrator" required class="w-full p-3.5 border border-zen-border dark:border-zen-border-dark rounded-xl !bg-zen-bg dark:!bg-zen-bg-dark text-zen-text dark:text-zen-text-dark outline-none text-sm font-medium transition-colors focus:border-zen-accent dark:focus:border-zen-accent-dark appearance-none" />
              </div>
              <div class="form-group">
                <label class="block text-[11px] font-extrabold text-zen-text-secondary dark:text-zen-text-secondary-dark uppercase mb-2 tracking-wide">Email</label>
                <input type="email" id="input-email" value="admin@sovra.com" disabled class="w-full p-3.5 border border-zen-border dark:border-zen-border-dark rounded-xl !bg-zen-bg dark:!bg-zen-bg-dark text-zen-text dark:text-zen-text-dark outline-none text-sm font-medium transition-colors opacity-70 cursor-not-allowed appearance-none" />
              </div>
            </div>
            <button type="submit" class="px-8 py-3.5 bg-zen-accent dark:bg-zen-accent-dark text-zen-sidebar-bg dark:text-zen-sidebar-bg-dark border-none rounded-xl font-bold cursor-pointer transition-transform hover:opacity-90 hover:-translate-y-px">Simpan Perubahan</button>
          </form>
        </div>
      </div>
    </main>
  </div>

  <script>
    import { showToast } from '../../lib/toast';

    async function handleAvatarUpload(e) {
      const file = e.target.files[0];
      if (!file) return;

      const token = localStorage.getItem("access_token");
      const user = JSON.parse(localStorage.getItem("user") || "{}");
      
      const formData = new FormData();
      formData.append('avatar', file);

      try {
        const res = await fetch(`${window.API_URL}/api/profile/avatar`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}` },
          body: formData
        });
        const data = await res.json();
        if (res.ok) {
          showToast(data.message, 'success');
          user.avatar_url = data.avatar_url;
          localStorage.setItem('user', JSON.stringify(user));
          
          const img = document.getElementById('avatar-img') as HTMLImageElement;
          if (img) {
            img.src = `${window.API_URL}${data.avatar_url}`;
            img.classList.remove('hidden');
            document.getElementById('avatar-initial')?.classList.add('hidden');
          }
          window.dispatchEvent(new Event('storage'));
        } else {
          showToast(data.error || 'Gagal unggah', 'error');
        }
      } catch (err) {
        showToast('Koneksi gagal', 'error');
      }
    }

    async function handleUpdateProfile(e) {
      e.preventDefault();
      const token = localStorage.getItem("access_token");
      const user = JSON.parse(localStorage.getItem("user") || "{}");
      const name = (document.getElementById("input-name") as HTMLInputElement).value;

      try {
        const res = await fetch(`${window.API_URL}/api/profile`, {
          method: 'PUT',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}` 
          },
          body: JSON.stringify({ full_name: name })
        });
        
        if (res.ok) {
          showToast('Profil Diperbarui!', 'success');
          user.full_name = name;
          user.name = name;
          localStorage.setItem('user', JSON.stringify(user));
          document.getElementById("display-name")!.innerText = name;
          document.getElementById("avatar-initial")!.innerText = name[0].toUpperCase();
          window.dispatchEvent(new Event('storage'));
        } else {
          showToast('Gagal perbarui profil', 'error');
        }
      } catch (err) {
        showToast('Koneksi gagal', 'error');
      }
    }

    function init() {
      const user = JSON.parse(localStorage.getItem("user") || "{}");
      if (!user || (user.role !== "admin" && user.role !== "super_admin")) {
        window.location.href = "/admin/login";
        return;
      }

      const nameEl = document.getElementById("display-name");
      const emailEl = document.getElementById("display-email");
      const nameInput = document.getElementById("input-name") as HTMLInputElement;
      const emailInput = document.getElementById("input-email") as HTMLInputElement;
      const avatarInitial = document.getElementById("avatar-initial");
      const avatarImg = document.getElementById("avatar-img") as HTMLImageElement;
      
      const name = user.full_name || user.name || "Admin";
      if(nameEl) nameEl.innerText = name;
      if(emailEl) emailEl.innerText = user.email || "";
      if(nameInput) nameInput.value = name;
      if(emailInput) emailInput.value = user.email || "";
      if(avatarInitial) avatarInitial.innerText = name[0].toUpperCase();

      if (user.avatar_url && avatarImg) {
        avatarImg.src = `${window.API_URL}${user.avatar_url}`;
        avatarImg.classList.remove('hidden');
        avatarInitial?.classList.add('hidden');
      }

      const uploadInput = document.getElementById("avatar-upload");
      if (uploadInput) uploadInput.onchange = handleAvatarUpload;

      const profileForm = document.getElementById("admin-profile-form");
      if (profileForm) profileForm.onsubmit = handleUpdateProfile;
    }

    document.addEventListener('astro:page-load', init, { once: true });
    
    // Fallback if already loaded
    if (document.readyState === 'complete') init();
  </script>
</Layout>
