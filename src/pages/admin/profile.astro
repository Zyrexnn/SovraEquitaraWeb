---
import Layout from '../../layouts/Layout.astro';
import { ThemeToggle } from '../../components/ThemeToggle';
---

<Layout title="Profile Admin — SovraEquitara">
  <div class="zen-admin-root">
    <aside class="zen-sidebar">
      <div class="sidebar-header">
        <img src="/logo.svg" alt="Sovra" class="logo-mark dark:brightness-0 dark:invert">
        <ThemeToggle client:load />
      </div>
      
      <nav class="sidebar-nav">
        <a href="/admin/dashboard" class="nav-item">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="3" width="7" height="7" rx="1"></rect>
            <rect x="14" y="14" width="7" height="7" rx="1"></rect>
            <rect x="3" y="14" width="7" height="7" rx="1"></rect>
          </svg>
          <span>Dashboard</span>
        </a>
        <a href="/admin/profile" class="nav-item active">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
          <span>Profile</span>
        </a>
      </nav>

      <div class="sidebar-footer">
        <div class="admin-profile">
          <div class="profile-avatar">A</div>
          <div class="profile-info">
            <div class="profile-name" id="admin-name-sidebar">Admin</div>
            <div class="profile-status">Online</div>
          </div>
        </div>
        <button id="logout-btn" class="logout-btn">Logout</button>
      </div>
    </aside>

    <main class="zen-main">
      <div class="main-container">
        <header class="page-header">
          <div>
            <h1 class="page-title">Profil Admin</h1>
            <p class="page-subtitle">Kelola informasi akun administrator</p>
          </div>
        </header>

        <div class="profile-card">
          <div class="profile-header">
            <div class="avatar-huge">A</div>
            <div class="header-info">
              <h2 id="display-name" class="text-2xl font-bold">Administrator</h2>
              <p id="display-email" class="text-stone-500">admin@sovra.com</p>
            </div>
          </div>

          <div class="profile-form">
            <div class="form-grid">
              <div class="form-group">
                <label>Nama Lengkap</label>
                <input type="text" id="input-name" value="Administrator" />
              </div>
              <div class="form-group">
                <label>Email</label>
                <input type="email" id="input-email" value="admin@sovra.com" disabled />
              </div>
            </div>
            <button class="btn-save">Simpan Perubahan</button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <style is:global>
    :root {
      --zen-bg: #fbfbfb;
      --zen-sidebar-bg: #ffffff;
      --zen-card-bg: #ffffff;
      --zen-border: #f0f0f0;
      --zen-text-primary: #1a1a1a;
      --zen-text-secondary: #777777;
      --zen-accent: #000000;
      --zen-radius: 20px;
    }

    .dark {
      --zen-bg: #010101;
      --zen-sidebar-bg: #0B0B0F;
      --zen-card-bg: #0B0B0F;
      --zen-border: #1E293B;
      --zen-text-primary: #ffffff;
      --zen-text-secondary: #94A3B8;
      --zen-accent: #ffffff;
    }

    .zen-admin-root { display: flex; min-height: 100vh; background: var(--zen-bg); color: var(--zen-text-primary); transition: 0.3s; }
    
    .zen-sidebar { 
      width: 280px; background: var(--zen-sidebar-bg); border-right: 1px solid var(--zen-border); position: fixed; height: 100vh; z-index: 100; 
      display: flex; flex-direction: column; transition: 0.3s;
    }
    .sidebar-header { padding: 40px 32px; display: flex; align-items: center; justify-content: space-between; }
    .logo-mark { height: 32px; }
    
    .sidebar-nav { padding: 0 16px; flex: 1; }
    .nav-item { 
      display: flex; align-items: center; gap: 12px; padding: 14px 16px; text-decoration: none; color: var(--zen-text-secondary); 
      font-weight: 600; font-size: 14px; border-radius: 14px; margin-bottom: 6px; transition: 0.2s;
    }
    .nav-item.active { background: var(--zen-accent); color: var(--zen-sidebar-bg); }
    .nav-item:hover:not(.active) { background: var(--zen-bg); }

    .sidebar-footer { padding: 24px; border-top: 1px solid var(--zen-border); }
    .admin-profile { display: flex; align-items: center; gap: 12px; padding: 12px; background: var(--zen-bg); border-radius: 16px; margin-bottom: 16px; }
    .profile-avatar { width: 36px; height: 36px; background: var(--zen-border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 14px; }
    .profile-info { flex: 1; min-width: 0; }
    .profile-name { font-size: 13px; font-weight: 700; color: var(--zen-text-primary); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .profile-status { font-size: 10px; color: #10b981; font-weight: 700; text-transform: uppercase; }
    
    .logout-btn { 
      width: 100%; padding: 12px; background: transparent; border: 1px solid var(--zen-border); border-radius: 12px; 
      font-size: 13px; font-weight: 700; color: var(--zen-text-secondary); cursor: pointer; transition: 0.2s;
    }
    .logout-btn:hover { background: #fee2e2; color: #ef4444; border-color: #ef4444; }

    .zen-main { flex: 1; margin-left: 280px; padding: 60px; }
    .main-container { max-width: 900px; margin: 0 auto; }
    .page-header { margin-bottom: 48px; }
    .page-title { font-size: 32px; font-weight: 800; margin: 0 0 4px 0; }
    .page-subtitle { color: var(--zen-text-secondary); font-size: 15px; }
    
    .profile-card { background: var(--zen-card-bg); border: 1px solid var(--zen-border); border-radius: var(--zen-radius); padding: 40px; }
    .profile-header { display: flex; align-items: center; gap: 32px; margin-bottom: 48px; }
    .avatar-huge { width: 80px; height: 80px; background: var(--zen-border); border-radius: 24px; display: flex; align-items: center; justify-content: center; font-size: 32px; font-weight: 800; }
    
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 32px; }
    .form-group label { display: block; font-size: 11px; font-weight: 800; color: var(--zen-text-secondary); text-transform: uppercase; margin-bottom: 8px; letter-spacing: 0.05em; }
    .form-group input { 
      width: 100%; padding: 14px; border: 1px solid var(--zen-border); border-radius: 12px; background: var(--zen-bg); 
      color: var(--zen-text-primary); outline: none; font-size: 14px; font-weight: 500; transition: 0.2s;
    }
    .form-group input:focus { border-color: var(--zen-accent); }
    .btn-save { padding: 14px 32px; background: var(--zen-accent); color: var(--zen-sidebar-bg); border: none; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.2s; }
    .btn-save:hover { opacity: 0.9; transform: translateY(-1px); }

    @media (max-width: 1024px) {
      .zen-sidebar { transform: translateX(-100%); }
      .zen-main { margin-left: 0; padding: 32px; }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    const user = JSON.parse(localStorage.getItem("user") || "{}");
    if (!user || user.role !== "admin") {
      window.location.href = "/admin/login";
    } else {
      const nameEl = document.getElementById("display-name");
      const sidebarNameEl = document.getElementById("admin-name-sidebar");
      const emailEl = document.getElementById("display-email");
      const nameInput = document.getElementById("input-name") as HTMLInputElement;
      const emailInput = document.getElementById("input-email") as HTMLInputElement;
      
      if(nameEl) nameEl.innerText = user.full_name || "Admin";
      if(sidebarNameEl) sidebarNameEl.innerText = user.full_name || "Admin";
      if(emailEl) emailEl.innerText = user.email || "";
      if(nameInput) nameInput.value = user.full_name || "";
      if(emailInput) emailInput.value = user.email || "";
    }

    document.getElementById("logout-btn")?.addEventListener("click", () => {
      localStorage.clear();
      window.location.href = "/admin/login";
    });
  </script>
</Layout>
