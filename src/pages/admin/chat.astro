---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Chat Inbox — SovraEquitara">
  <script is:inline define:vars={{ API_URL }}>
    window.API_URL = API_URL;
  </script>

  <div class="flex min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark font-display" id="admin-root" data-api-url={API_URL}>
    <Sidebar activePage="chat" />

    <main class="flex-1 lg:ml-72 min-h-screen min-w-0 w-full overflow-x-hidden flex flex-col">
      <div class="max-w-7xl mx-auto w-full p-4 sm:p-6 lg:p-12 flex-1 flex flex-col gap-6">
        <header class="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 class="text-3xl lg:text-4xl font-black tracking-tight flex items-center gap-3">Chat Inbox <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-500 text-base">💬</span></h1>
            <p class="text-stone-500 font-bold mt-1 text-sm">Kelola pesan dari warga dan admin.</p>
          </div>
          <div class="flex items-center gap-3">
            <select id="filter-role" class="px-4 py-3 bg-white dark:bg-stone-900 border border-stone-200 dark:border-white/10 rounded-2xl text-sm font-bold outline-none cursor-pointer">
              <option value="">Semua Role</option>
              <option value="USER">Warga</option>
              <option value="admin">Admin</option>
            </select>
            <div id="unread-badge" class="hidden px-4 py-3 bg-red-50 dark:bg-red-500/10 text-red-500 rounded-2xl text-sm font-black border border-red-200 dark:border-red-500/20">0 belum dibaca</div>
          </div>
        </header>

        <!-- Bento Grid: Conversation List + Chat Detail -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 flex-1 min-h-0">
          <!-- Conversation List -->
          <div class="lg:col-span-4 bg-white dark:bg-stone-900 rounded-[32px] border border-stone-200 dark:border-white/10 shadow-sm flex flex-col overflow-hidden min-h-[400px] lg:min-h-0">
            <div class="p-5 border-b border-stone-100 dark:border-white/5">
              <div class="relative">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-stone-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input id="search-conv" type="text" placeholder="Cari percakapan..." class="w-full pl-11 pr-4 py-3 bg-stone-50 dark:bg-white/5 border border-stone-100 dark:border-white/5 rounded-2xl text-sm font-bold outline-none focus:ring-2 focus:ring-blue-500/20" />
              </div>
            </div>
            <div id="conv-list" class="flex-1 overflow-y-auto p-3 space-y-1.5 scrollbar-hide">
              <div class="flex items-center justify-center h-32 text-stone-400 font-bold text-sm">Memuat...</div>
            </div>
          </div>

          <!-- Chat Detail Panel -->
          <div class="lg:col-span-8 bg-white dark:bg-stone-900 rounded-[32px] border border-stone-200 dark:border-white/10 shadow-sm flex flex-col overflow-hidden min-h-[500px] lg:min-h-0">
            <!-- Empty State -->
            <div id="chat-empty" class="flex-1 flex flex-col items-center justify-center gap-4 text-stone-400 p-8">
              <div class="w-20 h-20 rounded-full bg-stone-50 dark:bg-white/5 flex items-center justify-center text-4xl border border-stone-100 dark:border-white/5">💬</div>
              <p class="font-bold text-sm text-center">Pilih percakapan untuk mulai membalas pesan.</p>
            </div>

            <!-- Active Chat -->
            <div id="chat-active" class="hidden flex-1 flex flex-col">
              <!-- Chat Header -->
              <div class="px-6 py-4 border-b border-stone-100 dark:border-white/5 flex items-center gap-4">
                <button id="chat-back-btn" class="lg:hidden p-2 hover:bg-stone-100 dark:hover:bg-white/5 rounded-xl">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <div id="chat-header-avatar" class="w-11 h-11 rounded-2xl bg-stone-900 dark:bg-white text-white dark:text-black flex items-center justify-center font-black text-sm cursor-pointer hover:scale-105 transition-transform" onclick="window.openProfileFromChat()">A</div>
                <div class="flex-1 min-w-0 cursor-pointer" onclick="window.openProfileFromChat()">
                  <div id="chat-header-name" class="font-black text-sm truncate">Nama User</div>
                  <div id="chat-header-role" class="text-[10px] font-bold text-stone-400 uppercase tracking-widest">USER</div>
                </div>
              </div>

              <!-- Messages -->
              <div id="chat-messages" class="flex-1 p-6 overflow-y-auto space-y-4 scrollbar-hide"></div>

              <!-- Reply Input -->
              <div class="p-4 border-t border-stone-100 dark:border-white/5 bg-stone-50/50 dark:bg-stone-950/50">
                <form id="reply-form" class="flex items-end gap-3">
                  <textarea id="reply-input" rows="1" placeholder="Tulis balasan..." class="w-full px-5 py-3.5 bg-white dark:bg-stone-900 border border-stone-200 dark:border-white/10 rounded-2xl text-sm font-bold outline-none focus:ring-2 focus:ring-blue-500/20 resize-none min-h-[48px] max-h-28"></textarea>
                  <button type="submit" class="p-3.5 bg-stone-900 dark:bg-white text-white dark:text-black rounded-2xl hover:scale-105 transition-transform shadow-lg">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Profile Modal -->
    <div id="profile-modal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
      <div class="absolute inset-0 bg-stone-900/40 dark:bg-black/80 backdrop-blur-sm" onclick="document.getElementById('profile-modal').classList.add('hidden')"></div>
      <div class="relative bg-white dark:bg-stone-900 w-full max-w-md rounded-[32px] shadow-2xl border border-stone-200 dark:border-white/10 overflow-hidden">
        <div class="p-8 flex flex-col items-center gap-4 text-center">
          <div id="pm-avatar" class="w-20 h-20 rounded-3xl bg-stone-900 dark:bg-white text-white dark:text-black flex items-center justify-center font-black text-3xl">U</div>
          <div>
            <h3 id="pm-name" class="text-xl font-black">Nama</h3>
            <p id="pm-email" class="text-sm text-stone-400 font-bold mt-1">email</p>
          </div>
          <div class="flex gap-3 w-full">
            <div class="flex-1 p-4 rounded-2xl bg-stone-50 dark:bg-white/5 border border-stone-100 dark:border-white/5 text-center">
              <div class="text-[10px] font-black text-stone-400 uppercase tracking-widest">Role</div>
              <div id="pm-role" class="font-black text-sm mt-1">USER</div>
            </div>
            <div class="flex-1 p-4 rounded-2xl bg-stone-50 dark:bg-white/5 border border-stone-100 dark:border-white/5 text-center">
              <div class="text-[10px] font-black text-stone-400 uppercase tracking-widest">Poin</div>
              <div id="pm-points" class="font-black text-sm mt-1">0</div>
            </div>
          </div>
          <div class="w-full p-4 rounded-2xl bg-stone-50 dark:bg-white/5 border border-stone-100 dark:border-white/5 text-left">
            <div class="text-[10px] font-black text-stone-400 uppercase tracking-widest mb-1">Bergabung</div>
            <div id="pm-joined" class="font-bold text-sm">-</div>
          </div>
          <button onclick="document.getElementById('profile-modal').classList.add('hidden')" class="w-full py-3.5 bg-stone-100 dark:bg-white/5 hover:bg-stone-200 dark:hover:bg-white/10 rounded-2xl font-black text-sm transition-colors">Tutup</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { showToast } from '../../lib/toast';
    const root = document.getElementById("admin-root");
    const API_URL = root?.dataset.apiUrl || "http://localhost:3000";
    let conversations = [];
    let activeConvId = null;
    let activeParticipantId = null;
    let pollInterval = null;

    async function init() {
      const token = localStorage.getItem("access_token");
      const user = JSON.parse(localStorage.getItem("user") || "{}");
      if (!token || (user.role !== "admin" && user.role !== "super_admin")) return window.location.href = "/admin/login";
      await loadConversations();
      startPolling();
    }

    function startPolling() {
      if (pollInterval) clearInterval(pollInterval);
      pollInterval = setInterval(() => {
        loadConversations(true);
        if (activeConvId) loadMessages(activeConvId, true);
      }, 4000);
    }

    async function loadConversations(silent = false) {
      const token = localStorage.getItem("access_token");
      const roleFilter = (document.getElementById("filter-role") as HTMLSelectElement).value;
      try {
        const res = await fetch(`${API_URL}/api/admin/chat/conversations?role=${roleFilter}`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        const json = await res.json();
        conversations = json.data || [];
        renderConversations(silent);
      } catch(e) { console.error(e); }
    }

    function renderConversations(silent = false) {
      const list = document.getElementById("conv-list");
      const search = (document.getElementById("search-conv") as HTMLInputElement).value.toLowerCase();
      if (!list) return;

      let filtered = conversations;
      if (search) filtered = filtered.filter(c => c.participant?.full_name?.toLowerCase().includes(search) || c.participant?.email?.toLowerCase().includes(search));

      const totalUnread = conversations.reduce((a, c) => a + (c.unread_count || 0), 0);
      const badge = document.getElementById("unread-badge");
      if (badge) {
        if (totalUnread > 0) { badge.classList.remove("hidden"); badge.textContent = `${totalUnread} belum dibaca`; }
        else { badge.classList.add("hidden"); }
      }

      if (filtered.length === 0) {
        list.innerHTML = '<div class="flex items-center justify-center h-32 text-stone-400 font-bold text-sm">Belum ada percakapan.</div>';
        return;
      }

      list.innerHTML = filtered.map(c => {
        const p = c.participant || {};
        const initial = (p.full_name || "U")[0].toUpperCase();
        const isActive = c.id === activeConvId;
        const roleLabel = p.role === "admin" ? "Admin" : "Warga";
        const roleColor = p.role === "admin" ? "text-blue-500" : "text-emerald-500";
        const unread = c.unread_count || 0;
        const time = c.last_message_at ? new Date(c.last_message_at).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" }) : "";
        return `
          <div class="flex items-center gap-3.5 p-3.5 rounded-2xl cursor-pointer transition-all duration-200 group ${isActive ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg' : 'hover:bg-stone-50 dark:hover:bg-white/5'}" onclick="window.openConversation('${c.id}', '${p.id}')">
            <div class="w-11 h-11 rounded-2xl ${isActive ? 'bg-white dark:bg-stone-900 text-black dark:text-white' : 'bg-stone-100 dark:bg-white/10 text-stone-700 dark:text-stone-300'} flex items-center justify-center font-black text-sm shrink-0 cursor-pointer" onclick="event.stopPropagation(); window.openProfileModal('${p.id}')">${initial}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="font-black text-sm truncate">${p.full_name || "Unknown"}</span>
                <span class="text-[10px] font-bold ${isActive ? 'opacity-60' : 'text-stone-400'} shrink-0">${time}</span>
              </div>
              <div class="flex items-center justify-between gap-2 mt-0.5">
                <span class="text-xs ${isActive ? 'opacity-70' : 'text-stone-400'} truncate font-medium">${c.last_message || "Belum ada pesan"}</span>
                ${unread > 0 && !isActive ? `<span class="shrink-0 w-5 h-5 rounded-full bg-red-500 text-white text-[10px] font-black flex items-center justify-center">${unread}</span>` : ''}
              </div>
              <span class="text-[9px] font-black uppercase tracking-widest ${isActive ? 'opacity-50' : roleColor}">${roleLabel}</span>
            </div>
          </div>`;
      }).join("");
    }

    window.openConversation = async (convId: string, participantId: string) => {
      activeConvId = convId;
      activeParticipantId = participantId;
      document.getElementById("chat-empty")?.classList.add("hidden");
      const chatActive = document.getElementById("chat-active");
      if (chatActive) { chatActive.classList.remove("hidden"); chatActive.classList.add("flex"); }

      const conv = conversations.find(c => c.id === convId);
      const p = conv?.participant || {};
      const headerAvatar = document.getElementById("chat-header-avatar");
      const headerName = document.getElementById("chat-header-name");
      const headerRole = document.getElementById("chat-header-role");
      if (headerAvatar) headerAvatar.textContent = (p.full_name || "U")[0].toUpperCase();
      if (headerName) headerName.textContent = p.full_name || "Unknown";
      if (headerRole) headerRole.textContent = p.role === "admin" ? "ADMIN" : "WARGA";

      await loadMessages(convId);
      renderConversations(true);
    };

    async function loadMessages(convId: string, silent = false) {
      const token = localStorage.getItem("access_token");
      const container = document.getElementById("chat-messages");
      if (!container) return;
      if (!silent) container.innerHTML = '<div class="flex justify-center py-8"><div class="w-7 h-7 border-[3px] border-stone-200 dark:border-white/10 border-t-stone-900 dark:border-t-white rounded-full animate-spin"></div></div>';

      try {
        const res = await fetch(`${API_URL}/api/admin/chat/conversations/${convId}/messages`, {
          headers: { "Authorization": `Bearer ${token}` }
        });
        const json = await res.json();
        const messages = json.data || [];
        const user = JSON.parse(localStorage.getItem("user") || "{}");

        container.innerHTML = messages.length === 0
          ? '<div class="flex items-center justify-center h-full text-stone-400 font-bold text-sm">Belum ada pesan.</div>'
          : messages.map(m => {
              const isMine = m.sender_id === user.id;
              const senderName = m.sender?.full_name || "Unknown";
              const time = new Date(m.created_at).toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" });
              return `
                <div class="flex gap-3 max-w-[85%] ${isMine ? 'self-end flex-row-reverse ml-auto' : ''}">
                  <div class="w-8 h-8 rounded-xl ${isMine ? 'bg-stone-900 dark:bg-white text-white dark:text-black' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400'} flex items-center justify-center font-black text-xs shrink-0 cursor-pointer" onclick="window.openProfileModal('${m.sender_id}')">${(senderName)[0].toUpperCase()}</div>
                  <div>
                    <div class="flex items-center gap-2 mb-1 ${isMine ? 'flex-row-reverse' : ''}">
                      <span class="text-[10px] font-bold text-stone-400">${senderName}</span>
                      <span class="text-[9px] text-stone-300 dark:text-stone-600">${time}</span>
                    </div>
                    <div class="px-4 py-3 rounded-2xl text-sm font-medium ${isMine ? 'bg-stone-900 dark:bg-white text-white dark:text-black rounded-tr-sm' : 'bg-stone-50 dark:bg-white/5 rounded-tl-sm border border-stone-100 dark:border-white/5'}">${m.content}</div>
                  </div>
                </div>`;
            }).join("");

        if (!silent) container.scrollTo({ top: container.scrollHeight, behavior: "smooth" });
      } catch(e) { console.error(e); }
    }

    // Reply
    document.getElementById("reply-form")?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!activeConvId) return;
      const input = document.getElementById("reply-input") as HTMLTextAreaElement;
      const val = input.value.trim();
      if (!val) return;

      const token = localStorage.getItem("access_token");
      try {
        const res = await fetch(`${API_URL}/api/admin/chat/conversations/${activeConvId}/reply`, {
          method: "POST",
          headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` },
          body: JSON.stringify({ content: val })
        });
        if (res.ok) { input.value = ""; await loadMessages(activeConvId); await loadConversations(true); }
        else { showToast({ message: "Gagal mengirim balasan", type: "error" }); }
      } catch(e) { showToast({ message: "Koneksi gagal", type: "error" }); }
    });

    // Profile Modal
    window.openProfileModal = async (userId: string) => {
      try {
        const res = await fetch(`${API_URL}/api/profiles/${userId}`);
        const json = await res.json();
        const p = json.data;
        if (!p) return;
        (document.getElementById("pm-avatar") as HTMLElement).textContent = (p.full_name || "U")[0].toUpperCase();
        (document.getElementById("pm-name") as HTMLElement).textContent = p.full_name || "-";
        (document.getElementById("pm-email") as HTMLElement).textContent = p.email || "-";
        (document.getElementById("pm-role") as HTMLElement).textContent = p.role === "admin" ? "Admin" : p.role === "super_admin" ? "Super Admin" : "Warga";
        (document.getElementById("pm-points") as HTMLElement).textContent = p.points || 0;
        (document.getElementById("pm-joined") as HTMLElement).textContent = new Date(p.created_at).toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" });
        const modal = document.getElementById("profile-modal");
        if (modal) { modal.classList.remove("hidden"); modal.classList.add("flex"); }
      } catch(e) {}
    };

    window.openProfileFromChat = () => { if (activeParticipantId) window.openProfileModal(activeParticipantId); };

    // Filters & search
    document.getElementById("filter-role")?.addEventListener("change", () => loadConversations());
    document.getElementById("search-conv")?.addEventListener("input", () => renderConversations());

    // Auto-resize reply input
    document.getElementById("reply-input")?.addEventListener("input", function() {
      this.style.height = "auto";
      this.style.height = this.scrollHeight + "px";
    });

    // Back button (mobile)
    document.getElementById("chat-back-btn")?.addEventListener("click", () => {
      activeConvId = null;
      document.getElementById("chat-active")?.classList.add("hidden");
      document.getElementById("chat-empty")?.classList.remove("hidden");
      renderConversations(true);
    });


    document.addEventListener('astro:page-load', init);
    if (document.readyState === 'complete') init();
  </script>
</Layout>