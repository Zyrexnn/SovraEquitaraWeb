---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Verifikasi OTP — SovraEquitara">
  <div class="fixed top-6 right-6 z-50">
    <ThemeToggle client:load />
  </div>

  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-8 bg-zen-bg dark:bg-zen-bg-dark transition-colors duration-300">
    <div class="w-full max-w-md animate-fade-in">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-20 sm:h-24 mx-auto mb-6 dark:brightness-0 dark:invert" />
        </a>
        <h1 class="text-3xl sm:text-4xl font-display font-bold mb-2 text-stone-900 dark:text-white">Verifikasi Akun</h1>
        <p id="instruction-text" class="text-base text-stone-600 dark:text-gray-400 font-medium">Masukkan kode OTP yang dikirim ke email Anda.</p>
      </div>

      <!-- Form Card -->
      <div class="card shadow-xl dark:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
        <form id="form-verify" class="space-y-6">
          <div class="space-y-2">
            <label for="otp" class="block text-sm font-bold text-stone-700 dark:text-gray-300 uppercase tracking-widest text-center">
              Kode OTP (6 Digit)
            </label>
            <input
              type="text"
              id="otp"
              placeholder="000000"
              maxlength="6"
              required
              class="w-full !bg-zen-bg dark:!bg-zen-bg-dark border border-zen-border dark:border-zen-border-dark rounded-2xl p-4 px-5 text-zen-text dark:text-zen-text-dark font-display text-[24px] tracking-[0.2em] font-extrabold text-center transition-all duration-300 outline-none focus:border-blue-500 focus:ring-4 focus:ring-black/5 dark:focus:ring-white/5 appearance-none"
            />
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="btn-submit"
            class="btn-primary w-full py-4 text-lg"
          >
            Verifikasi & Masuk
          </button>
        </form>

        <!-- Divider -->
        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-stone-200 dark:border-white/10"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase tracking-widest font-bold">
            <span class="bg-zen-card dark:bg-zen-card-dark px-4 text-zen-text-secondary dark:text-zen-text-secondary-dark rounded-full">Atau</span>
          </div>
        </div>

        <!-- Login Link -->
        <p class="text-center text-sm font-medium text-stone-600 dark:text-gray-400">
          Tidak menerima kode?
          <a href="/register" class="text-stone-900 dark:text-white font-bold hover:underline ml-1">Daftar ulang</a>
        </p>

        <!-- Resend OTP Action -->
        <div class="text-center mt-6 pt-4 border-t border-stone-100 dark:border-white/5">
          <button
            type="button"
            id="btn-resend"
            class="text-sm font-bold text-emerald-500 dark:text-emerald-400 hover:underline disabled:opacity-50 disabled:no-underline disabled:cursor-not-allowed"
          >
            Kirim Ulang OTP
          </button>
          <p id="cooldown-text" class="text-xs text-stone-500 dark:text-gray-400 mt-2 font-medium hidden animate-fade-in">
            Silakan tunggu <span id="cooldown-seconds" class="font-bold text-red-500">60</span> detik sebelum meminta OTP baru.
          </p>
        </div>
      </div>

      <!-- Footer Info -->
      <p class="text-center mt-12 text-xs font-bold text-stone-400 dark:text-gray-600 tracking-widest uppercase">
        &copy; 2026 SovraEquitara &bull; Aman & Transparan
      </p>
    </div>
  </main>
</Layout>

<script>
  import { showToast } from '../lib/toast';
  const API_URL = 'http://localhost:3000';
  const urlParams = new URLSearchParams(window.location.search);
  const email = urlParams.get('email');

  if (!email) {
    window.location.href = '/register';
  } else {
    const instruction = document.getElementById('instruction-text');
    if (instruction) instruction.textContent = `Kode OTP telah dikirim ke ${email}`;
  }

  const form = document.getElementById('form-verify') as HTMLFormElement;
  const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;
  const btnResend = document.getElementById('btn-resend') as HTMLButtonElement;
  const cooldownText = document.getElementById('cooldown-text') as HTMLDivElement;
  const cooldownSeconds = document.getElementById('cooldown-seconds') as HTMLSpanElement;

  let cooldownTimer: any = null;
  let remainingSeconds = 0;

  function startCooldown(seconds: number) {
    if (cooldownTimer) clearInterval(cooldownTimer);
    remainingSeconds = seconds;
    btnResend.disabled = true;
    cooldownText.classList.remove('hidden');
    cooldownSeconds.textContent = String(remainingSeconds);

    cooldownTimer = setInterval(() => {
      remainingSeconds--;
      if (remainingSeconds <= 0) {
        clearInterval(cooldownTimer);
        cooldownTimer = null;
        btnResend.disabled = false;
        cooldownText.classList.add('hidden');
      } else {
        cooldownSeconds.textContent = String(remainingSeconds);
      }
    }, 1000);
  }

  btnResend?.addEventListener('click', async () => {
    if (remainingSeconds > 0) return;
    
    btnResend.disabled = true;
    btnResend.textContent = 'Mengirim...';

    try {
      const res = await fetch(`${API_URL}/api/auth/resend-otp`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      const data = await res.json();

      if (res.ok) {
        showToast({ message: 'Kode OTP baru telah dikirim!', type: 'success' });
        startCooldown(60); // Standard 60 seconds cooldown on success
      } else {
        if (data.cooldown) {
          const secs = parseInt(data.cooldown, 10) || 60;
          showToast({ message: data.error, type: 'error' });
          startCooldown(secs);
        } else {
          showToast({ message: data.error || 'Gagal mengirim ulang OTP.', type: 'error' });
        }
      }
    } catch (err) {
      showToast({ message: 'Terjadi kesalahan koneksi.', type: 'error' });
    } finally {
      btnResend.textContent = 'Kirim Ulang OTP';
      if (!cooldownTimer) btnResend.disabled = false;
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const otp = (document.getElementById('otp') as HTMLInputElement).value;

    if (otp.length !== 6) {
      showToast({ message: 'Kode OTP harus 6 digit', type: 'error' });
      return;
    }

    btnSubmit.disabled = true;
    btnSubmit.innerText = 'Memverifikasi...';

    try {
      const res = await fetch(`${API_URL}/api/auth/verify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, token: otp })
      });

      const data = await res.json();

      if (res.ok) {
        showToast({ message: 'Verifikasi sukses! Selamat datang.', type: 'success' });
        
        localStorage.setItem('access_token', data.access_token);
        localStorage.setItem('user', JSON.stringify(data.user));

        setTimeout(() => {
          if (data.user.role === 'super_admin' || data.user.role === 'SUPER_ADMIN') {
            window.location.href = '/superadmin/dashboard';
          } else if (data.user.role === 'admin' || data.user.role === 'ADMIN') {
            window.location.href = '/admin/dashboard';
          } else {
            window.location.href = '/dashboard';
          }
        }, 1500);
      } else {
        showToast({ message: data.error || 'Verifikasi gagal. Kode OTP salah atau kadaluarsa.', type: 'error' });
        if (res.status === 429) {
          startCooldown(60); // Trigger 1 minute lockout cooldown
        }
      }
    } catch (err) {
      console.error('Verify error:', err);
      showToast({ message: 'Terjadi kesalahan koneksi. Pastikan server backend berjalan.', type: 'error' });
    } finally {
      btnSubmit.disabled = false;
      btnSubmit.innerText = 'Verifikasi & Masuk';
    }
  });
</script>
