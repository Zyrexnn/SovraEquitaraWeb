---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Masuk — SovraEquitara">
  <div class="fixed top-6 right-6 z-50">
    <ThemeToggle client:load />
  </div>

  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-8 bg-stone-50 dark:bg-[#010101] transition-colors duration-300">
    <div class="w-full max-w-md animate-fade-in">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-12 sm:h-14 mx-auto mb-6 dark:brightness-0 dark:invert" />
        </a>
        <h1 class="text-3xl sm:text-4xl font-display font-bold mb-2 text-stone-900 dark:text-white">Selamat Datang</h1>
        <p class="text-base text-stone-600 dark:text-gray-400 font-medium">Masuk untuk melanjutkan kontribusi Anda</p>
      </div>

      <!-- Form Card -->
      <div class="card shadow-xl dark:shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
        <form id="form-login" class="space-y-6">
          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-bold text-stone-700 dark:text-gray-300 mb-2 uppercase tracking-widest">
              Email
            </label>
            <input
              type="email"
              id="email"
              placeholder="nama@email.com"
              required
              class="input"
            />
          </div>

          <!-- Password -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="password" class="block text-sm font-bold text-stone-700 dark:text-gray-300 uppercase tracking-widest">
                Kata Sandi
              </label>
              <a href="#" class="text-xs font-bold text-amber-600 hover:text-amber-500 transition-colors">Lupa sandi?</a>
            </div>
            <input
              type="password"
              id="password"
              placeholder="••••••••"
              required
              class="input"
            />
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="btn-submit"
            class="btn-primary w-full py-4 text-lg"
          >
            Masuk Sekarang
          </button>
        </form>

        <!-- Divider -->
        <div class="relative my-8">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-stone-200 dark:border-white/10"></div>
          </div>
          <div class="relative flex justify-center text-xs uppercase tracking-widest font-bold">
            <span class="bg-white dark:bg-[#111] px-4 text-stone-400 dark:text-gray-500 rounded-full">Atau</span>
          </div>
        </div>

        <!-- Register Link -->
        <p class="text-center text-sm font-medium text-stone-600 dark:text-gray-400">
          Belum punya akun?
          <a href="/register" class="text-stone-900 dark:text-white font-bold hover:underline ml-1">Daftar gratis</a>
        </p>
      </div>

      <!-- Footer Info -->
      <p class="text-center mt-12 text-xs font-bold text-stone-400 dark:text-gray-600 tracking-widest uppercase">
        &copy; 2026 SovraEquitara &bull; Aman & Transparan
      </p>
    </div>
  </main>

  <script>
    const API_URL = 'http://localhost:3000';
    const form = document.getElementById('form-login') as HTMLFormElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      btnSubmit.disabled = true;
      btnSubmit.innerText = 'Memverifikasi...';

      try {
        const res = await fetch(`${API_URL}/api/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });

        const data = await res.json();

        if (res.ok) {
          localStorage.setItem('access_token', data.token);
          localStorage.setItem('user', JSON.stringify(data.user));
          
          if (data.user.role === 'admin' || data.user.role === 'ADMIN') {
            window.location.href = '/admin/dashboard';
          } else {
            window.location.href = '/dashboard';
          }
        } else {
          alert(data.message || 'Login gagal. Silakan periksa kembali email dan kata sandi Anda.');
        }
      } catch (err) {
        console.error('Login error:', err);
        alert('Terjadi kesalahan koneksi. Pastikan server backend berjalan.');
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Masuk Sekarang';
      }
    });
  </script>
</Layout>
