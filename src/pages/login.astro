---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="Masuk — SovraEquitara">
  <div class="fixed top-6 right-6 z-50">
    <ThemeToggle client:load />
  </div>

  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-12 bg-canvas-bg transition-colors duration-300">
    <div class="w-full max-w-md animate-fade-in py-12">
      <!-- Logo -->
      <div class="text-center mb-10">
        <a href="/" class="inline-block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-20 sm:h-24 mx-auto mb-8 dark:brightness-0 dark:invert" />
        </a>
        <h1 class="display-md mb-3">Selamat Datang</h1>
        <p class="text-base text-ink-muted font-medium">Masuk untuk melanjutkan kontribusi Anda</p>
      </div>

      <!-- Form Card -->
      <div class="card-zen">
        <form id="form-login" class="space-y-6">
          <!-- Email -->
          <div>
            <label for="email" class="block text-[11px] font-bold text-ink-tertiary mb-2 uppercase tracking-widest">
              Email
            </label>
            <input
              type="email"
              id="email"
              placeholder="nama@email.com"
              required
              class="input-zen"
            />
          </div>

          <!-- Password -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="password" class="block text-[11px] font-bold text-ink-tertiary uppercase tracking-widest">
                Kata Sandi
              </label>
              <a href="/forgot-password" class="text-[11px] font-bold text-ink hover:text-ink-muted transition-colors uppercase tracking-widest">Lupa sandi?</a>
            </div>
            <input
              type="password"
              id="password"
              placeholder="••••••••"
              required
              class="input-zen"
            />
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            id="btn-submit"
            class="btn-pill-primary w-full py-4 mt-2"
          >
            Masuk Sekarang
          </button>
        </form>

        <!-- Divider -->
        <div class="relative my-10">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-hairline"></div>
          </div>
          <div class="relative flex justify-center text-[10px] uppercase tracking-widest font-bold">
            <span class="bg-canvas-surface px-4 text-ink-tertiary rounded-full">Atau</span>
          </div>
        </div>

        <!-- Register Link -->
        <p class="text-center text-sm font-medium text-ink-muted">
          Belum punya akun?
          <a href="/register" class="text-ink font-bold hover:underline ml-1">Daftar gratis</a>
        </p>
      </div>

      <!-- Footer Info -->
      <p class="text-center mt-16 text-[10px] font-bold text-ink-tertiary tracking-widest uppercase">
        &copy; 2026 SovraEquitara &bull; Aman & Transparan
      </p>
    </div>
  </main>

  <script>
    import { showToast } from '../lib/toast';
    const API_URL = 'http://localhost:3000';

    // Auto redirect if already logged in
    const token = localStorage.getItem('access_token');
    const userRaw = localStorage.getItem('user');
    if (token && userRaw) {
      try {
        const user = JSON.parse(userRaw);
        if (user.role === 'super_admin' || user.role === 'SUPER_ADMIN') window.location.href = '/superadmin/dashboard';
        else if (user.role === 'admin' || user.role === 'ADMIN') window.location.href = '/admin/dashboard';
        else window.location.href = '/dashboard';
      } catch (e) {}
    }

    const form = document.getElementById('form-login') as HTMLFormElement;
    const btnSubmit = document.getElementById('btn-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      btnSubmit.disabled = true;
      btnSubmit.innerText = 'Memverifikasi...';

      try {
        const res = await fetch(`${API_URL}/api/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });

        const data = await res.json();

        if (res.ok) {
          localStorage.setItem('access_token', data.access_token);
          localStorage.setItem('user', JSON.stringify(data.user));
          
          if (data.user.role === 'super_admin' || data.user.role === 'SUPER_ADMIN') {
            window.location.href = '/superadmin/dashboard';
          } else if (data.user.role === 'admin' || data.user.role === 'ADMIN') {
            window.location.href = '/admin/dashboard';
          } else {
            window.location.href = '/dashboard';
          }
        } else {
          showToast({ message: data.message || 'Login gagal. Silakan periksa kembali email dan kata sandi Anda.', type: 'error' });
        }
      } catch (err) {
        console.error('Login error:', err);
        showToast({ message: 'Terjadi kesalahan koneksi. Pastikan server backend berjalan.', type: 'error' });
      } finally {
        btnSubmit.disabled = false;
        btnSubmit.innerText = 'Masuk Sekarang';
      }
    });
  </script>
</Layout>
