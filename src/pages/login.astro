---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Masuk — SovraEquitara">
  <main class="min-h-screen flex items-center justify-center p-4 sm:p-6 lg:p-8">
    <div class="w-full max-w-md animate-fade-in">
      <!-- Logo -->
      <div class="text-center mb-8">
        <img src="/logo.svg" alt="SovraEquitara" class="h-12 sm:h-14 mx-auto mb-6" />
        <h1 class="text-2xl sm:text-3xl font-display font-bold mb-2">Selamat Datang</h1>
        <p class="text-sm sm:text-base text-gray-600">Masuk untuk melanjutkan kontribusi Anda</p>
      </div>

      <!-- Form Card -->
      <div class="card">
        <form id="form-login" class="space-y-5">
          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
              Email
            </label>
            <input
              type="email"
              id="email"
              placeholder="nama@email.com"
              required
              class="input"
            />
          </div>

          <!-- Password -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="password" class="block text-sm font-semibold text-gray-700">
                Kata Sandi
              </label>
              <a href="/forgot-password" class="text-xs font-semibold text-brand hover:text-brand-light">
                Lupa?
              </a>
            </div>
            <input
              type="password"
              id="password"
              placeholder="••••••••"
              required
              class="input"
            />
          </div>

          <!-- Error Message -->
          <div id="error-message" class="hidden p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700"></div>

          <!-- Submit Button -->
          <button type="submit" id="btn-login" class="btn-primary w-full">
            <span>Masuk Sekarang</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </form>

        <!-- Divider -->
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-stone-200"></div>
          </div>
          <div class="relative flex justify-center text-xs">
            <span class="px-3 bg-white text-gray-500 font-medium">ATAU</span>
          </div>
        </div>

        <!-- Register Link -->
        <p class="text-center text-sm text-gray-600">
          Belum punya akun?
          <a href="/register" class="font-bold text-brand hover:text-brand-light">
            Daftar Warga
          </a>
        </p>
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast" class="fixed bottom-4 right-4 sm:bottom-6 sm:right-6 transform translate-x-[200%] transition-transform duration-300 ease-out">
      <div class="bg-brand text-white px-5 py-3 rounded-2xl shadow-large flex items-center gap-3 min-w-[280px]">
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <span id="toast-message" class="text-sm font-semibold"></span>
      </div>
    </div>
  </main>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    
    // Redirect if already logged in
    if (localStorage.getItem('access_token')) {
      window.location.href = '/dashboard';
    }

    const form = document.getElementById('form-login') as HTMLFormElement;
    const btn = document.getElementById('btn-login') as HTMLButtonElement;
    const errorDiv = document.getElementById('error-message') as HTMLDivElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      // Hide previous errors
      errorDiv.classList.add('hidden');
      
      // Loading state
      btn.disabled = true;
      btn.innerHTML = `
        <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>Memproses...</span>
      `;

      try {
        const res = await fetch(`${API_URL}/api/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Login gagal');

        // Save to localStorage
        localStorage.setItem('access_token', data.access_token);
        localStorage.setItem('user', JSON.stringify(data.user));
        
        // Show success toast
        showToast('Login berhasil! Mengalihkan...');
        
        // Redirect based on role
        setTimeout(() => {
          const role = (data.user.role || '').toUpperCase();
          window.location.href = role === 'ADMIN' ? '/admin/dashboard' : '/dashboard';
        }, 1000);

      } catch (err: any) {
        errorDiv.textContent = err.message;
        errorDiv.classList.remove('hidden');
        
        // Reset button
        btn.disabled = false;
        btn.innerHTML = `
          <span>Masuk Sekarang</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        `;
      }
    });

    function showToast(message: string) {
      const toast = document.getElementById('toast') as HTMLDivElement;
      const toastMessage = document.getElementById('toast-message') as HTMLSpanElement;
      
      toastMessage.textContent = message;
      toast.style.transform = 'translateX(0)';
      
      setTimeout(() => {
        toast.style.transform = 'translateX(200%)';
      }, 3000);
    }
  </script>
</Layout>
