---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Masuk — SovraEquitara">
  <div class="auth-viewport">
    <div class="auth-container animate-up">
      <header class="auth-header">
        <div class="logo-pill">
          <img src="/logo.svg" alt="Sovra" />
        </div>
        <h1>Selamat Datang</h1>
        <p>Silakan masuk untuk melanjutkan kontribusi Anda.</p>
      </header>

      <div class="auth-card glass">
        <form id="form-login" class="auth-form">
          <div class="field-group">
            <label for="email">Alamat Email</label>
            <div class="input-wrapper">
              <input type="email" id="email" placeholder="nama@email.com" required />
            </div>
          </div>

          <div class="field-group">
            <div class="label-row">
              <label for="password">Kata Sandi</label>
              <a href="/forgot-password" class="forgot-link">Lupa?</a>
            </div>
            <div class="input-wrapper">
              <input type="password" id="password" placeholder="••••••••" required />
            </div>
          </div>

          <button type="submit" id="btn-login" class="btn btn-primary w-full">
            Masuk Sekarang
          </button>
        </form>

        <div class="auth-divider">
          <span>atau</span>
        </div>

        <div class="auth-footer">
          <p>Belum punya akun? <a href="/register">Daftar Warga</a></p>
        </div>
      </div>
    </div>

    <div id="toast" class="toast-bento"></div>
  </div>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
    
    if (localStorage.getItem('access_token')) {
      window.location.href = '/dashboard';
    }

    const form = document.getElementById('form-login');
    const btn = document.getElementById('btn-login');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      if (btn) {
        btn.textContent = 'Memproses...';
        (btn as HTMLButtonElement).disabled = true;
      }

      try {
        const res = await fetch(`${API_URL}/api/auth/login`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });

        const data = await res.json();

        if (!res.ok) throw new Error(data.error || 'Login gagal');

        localStorage.setItem('access_token', data.access_token);
        localStorage.setItem('user', JSON.stringify(data.user));
        
        showToast('Login berhasil! Mengalihkan...');
        setTimeout(() => {
          const role = (data.user.role || '').toUpperCase();
          window.location.href = (role === 'ADMIN') 
            ? '/admin/dashboard' 
            : '/dashboard';
        }, 1000);

      } catch (err: any) {
        showToast(err.message, 'error');
        if (btn) {
          btn.textContent = 'Masuk Sekarang';
          (btn as HTMLButtonElement).disabled = false;
        }
      }
    });

    function showToast(msg: string, type = 'success') {
      const toast = document.getElementById('toast');
      if (!toast) return;
      toast.textContent = msg;
      toast.className = `toast-bento show ${type}`;
      setTimeout(() => toast.className = 'toast-bento', 3000);
    }
  </script>
</Layout>

<style>
  .auth-viewport {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: var(--color-bg);
  }

  .auth-container {
    width: 100%;
    max-width: 440px;
  }

  .auth-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .logo-pill {
    width: 120px; height: auto;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 32px;
  }
  .logo-pill img { width: 100%; height: auto; object-fit: contain; }

  .auth-header h1 { font-size: 32px; font-weight: 800; color: var(--color-text-title); margin-bottom: 8px; }
  .auth-header p { font-size: 15px; color: var(--color-text-muted); font-weight: 500; }

  .auth-card {
    padding: var(--space-2xl);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-premium);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .field-group { display: flex; flex-direction: column; gap: 8px; }
  .label-row { display: flex; justify-content: space-between; align-items: center; }
  .field-group label { font-size: 13px; font-weight: 800; color: var(--color-text-title); }
  .forgot-link { font-size: 12px; font-weight: 800; color: var(--color-brand); text-decoration: none; }

  .input-wrapper input {
    width: 100%;
    background: #F9FAFB;
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    padding: 16px 20px;
    color: var(--color-text-title);
    font-family: inherit;
    font-size: 15px;
    transition: all 0.2s;
  }
  .input-wrapper input:focus {
    outline: none;
    border-color: var(--color-accent);
    background: white;
    box-shadow: 0 0 0 4px rgba(253, 224, 71, 0.1);
  }

  .auth-divider {
    text-align: center;
    position: relative;
    margin: var(--space-2xl) 0;
  }
  .auth-divider::before {
    content: ""; position: absolute; top: 50%; left: 0; right: 0;
    height: 1px; background: var(--color-border); z-index: 1;
  }
  .auth-divider span {
    position: relative; z-index: 2;
    background: var(--color-surface);
    padding: 0 16px;
    font-size: 11px; font-weight: 900; color: var(--color-text-muted);
    text-transform: uppercase; letter-spacing: 0.1em;
  }

  .auth-footer { text-align: center; }
  .auth-footer p { font-size: 14px; color: var(--color-text-muted); font-weight: 600; }
  .auth-footer a { color: var(--color-brand); font-weight: 800; text-decoration: none; border-bottom: 2px solid var(--color-accent); }

  .w-full { width: 100%; }

  /* Toast Re-use from Shared */
  .toast-bento {
    position: fixed; top: 32px; right: 32px; padding: 16px 32px; border-radius: 20px;
    background: var(--color-brand); color: #fff; font-weight: 700; font-size: 15px;
    transform: translateX(120%); opacity: 0; transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    z-index: 1000; box-shadow: 0 15px 35px rgba(26, 26, 26, 0.2);
  }
  .toast-bento.show { transform: translateX(0); opacity: 1; }
  .toast-bento.error { background: var(--color-danger); }

  @media (max-width: 768px) {
    .auth-viewport { padding: var(--space-lg); }
    .auth-card { padding: var(--space-xl); }
    .toast-bento { left: 24px; right: 24px; top: 24px; transform: translateY(-150%); text-align: center; }
    .toast-bento.show { transform: translateY(0); }
  }
</style>
