---
import Layout from '../layouts/Layout.astro';
import { ThemeToggle } from '../components/ThemeToggle';
import { AnimeHero } from '../components/AnimeHero';
import { BentoGridFeatures } from '../components/BentoGridFeatures';
import { DashboardShowcase } from '../components/DashboardShowcase';
import { HowItWorks } from '../components/HowItWorks';
import { LeaderboardPreview } from '../components/LeaderboardPreview';
import { CitizenReportsCarousel } from '../components/CitizenReportsCarousel';
import { AnimatedCounter } from '../components/AnimatedCounter';
---

<Layout title="SovraEquitara — Civic Tech for Future Cities">
  <!-- Navigation -->
  <nav class="fixed top-4 sm:top-6 left-1/2 -translate-x-1/2 w-[95%] max-w-6xl z-50 rounded-2xl border border-stone-200/50 dark:border-white/10 bg-white/70 dark:bg-black/40 backdrop-blur-xl shadow-sm transition-all duration-300">
    <div class="px-4 sm:px-8">
      <div class="flex items-center justify-between h-16 sm:h-20">
        <a href="/" class="block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-10 sm:h-14 dark:brightness-0 dark:invert" />
        </a>
        
        <div class="hidden md:flex items-center gap-6 lg:gap-8">
          <a href="#features" class="text-[11px] font-bold text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-[0.2em]">Fitur</a>
          <a href="#how" class="text-[11px] font-bold text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-[0.2em]">Cara Kerja</a>
          <a href="#leaderboard" class="text-[11px] font-bold text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-[0.2em]">Leaderboard</a>
        </div>
        
        <div class="flex items-center gap-3 sm:gap-4">
          <ThemeToggle client:load />
          
          {/* Mobile Menu Button */}
          <button id="mobile-menu-btn" class="md:hidden p-2 text-stone-600 dark:text-stone-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>

          <div id="nav-cta" class="hidden md:flex items-center gap-3">
            <!-- Injected by JS -->
          </div>
        </div>
      </div>
    </div>
    
    {/* Mobile Menu Dropdown */}
    <div id="mobile-menu" class="hidden md:hidden border-t border-stone-200/50 dark:border-white/10 px-4 py-4 bg-white/95 dark:bg-black/95 backdrop-blur-xl rounded-b-2xl">
      <div class="flex flex-col gap-4">
        <a href="#features" class="text-xs font-bold text-stone-600 dark:text-stone-300 uppercase tracking-widest">Fitur</a>
        <a href="#how" class="text-xs font-bold text-stone-600 dark:text-stone-300 uppercase tracking-widest">Cara Kerja</a>
        <a href="#leaderboard" class="text-xs font-bold text-stone-600 dark:text-stone-300 uppercase tracking-widest">Leaderboard</a>
        <div id="mobile-nav-cta" class="flex flex-col gap-2 pt-2 border-t border-stone-100 dark:border-white/5">
           <!-- Injected by JS -->
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section (Anime.js Powered) -->
  <AnimeHero client:load />

  <!-- Trust Bar (Marquee) -->
  <section class="py-10 bg-white dark:bg-[#050505] border-y border-stone-100 dark:border-white/[0.02] overflow-hidden flex items-center">
    <div class="w-full flex gap-12 items-center text-stone-300 dark:text-stone-800 font-display font-extrabold text-2xl sm:text-3xl uppercase tracking-wider marquee-track">
      <span>Dinas PUPR</span>
      <span>•</span>
      <span>Forum Warga</span>
      <span>•</span>
      <span>Smart City ID</span>
      <span>•</span>
      <span>Urban Future</span>
      <span>•</span>
      <span>Bappeda</span>
      <span>•</span>
      <span>Dinas PUPR</span>
      <span>•</span>
      <span>Forum Warga</span>
      <span>•</span>
      <span>Smart City ID</span>
      <span>•</span>
      <span>Urban Future</span>
      <span>•</span>
      <span>Bappeda</span>
    </div>
  </section>

  <!-- Dashboard Showcase Section -->
  <DashboardShowcase client:load />

  <!-- Features Grid (Anime.js Bento Grid) -->
  <BentoGridFeatures client:load />

  <!-- How It Works Section -->
  <HowItWorks client:load />

  <!-- Leaderboard Section -->
  <LeaderboardPreview client:load />

  <!-- Citizen Reports Section -->
  <CitizenReportsCarousel client:load />

  <!-- Stats Section -->
  <section id="stats" class="py-24 sm:py-32 px-4 sm:px-6 lg:px-8 bg-stone-50 dark:bg-white/[0.01] border-y border-stone-200/50 dark:border-white/[0.05] transition-colors duration-300">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 sm:gap-8">
        <AnimatedCounter client:load value={14800} suffix="+" label="Laporan Tuntas" className="text-stone-900 dark:text-white" labelClassName="text-stone-400" />
        <AnimatedCounter client:load value={25} suffix="+" label="Wilayah Tercover" className="text-amber-500" labelClassName="text-stone-400" />
        <AnimatedCounter client:load value={200000} suffix="+" label="Poin Reputasi" className="text-stone-900 dark:text-white" labelClassName="text-stone-400" />
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 sm:py-32 px-4 sm:px-6 lg:px-8 bg-white dark:bg-black transition-colors duration-300">
    <div class="max-w-5xl mx-auto">
      <div class="p-10 sm:p-20 rounded-[2.5rem] sm:rounded-[3rem] text-center bg-stone-900 dark:bg-white/[0.03] border border-transparent dark:border-white/[0.05] relative overflow-hidden shadow-2xl">
        <div class="absolute top-0 right-0 w-[40rem] h-[40rem] bg-amber-500/20 dark:bg-amber-500/10 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/3"></div>
        <div class="absolute bottom-0 left-0 w-[40rem] h-[40rem] bg-blue-500/20 dark:bg-blue-500/10 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/3"></div>
        
        <div class="relative z-10">
          <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 text-transparent bg-clip-text bg-gradient-to-br from-white to-stone-400 tracking-tight pb-2">
            Mulai Berdampak Hari Ini
          </h2>
          <p class="text-base sm:text-lg text-stone-300 dark:text-stone-400 mb-12 max-w-2xl mx-auto font-medium leading-relaxed">
            Bergabunglah dengan ribuan warga dan jadilah bagian dari perubahan positif infrastruktur kota kita.
          </p>
          <div id="cta-buttons" class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
            <!-- Injected by JS -->
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-zen-bg dark:bg-[#050505] border-t border-stone-200/50 dark:border-white/[0.05] py-16 px-4 sm:px-6 lg:px-8 transition-colors duration-300">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 mb-16">
        <div class="md:col-span-5">
          <a href="/" class="block hover:opacity-80 transition-opacity w-fit">
            <img src="/logo.svg" alt="SovraEquitara" class="h-14 mb-6 dark:brightness-0 dark:invert" />
          </a>
          <p class="text-sm text-stone-500 dark:text-stone-400 max-w-sm leading-relaxed font-medium">
            Platform Civic Tech generasi baru untuk transparansi, partisipasi warga, dan pembangunan infrastruktur pintar.
          </p>
        </div>
        <div class="md:col-span-2 md:col-start-8">
          <h4 class="font-bold text-stone-900 dark:text-white mb-6 uppercase tracking-[0.2em] text-xs">Produk</h4>
          <ul class="space-y-4 text-sm font-medium text-stone-500 dark:text-stone-400">
            <li><a href="#features" class="hover:text-stone-900 dark:hover:text-white transition-colors">Fitur</a></li>
            <li><a href="#how" class="hover:text-stone-900 dark:hover:text-white transition-colors">Cara Kerja</a></li>
            <li><a href="#stats" class="hover:text-stone-900 dark:hover:text-white transition-colors">Statistik</a></li>
          </ul>
        </div>
        <div class="md:col-span-2">
          <h4 class="font-bold text-stone-900 dark:text-white mb-6 uppercase tracking-[0.2em] text-xs">Komunitas</h4>
          <ul class="space-y-4 text-sm font-medium text-stone-500 dark:text-stone-400">
            <li><a href="#leaderboard" class="hover:text-stone-900 dark:hover:text-white transition-colors">Leaderboard</a></li>
            <li><a href="/public-reports" class="hover:text-stone-900 dark:hover:text-white transition-colors">Laporan Terbuka</a></li>
          </ul>
        </div>
      </div>
      <div class="pt-8 border-t border-stone-200/50 dark:border-white/[0.05] flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-[11px] font-bold text-stone-400 dark:text-stone-600 uppercase tracking-[0.1em]">
          &copy; 2026 SOVRAEQUITARA. ALL RIGHTS RESERVED.
        </p>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Mobile Menu Toggle
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if(btn && menu) {
        btn.addEventListener('click', () => {
          menu.classList.toggle('hidden');
        });
      }

      // Auth state management
      const token = localStorage.getItem('access_token');
      const userRaw = localStorage.getItem('user');
      
      const navCta = document.getElementById('nav-cta');
      const mobileNavCta = document.getElementById('mobile-nav-cta');
      const heroCta = document.getElementById('hero-cta');
      const ctaButtons = document.getElementById('cta-buttons');

      // Shared button classes
      const primaryBtnClass = "inline-flex items-center justify-center px-6 py-2.5 bg-stone-900 text-white dark:bg-white dark:text-black rounded-xl font-bold text-sm hover:scale-105 active:scale-95 transition-all shadow-sm";
      const secondaryBtnClass = "inline-flex items-center justify-center px-6 py-2.5 bg-white text-stone-900 dark:bg-white/[0.05] dark:text-white border border-stone-200/50 dark:border-white/10 rounded-xl font-bold text-sm hover:bg-stone-50 dark:hover:bg-white/10 active:scale-95 transition-all shadow-sm";
      const darkPrimaryBtnClass = "inline-flex items-center justify-center px-8 py-3.5 bg-white text-stone-900 rounded-xl font-bold text-sm sm:text-base hover:scale-105 active:scale-95 transition-all shadow-xl";
      const darkSecondaryBtnClass = "inline-flex items-center justify-center px-8 py-3.5 bg-white/10 text-white border border-white/20 rounded-xl font-bold text-sm sm:text-base hover:bg-white/20 active:scale-95 transition-all backdrop-blur-md";

      if (token && userRaw) {
        const user = JSON.parse(userRaw);
        const isAdmin = user.role === 'admin' || user.role === 'ADMIN';
        const isSuperAdmin = user.role === 'super_admin' || user.role === 'SUPER_ADMIN';
        const dashLink = isSuperAdmin ? '/superadmin/dashboard' : (isAdmin ? '/admin/dashboard' : '/dashboard');

        const navDashBtn = `<a href="${dashLink}" class="${primaryBtnClass}">Dashboard</a>`;
        if (navCta) navCta.innerHTML = navDashBtn;
        if (mobileNavCta) mobileNavCta.innerHTML = navDashBtn;

        if (heroCta) {
          heroCta.innerHTML = `<a href="${dashLink}" class="${primaryBtnClass} !px-8 !py-3.5 !text-base">Masuk ke Dashboard</a>`;
        }
        if (ctaButtons) {
          ctaButtons.innerHTML = `<a href="${dashLink}" class="${darkPrimaryBtnClass}">Masuk ke Dashboard</a>`;
        }
      } else {
        const loginLink = `<a href="/login" class="text-[11px] font-bold text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-[0.2em] mr-2">Masuk</a>`;
        const registerLink = `<a href="/register" class="${primaryBtnClass}">Daftar</a>`;
        
        if (navCta) {
          navCta.innerHTML = loginLink + registerLink;
        }
        if (mobileNavCta) {
          mobileNavCta.innerHTML = `
            <a href="/login" class="${secondaryBtnClass} w-full">Masuk</a>
            <a href="/register" class="${primaryBtnClass} w-full">Daftar</a>
          `;
        }
        if (heroCta) {
          heroCta.innerHTML = `
            <a href="/register" class="${primaryBtnClass} !px-8 !py-3.5 !text-base">Mulai Lapor Gratis</a>
            <a href="#how" class="${secondaryBtnClass} !px-8 !py-3.5 !text-base">Pelajari Sistem</a>
          `;
        }
        if (ctaButtons) {
          ctaButtons.innerHTML = `
            <a href="/register" class="${darkPrimaryBtnClass}">Daftar Sekarang</a>
            <a href="/login" class="${darkSecondaryBtnClass}">Masuk ke Akun</a>
          `;
        }
      }
    });
  </script>
</Layout>
