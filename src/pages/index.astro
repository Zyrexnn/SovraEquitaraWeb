---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SovraEquitara — Bangun Kota Bersama">
  <main class="landing-page">
    <!-- Navigation -->
    <nav class="landing-nav animate-up">
      <div class="nav-container glass">
        <div class="logo-area">
          <img src="/logo.svg" alt="SovraEquitara" class="nav-logo" />
        </div>
        <div class="nav-actions">
          <a href="/login" class="btn btn-glass btn-sm">Masuk</a>
          <a href="/register" class="btn btn-primary btn-sm">Mulai</a>
        </div>
      </div>
    </nav>

    <!-- Hero & Bento Grid -->
    <div class="content-wrapper">
      <div class="bento-grid-landing">
        <!-- Main Hero Card -->
        <section class="bento-item bento-hero-main glass animate-up delay-1">
          <div class="hero-inner">
            <span class="badge-premium">PLATFORM CIVIC TECH 2026</span>
            <h1 class="display-text">Satu Laporan,<br/><span class="text-gradient">Ribuan Perubahan.</span></h1>
            <p class="hero-p">Berdayakan suara Anda untuk memperbaiki infrastruktur kota. Cepat, transparan, dan terverifikasi secara cerdas.</p>
            <div class="hero-cta-group">
              <a href="/register" class="btn btn-primary btn-lg">Daftar Sekarang</a>
              <a href="#about" class="btn btn-glass btn-lg">Pelajari Alur</a>
            </div>
          </div>
        </section>

        <!-- Stats Card -->
        <section class="bento-item bento-stats glass animate-up delay-2">
          <div class="stat-circle">
            <svg viewBox="0 0 100 100">
              <circle cx="50" cy="50" r="45" fill="none" stroke="rgba(44, 62, 80, 0.1)" stroke-width="8"></circle>
              <circle cx="50" cy="50" r="45" fill="none" stroke="var(--color-brand)" stroke-width="8" stroke-dasharray="283" stroke-dashoffset="70" class="circle-progress"></circle>
            </svg>
            <div class="stat-content">
              <span class="stat-num" id="total-reports">0</span>
              <span class="stat-label">Laporan Selesai</span>
            </div>
          </div>
        </section>

        <!-- Feature Card 1 -->
        <section class="bento-item bento-feature glass animate-up delay-3">
          <div class="feat-icon brand-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <h3>Presisi Lokasi</h3>
          <p>Titik koordinat akurat untuk setiap laporan yang Anda kirimkan.</p>
        </section>

        <!-- Feature Card 2 -->
        <section class="bento-item bento-feature glass animate-up delay-4">
          <div class="feat-icon success-glow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>Verifikasi Cepat</h3>
          <p>Validasi sistem cerdas memastikan laporan Anda segera diproses.</p>
        </section>

        <!-- Leaderboard Preview -->
        <section class="bento-item bento-leader glass animate-up delay-5">
          <div class="card-header-row">
            <h3>Pahlawan Warga</h3>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--color-warning)" stroke-width="2.5"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"></path></svg>
          </div>
          <div class="leader-preview-list">
            <div class="p-item"><span>1. Budi Santoso</span><strong>1,240 pts</strong></div>
            <div class="p-item"><span>2. Citra Dewi</span><strong>980 pts</strong></div>
            <div class="p-item"><span>3. Andi Wijaya</span><strong>850 pts</strong></div>
          </div>
        </section>
      </div>
    </div>

    <footer class="landing-footer">
      <p>&copy; 2026 SovraEquitara. Membangun masa depan perkotaan yang lebih transparan.</p>
    </footer>
  </main>
</Layout>

<script>
  function animateCounter(id: string, target: number) {
    const el = document.getElementById(id);
    if (!el) return;
    let current = 0;
    const step = target / 60;
    const timer = setInterval(() => {
      current += step;
      if (current >= target) {
        el.textContent = target.toLocaleString();
        clearInterval(timer);
      } else {
        el.textContent = Math.floor(current).toLocaleString();
      }
    }, 16);
  }

  animateCounter('total-reports', 14820);
</script>

<style>
  .landing-page { min-height: 100vh; overflow-x: hidden; position: relative; }

  /* Navigation */
  .landing-nav {
    position: fixed; top: 20px; left: 0; right: 0; z-index: 1000;
    padding: 0 var(--space-lg);
  }
  .nav-container {
    max-width: 1100px; margin: 0 auto; padding: 12px 24px;
    border-radius: var(--radius-full); display: flex; justify-content: space-between; align-items: center;
  }
  .logo-area { display: flex; align-items: center; gap: 12px; }
  .nav-logo { height: 56px; width: auto; filter: brightness(0) sepia(1) hue-rotate(175deg) saturate(300%) brightness(0.3); }
  .nav-actions { display: flex; gap: 12px; }
  .btn-sm { padding: 8px 16px; font-size: 13px; }

  /* Layout Wrapper */
  .content-wrapper { padding: 100px var(--space-lg) var(--space-2xl); max-width: 1100px; margin: 0 auto; }

  /* Bento Grid Landing */
  .bento-grid-landing {
    display: grid; grid-template-columns: 1fr; gap: var(--space-md);
  }

  .bento-item { padding: var(--space-xl); border-radius: var(--radius-lg); }

  /* Hero Main */
  .bento-hero-main {
    background: radial-gradient(circle at top right, rgba(44, 62, 80, 0.05), transparent),
                linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(244, 241, 234, 0.95));
  }
  .badge-premium {
    display: inline-block; padding: 4px 12px; border-radius: 8px;
    background: rgba(44, 62, 80, 0.05); color: var(--color-brand);
    font-size: 10px; font-weight: 800; letter-spacing: 0.1em; margin-bottom: 20px;
    border: 1px solid rgba(44, 62, 80, 0.2);
  }
  .display-text { font-size: 40px; line-height: 1.1; margin-bottom: 20px; }
  .text-gradient { background: linear-gradient(to right, var(--color-brand), #475569); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-p { font-size: 16px; color: var(--color-text-muted); max-width: 500px; margin-bottom: 32px; line-height: 1.6; }
  .hero-cta-group { display: flex; flex-wrap: wrap; gap: 16px; }
  .btn-lg { padding: 16px 32px; font-size: 16px; border-radius: var(--radius-md); }

  /* Stats Card */
  .bento-stats { display: flex; align-items: center; justify-content: center; }
  .stat-circle { position: relative; width: 180px; height: 180px; }
  .stat-circle svg { transform: rotate(-90deg); }
  .circle-progress { transition: stroke-dashoffset 2s ease-out; }
  .stat-content { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .stat-num { font-size: 32px; font-weight: 800; color: var(--color-brand); line-height: 1; }
  .stat-label { font-size: 10px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; margin-top: 4px; }

  /* Feature Cards */
  .bento-feature h3 { font-size: 20px; margin: 16px 0 8px; }
  .bento-feature p { font-size: 14px; color: var(--color-text-muted); }
  .feat-icon { width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; color: white; }
  .brand-glow { background: var(--color-brand); box-shadow: 0 10px 20px rgba(44, 62, 80, 0.3); }
  .success-glow { background: var(--color-success); box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3); }

  /* Leaderboard Preview */
  .bento-leader h3 { font-size: 18px; }
  .card-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
  .leader-preview-list { display: flex; flex-direction: column; gap: 12px; }
  .p-item { display: flex; justify-content: space-between; padding: 12px; background: rgba(44, 62, 80, 0.05); border-radius: 12px; font-size: 13px; font-weight: 600; }
  .p-item strong { color: var(--color-brand); }

  .landing-footer { text-align: center; padding: var(--space-2xl) var(--space-lg); border-top: 1px solid var(--color-border); font-size: 12px; color: var(--color-text-muted); }

  /* Desktop Queries */
  @media (min-width: 768px) {
    .bento-grid-landing { grid-template-columns: repeat(2, 1fr); }
    .bento-hero-main { grid-column: span 2; padding: var(--space-2xl); }
    .display-text { font-size: 64px; }
    .hero-inner { padding: 40px 0; }
  }

  @media (min-width: 1024px) {
    .bento-grid-landing { grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(2, auto); }
    .bento-hero-main { grid-column: 1 / 4; grid-row: 1 / 2; }
    .bento-stats { grid-column: 4 / 5; grid-row: 1 / 2; }
    .bento-feature { grid-column: span 1; }
    .bento-leader { grid-column: 3 / 5; }
  }
</style>
