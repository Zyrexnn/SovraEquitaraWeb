---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SovraEquitara — Bangun Kota Bersama">
  <main class="zen-landing">
    <!-- Header Nav -->
    <nav class="zen-nav animate-up">
      <div class="nav-container glass">
        <div class="logo-area">
          <img src="/logo.svg" alt="Sovra" class="nav-logo" />
        </div>
        <div class="nav-actions">
          <a href="/login" class="zen-link">Masuk</a>
          <a href="/register" class="zen-btn-nav">Mulai</a>
        </div>
      </div>
    </nav>

    <div class="zen-content scroll-slim">
      <div class="bento-grid-zen">
        <!-- Hero Section -->
        <section class="bento-item hero-zen glass animate-up delay-1">
          <div class="hero-content">
            <span class="zen-badge">CIVIC TECH 2026</span>
            <h1 class="zen-display">Satu Laporan,<br/><span class="accent-text">Ribuan Perubahan.</span></h1>
            <p class="zen-lead">Berdayakan suara Anda untuk memperbaiki infrastruktur kota secara transparan dan terverifikasi.</p>
            <div class="zen-cta-row">
              <a href="/register" class="btn btn-primary">Daftar Sekarang</a>
              <a href="/login" class="btn btn-glass">Masuk Dashboard</a>
            </div>
          </div>
          <div class="zen-decoration">
            <div class="zen-blob blob-hero"></div>
          </div>
        </section>

        <!-- Stats Bento -->
        <section class="bento-item stats-zen glass animate-up delay-2">
          <div class="zen-circular">
            <svg viewBox="0 0 100 100">
              <circle cx="50" cy="50" r="45" class="cir-bg"></circle>
              <circle cx="50" cy="50" r="45" class="cir-val" id="progress-circle"></circle>
            </svg>
            <div class="cir-content">
              <span class="cir-num" id="total-reports">0</span>
              <span class="cir-label">LAPORAN</span>
            </div>
          </div>
          <p class="zen-small">Tuntas & Terverifikasi</p>
        </section>

        <!-- Feature 1 -->
        <section class="bento-item feat-zen glass animate-up delay-3">
          <div class="feat-icon-zen">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <h3>Presisi Lokasi</h3>
          <p>Titik koordinat akurat untuk setiap laporan infrastruktur Anda.</p>
        </section>

        <!-- Feature 2 -->
        <section class="bento-item feat-zen glass animate-up delay-4">
          <div class="feat-icon-zen accent">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>Verifikasi Cepat</h3>
          <p>Validasi sistem cerdas memastikan laporan Anda segera diproses oleh admin.</p>
        </section>

        <!-- Leaderboard -->
        <section class="bento-item leader-zen glass animate-up delay-5">
          <div class="leader-header">
            <h3>Pahlawan Warga</h3>
            <span class="star-icon">✦</span>
          </div>
          <div class="leader-rows">
            <div class="l-row"><span>Budi Santoso</span><strong>1,240 pts</strong></div>
            <div class="l-row"><span>Citra Dewi</span><strong>980 pts</strong></div>
            <div class="l-row"><span>Andi Wijaya</span><strong>850 pts</strong></div>
          </div>
        </section>
      </div>

      <footer class="zen-footer">
        <p>&copy; 2026 SovraEquitara. Membangun masa depan kota yang lebih transparan.</p>
      </footer>
    </div>
  </main>
</Layout>

<script>
  function animateCounter(id: string, target: number) {
    const el = document.getElementById(id);
    if (!el) return;
    let current = 0;
    const duration = 2000;
    const startTime = performance.now();

    function update(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      current = Math.floor(ease * target);
      el!.textContent = current.toLocaleString();
      
      if (progress < 1) requestAnimationFrame(update);
    }
    requestAnimationFrame(update);
  }

  animateCounter('total-reports', 14820);
  
  // Circle Progress
  setTimeout(() => {
    const circle = document.getElementById('progress-circle');
    if (circle) (circle as any).style.strokeDashoffset = "80";
  }, 500);
</script>

<style>
  .zen-landing { 
    min-height: 100vh; background: var(--color-bg); 
    color: var(--color-text-body); font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* Navigation */
  .zen-nav { position: fixed; top: 24px; left: 0; right: 0; z-index: 1000; padding: 0 var(--space-xl); }
  .nav-container { 
    max-width: 1200px; margin: 0 auto; padding: 12px 24px;
    border-radius: 99px; display: flex; justify-content: space-between; align-items: center;
    box-shadow: var(--shadow-premium);
  }
  .nav-logo { height: 50px; width: auto; filter: brightness(0); }
  .nav-actions { display: flex; align-items: center; gap: 24px; }
  .zen-link { font-size: 14px; font-weight: 800; color: var(--color-text-title); text-decoration: none; }
  .zen-btn-nav { 
    background: var(--color-brand); color: white; padding: 10px 24px; 
    border-radius: 99px; font-size: 13px; font-weight: 800; text-decoration: none;
    transition: all 0.3s;
  }
  .zen-btn-nav:hover { transform: scale(1.05); }

  /* Content Layout */
  .zen-content { padding: 140px var(--space-xl) 60px; max-width: 1240px; margin: 0 auto; }
  .bento-grid-zen { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); }

  /* Hero Card */
  .hero-zen { 
    grid-column: span 1; padding: var(--space-3xl); 
    display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden;
  }
  .zen-badge { 
    font-size: 11px; font-weight: 900; color: var(--color-brand); 
    background: var(--color-accent); padding: 6px 14px; border-radius: 8px;
    margin-bottom: 24px; display: inline-block; letter-spacing: 0.1em;
  }
  .zen-display { font-size: 48px; line-height: 1.1; font-weight: 800; color: var(--color-text-title); margin-bottom: 24px; }
  .accent-text { color: var(--color-brand); opacity: 0.8; }
  .zen-lead { font-size: 18px; color: var(--color-text-muted); max-width: 540px; margin-bottom: 40px; line-height: 1.6; }
  .zen-cta-row { display: flex; gap: 16px; flex-wrap: wrap; }

  .zen-blob { 
    position: absolute; width: 400px; height: 400px; 
    background: var(--color-accent); opacity: 0.2; 
    border-radius: 50%; filter: blur(80px); z-index: -1; 
    top: -100px; right: -100px;
    animation: blob-move 12s infinite alternate ease-in-out;
  }
  @keyframes blob-move { from { transform: translate(0,0); } to { transform: translate(-100px, 50px); } }

  /* Stats Bento */
  .stats-zen { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: var(--space-2xl); }
  .zen-circular { position: relative; width: 180px; height: 180px; margin-bottom: 16px; }
  .cir-bg { fill: none; stroke: var(--color-border); stroke-width: 8; }
  .cir-val { 
    fill: none; stroke: var(--color-brand); stroke-width: 8; 
    stroke-dasharray: 283; stroke-dashoffset: 283;
    stroke-linecap: round; transform: rotate(-90deg); transform-origin: center;
    transition: stroke-dashoffset 2s var(--transition-smooth);
  }
  .cir-content { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .cir-num { font-size: 34px; font-weight: 900; color: var(--color-text-title); }
  .cir-label { font-size: 10px; font-weight: 800; color: var(--color-text-muted); letter-spacing: 0.1em; }
  .zen-small { font-size: 12px; font-weight: 700; color: var(--color-text-muted); }

  /* Features */
  .feat-zen { padding: var(--space-xl); }
  .feat-icon-zen { 
    width: 56px; height: 56px; border-radius: 20px; 
    background: var(--color-brand); color: white;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 24px;
  }
  .feat-icon-zen.accent { background: var(--color-accent); color: var(--color-brand); }
  .feat-zen h3 { font-size: 20px; font-weight: 800; margin-bottom: 12px; }
  .feat-zen p { font-size: 14px; color: var(--color-text-muted); line-height: 1.6; }

  /* Leaderboard */
  .leader-zen { padding: var(--space-xl); }
  .leader-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
  .leader-header h3 { font-size: 18px; font-weight: 800; }
  .star-icon { color: var(--color-brand); font-size: 20px; }
  .leader-rows { display: flex; flex-direction: column; gap: 12px; }
  .l-row { 
    display: flex; justify-content: space-between; padding: 14px 20px; 
    background: var(--color-bg); border-radius: 16px; 
    font-size: 13px; font-weight: 700;
  }
  .l-row strong { color: var(--color-brand); }

  /* Footer */
  .zen-footer { text-align: center; margin-top: 80px; padding: 40px 0; border-top: 1px solid var(--color-border); font-size: 12px; color: var(--color-text-muted); }

  /* Responsive */
  @media (min-width: 768px) {
    .bento-grid-zen { grid-template-columns: repeat(2, 1fr); }
    .hero-zen { grid-column: span 2; padding: var(--space-3xl); }
    .zen-display { font-size: 72px; }
  }

  @media (min-width: 1024px) {
    .bento-grid-zen { grid-template-columns: repeat(4, 1fr); }
    .hero-zen { grid-column: 1 / 4; }
    .stats-zen { grid-column: 4 / 5; }
    .leader-zen { grid-column: 3 / 5; }
  }
</style>
