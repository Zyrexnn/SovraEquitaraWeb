---
import Layout from '../layouts/Layout.astro';
import { DashboardShowcase } from '../components/DashboardShowcase';
import { HeroTitle } from '../components/HeroTitle';
import { ThemeToggle } from '../components/ThemeToggle';
---

<Layout title="SovraEquitara — Civic Tech for Future Cities">
  <!-- Navigation -->
  <nav class="fixed top-4 sm:top-6 left-1/2 -translate-x-1/2 w-[95%] max-w-6xl z-50 rounded-2xl border border-stone-200/50 dark:border-white/10 bg-white/80 dark:bg-black/40 backdrop-blur-xl shadow-lg dark:shadow-[0_8px_32px_0_rgba(0,0,0,0.8)] transition-all duration-300">
    <div class="px-4 sm:px-8">
      <div class="flex items-center justify-between h-14 sm:h-16">
        <a href="/" class="block hover:opacity-80 transition-opacity">
          <img src="/logo.svg" alt="SovraEquitara" class="h-6 sm:h-8 dark:brightness-0 dark:invert" />
        </a>
        
        <div class="hidden md:flex items-center gap-6 lg:gap-8">
          <a href="#features" class="text-xs font-bold text-stone-600 dark:text-white/50 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-widest">Fitur</a>
          <a href="#how" class="text-xs font-bold text-stone-600 dark:text-white/50 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-widest">Cara Kerja</a>
          <a href="#stats" class="text-xs font-bold text-stone-600 dark:text-white/50 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-widest">Dampak</a>
        </div>
        
        <div class="flex items-center gap-3">
          <ThemeToggle client:load />
          <div id="nav-cta" class="flex items-center gap-3">
            <!-- Injected by JS -->
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section class="pt-32 sm:pt-40 pb-16 sm:pb-24 px-4 sm:px-6 lg:px-8 overflow-hidden relative bg-gradient-to-b from-stone-50 to-white dark:from-[#010101] dark:to-black transition-colors duration-300">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full pointer-events-none -z-10">
      <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] bg-amber-500/20 dark:bg-amber-500/10 blur-[150px] rounded-full"></div>
      <div class="absolute bottom-[0%] right-[-10%] w-[50%] h-[50%] bg-indigo-500/20 dark:bg-brand/10 blur-[150px] rounded-full"></div>
    </div>

    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-4xl mx-auto animate-fade-in relative z-10">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/50 dark:bg-white/5 border border-stone-200 dark:border-white/10 rounded-full mb-8 backdrop-blur-md">
          <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
          <span class="text-xs sm:text-sm font-bold text-stone-600 dark:text-gray-400">Civic Tech Innovation 2026</span>
        </div>
        
        <HeroTitle client:load />
        
        <p class="text-lg sm:text-xl text-stone-600 dark:text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed">
          Platform yang menghubungkan warga dengan pembuat kebijakan melalui pelaporan infrastruktur berbasis AI yang transparan dan terverifikasi.
        </p>
        
        <div id="hero-cta" class="flex flex-col sm:flex-row items-center justify-center gap-5">
          <!-- Injected by JS -->
        </div>
      </div>
    </div>
  </section>

  <!-- Dashboard Showcase Section -->
  <DashboardShowcase client:load />

  <!-- Trust Bar -->
  <section class="py-12 bg-stone-100 dark:bg-black border-y border-stone-200 dark:border-white/5 transition-colors duration-300">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-bold text-stone-500 dark:text-gray-500 tracking-widest mb-8">DIPERCAYA OLEH</p>
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
        <div class="text-lg sm:text-xl font-bold text-stone-400 dark:text-gray-600">Dinas PUPR</div>
        <div class="text-lg sm:text-xl font-bold text-stone-400 dark:text-gray-600">Forum Warga</div>
        <div class="text-lg sm:text-xl font-bold text-stone-400 dark:text-gray-600">Smart City ID</div>
        <div class="text-lg sm:text-xl font-bold text-stone-400 dark:text-gray-600">Urban Future</div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-white dark:bg-[#010101] transition-colors duration-300">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 text-stone-900 dark:text-white">
          Solusi Cerdas untuk Kota Pintar
        </h2>
        <p class="text-base sm:text-lg text-stone-600 dark:text-gray-400 max-w-2xl mx-auto font-medium">
          Platform yang dirancang untuk efisiensi, akurasi, dan transparansi
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature 1 -->
        <div class="p-8 rounded-3xl bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 group hover:bg-stone-100 dark:hover:bg-white/10 transition-all">
          <div class="w-12 h-12 bg-amber-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-stone-900 dark:text-white">Presisi Geospasial</h3>
          <p class="text-sm text-stone-600 dark:text-gray-400 leading-relaxed">Deteksi lokasi otomatis dengan akurasi tinggi menggunakan teknologi satelit</p>
        </div>

        <!-- Feature 2 -->
        <div class="p-8 rounded-3xl bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 group hover:bg-stone-100 dark:hover:bg-white/10 transition-all">
          <div class="w-12 h-12 bg-blue-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-stone-900 dark:text-white">Validasi AI</h3>
          <p class="text-sm text-stone-600 dark:text-gray-400 leading-relaxed">Verifikasi gambar otomatis untuk mencegah laporan duplikat dan spam</p>
        </div>

        <!-- Feature 3 -->
        <div class="p-8 rounded-3xl bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 group hover:bg-stone-100 dark:hover:bg-white/10 transition-all">
          <div class="w-12 h-12 bg-green-500/20 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3 text-stone-900 dark:text-white">Sistem Gamifikasi</h3>
          <p class="text-sm text-stone-600 dark:text-gray-400 leading-relaxed">Dapatkan poin dan lencana untuk setiap kontribusi nyata bagi kota</p>
        </div>

        <!-- Feature 4 -->
        <div class="p-8 rounded-3xl bg-stone-50 dark:bg-white/5 border border-stone-200 dark:border-white/10 group hover:bg-stone-100 dark:hover:bg-white/10 transition-all md:col-span-2 lg:col-span-3">
          <div class="flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-14 h-14 bg-purple-500/20 rounded-2xl flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-2xl font-bold mb-3 text-stone-900 dark:text-white">Transparansi Real-time</h3>
              <p class="text-base text-stone-600 dark:text-gray-400 leading-relaxed">Pantau setiap tahapan perbaikan dari verifikasi hingga penyelesaian langsung di dashboard Anda</p>
            </div>
            <div class="flex items-center gap-3">
              <div class="px-4 py-2 bg-amber-500/10 border border-amber-500/20 rounded-full text-xs font-bold text-amber-500">Lapor</div>
              <svg class="w-4 h-4 text-stone-300 dark:text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
              <div class="px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-xs font-bold text-blue-500">Proses</div>
              <svg class="w-4 h-4 text-stone-300 dark:text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
              <div class="px-4 py-2 bg-green-500/10 border border-green-500/20 rounded-full text-xs font-bold text-green-500">Selesai</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="stats" class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-stone-50 dark:bg-brand/10 border-y border-stone-200 dark:border-white/5 transition-colors duration-300">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12">
        <div class="text-center">
          <div class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-2 text-stone-900 dark:text-brand">14.8k+</div>
          <div class="text-sm sm:text-base text-stone-500 dark:text-gray-400 font-bold uppercase tracking-widest">Laporan Tuntas</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-2 text-amber-500">25+</div>
          <div class="text-sm sm:text-base text-stone-500 dark:text-gray-400 font-bold uppercase tracking-widest">Wilayah Tercover</div>
        </div>
        <div class="text-center">
          <div class="text-4xl sm:text-5xl lg:text-6xl font-bold mb-2 text-stone-900 dark:text-brand">200k+</div>
          <div class="text-sm sm:text-base text-stone-500 dark:text-gray-400 font-bold uppercase tracking-widest">Poin Diberikan</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-24 px-4 sm:px-6 lg:px-8 bg-white dark:bg-black transition-colors duration-300">
    <div class="max-w-4xl mx-auto">
      <div class="p-8 sm:p-16 rounded-[2rem] sm:rounded-[3rem] text-center bg-stone-50 dark:bg-gradient-to-br dark:from-white/5 dark:to-transparent border border-stone-200 dark:border-white/10 relative overflow-hidden shadow-xl">
        <div class="absolute top-0 left-0 w-full h-full bg-amber-500/5 dark:bg-brand/5 blur-[100px] -z-10"></div>
        <h2 class="text-3xl sm:text-5xl font-bold mb-6 text-stone-900 dark:text-white">
          Siap Menjadi Pahlawan Warga?
        </h2>
        <p class="text-base sm:text-lg text-stone-600 dark:text-gray-400 mb-10 max-w-2xl mx-auto font-medium leading-relaxed">
          Bergabunglah dengan ribuan warga lainnya dalam membangun infrastruktur kota yang lebih baik
        </p>
        <div id="cta-buttons" class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <!-- Injected by JS -->
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-stone-50 dark:bg-black border-t border-stone-200 dark:border-white/5 py-16 px-4 sm:px-6 lg:px-8 transition-colors duration-300">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
        <div class="md:col-span-2">
          <a href="/" class="block hover:opacity-80 transition-opacity">
            <img src="/logo.svg" alt="SovraEquitara" class="h-8 mb-6 dark:brightness-0 dark:invert" />
          </a>
          <p class="text-base text-stone-500 dark:text-gray-500 max-w-sm leading-relaxed">
            Civic Tech Innovation untuk masa depan kota yang lebih baik. <br/> Mengubah setiap laporan menjadi aksi nyata.
          </p>
        </div>
        <div>
          <h4 class="font-bold text-stone-900 dark:text-white mb-6 uppercase tracking-widest text-xs">Produk</h4>
          <ul class="space-y-3 text-sm text-stone-500 dark:text-gray-500">
            <li><a href="#features" class="hover:text-stone-900 dark:hover:text-white transition-colors">Fitur Utama</a></li>
            <li><a href="#stats" class="hover:text-stone-900 dark:hover:text-white transition-colors">Dampak Sosial</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold text-stone-900 dark:text-white mb-6 uppercase tracking-widest text-xs">Komunitas</h4>
          <ul class="space-y-3 text-sm text-stone-500 dark:text-gray-500">
            <li><a href="/dashboard" class="hover:text-stone-900 dark:hover:text-white transition-colors">Leaderboard</a></li>
            <li><a href="#" class="hover:text-stone-900 dark:hover:text-white transition-colors">Pusat Bantuan</a></li>
          </ul>
        </div>
      </div>
      <div class="pt-12 border-t border-stone-200 dark:border-white/5 text-center text-xs font-bold text-stone-400 dark:text-gray-600 tracking-widest">
        <p>&copy; 2026 SOVRAEQUITARA. ALL RIGHTS RESERVED.</p>
      </div>
    </div>
  </footer>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const token = localStorage.getItem('access_token');
      const userRaw = localStorage.getItem('user');
      
      const navCta = document.getElementById('nav-cta');
      const heroCta = document.getElementById('hero-cta');
      const ctaButtons = document.getElementById('cta-buttons');

      const primaryBtnClass = "btn-primary text-sm sm:text-base px-8 py-3 rounded-2xl font-bold transition-all";
      const secondaryBtnClass = "bg-stone-200 dark:bg-white/10 text-stone-900 dark:text-white border border-stone-300 dark:border-white/20 px-8 py-3 rounded-2xl text-sm sm:text-base font-bold hover:bg-stone-300 dark:hover:bg-white/20 transition-all";

      if (token && userRaw) {
        const user = JSON.parse(userRaw);
        const isAdmin = user.role === 'admin' || user.role === 'ADMIN';
        const dashLink = isAdmin ? '/admin/dashboard' : '/dashboard';

        if (navCta) {
          navCta.innerHTML = `<a href="${dashLink}" class="${primaryBtnClass} !py-2 !px-6 !text-xs">Buka Dashboard</a>`;
        }
        if (heroCta) {
          heroCta.innerHTML = `<a href="${dashLink}" class="${primaryBtnClass} !px-10 !py-4 !text-lg">Lanjutkan ke Dashboard</a>`;
        }
        if (ctaButtons) {
          ctaButtons.innerHTML = `<a href="${dashLink}" class="${primaryBtnClass} !px-10 !py-4 !text-lg">Lanjutkan ke Dashboard</a>`;
        }
      } else {
        if (navCta) {
          navCta.innerHTML = `
            <a href="/login" class="text-xs font-bold text-stone-600 dark:text-white/70 hover:text-stone-900 dark:hover:text-white transition-colors uppercase tracking-widest mr-4">Masuk</a>
            <a href="/register" class="${primaryBtnClass} !py-2 !px-6 !text-xs">Gabung</a>
          `;
        }
        if (heroCta) {
          heroCta.innerHTML = `
            <a href="/register" class="${primaryBtnClass} !px-10 !py-4 !text-lg">Mulai Lapor Gratis</a>
            <a href="#features" class="${secondaryBtnClass} !px-10 !py-4 !text-lg">Lihat Cara Kerja</a>
          `;
        }
        if (ctaButtons) {
          ctaButtons.innerHTML = `
            <a href="/register" class="${primaryBtnClass} !px-10 !py-4 !text-lg">Daftar Sekarang</a>
            <a href="/login" class="${secondaryBtnClass} !px-10 !py-4 !text-lg">Masuk</a>
          `;
        }
      }
    });
  </script>
</Layout>
