---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SovraEquitara — Civic Tech for Future Cities">
  <main class="saas-landing">
    <!-- Sticky Header -->
    <nav class="saas-nav">
      <div class="nav-blur"></div>
      <div class="nav-content">
        <div class="logo-area">
          <img src="/logo.svg" alt="SovraEquitara" class="nav-logo" />
        </div>
        <div class="nav-links">
          <a href="#features">Fitur</a>
          <a href="#how-it-works">Cara Kerja</a>
          <a href="#stats">Dampak</a>
        </div>
        <div class="nav-cta">
          <!-- Injected by JS -->
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-container container">
        <div class="hero-badge animate-up">
          <span class="dot"></span> Civic Tech Innovation 2026
        </div>
        <h1 class="hero-title animate-up">Suarakan Perubahan,<br/><span class="text-gradient">Bangun Kota Masa Depan.</span></h1>
        <p class="hero-lead animate-up">SovraEquitara menghubungkan warga dengan pembuat kebijakan melalui pelaporan infrastruktur berbasis AI yang transparan dan terverifikasi.</p>
        <div class="hero-actions animate-up">
          <!-- Injected by JS -->
        </div>
        
        <div class="hero-mockup animate-up">
          <div class="mockup-container glass">
            <img src="/dashboard.svg" alt="Dashboard Preview" />
            <div class="mockup-floating floating-1 glass">
              <div class="f-icon">✦</div>
              <div class="f-text">AI Verified</div>
            </div>
            <div class="mockup-floating floating-2 glass">
              <div class="f-icon">📍</div>
              <div class="f-text">Real-time Map</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="trust-section">
      <div class="container">
        <p class="trust-title">DIPERCAYA OLEH KOMUNITAS & PEMERINTAH</p>
        <div class="trust-logos">
          <div class="logo-item">Dinas PUPR</div>
          <div class="logo-item">Forum Warga</div>
          <div class="logo-item">Smart City ID</div>
          <div class="logo-item">Urban Future</div>
        </div>
      </div>
    </section>

    <!-- Features Bento -->
    <section id="features" class="features-section">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Solusi Cerdas untuk Kota Pintar</h2>
          <p class="section-lead">Platform yang dirancang untuk efisiensi, akurasi, dan transparansi.</p>
        </div>
        
        <div class="bento-grid">
          <div class="bento-card card-large glass">
            <div class="card-content">
              <div class="card-tag">Smart Mapping</div>
              <h3>Presisi Koordinat Geospasial</h3>
              <p>Sistem kami secara otomatis mendeteksi lokasi kerusakan dengan tingkat akurasi tinggi menggunakan satelit.</p>
            </div>
            <div class="card-visual">
              <div class="visual-map-dot"></div>
            </div>
          </div>
          
          <div class="bento-card card-medium glass">
            <div class="card-content">
              <div class="card-tag">Verification</div>
              <h3>Validasi AI Multi-layer</h3>
              <p>Mencegah laporan duplikat dan spam dengan verifikasi gambar otomatis.</p>
            </div>
          </div>
          
          <div class="bento-card card-medium glass">
            <div class="card-content">
              <div class="card-tag">Gamification</div>
              <h3>Sistem Pahlawan Warga</h3>
              <p>Dapatkan poin dan lencana untuk setiap kontribusi nyata Anda bagi kota.</p>
            </div>
          </div>
          
          <div class="bento-card card-wide glass">
            <div class="card-content-row">
              <div class="c-left">
                <h3>Transparansi Real-time</h3>
                <p>Pantau setiap tahapan perbaikan mulai dari verifikasi hingga penyelesaian akhir langsung di dashboard Anda.</p>
              </div>
              <div class="c-right">
                <div class="status-steps">
                  <div class="step active">Lapor</div>
                  <div class="step active">Proses</div>
                  <div class="step">Selesai</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Impact Stats -->
    <section id="stats" class="stats-section">
      <div class="container stats-container glass">
        <div class="stat-item">
          <span class="stat-num">14.8k+</span>
          <span class="stat-label">Laporan Tuntas</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">25+</span>
          <span class="stat-label">Wilayah Tercover</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">200k+</span>
          <span class="stat-label">Poin Diberikan</span>
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-card glass-bright">
          <h2>Siap Menjadi Pahlawan Warga?</h2>
          <p>Bergabunglah dengan ribuan warga lainnya dalam membangun infrastruktur kota yang lebih baik.</p>
          <div class="cta-btns">
            <!-- Injected by JS -->
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container footer-content">
        <div class="f-brand">
          <img src="/logo.svg" alt="SovraEquitara" class="footer-logo" />
          <p>Civic Tech Innovation for 2026.</p>
        </div>
        <div class="f-links">
          <div class="link-group">
            <h4>Produk</h4>
            <a href="#">Fitur</a>
            <a href="#">Peta Interaktif</a>
          </div>
          <div class="link-group">
            <h4>Komunitas</h4>
            <a href="#">Leaderboard</a>
            <a href="#">FAQ</a>
          </div>
        </div>
      </div>
      <div class="f-bottom">
        <p>&copy; 2026 SovraEquitara. Built with purpose.</p>
      </div>
    </footer>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const token = localStorage.getItem('access_token');
      const userRaw = localStorage.getItem('user');
      const navCta = document.querySelector('.nav-cta');
      const heroCta = document.querySelector('.hero-actions');
      const finalCta = document.querySelector('.cta-btns');

      if (token && userRaw) {
        const user = JSON.parse(userRaw);
        const isAdmin = user.role === 'admin' || user.role === 'ADMIN';
        const dashLink = isAdmin ? '/admin/dashboard' : '/dashboard';

        if (navCta) {
          navCta.innerHTML = `<a href="${dashLink}" class="btn-mulai">Buka Dashboard</a>`;
        }
        if (heroCta) {
          heroCta.innerHTML = `<a href="${dashLink}" class="btn btn-primary btn-lg">Lanjutkan ke Dashboard</a>`;
        }
        if (finalCta) {
          finalCta.innerHTML = `<a href="${dashLink}" class="btn btn-primary btn-lg">Lanjutkan ke Dashboard</a>`;
        }
      } else {
        if (navCta) {
          navCta.innerHTML = `
            <a href="/login" class="link-login">Masuk</a>
            <a href="/register" class="btn-mulai">Gabung Sekarang</a>
          `;
        }
        if (heroCta) {
          heroCta.innerHTML = `
            <a href="/register" class="btn btn-primary btn-lg">Mulai Lapor Gratis</a>
            <a href="#how-it-works" class="btn btn-glass btn-lg">Lihat Cara Kerja</a>
          `;
        }
        if (finalCta) {
          finalCta.innerHTML = `
            <a href="/register" class="btn btn-primary btn-lg">Daftar Sekarang</a>
            <a href="/login" class="btn btn-glass btn-lg">Cek Dashboard</a>
          `;
        }
      }
    });
  </script>
</Layout>

<style is:global>
  :root {
    --container-max: 1200px;
  }
  
  .saas-landing { background: var(--color-bg); min-height: 100vh; font-family: var(--font-sans); }
  .container { max-width: var(--container-max); margin: 0 auto; padding: 0 24px; }
  .saas-landing * { box-sizing: border-box; }

  /* Navbar */
  .saas-nav { 
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000; height: 80px; 
    display: flex; align-items: center; transition: all 0.3s;
  }
  .nav-blur { 
    position: absolute; inset: 0; 
    background: rgba(245, 242, 237, 0.9);
    backdrop-filter: blur(20px); 
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
  }
  .nav-content { position: relative; width: 100%; max-width: var(--container-max); margin: 0 auto; padding: 0 24px; display: flex; justify-content: space-between; align-items: center; }
  .logo-area { display: flex; align-items: center; }
  .nav-logo { height: 44px; width: auto; object-fit: contain; }
  
  .nav-links { display: flex; gap: 32px; }
  .nav-links a { text-decoration: none; color: var(--color-text-title) !important; font-size: 14px; font-weight: 600; opacity: 0.6; transition: 0.2s; }
  .nav-links a:hover { opacity: 1; }
  
  .nav-cta { display: flex; align-items: center; gap: 24px; }
  .link-login { text-decoration: none; color: var(--color-text-title) !important; font-size: 14px; font-weight: 700; opacity: 0.7; transition: 0.2s; }
  .link-login:hover { opacity: 1; }
  
  .btn-mulai { 
    background: var(--color-brand) !important; 
    color: white !important; 
    padding: 12px 24px; 
    border-radius: 12px; 
    text-decoration: none !important; 
    font-size: 14px; 
    font-weight: 700; 
    transition: 0.3s; 
    display: inline-flex; 
    align-items: center; 
    justify-content: center;
    box-shadow: 0 4px 12px rgba(26, 26, 26, 0.15);
    border: none;
    cursor: pointer;
  }
  .btn-mulai:hover { 
    transform: translateY(-2px); 
    box-shadow: 0 8px 20px rgba(26, 26, 26, 0.2); 
    background: #000 !important;
  }

  /* Hero */
  .hero-section { padding: 180px 0 100px; text-align: center; position: relative; overflow: hidden; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: white; padding: 6px 16px; border-radius: 99px; font-size: 12px; font-weight: 800; border: 1px solid var(--color-border); margin-bottom: 32px; }
  .hero-badge .dot { width: 6px; height: 6px; background: var(--color-accent); border-radius: 50%; }
  
  .hero-title { font-size: 80px; line-height: 1.05; font-weight: 800; letter-spacing: -0.04em; margin-bottom: 24px; }
  .text-gradient { background: linear-gradient(90deg, var(--color-brand), #444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-lead { font-size: 20px; color: var(--color-text-muted); max-width: 640px; margin: 0 auto 48px; line-height: 1.6; }
  .hero-actions { display: flex; justify-content: center; gap: 16px; }
  
  .hero-mockup { margin-top: 80px; perspective: 1000px; position: relative; }
  .mockup-container { 
    max-width: 1000px; margin: 0 auto; border-radius: 24px; overflow: hidden; 
    transform: rotateX(10deg); transition: transform 0.5s;
    box-shadow: 0 50px 100px -20px rgba(0,0,0,0.15);
  }
  .mockup-container:hover { transform: rotateX(0deg); }
  .mockup-container img { width: 100%; display: block; }
  
  .mockup-floating { position: absolute; padding: 12px 24px; border-radius: 16px; display: flex; align-items: center; gap: 12px; font-weight: 800; font-size: 14px; animation: float 6s infinite ease-in-out; }
  .floating-1 { top: 20%; left: 5%; background: white; }
  .floating-2 { bottom: 20%; right: 5%; background: white; animation-delay: -3s; }
  @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

  /* Trust Bar */
  .trust-section { padding: 40px 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
  .trust-title { font-size: 11px; font-weight: 800; color: var(--color-text-muted); letter-spacing: 0.2em; text-align: center; margin-bottom: 32px; }
  .trust-logos { display: flex; justify-content: center; gap: 60px; opacity: 0.5; font-weight: 900; font-size: 18px; flex-wrap: wrap; }

  /* Features */
  .features-section { padding: 120px 0; }
  .section-header { text-align: center; margin-bottom: 80px; }
  .section-title { font-size: 42px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 16px; }
  .section-lead { font-size: 18px; color: var(--color-text-muted); }

  .bento-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .bento-card { padding: 40px; border-radius: 32px; display: flex; flex-direction: column; justify-content: space-between; }
  .card-tag { font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text-muted); margin-bottom: 16px; }
  .bento-card h3 { font-size: 24px; font-weight: 800; margin-bottom: 12px; }
  .bento-card p { font-size: 15px; color: var(--color-text-muted); line-height: 1.6; }
  
  .card-large { grid-column: span 2; height: 400px; background: white; }
  .card-medium { grid-column: span 1; height: 400px; background: white; }
  .card-wide { grid-column: span 3; background: var(--color-brand); color: white; }
  .card-wide h3 { color: white; }
  .card-wide p { color: rgba(255,255,255,0.6); }
  
  .card-content-row { display: flex; justify-content: space-between; align-items: center; width: 100%; }
  .status-steps { display: flex; gap: 12px; }
  .step { padding: 8px 20px; border-radius: 99px; background: rgba(255,255,255,0.1); font-size: 12px; font-weight: 800; }
  .step.active { background: var(--color-accent); color: var(--color-brand); }

  /* Stats */
  .stats-section { padding: 80px 0; }
  .stats-container { display: flex; justify-content: space-around; align-items: center; padding: 60px; border-radius: 32px; }
  .stat-item { text-align: center; }
  .stat-num { display: block; font-size: 48px; font-weight: 900; color: var(--color-text-title); letter-spacing: -0.04em; }
  .stat-label { font-size: 14px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; }
  .stat-divider { width: 1px; height: 60px; background: var(--color-border); }

  /* Final CTA */
  .cta-section { padding: 120px 0; text-align: center; }
  .cta-card { padding: 80px 40px; border-radius: 40px; }
  .cta-card h2 { font-size: 48px; font-weight: 800; margin-bottom: 24px; }
  .cta-card p { font-size: 18px; color: var(--color-text-muted); max-width: 540px; margin: 0 auto 40px; }
  .cta-btns { display: flex; justify-content: center; gap: 16px; }

  /* Footer */
  .footer { padding: 80px 0 40px; border-top: 1px solid var(--color-border); }
  .footer-content { display: flex; justify-content: space-between; margin-bottom: 60px; }
  .footer-logo { height: 64px; width: auto; object-fit: contain; margin-bottom: 20px; }
  .f-brand p { font-size: 14px; color: var(--color-text-muted); max-width: 240px; }
  .f-links { display: flex; gap: 80px; }
  .link-group h4 { font-size: 14px; font-weight: 800; margin-bottom: 20px; }
  .link-group a { display: block; text-decoration: none; color: var(--color-text-muted); font-size: 14px; margin-bottom: 12px; transition: 0.3s; }
  .link-group a:hover { color: var(--color-brand); }
  .f-bottom { border-top: 1px solid var(--color-border); padding-top: 40px; text-align: center; font-size: 12px; color: var(--color-text-muted); }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-logo { height: 56px; }
    .hero-title { font-size: 48px; }
    .hero-lead { font-size: 16px; }
    .nav-links { display: none; }
    .bento-grid { grid-template-columns: 1fr; }
    .card-large, .card-medium, .card-wide { grid-column: span 1; height: auto; }
    .stats-container { flex-direction: column; gap: 40px; }
    .stat-divider { display: none; }
    .footer-content { flex-direction: column; gap: 60px; }
  }
</style>
