---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
---

<Layout title="Profil Super Admin — SovraEquitara">
  <script is:inline define:vars={{ API_URL }}>
    window.API_URL = API_URL;
  </script>

  <div class="flex min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark transition-all duration-300 font-display">
    <Sidebar activePage="profile" />

    <main class="flex-1 lg:ml-72 p-6 lg:p-12">
      <div class="max-w-3xl mx-auto space-y-8">

        <!-- Page Header -->
        <header class="mb-2">
          <h1 class="text-3xl font-black tracking-tight">Profil Super Admin</h1>
          <p class="text-stone-500 font-bold mt-1 text-sm">Kelola informasi dan keamanan akun super administrator</p>
        </header>

        <!-- Identity Card -->
        <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-white/10 rounded-3xl p-8 shadow-sm">
          <div class="flex items-center gap-6 mb-8">
            <div class="relative group shrink-0">
              <div id="avatar-container" class="w-20 h-20 bg-violet-100 dark:bg-violet-900/40 rounded-2xl flex items-center justify-center text-3xl font-black text-violet-600 dark:text-violet-400 overflow-hidden">
                <span id="avatar-initial">S</span>
                <img id="avatar-img" src="" class="w-full h-full object-cover hidden" alt="Avatar" />
              </div>
              <label for="avatar-upload" title="Ubah Foto Profil"
                class="absolute -bottom-2 -right-2 w-8 h-8 bg-violet-500 hover:bg-violet-600 border-2 border-white dark:border-stone-900 rounded-full shadow flex items-center justify-center text-white cursor-pointer transition-transform hover:scale-110 z-10">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path>
                  <circle cx="12" cy="13" r="4"></circle>
                </svg>
              </label>
              <input type="file" id="avatar-upload" accept="image/jpeg,image/png,image/webp" class="hidden" />
            </div>
            <div>
              <h2 id="display-name" class="text-2xl font-black">Memuat...</h2>
              <p id="display-email" class="text-stone-500 text-sm font-semibold mt-0.5">Memuat...</p>
              <span class="mt-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-black uppercase tracking-wider bg-violet-100 dark:bg-violet-900/40 text-violet-600 dark:text-violet-300">
                Super Administrator
              </span>
            </div>
          </div>

          <!-- Profile Form -->
          <form id="sa-profile-form" class="space-y-5">
            <div>
              <label class="block text-[10px] font-black text-stone-400 uppercase tracking-[0.15em] mb-1.5">Nama Lengkap</label>
              <input type="text" id="input-name" required
                class="w-full p-3.5 rounded-xl border-2 border-stone-200 dark:border-white/10 bg-stone-50 dark:bg-black/30 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 transition-all" />
            </div>
            <div>
              <label class="block text-[10px] font-black text-stone-400 uppercase tracking-[0.15em] mb-1.5">Email</label>
              <input type="email" id="input-email" disabled
                class="w-full p-3.5 rounded-xl border-2 border-stone-200 dark:border-white/10 bg-stone-100/50 dark:bg-black/10 text-sm font-bold opacity-60 cursor-not-allowed" />
            </div>
            <div class="pt-2">
              <button type="submit" id="btn-save-profile"
                class="px-8 py-3.5 bg-violet-600 hover:bg-violet-700 text-white rounded-xl font-black text-sm uppercase tracking-widest cursor-pointer border-none transition-all shadow-md hover:shadow-violet-500/30">
                Simpan Perubahan
              </button>
            </div>
          </form>
        </div>

        <!-- Security Card -->
        <div class="bg-white dark:bg-stone-900 border border-stone-200 dark:border-white/10 rounded-3xl p-8 shadow-sm">
          <div class="flex items-center gap-3 mb-6">
            <div class="p-2.5 bg-violet-50 dark:bg-violet-900/30 rounded-xl">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#7c3aed" stroke-width="2.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <div>
              <h3 class="font-black text-base">Keamanan Akun</h3>
              <p class="text-xs font-semibold text-stone-400">Ubah kata sandi langsung tanpa perlu OTP email</p>
            </div>
          </div>

          <div class="h-px w-full bg-stone-100 dark:bg-white/5 mb-6"></div>

          <!-- Error Banner -->
          <div id="pw-error-banner" class="hidden mb-4 px-4 py-3 bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-900/40 rounded-xl">
            <p id="pw-error-text" class="text-xs font-bold text-red-600 dark:text-red-400"></p>
          </div>

          <form id="form-change-pw" class="space-y-4">
            <div>
              <label class="block text-[10px] font-black text-stone-400 uppercase tracking-[0.15em] mb-1.5">Kata Sandi Saat Ini</label>
              <input type="password" id="current_password" placeholder="••••••••" required
                class="w-full p-3.5 rounded-xl border-2 border-stone-200 dark:border-white/10 bg-stone-50 dark:bg-black/30 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 transition-all" />
            </div>
            <div>
              <label class="block text-[10px] font-black text-stone-400 uppercase tracking-[0.15em] mb-1.5">Kata Sandi Baru</label>
              <input type="password" id="new_password" placeholder="Minimal 6 karakter" required
                class="w-full p-3.5 rounded-xl border-2 border-stone-200 dark:border-white/10 bg-stone-50 dark:bg-black/30 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 transition-all" />
            </div>
            <div>
              <label class="block text-[10px] font-black text-stone-400 uppercase tracking-[0.15em] mb-1.5">Konfirmasi Sandi Baru</label>
              <input type="password" id="confirm_password" placeholder="Ulangi kata sandi baru" required
                class="w-full p-3.5 rounded-xl border-2 border-stone-200 dark:border-white/10 bg-stone-50 dark:bg-black/30 text-sm font-bold outline-none focus:border-violet-500 focus:ring-4 focus:ring-violet-500/10 transition-all" />
            </div>
            <div class="pt-2">
              <button type="submit" id="btn-change-pw"
                class="px-8 py-3.5 bg-violet-600 hover:bg-violet-700 text-white rounded-xl font-black text-sm uppercase tracking-widest cursor-pointer border-none transition-all shadow-md hover:shadow-violet-500/30">
                Perbarui Kata Sandi
              </button>
            </div>
          </form>
        </div>

        <!-- Danger Zone -->
        <div class="bg-red-50 dark:bg-red-950/20 border border-red-200 dark:border-red-900/30 rounded-3xl p-8">
          <h3 class="font-black text-red-700 dark:text-red-400 text-base mb-1">Keluar dari Sistem</h3>
          <p class="text-xs font-semibold text-red-500/80 dark:text-red-500/60 mb-5">Sesi Anda akan berakhir dan Anda harus masuk kembali.</p>
          <button id="btn-logout"
            class="px-6 py-3 bg-white dark:bg-red-950/30 border-2 border-red-300 dark:border-red-700/50 text-red-600 dark:text-red-400 rounded-xl font-black text-xs uppercase tracking-widest cursor-pointer hover:bg-red-600 hover:text-white hover:border-red-600 transition-all">
            Keluar
          </button>
        </div>

      </div>
    </main>
  </div>

  <script>
    import { showToast } from '../../lib/toast';

    const API_URL = (window as any).API_URL || 'http://localhost:3000';

    function getToken() { return localStorage.getItem('access_token') || ''; }
    function getUser()  { return JSON.parse(localStorage.getItem('user') || '{}'); }

    function setError(msg: string) {
      const banner = document.getElementById('pw-error-banner')!;
      const text   = document.getElementById('pw-error-text')!;
      if (msg) {
        text.textContent = msg;
        banner.classList.remove('hidden');
      } else {
        banner.classList.add('hidden');
      }
    }

    async function handleAvatarUpload(e: Event) {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;
      const user = getUser();
      const formData = new FormData();
      formData.append('avatar', file);
      try {
        const res = await fetch(`${API_URL}/api/profile/avatar`, {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${getToken()}` },
          body: formData
        });
        const data = await res.json();
        if (res.ok) {
          showToast(data.message || 'Foto profil diperbarui!', 'success');
          user.avatar_url = data.avatar_url;
          localStorage.setItem('user', JSON.stringify(user));
          const img = document.getElementById('avatar-img') as HTMLImageElement;
          if (img) {
            img.src = `${API_URL}${data.avatar_url}`;
            img.classList.remove('hidden');
            document.getElementById('avatar-initial')?.classList.add('hidden');
          }
          window.dispatchEvent(new Event('storage'));
        } else {
          showToast(data.error || 'Gagal unggah foto', 'error');
        }
      } catch {
        showToast('Koneksi gagal', 'error');
      }
    }

    async function handleUpdateProfile(e: Event) {
      e.preventDefault();
      const btn = document.getElementById('btn-save-profile') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Menyimpan...';
      const user = getUser();
      const name = (document.getElementById('input-name') as HTMLInputElement).value;
      try {
        const res = await fetch(`${API_URL}/api/profile`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
          body: JSON.stringify({ full_name: name })
        });
        if (res.ok) {
          showToast('Profil berhasil diperbarui!', 'success');
          user.full_name = name;
          user.name = name;
          localStorage.setItem('user', JSON.stringify(user));
          (document.getElementById('display-name') as HTMLElement).innerText = name;
          (document.getElementById('avatar-initial') as HTMLElement).innerText = name[0]?.toUpperCase() || 'S';
          window.dispatchEvent(new Event('storage'));
        } else {
          showToast('Gagal memperbarui profil', 'error');
        }
      } catch {
        showToast('Koneksi gagal', 'error');
      }
      btn.disabled = false;
      btn.textContent = 'Simpan Perubahan';
    }

    async function handleChangePassword(e: Event) {
      e.preventDefault();
      setError('');
      const current = (document.getElementById('current_password') as HTMLInputElement).value;
      const newPw   = (document.getElementById('new_password') as HTMLInputElement).value;
      const confirm = (document.getElementById('confirm_password') as HTMLInputElement).value;

      if (newPw.length < 6) { setError('Kata sandi baru minimal 6 karakter.'); return; }
      if (newPw !== confirm) { setError('Konfirmasi kata sandi tidak cocok.'); return; }

      const btn = document.getElementById('btn-change-pw') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = 'Menyimpan...';

      try {
        const res = await fetch(`${API_URL}/api/profile/password`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
          body: JSON.stringify({ current_password: current, new_password: newPw })
        });
        const data = await res.json();
        if (res.ok) {
          showToast('Kata sandi berhasil diperbarui!', 'success');
          (document.getElementById('form-change-pw') as HTMLFormElement).reset();
          setError('');
        } else {
          setError(data.error || 'Gagal memperbarui kata sandi. Periksa kata sandi saat ini.');
        }
      } catch {
        setError('Koneksi gagal. Coba lagi.');
      }
      btn.disabled = false;
      btn.textContent = 'Perbarui Kata Sandi';
    }

    function init() {
      const user = getUser();
      const role = (user.role || '').toLowerCase();
      if (!user || role !== 'super_admin') {
        window.location.href = '/admin/login';
        return;
      }

      const name = user.full_name || user.name || 'Super Admin';
      (document.getElementById('display-name') as HTMLElement).innerText = name;
      (document.getElementById('display-email') as HTMLElement).innerText = user.email || '';
      (document.getElementById('input-name') as HTMLInputElement).value = name;
      (document.getElementById('input-email') as HTMLInputElement).value = user.email || '';
      (document.getElementById('avatar-initial') as HTMLElement).innerText = name[0]?.toUpperCase() || 'S';

      if (user.avatar_url) {
        const img = document.getElementById('avatar-img') as HTMLImageElement;
        img.src = `${API_URL}${user.avatar_url}`;
        img.classList.remove('hidden');
        document.getElementById('avatar-initial')?.classList.add('hidden');
      }

      document.getElementById('avatar-upload')!.onchange = handleAvatarUpload;
      document.getElementById('sa-profile-form')!.onsubmit = handleUpdateProfile;
      document.getElementById('form-change-pw')!.onsubmit = handleChangePassword;
      document.getElementById('btn-logout')!.onclick = () => {
        localStorage.clear();
        window.location.href = '/admin/login';
      };
    }

    document.addEventListener('astro:page-load', init, { once: true });
    if (document.readyState === 'complete') init();
  </script>
</Layout>
