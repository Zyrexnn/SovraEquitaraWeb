---
import { ThemeToggle } from './ThemeToggle';

interface Props {
  activePage: 'dashboard' | 'leaderboard' | 'ai-assistant' | 'admins' | 'chat' | 'profile';
}

const { activePage } = Astro.props;
---

<aside class="fixed inset-y-0 left-0 w-72 bg-zen-sidebar-bg dark:bg-zen-sidebar-bg-dark border-r border-zen-border dark:border-zen-border-dark flex flex-col z-40 transition-transform lg:translate-x-0 -translate-x-full" id="sidebar">
  <div class="p-8 flex items-center justify-between border-b border-zen-border dark:border-zen-border-dark">
    <img src="/logo.svg" alt="Sovra" class="h-14 dark:brightness-0 dark:invert">
    <ThemeToggle client:load />
  </div>
  
  <nav class="flex-1 p-6 space-y-2">
    <a href="/admin/dashboard" id="nav-dashboard" class={`flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300 font-bold group ${activePage === 'dashboard' ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg shadow-stone-900/10 dark:shadow-white/5' : 'hover:bg-stone-100 dark:hover:bg-white/5 text-stone-500 dark:text-stone-400'}`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={activePage === 'dashboard' ? '' : 'group-hover:scale-110 transition-transform'}>
        <rect x="3" y="3" width="7" height="7" rx="1"></rect>
        <rect x="14" y="3" width="7" height="7" rx="1"></rect>
        <rect x="14" y="14" width="7" height="7" rx="1"></rect>
        <rect x="3" y="14" width="7" height="7" rx="1"></rect>
      </svg>
      <span>Dashboard</span>
    </a>
    <a href="/admin/leaderboard" class={`flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300 font-bold group ${activePage === 'leaderboard' ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg shadow-stone-900/10 dark:shadow-white/5' : 'hover:bg-stone-100 dark:hover:bg-white/5 text-stone-500 dark:text-stone-400'}`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={activePage === 'leaderboard' ? '' : 'group-hover:scale-110 transition-transform'}>
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
      <span>Peringkat Warga</span>
    </a>
    <a href="/admin/ai-assistant" class={`flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300 font-bold group ${activePage === 'ai-assistant' ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg shadow-stone-900/10 dark:shadow-white/5' : 'hover:bg-stone-100 dark:hover:bg-white/5 text-stone-500 dark:text-stone-400'}`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={activePage === 'ai-assistant' ? '' : 'group-hover:scale-110 transition-transform'}>
        <path d="M12 2a10 10 0 1 0 10 10H12V2Z"></path>
        <path d="M12 12 2.1 14.9"></path>
        <path d="M12 12 14.9 2.1"></path>
      </svg>
      <span>AI Assistant</span>
    </a>
    <div id="superadmin-links" class="hidden space-y-2">
      <a href="/superadmin/admins" class={`flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300 font-bold group ${activePage === 'admins' ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg shadow-stone-900/10 dark:shadow-white/5' : 'hover:bg-stone-100 dark:hover:bg-white/5 text-stone-500 dark:text-stone-400'}`}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={activePage === 'admins' ? '' : 'group-hover:scale-110 transition-transform'}>
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
          <circle cx="11" cy="7" r="4"></circle>
          <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
        </svg>
        <span>Kelola Admin</span>
      </a>
      <a href="/superadmin/chat" class={`flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300 font-bold group ${activePage === 'chat' ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg shadow-stone-900/10 dark:shadow-white/5' : 'hover:bg-stone-100 dark:hover:bg-white/5 text-stone-500 dark:text-stone-400'}`}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={activePage === 'chat' ? '' : 'group-hover:scale-110 transition-transform'}>
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <span>Chat Inbox</span>
      </a>
    </div>
    <a href="/admin/profile" class={`flex items-center gap-4 px-5 py-4 rounded-2xl transition-all duration-300 font-bold group ${activePage === 'profile' ? 'bg-stone-900 dark:bg-white text-white dark:text-black shadow-lg shadow-stone-900/10 dark:shadow-white/5' : 'hover:bg-stone-100 dark:hover:bg-white/5 text-stone-500 dark:text-stone-400'}`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class={activePage === 'profile' ? '' : 'group-hover:scale-110 transition-transform'}>
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      <span>Profile</span>
    </a>
  </nav>

  <div class="p-6 border-t border-zen-border dark:border-zen-border-dark space-y-4">
    <div class="flex items-center gap-4 p-4 rounded-2xl bg-zen-surface dark:bg-white/5 border border-zen-border dark:border-zen-border-dark">
      <div class="w-10 h-10 rounded-xl bg-stone-900 dark:bg-white text-white dark:text-black flex items-center justify-center font-black" id="sidebar-avatar">A</div>
      <div class="overflow-hidden">
        <div class="text-xs font-black truncate" id="admin-name-sidebar">Administrator</div>
        <div class="text-[10px] font-bold text-green-500 uppercase tracking-widest flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Online
        </div>
      </div>
    </div>
    <button id="logout-btn" class="w-full flex items-center gap-3 px-5 py-4 rounded-xl text-stone-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 font-bold transition-all duration-300">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
        <polyline points="16 17 21 12 16 7"></polyline>
        <line x1="21" y1="12" x2="9" y2="12"></line>
      </svg>
      <span>Logout Portal</span>
    </button>
  </div>
</aside>

<script>
  function initSidebar() {
    const user = JSON.parse(localStorage.getItem("user") || "{}");
    const nameEl = document.getElementById("admin-name-sidebar");
    const avatarEl = document.getElementById("sidebar-avatar");
    const superLinks = document.getElementById("superadmin-links");
    const navDashboard = document.getElementById("nav-dashboard") as HTMLAnchorElement;

    if (nameEl) nameEl.innerText = user.full_name || "Admin";
    if (avatarEl) avatarEl.innerText = (user.full_name || "A")[0].toUpperCase();

    if (user.role === "super_admin") {
      if (superLinks) superLinks.classList.remove("hidden");
      if (navDashboard) navDashboard.href = "/superadmin/dashboard";
      if (nameEl) nameEl.innerText = (user.full_name || "Admin") + " (Super)";
    }

    document.getElementById("logout-btn")?.addEventListener("click", () => {
      localStorage.clear();
      window.location.href = "/admin/login";
    });

    // Mobile menu handling is usually in the page, but let's add it here if possible
    // Wait, the button is outside the sidebar, so we can't easily handle it here without global selector
  }

  // Run immediately and also on Astro page load if using transitions
  initSidebar();
  document.addEventListener('astro:after-swap', initSidebar);
</script>
