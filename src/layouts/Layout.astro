---
import '../styles/tailwind.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SovraEquitara — Smart City Infrastructure Ecosystem",
  description = "Platform Smart City terintegrasi untuk pelaporan infrastruktur, manajemen tata kota, dan kolaborasi warga berbasis AI."
} = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1A1A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />

    <style is:global>
      /* Page Transition Progress Bar */
      ::view-transition-group(root) {
        animation-duration: 0.5s;
        animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* Custom Loading Bar */
      .astro-route-announcer { display: none; }
      
      #nprogress { pointer-events: none; }
      #nprogress .bar {
        background: #3B82F6;
        position: fixed;
        z-index: 2000;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
      }

      /* Transitions */
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      
      .dark #nprogress .bar { background: #60A5FA; }
    </style>

    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const applyTheme = (theme) => {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      // Initial apply
      const currentTheme = getTheme();
      applyTheme(currentTheme);

      // Listen for local storage changes from other tabs
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') {
          applyTheme(e.newValue);
        }
      });
    </script>
  </head>
  <body class="min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark antialiased transition-colors duration-300">
    <slot />

    <!-- Global Emergency Modal -->
    <div id="global-emergency-modal" class="fixed inset-0 bg-red-900/80 backdrop-blur-md z-[9999] hidden items-center justify-center p-6">
      <div class="bg-white dark:bg-stone-900 w-full max-w-md rounded-[32px] shadow-2xl overflow-hidden flex flex-col scale-95 opacity-0 transition-all duration-300" id="global-emergency-content">
        <div class="bg-red-500 p-6 flex flex-col items-center justify-center text-white">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mb-2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          <h2 class="text-2xl font-black tracking-widest uppercase m-0 text-center">Pesan Darurat!</h2>
        </div>
        <div class="p-8 flex flex-col items-center text-center">
          <h3 id="emergency-title" class="text-xl font-bold text-zen-text dark:text-zen-text-dark mb-4"></h3>
          <p id="emergency-message" class="text-stone-600 dark:text-stone-300 font-medium mb-8 leading-relaxed"></p>
          <button id="btn-close-emergency" class="px-8 py-3.5 bg-stone-900 dark:bg-white text-white dark:text-black rounded-xl font-bold w-full hover:scale-105 transition-transform shadow-lg">SAYA MENGERTI</button>
        </div>
      </div>
    </div>

    <!-- Global Notification Panel -->
    <div id="global-notif-panel" class="fixed top-24 lg:top-8 right-4 lg:right-8 w-80 sm:w-96 bg-white dark:bg-stone-900 border border-zen-border dark:border-zen-border-dark shadow-2xl rounded-3xl z-[5000] hidden flex-col overflow-hidden transition-all duration-300 opacity-0 translate-y-[-20px]">
      <div class="p-4 border-b border-zen-border dark:border-zen-border-dark flex justify-between items-center bg-stone-50 dark:bg-stone-950">
        <span class="font-black text-sm uppercase tracking-widest text-zen-text dark:text-zen-text-dark">Notifikasi</span>
        <div class="flex items-center gap-2">
          <button id="btn-clear-all-notifs" class="text-[10px] font-bold text-stone-400 hover:text-red-500 transition-colors uppercase tracking-widest bg-stone-100 dark:bg-white/5 px-2 py-1 rounded-md hidden">Hapus Semua</button>
          <button id="btn-close-notif-panel" class="text-stone-400 hover:text-stone-900 dark:hover:text-white transition-colors"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
        </div>
      </div>
      <div id="global-notif-list" class="max-h-[60vh] overflow-y-auto p-2 flex flex-col gap-1">
        <div class="p-4 text-center text-stone-400 font-bold text-xs">Memuat notifikasi...</div>
      </div>
    </div>

    <script>
      import '../lib/toast';
      import NProgress from 'nprogress';

      // Configure NProgress
      NProgress.configure({ 
        showSpinner: false,
        easing: 'ease',
        speed: 500,
        trickleSpeed: 200
      });

      document.addEventListener('astro:before-preparation', () => {
        NProgress.start();
      });
      document.addEventListener('astro:page-load', () => {
        NProgress.done();
        initGlobalNotifications();
      });

      let notifPollInterval = null;
      let seenEmergencies = new Set();
      let hiddenNotifs = new Set();
      
      // Load local states
      try {
        const storedEmerg = localStorage.getItem('seen_emergencies');
        if (storedEmerg) seenEmergencies = new Set(JSON.parse(storedEmerg));
        
        const storedHidden = localStorage.getItem('hidden_notifs');
        if (storedHidden) hiddenNotifs = new Set(JSON.parse(storedHidden));
      } catch(e) {}

      function initGlobalNotifications() {
        const token = localStorage.getItem('access_token');
        if (!token) return;

        fetchNotifications(token);
        
        if (notifPollInterval) clearInterval(notifPollInterval);
        notifPollInterval = setInterval(() => fetchNotifications(token, true), 10000);

        const closePanelBtn = document.getElementById('btn-close-notif-panel');
        if (closePanelBtn) {
          closePanelBtn.onclick = () => {
            const panel = document.getElementById('global-notif-panel');
            if (panel) {
              panel.classList.remove('opacity-100', 'translate-y-0');
              panel.classList.add('opacity-0', 'translate-y-[-20px]');
              setTimeout(() => panel.classList.add('hidden'), 300);
            }
          };
        }

        const clearAllBtn = document.getElementById('btn-clear-all-notifs');
        if (clearAllBtn) {
          clearAllBtn.onclick = () => {
            // Get all current loaded notifs and hide them
            const items = document.querySelectorAll('.notif-item');
            items.forEach(el => hiddenNotifs.add(el.getAttribute('data-id')));
            localStorage.setItem('hidden_notifs', JSON.stringify([...hiddenNotifs]));
            fetchNotifications(token, true); // Refresh list
          };
        }

        const closeEmergBtn = document.getElementById('btn-close-emergency');
        if (closeEmergBtn) {
          closeEmergBtn.onclick = () => {
            const modal = document.getElementById('global-emergency-modal');
            const content = document.getElementById('global-emergency-content');
            if (modal && content) {
              content.classList.add('scale-95', 'opacity-0');
              setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
              }, 300);
            }
          };
        }
      }

      window.hideNotification = async (id) => {
        const user = JSON.parse(localStorage.getItem('user') || '{}');
        const token = localStorage.getItem('access_token');
        
        if (user.role === 'admin' || user.role === 'ADMIN' || user.role === 'super_admin' || user.role === 'SUPER_ADMIN') {
          try {
            const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
            const res = await fetch(`${API_URL}/api/admin/notifications/${id}`, {
              method: 'DELETE',
              headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) {
              if (token) fetchNotifications(token, true);
              return;
            }
          } catch(e) {
            console.error("Gagal menghapus notifikasi:", e);
          }
        }

        hiddenNotifs.add(id);
        localStorage.setItem('hidden_notifs', JSON.stringify([...hiddenNotifs]));
        if (token) fetchNotifications(token, true);
      };

      window.toggleGlobalNotifPanel = () => {
        const panel = document.getElementById('global-notif-panel');
        if (panel) {
          if (panel.classList.contains('hidden')) {
            panel.classList.remove('hidden');
            setTimeout(() => panel.classList.remove('opacity-0', 'translate-y-[-20px]'), 10);
            setTimeout(() => panel.classList.add('opacity-100', 'translate-y-0'), 10);
          } else {
            panel.classList.remove('opacity-100', 'translate-y-0');
            panel.classList.add('opacity-0', 'translate-y-[-20px]');
            setTimeout(() => panel.classList.add('hidden'), 300);
          }
        }
      };

      async function fetchNotifications(token, silent = false) {
        try {
          const API_URL = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
          const res = await fetch(`${API_URL}/api/notifications`, {
            headers: { 'Authorization': `Bearer ${token}` }
          });
          if (!res.ok) return;
          const data = await res.json();
          const allNotifs = data.data || [];
          
          // Filter out hidden notifications
          const notifs = allNotifs.filter(n => !hiddenNotifs.has(n.id));

          const clearAllBtn = document.getElementById('btn-clear-all-notifs');
          if (clearAllBtn) {
            if (notifs.length > 0) clearAllBtn.classList.remove('hidden');
            else clearAllBtn.classList.add('hidden');
          }

          // Render List
          const list = document.getElementById('global-notif-list');
          if (list) {
            if (notifs.length === 0) {
              list.innerHTML = '<div class="p-6 text-center text-stone-400 font-bold text-xs uppercase tracking-widest">Tidak ada notifikasi</div>';
            } else {
              list.innerHTML = notifs.map(n => {
                const isEmerg = n.type === 'EMERGENCY';
                const isWarn = n.type === 'WARNING';
                const icon = isEmerg ? '🚨' : (isWarn ? '⚠️' : 'ℹ️');
                const bgClass = isEmerg ? 'bg-red-50 dark:bg-red-500/10' : (isWarn ? 'bg-amber-50 dark:bg-amber-500/10' : 'bg-transparent hover:bg-stone-50 dark:hover:bg-white/5');
                const titleClass = isEmerg ? 'text-red-600 dark:text-red-400' : (isWarn ? 'text-amber-600 dark:text-amber-400' : 'text-zen-text dark:text-zen-text-dark');
                
                return `
                  <div class="notif-item relative p-3 sm:p-4 rounded-2xl flex items-start gap-3 transition-colors ${bgClass} group" data-id="${n.id}">
                    <div class="text-xl shrink-0">${icon}</div>
                    <div class="flex-1 pr-6">
                      <div class="font-extrabold text-sm mb-1 ${titleClass}">${n.title}</div>
                      <div class="text-xs text-stone-600 dark:text-stone-300 font-medium leading-relaxed">${n.message}</div>
                      ${n.action_url ? `<a href="${n.action_url}" class="inline-block mt-2 px-3 py-1.5 bg-stone-900 dark:bg-white text-white dark:text-black text-[10px] font-black rounded-lg hover:scale-105 transition-transform uppercase tracking-widest">Lihat Detail</a>` : ''}
                      <div class="text-[9px] font-bold text-stone-400 mt-2 uppercase tracking-widest">${new Date(n.created_at).toLocaleDateString('id-ID', {day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit'})}</div>
                    </div>
                    <button class="absolute top-3 right-3 text-stone-300 hover:text-red-500 transition-colors lg:opacity-0 group-hover:opacity-100" onclick="window.hideNotification('${n.id}')" title="Hapus Notifikasi">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                  </div>
                `;
              }).join('');
            }
          }

          // Check for Emergency
          const emergency = allNotifs.find(n => n.type === 'EMERGENCY'); // Also trigger emergency if it's new (even if not strictly in visible list, though it usually would be)
          if (emergency && !seenEmergencies.has(emergency.id)) {
            showEmergencyPopup(emergency);
            seenEmergencies.add(emergency.id);
            localStorage.setItem('seen_emergencies', JSON.stringify([...seenEmergencies]));
          }

          // Dispatch event for UI updates (e.g. bell icon)
          window.dispatchEvent(new CustomEvent('notificationsUpdated', { detail: { count: notifs.length, emergencyCount: notifs.filter(n=>n.type==='EMERGENCY').length } }));

        } catch(e) {}
      }

      function showEmergencyPopup(notif) {
        const modal = document.getElementById('global-emergency-modal');
        const content = document.getElementById('global-emergency-content');
        if (modal && content) {
          document.getElementById('emergency-title').textContent = notif.title;
          document.getElementById('emergency-message').textContent = notif.message;
          
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          setTimeout(() => content.classList.remove('scale-95', 'opacity-0'), 10);
        }
      }
    </script>
  </body>
</html>

