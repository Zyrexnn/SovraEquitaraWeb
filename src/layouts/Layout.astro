---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SovraEquitara — Platform Pelaporan Infrastruktur",
  description = "Platform civic tech untuk melaporkan kerusakan infrastruktur dengan sistem gamifikasi dan kecerdasan buatan."
} = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1A1A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="min-h-screen bg-stone-50 dark:bg-[#010101] text-gray-900 dark:text-white antialiased transition-colors duration-300">
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/tailwind.css';
</style>
