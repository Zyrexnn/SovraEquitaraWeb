---
import '../styles/tailwind.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "SovraEquitara — Smart City Infrastructure Ecosystem",
  description = "Platform Smart City terintegrasi untuk pelaporan infrastruktur, manajemen tata kota, dan kolaborasi warga berbasis AI."
} = Astro.props;
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#1A1A1A" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />

    <style is:global>
      /* Page Transition Progress Bar */
      ::view-transition-group(root) {
        animation-duration: 0.5s;
        animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* Custom Loading Bar */
      .astro-route-announcer { display: none; }
      
      #nprogress { pointer-events: none; }
      #nprogress .bar {
        background: #3B82F6;
        position: fixed;
        z-index: 2000;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
      }

      /* Transitions */
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }
      
      .dark #nprogress .bar { background: #60A5FA; }
    </style>

    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const applyTheme = (theme) => {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      // Initial apply
      const currentTheme = getTheme();
      applyTheme(currentTheme);

      // Listen for local storage changes from other tabs
      window.addEventListener('storage', (e) => {
        if (e.key === 'theme') {
          applyTheme(e.newValue);
        }
      });
    </script>
  </head>
  <body class="min-h-screen bg-zen-bg dark:bg-zen-bg-dark text-zen-text dark:text-zen-text-dark antialiased transition-colors duration-300">
    <slot />
    <script>
      import '../lib/toast';
      import NProgress from 'nprogress';

      // Configure NProgress
      NProgress.configure({ 
        showSpinner: false,
        easing: 'ease',
        speed: 500,
        trickleSpeed: 200
      });

      document.addEventListener('astro:before-preparation', () => {
        NProgress.start();
      });
      document.addEventListener('astro:page-load', () => {
        NProgress.done();
      });
    </script>
  </body>
</html>

